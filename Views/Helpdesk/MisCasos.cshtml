<!-- View: MisCasos.cshtml -->
@model IEnumerable<slnRhonline.Models.Caso>
@{
    ViewBag.Title = "Mis Casos";
    Layout = "~/Views/Shared/_mainLayout.cshtml";

    var totalCasos = Model.Count();
    var casosEnProceso = Model.Count(c => c.Estado == "En Proceso");
    var casosCerrados = Model.Count(c => c.Estado == "Cerrado");
    var casosAbiertos = Model.Count(c => c.Estado == "Abierto");
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/fancybox/3.5.7/jquery.fancybox.min.css" />

<style>
    /* Estética consistente con la otra página */
    body {
        background: #fff;
        color: #000;
    }

    .card {
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 12px;
    }

    .card-header {
        background: #f8f9fa;
        color: #000;
        border-bottom: 1px solid #dee2e6;
    }

    .kpi-card {
        border-left: .30rem solid #e11d48;
    }

        .kpi-card.orange {
            border-left-color: #f59e0b;
        }

        .kpi-card.green {
            border-left-color: #10b981;
        }

        .kpi-card.gray {
            border-left-color: #64748b;
        }

        .kpi-card .card-body {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .kpi-card .title {
            text-transform: uppercase;
            font-size: .8rem;
            opacity: .9;
            margin-bottom: .20rem;
        }

        .kpi-card .value {
            font-size: 1.35rem;
            font-weight: 700;
        }

        .kpi-card .icon {
            font-size: 2rem;
            opacity: .8;
        }

    .table-striped tbody tr:nth-of-type(odd) {
        background: #f7f7f7;
    }

    .table thead th {
        background: #e9ecef;
        color: #000;
    }

    .pill {
        display: inline-block;
        padding: .18rem .55rem;
        border-radius: 999px;
        color: #fff;
        font-weight: 600;
        font-size: .82rem
    }

    .pill-open {
        background: #e11d48
    }

    .pill-proc {
        background: #f59e0b
    }

    .pill-close {
        background: #10b981
    }

    .btn-primary {
        border-radius: 10px;
    }
</style>

<div class="container-fluid">

    <!-- KPIs -->
    <div class="row">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card kpi-card gray shadow h-100">
                <div class="card-body">
                    <div>
                        <div class="title">Total Casos</div>
                        <div class="value">@totalCasos</div>
                    </div>
                    <div class="icon"><i class="fas fa-folder"></i></div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card kpi-card shadow h-100">
                <div class="card-body">
                    <div>
                        <div class="title">Abiertos</div>
                        <div class="value">@casosAbiertos</div>
                    </div>
                    <div class="icon"><i class="fas fa-folder-open"></i></div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card kpi-card orange shadow h-100">
                <div class="card-body">
                    <div>
                        <div class="title">En Proceso</div>
                        <div class="value">@casosEnProceso</div>
                    </div>
                    <div class="icon"><i class="fas fa-spinner"></i></div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card kpi-card green shadow h-100">
                <div class="card-body">
                    <div>
                        <div class="title">Cerrados</div>
                        <div class="value">@casosCerrados</div>
                    </div>
                    <div class="icon"><i class="fas fa-check-circle"></i></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Botón para Crear Nuevo Caso -->
    <div class="row mb-3">
        <div class="col text-right">
            <button id="btnCrearCaso" class="btn btn-primary"><i class="fas fa-plus mr-1"></i> Crear Nuevo Caso</button>
        </div>
    </div>

    <!-- Tabla de casos -->
        <div class="row">
            <div class="col-md-12">
                <div class="card shadow">
                    <div class="card-header">
                        <h6 class="m-0 font-weight-bold">Mis Casos</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table id="tablaCasos" class="table table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th>Usuario</th>
                                        <th>Título</th>
                                        <th>Tipo de caso</th> <!-- antes decía Título -->
                                        <th>Estado</th>
                                        <th>Prioridad</th>
                                        <th>Fecha de Creación</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var caso in Model.OrderByDescending(x => x.FechaCreacion))
                                    {
                                        var orderKey = caso.FechaCreacion.ToString("yyyyMMdd"); // para orden correcto
                                        <tr>
                                            <td>@caso.UsuarioID</td>
                                            <td>@caso.Titulo</td>
                                            <td>@caso.TipoCaso</td>
                                            <td>@caso.Estado</td>
                                            <td>@caso.Prioridad</td>
                                            <td data-order="@orderKey">@caso.FechaCreacion.ToString("dd/MM/yyyy")</td>
                                            <td>
                                                <button class="btn btn-info btn-sm btnVerDetalle" data-id="@caso.ID">
                                                    <i class="fas fa-eye mr-1"></i> Ver Detalle
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    <!-- Modal: Ver Detalle -->
    <div class="modal fade" id="modalVerDetalleCaso" tabindex="-1" role="dialog" aria-labelledby="verDetalleModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Detalle del Caso</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Cerrar"><span aria-hidden="true">&times;</span></button>
                </div>
                <div class="modal-body" id="detalleCasoContent"></div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal: Crear Caso -->
    <div class="modal fade" id="modalCrearCaso" tabindex="-1" role="dialog" aria-labelledby="crearCasoModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Crear Nuevo Caso</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Cerrar"><span aria-hidden="true">&times;</span></button>
                </div>
                <div class="modal-body">
                    @Html.AntiForgeryToken()
                    <form id="formCrearCaso" enctype="multipart/form-data">
                        <div class="form-group">
                            <label for="ParaQuien">Usuario</label>
                            <input list="empleados" class="form-control" id="ParaQuien" name="ParaQuien" required>
                            <datalist id="empleados">
                                <option value="">Seleccione un empleado</option>
                                <!-- opciones por AJAX -->
                            </datalist>
                        </div>
                        <div class="form-group">
                            <label for="Titulo">Título</label>
                            <input type="text" class="form-control" id="Titulo" name="Titulo" required>
                        </div>
                        <div class="form-group">
                            <label for="Descripcion">Descripción</label>
                            <textarea class="form-control" id="Descripcion" name="Descripcion" rows="3" required></textarea>
                        </div>
                        <div class="form-group">
                            <label for="Prioridad">Prioridad</label>
                            <select class="form-control" id="Prioridad" name="Prioridad" required>
                                <option value="Alta">Alta</option>
                                <option value="Media">Media</option>
                                <option value="Baja">Baja</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="TipoCaso">Tipo de Caso</label>
                            <select class="form-control" id="TipoCaso" name="TipoCaso" required>
                                <option value="Otras-SolicitudesOProblema">Otras - Solicitudes o Problema</option>

                                <option value="RHOnline-Viatico">RHOnline - Viático</option>
                                <option value="RHOnline-HoraExtra">RHOnline - Hora Extra</option>
                                <option value="RHOnline-Cita">RHOnline - Cita</option>
                                <option value="RHOnline-Extraplan">RHOnline - Extraplan</option>
                                <option value="RHOnline-Traslado">RHOnlin e - Traslado</option>
                                <option value="RHOnline-Consumo">RHOnline - Consumo</option>
                                <option value="Sigho-Vacaciones">Sigho - Vacaciones</option>
                                <option value="Sigho-Otros">Sigho - Otros</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="archivos">Archivos Adjuntos</label>
                            <input type="file" class="form-control" id="archivos" name="archivos" multiple accept=".jpg,.jpeg,.png">
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    <button type="button" id="btnGuardarCaso" class="btn btn-primary">Guardar Caso</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Content/js2024/jquery.jeditable.min.js"></script>
    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.buttons.min.js"></script>
    <script src="~/onlinejs/buttons.html5.min.js"></script>
    <script src="~/onlinejs/buttons.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.select.min.js"></script>
    <script src="~/onlinejs/bootstrap.bundle.min.js"></script>
    <script src="~/onlinejs/bootstrap.min.js"></script>
    <script src="~/onlinejs/loadingoverlay.min.js"></script>
    <script src="~/onlinejs/dataTables.responsive.min.js"></script>
    <script src="~/Content/plugin/sweetalert2/sweetalert2.all.js"></script>
    <script src="~/onlinejs/moment.min.js"></script>
    <script src="~/onlinejs/jszip.min.js"></script>
    <script src="~/onlinejs/jquery-ui.js"></script>
    <script src="~/onlinejs/spin.min.js"></script>
     <script src="~/onlinejs/jquery.fancybox.min.js"></script>
    <script>
        // convierte texto de estado -> pill visual
        function estadoAPill(texto){
            if(texto==='Abierto') return '<span class="pill pill-open">Abierto</span>';
            if(texto==='En Proceso') return '<span class="pill pill-proc">En Proceso</span>';
            if(texto==='Cerrado') return '<span class="pill pill-close">Cerrado</span>';
            return texto || '-';
        }

        $(document).ready(function () {

            // Fancybox
            $('[data-fancybox="gallery"]').fancybox({ buttons: ["zoom","close"], loop:false, protect:true });

            // DataTable (DOM-based). Orden por fecha desc (columna 4 -> index 4).
            var dt = $('#tablaCasos').DataTable({
                responsive: true,
                order: [[4,'desc']],
                pageLength: 10,
                lengthMenu: [10,20,50,100],
                drawCallback: function(){
                    // aplicar pill al col Estado (3ra col)
                    $('#tablaCasos tbody tr').each(function(){
                        var $td = $(this).children('td').eq(2);
                        if($td.find('.pill').length===0){
                            $td.html( estadoAPill( ($td.text()||'').trim() ) );
                        }
                    });
                }
            });

            // Abrir modal: crear
            $('#btnCrearCaso').click(function () {
                $('#formCrearCaso')[0].reset();
                $('#empleados').find('option:not(:first)').remove();

                $.ajax({
                    url: '@Url.Action("ObtenerEmpleados", "Helpdesk")',
                    type: 'GET',
                    dataType: 'json'
                }).done(function(data){
                    if (Array.isArray(data)) {
                        data.forEach(function (empleado) {
                            var opt = new Option(empleado.nombre_completo, empleado.correo);
                            $('#empleados').append(opt);
                        });
                    }
                    $('#modalCrearCaso').modal('show');
                }).fail(function(){
                    Swal.fire('Error', 'No se pudo cargar la lista de empleados.', 'error');
                });
            });

            // Guardar caso
            $('#btnGuardarCaso').click(function () {
                const fd = new FormData(document.getElementById('formCrearCaso'));
                $.LoadingOverlay("show", { image:"", text:"Enviando, por favor espere..." });
                $.ajax({
                    url: '@Url.Content("~/Helpdesk/CrearCasox")',
                    type: 'POST',
                    data: fd,
                    processData: false,
                    contentType: false,
                    timeout: 0
                })
                .done(function (r) {
                    $.LoadingOverlay("hide");
                    if (r && r.success) {
                        Swal.fire('Éxito', r.message, 'success').then(() => location.reload());
                    } else {
                        Swal.fire('Error', (r && r.message) || 'No se pudo crear el caso.', 'error');
                    }
                })
                .fail(function (xhr) {
                    $.LoadingOverlay("hide");
                    console.error('Status:', xhr.status, 'Resp:', xhr.responseText);
                    Swal.fire('Error', 'Fallo de red/servidor.', 'error');
                });
            });

            // Ver detalle
            $('#tablaCasos').on('click', '.btnVerDetalle', function () {
                var casoId = $(this).data('id');
                $.ajax({
                    url: '@Url.Action("Details", "Helpdesk")/' + casoId,
                    type: 'GET',
                    dataType: 'json'
                })
                .done(function (response) {
                    var html = '';
                    html += '<h5 class="mb-2">'+ (response.Titulo || 'Detalle') +'</h5>';
                    html += '<p class="mb-1"><strong>Estado:</strong> '+ (response.Estado || '-') +'</p>';
                    html += '<p class="mb-3">'+ (response.Descripcion || 'Sin descripción') +'</p>';
                    html += '<h6>Archivos Adjuntos</h6>';
                    if (response.DatosArchivo && response.DatosArchivo.length > 0) {
                        html += `
                            <a href="data:image/webp;base64,${response.data}" data-fancybox="gallery">
                                <img src="data:image/webp;base64,${response.data}" alt="${response.NombreArchivo||''}" style="max-width: 100%; height: auto; border-radius:10px">
                            </a>`;
                    } else {
                        html += '<p>No hay archivos adjuntos.</p>';
                    }
                    $('#detalleCasoContent').html(html);
                    $('#modalVerDetalleCaso').modal('show');
                })
                .fail(function () {
                    Swal.fire('Error', 'Hubo un problema al cargar el detalle del caso.', 'error');
                });
            });
        });
    </script>
}
