@{
    ViewBag.Title = "Todos los Casos";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/fancybox/3.5.7/jquery.fancybox.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/rowgroup/1.3.1/css/rowGroup.dataTables.min.css" />
<!-- Responsive DataTables (CSS) -->
<link rel="stylesheet" href="~/onlinecss/responsive.bootstrap4.min.css" />

<style>
    .nav-link.active {
        color: #000 !important;
        font-weight: bold
    }

    /* Mantén la tabla dentro del contenedor (scroll horizontal si hace falta) */
    .table-responsive {
        overflow-x: auto !important;
        overflow-y: visible !important;
    }

    .dataTables_wrapper .row {
        overflow: visible !important;
    }

    /* Menú por encima de DT/modales */
    .dropdown-menu {
        z-index: 2000;
    }

    /* Columna Acciones: más ancha, sin wrap, para que no se recorte el botón */
    #tablaTodosLosCasos th:first-child,
    #tablaTodosLosCasos td:first-child {
        white-space: nowrap;
        width: 1%;
        min-width: 160px; /* <- da espacio al botón + caret */
    }

    /* Estilos existentes */
    body {
        background: #fff;
        color: #000
    }

    .card {
        background: #fff;
        border: 1px solid #dee2e6;
        margin-bottom: 30px;
        border-radius: 12px
    }

    .card-header {
        background: #f8f9fa;
        color: #000;
        border-bottom: 1px solid #dee2e6
    }

    .card h6, .h3, .h6 {
        color: #333
    }

    .kpi-card {
        border-left: .25rem solid #e11d48
    }

        .kpi-card .card-body {
            display: flex;
            align-items: center;
            justify-content: space-between
        }

        .kpi-card .icon {
            font-size: 2.2rem;
            opacity: .8;
            color: #e11d48
        }

    .table-striped tbody tr:nth-of-type(odd) {
        background: #f2f2f2
    }

    .table thead th {
        background: #e9ecef;
        color: #000
    }

    .btn-summary {
        border: 1px solid #e11d48;
        color: #e11d48;
        background: #fff
    }

        .btn-summary:hover {
            background: #e11d48;
            color: #fff
        }

    .pill {
        display: inline-block;
        padding: .2rem .55rem;
        border-radius: 999px;
        color: #fff;
        font-weight: 600;
        font-size: .85rem
    }

    .pill-open {
        background: #e11d48
    }

    .pill-proc {
        background: #f59e0b
    }

    .pill-close {
        background: #10b981
    }
</style>

<div class="container-fluid">
    <!-- Encabezado -->
    <div class="d-flex align-items-center justify-content-between">
        <h1 class="h3 my-3 text-dark text-center">@ViewBag.Title</h1>

        <button id="btnResumen" class="btn btn-summary my-3">
            <i class="fas fa-file-excel mr-1"></i> Resumen (Cerrados por gerencia)
        </button>
    </div>

    <!-- KPIs -->
    <div class="row">
        <div class="col-xl-4 col-lg-4">
            <div class="card kpi-card shadow mb-4">
                <div class="card-body">
                    <div>
                        <div class="text-uppercase mb-1">Casos Abiertos</div>
                        <div class="h5 mb-0 font-weight-bold" id="casosAbierto">0</div>
                    </div>
                    <div class="icon"><i class="fas fa-book-open"></i></div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-lg-4">
            <div class="card kpi-card shadow mb-4" style="border-left-color:#f59e0b">
                <div class="card-body">
                    <div>
                        <div class="text-uppercase mb-1">Procesando</div>
                        <div class="h5 mb-0 font-weight-bold" id="casosAtendidos">0</div>
                    </div>
                    <div class="icon"><i class="fas fa-headset"></i></div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-lg-4">
            <div class="card kpi-card shadow mb-4" style="border-left-color:#10b981">
                <div class="card-body">
                    <div>
                        <div class="text-uppercase mb-1">Casos Cerrados</div>
                        <div class="h5 mb-0 font-weight-bold" id="casosCerrados">0</div>
                    </div>
                    <div class="icon"><i class="fas fa-check-circle"></i></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de Casos -->
    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold">Listado de Casos</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table id="tablaTodosLosCasos" class="table table-striped table-bordered">
                            <thead>
                                <tr>
                                    <th>Acciones</th>
                                    <th>Usuario</th>
                                    <th>Título</th>
                                    <th>Tipo</th>
                                    <th>Estado</th>
                                    <th>Prioridad</th>
                                    <th>Fecha de Creación</th>
                                    <th>Gerencia</th>
                                    <th>Área</th>
                                    <th>Cargo</th>
                                    <th>Correo</th>
                                    <th>Teléfono</th>
                                </tr>
                            </thead>
                            <tfoot>
                                <tr>
                                    <th></th>
                                    <th>Usuario</th>
                                    <th>Título</th>
                                    <th>Tipo</th>
                                    <th>Estado</th>
                                    <th>Prioridad</th>
                                    <th>Fecha de Creación</th>
                                    <th>Gerencia</th>
                                    <th>Área</th>
                                    <th>Cargo</th>
                                    <th>Correo</th>
                                    <th>Teléfono</th>
                                </tr>
                            </tfoot>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal: Detalle del Caso -->
    <div class="modal fade" id="modalVerDetalleCaso" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Detalle del Caso</h5>
                    <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                </div>
                <div class="modal-body" id="detalleCasoContent"></div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal: Atender Caso -->
    <div class="modal fade" id="modalAtenderCaso" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Atender Caso</h5>
                    <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                </div>
                <div class="modal-body">
                    <div id="detalleCasoContentCasosx"></div>
                    <form id="formAtenderCasoCasos">
                        <input type="hidden" id="CasoIDCasos" name="CasoID">
                        <div class="form-group">
                            <label for="NotasCierreCasos">Notas de Atención</label>
                            <textarea class="form-control" id="NotasCierreCasos" name="NotasCierre" rows="3" required></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    <button type="button" id="btnGuardarAtencionCasos" class="btn btn-primary">Guardar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal: Resumen -->
    <div class="modal fade" id="modalResumen" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-md" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Cerrados por Gerencia</h5>
                    <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                </div>
                <div class="modal-body">
                    <div class="form-row">
                        <div class="form-group col-6">
                            <label>Desde</label>
                            <input type="date" id="sumDesde" class="form-control" />
                        </div>
                        <div class="form-group col-6">
                            <label>Hasta</label>
                            <input type="date" id="sumHasta" class="form-control" />
                        </div>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <button id="btnGenerarResumen" class="btn btn-primary btn-sm"><i class="fas fa-sync mr-1"></i>Generar</button>
                        <button id="btnResumenCSV" class="btn btn-outline-success btn-sm"><i class="fas fa-file-download mr-1"></i>Descargar CSV</button>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered mb-0">
                            <thead><tr><th>Gerencia</th><th>Total cerrados</th></tr></thead>
                            <tbody id="tbodyResumen"><tr><td colspan="2">Seleccione fechas y pulse Generar</td></tr></tbody>
                            <tfoot><tr><th>Total</th><th id="sumTotal">0</th></tr></tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<link href="~/onlinecss/tabulator.min.css" rel="stylesheet" />

@section Scripts {
    <script src="~/onlinejs/jquery-3.6.0.min.js"></script>
    <script src="~/onlinejs/bootstrap.bundle.min.js"></script>

    <script src="~/onlinejs/moment.min.js"></script>
    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.rowGroup.min.js"></script>
    <!-- Responsive DataTables (JS) -->
    <script src="~/onlinejs/dataTables.responsive.min.js"></script>
    <script src="~/onlinejs/responsive.bootstrap4.min.js"></script>

    <script src="~/Content/plugin/sweetalert2/sweetalert2.all.js"></script>
    <script src="~/onlinejs/loadingoverlay.min.js"></script>
    <script src="~/onlinejs/jquery.fancybox.min.js"></script>
    <script>
        // Helpers de fecha (.NET /Date(x)/)
        function parseNetDate(v){ if(!v) return null; if(typeof v==='string' && v.indexOf('/Date(')===0){ return new Date(parseInt(v.match(/\d+/)[0],10)); } return new Date(v); }
        function fechaDisplay(v){ const d=parseNetDate(v); return d? moment(d).format('DD/MM/YYYY') : '-'; }
        function fechaSortKey(v){ const d=parseNetDate(v); return d? moment(d).format('YYYYMMDD') : '00000000'; }

        // Estado -> pill
        function pill(v){
            if(v==='Abierto') return '<span class="pill pill-open">Abierto</span>';
            if(v==='En Proceso') return '<span class="pill pill-proc">En Proceso</span>';
            if(v==='Cerrado') return '<span class="pill pill-close">Cerrado</span>';
            return v||'-';
        }

        // Rank de estado para ordenar
        var estadoRank = { 'Abierto':0, 'En Proceso':1, 'Cerrado':2 };

        // Menú de acciones
        function menuAcciones(id,row){
            return `
                <div class="dropdown">
                    <button class="btn btn-primary btn-sm dropdown-toggle" data-toggle="dropdown">
                        <i class="fas fa-cogs"></i> Acciones
                    </button>
                    <div class="dropdown-menu dropdown-menu-right">
                        <a class="dropdown-item" href="#" onclick="verDetalle('${id}')"><i class="fas fa-eye mr-2"></i>Ver Detalle</a>
                        ${row.Estado==='Abierto' ? `<a class="dropdown-item" href="#" onclick="marcarEnProceso('${id}')"><i class="fas fa-tasks mr-2"></i>Marcar en Proceso</a>` : ``}
                        ${(row.Estado==='Abierto'||row.Estado==='En Proceso') ? `<a class="dropdown-item" href="#" onclick="atenderCaso('${id}')"><i class="fas fa-edit mr-2"></i>Atender</a>` : ``}
                    </div>
                </div>`;
        }

        // Dataset completo para KPIs/resumen
        var casosData = [];

        $(document).ready(function () {

            // DataTable
            var tabla_persona = $('#tablaTodosLosCasos').DataTable({
                ajax: { url: "@Url.Action("ObtenerCasosPaginados", "Helpdesk")", type: "GET", datatype: "json", dataSrc: "data" },
                columns: [
                    { data: "ID", orderable:false, searchable:false, render: function (data,type,row){ return menuAcciones(data,row); } },
                    { data: "NombreAutor" },
                    { data: "Titulo" },
                    { data: "TipoCaso" },

                    // Estado: para ordenar usamos el rank; para mostrar usamos pill
                    { data: "Estado", render: function(d, type){
                        if(type==='sort') return (d in estadoRank) ? estadoRank[d] : 99;
                        if(type==='filter') return d || '';
                        return pill(d);
                    }},

                    { data: "Prioridad" },

                    // Fecha de creación: sort por clave YYYYMMDD y display bonito
                    { data: "FechaCreacion", render: function (d, type) {
                        return (type==='display') ? fechaDisplay(d) : fechaSortKey(d);
                    }},

                    { data: "GerenciaAutor" },
                    { data: "AreaResponsable" },
                    { data: "CargoResponsable" },
                    { data: "Correo" },
                    { data: "TelefonoResponsable" }
                ],

                // Responsive (colapsar en móvil)
                responsive: { details: { type:'inline', target:'tr' } },
                autoWidth: false,

                // Prioridades de colapso (1 = más importante)
                columnDefs: [
                    { responsivePriority: 1, targets: 0 }, // Acciones
                    { responsivePriority: 2, targets: 2 }, // Título
                    { responsivePriority: 3, targets: 4 }, // Estado
                    { responsivePriority: 4, targets: 6 }, // Fecha
                    { responsivePriority: 5, targets: 1 }, // Usuario
                    { responsivePriority: 10001, targets: [10,11] } // Correo/Teléfono colapsan primero
                ],

                dom: 'Blfrtip',
                lengthMenu: [10, 20, 50, 100],
                pageLength: 10,
                language: { url: "@Url.Content("~/Scripts/datatable.es-ES.json")" },

                // ✅ Orden: Estado (rank asc) + FechaCreacion (desc = más reciente)
                order: [[4, 'asc'], [6, 'desc']],

                rowGroup: {
                    dataSrc: 'Estado',
                    startRender: function (rows, group) {
                        var cls = group==='Abierto' ? 'text-danger' : (group==='En Proceso' ? 'text-warning' : 'text-success');
                        return $('<tr/>').append('<td colspan="12"><strong class="'+cls+'">'+group+' ('+rows.count()+')</strong></td>');
                    }
                },

                initComplete: function () {
                    var api = this.api();
                    // Filtros en el footer
                    $('#tablaTodosLosCasos tfoot th').each(function (idx) {
                        $(this).html(idx===0 ? '' : '<input type="text" class="form-control form-control-sm" placeholder="Filtrar..." />');
                    });
                    api.columns().every(function () {
                        var that = this;
                        $('input', this.footer()).on('keyup change clear', function () {
                            if (that.search() !== this.value) that.search(this.value).draw();
                        });
                    });

                    // Dropdowns Bootstrap: evitar clipping
                    $('#tablaTodosLosCasos tbody').on('click', '.dropdown-toggle', function (e) {
                        e.stopPropagation();
                        $(this).siblings('.dropdown-menu').toggleClass('show');
                    });
                    $(document).on('click', function (e) {
                        if (!$('.dropdown-toggle').is(e.target) && $('.dropdown-toggle').has(e.target).length === 0 && $('.show').has(e.target).length === 0) {
                            $('.dropdown-menu').removeClass('show');
                        }
                    });
                }
            });

            // Mover el menú al body al mostrar (evita que se recorte)
            $('#tablaTodosLosCasos').on('shown.bs.dropdown', 'div.dropdown', function () {
                const $menu = $(this).find('.dropdown-menu');
                $('body').append($menu.detach());
                const offset = $(this).offset();
                $menu.css({
                    display: 'block',
                    position: 'absolute',
                    left: offset.left + 'px',
                    top: (offset.top + $(this).outerHeight()) + 'px'
                });
            });
            $('#tablaTodosLosCasos').on('hide.bs.dropdown', 'div.dropdown', function () {
                const $menu = $('body > .dropdown-menu.show, body > .dropdown-menu').last();
                $(this).append($menu.detach());
                $menu.attr('style', '');
            });

            // KPIs
            $.get('@Url.Action("ObtenerCasos", "Helpdesk")', function (data) {
                casosData = Array.isArray(data) ? data : [];
                $('#casosAbierto').text(casosData.filter(x => x.Estado === 'Abierto').length);
                $('#casosAtendidos').text(casosData.filter(x => x.Estado === 'En Proceso').length);
                $('#casosCerrados').text(casosData.filter(x => x.Estado === 'Cerrado').length);
            });

            // Resumen
            $('#btnResumen').on('click', function(){
                var now = new Date();
                var y = now.getFullYear(), m = (now.getMonth()+1).toString().padStart(2,'0');
                $('#sumDesde').val(`${y}-${m}-01`);
                $('#sumHasta').val(moment(now).format('YYYY-MM-DD'));
                $('#tbodyResumen').html('<tr><td colspan="2">Seleccione fechas y pulse Generar</td></tr>');
                $('#sumTotal').text('0');
                $('#modalResumen').modal('show');
            });

            $('#btnGenerarResumen').on('click', function(){
                var d = $('#sumDesde').val(), h = $('#sumHasta').val();
                if(!d || !h){ Swal.fire('Atención','Seleccione el rango de fechas.','warning'); return; }
                var desde = new Date(d+'T00:00:00'), hasta = new Date(h+'T23:59:59');
                var mapa = {}; var total = 0;
                casosData.forEach(function(x){
                    if(x.Estado !== 'Cerrado') return;
                    var f = parseNetDate(x.FechaFinalizacion); if(!f) return;
                    if(f < desde || f > hasta) return;
                    var g = x.GerenciaAutor || 'N/D';
                    mapa[g] = (mapa[g]||0) + 1; total++;
                });
                var filas = Object.keys(mapa).sort().map(function(k){
                    return `<tr><td>${k}</td><td><strong>${mapa[k]}</strong></td></tr>`;
                }).join('');
                $('#tbodyResumen').html(filas || '<tr><td colspan="2">Sin datos para el rango seleccionado</td></tr>');
                $('#sumTotal').text(total);
            });

            $('#btnResumenCSV').on('click', function(){
                var csv = "Gerencia,Total cerrados\n";
                $('#tbodyResumen tr').each(function(){
                    var tds = $(this).find('td');
                    if(tds.length===2){
                        csv += `"${$(tds[0]).text()}",${$(tds[1]).text().replace(/\D/g,'')}\n`;
                    }
                });
                var blob = new Blob([csv], {type: 'text/csv;charset=utf-8;'});
                var url = URL.createObjectURL(blob);
                var a = document.createElement('a');
                a.href = url; a.download = 'resumen_cerrados_por_gerencia.csv';
                document.body.appendChild(a); a.click(); document.body.removeChild(a);
                URL.revokeObjectURL(url);
            });

            // Guardar atención
            $('#btnGuardarAtencionCasos').click(function () {
                var formData = $('#formAtenderCasoCasos').serialize();
                $.LoadingOverlay("show", { image: "", text: "Enviando cambios, espere por favor..." });
                $.ajax({
                    url: '@Url.Action("AtenderCasocerrado", "Helpdesk")',
                    type: 'POST',
                    data: formData
                }).done(function (response) {
                    $.LoadingOverlay("hide");
                    if (response.success) {
                        Swal.fire('Éxito', response.message, 'success').then(function () { location.reload(); });
                    } else {
                        Swal.fire('Error', response.message || 'No se pudo guardar.', 'error');
                    }
                }).fail(function () {
                    $.LoadingOverlay("hide");
                    Swal.fire('Error', 'Hubo un problema al guardar la atención.', 'error');
                });
            });

        }); // ready

        // ===== Acciones globales =====
        function verDetalle(casoId) {
            $.ajax({
                url: '@Url.Action("Details", "Helpdesk")/' + casoId,
                type: 'GET'
            }).done(function (response) {
                var html = '';
                html += '<h5 class="mb-2">'+ (response.Titulo || 'Detalle') +'</h5>';
                html += '<p class="mb-1"><strong>Estado:</strong> '+ (response.Estado || '-') +'</p>';
                html += '<p class="mb-3">'+ (response.Descripcion || 'Sin descripción') +'</p>';
                html += '<h6>Archivos Adjuntos</h6>';
                if (response.DatosArchivo && response.DatosArchivo.length > 0) {
                    html += `
                        <a href="data:image/webp;base64,${response.data}" data-fancybox="gallery">
                            <img src="data:image/webp;base64,${response.data}" alt="${response.NombreArchivo || ''}" style="max-width: 100%; height: auto; border-radius:10px">
                        </a>`;
                } else {
                    html += '<p>No hay archivos adjuntos.</p>';
                }
                $('#detalleCasoContent').html(html);
                $('#modalVerDetalleCaso').modal('show');
            }).fail(function () {
                Swal.fire('Error', 'Hubo un problema al cargar el detalle del caso.', 'error');
            });
        }

        function atenderCaso(casoId) {
            $.ajax({
                url: '@Url.Action("Details", "Helpdesk")/' + casoId,
                type: 'GET'
            }).done(function (response) {
                var html = '';
                html += '<h6 class="mb-2">Notas del Soporte</h6>';
                html += '<p>'+ (response.NotasCierre || 'Sin respuesta del soporte') +'</p>';
                html += '<h6>Descripción</h6>';
                html += '<p>'+ (response.Descripcion || 'Sin descripción') +'</p>';
                html += '<h6>Archivos Adjuntos</h6>';
                if (response.DatosArchivo && response.DatosArchivo.length > 0) {
                    html += `
                        <a href="data:image/webp;base64,${response.data}" data-fancybox="gallery">
                            <img src="data:image/webp;base64,${response.data}" alt="${response.NombreArchivo || ''}" style="max-width: 100%; height: auto; border-radius:10px">
                        </a>`;
                } else {
                    html += '<p>No hay archivos adjuntos.</p>';
                }
                $('#detalleCasoContentCasosx').html(html);
                $('#CasoIDCasos').val(casoId);
                $('#modalAtenderCaso').modal('show');
            }).fail(function () {
                Swal.fire('Error', 'Hubo un problema al cargar el detalle del caso.', 'error');
            });
        }

        function marcarEnProceso(casoId) {
            $.ajax({
                url: '@Url.Action("MarcarEnProceso", "Helpdesk")',
                type: 'POST',
                data: { id: casoId }
            }).done(function (response) {
                if (response.success) {
                    Swal.fire('Éxito', 'El caso ha sido marcado como "En Proceso".', 'success').then(function () {
                        location.reload();
                    });
                } else {
                    Swal.fire('Error', response.message || 'No se pudo marcar el caso.', 'error');
                }
            }).fail(function () {
                Swal.fire('Error', 'Hubo un problema al intentar actualizar el caso.', 'error');
            });
        }

        // Exponer funciones globales
        window.verDetalle = verDetalle;
        window.atenderCaso = atenderCaso;
        window.marcarEnProceso = marcarEnProceso;
    </script>
}
