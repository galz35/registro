            });*@
                function renderChartCasos(container, chartType, casosFiltrados) {
                    var gerencias = [...new Set(casosFiltrados.map(caso => caso.GerenciaAutor))];

                    var seriesData = gerencias.map(function (gerencia) {
                        var data = casosFiltrados.filter(caso => caso.GerenciaAutor === gerencia).map(caso => {
                            return [new Date(parseInt(caso.FechaCreacion.match(/\d+/)[0])).getTime(), 1];
                        });

                        return {
                            name: gerencia,
                            data: data,
                            type: chartType
                        };
                    });

                    Highcharts.chart(container, {
                        chart: {
                            type: chartType,
                            backgroundColor: '#ffffff'
                        },
                        title: {
                            text: 'Tendencia de Casos Abiertos por Gerencia',
                            style: {
                                color: '#000'
                            }
                        },
                        xAxis: {
                            type: 'datetime',
                            labels: {
                                style: {
                                    color: '#000'
                                }
                            }
                        },
                        yAxis: {
                            title: {
                                text: 'Número de Casos',
                                style: {
                                    color: '#000'
                                }
                            },
                            labels: {
                                style: {
                                    color: '#000'
                                }
                            }
                        },
                        legend: {
                            itemStyle: {
                                color: '#000'
                            }
                        },
                        series: seriesData
                    });
                }
                function filtrarCasosUltimoMes(casosData) {
                    var ahora = new Date();
                    var unMesAtras = new Date();
                    unMesAtras.setMonth(ahora.getMonth() - 1); // Restar un mes

                    return casosData.filter(function (caso) {
                        var fechaCreacion = new Date(parseInt(caso.FechaCreacion.match(/\d+/)[0]));
                        return fechaCreacion >= unMesAtras && fechaCreacion <= ahora;
                    });
                }
                $(document).on('click', '.reply-button', function () {
                    var commentId = $(this).data('id');
                    var caso = casosData.find(c => c.ID === commentId);
                    $('#commentContentCasos').html(`
                    <h6>${caso.NombreAutor}</h6>
                    <p>${caso.Descripcion}</p>
                    <form id="formRespuestaCasos">
                        <div class="form-group">
                            <label for="respuestaCasos">Tu Respuesta</label>
                            <textarea class="form-control" id="respuestaCasos" rows="3" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Enviar Respuesta</button>
                    </form>`
                    );
                    $('#commentModalCasos').modal('show');
                });
                // Cambiar el tipo de gráfico de Casos
                $('#chartTypeCasos').change(function () {
                    var chartType = $(this).val();
                    renderChartCasos('graficoCasos', chartType);
                });

                // Expander el gráfico de Casos
                $('#expandChartCasos').click(function () {
                    var chartType = $('#chartTypeCasos').val();
                    $('#chartModalCasos').modal('show');
                    setTimeout(function () {
                        var casosFiltrados = filtrarCasosUltimoMes(casosData);

                        renderChartCasos('graficoCasosAmpliado', chartType, casosFiltrados);

                    }, 500);
                });

                // Comentarios de Casos
                var currentPageCasos = 1;
                var commentsPerPage = 3;

                function renderCommentsCasos() {
                    // Filtrar solo los casos que no están cerrados
                    var commentsDataCasos = casosData
                        .filter(caso => caso.Estado !== "Cerrado")
                        .map(caso => ({
                            id: caso.ID,
                            user: caso.NombreAutor,
                            area: caso.AreaAutor,
                            gerencia: caso.GerenciaAutor,
                            cargo: caso.CargoAutor,
                            comment: caso.Descripcion,
                            telefono: caso.TelefonoAutor
                        }));

                    var start = (currentPageCasos - 1) * commentsPerPage;
                    var end = start + commentsPerPage;
                    var paginatedComments = commentsDataCasos.slice(start, end);

                    $('#commentContainerCasos').empty();

                    paginatedComments.forEach(function (comment) {
                        var commentHtml = `
     <div class="comment d-flex align-items-start mb-4 p-3 bg-light border rounded shadow-sm">
    <div class="comment-content w-100">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="font-weight-bold text-primary mb-0">${comment.user}</h6>
            <small class="text-muted">Tel: ${comment.telefono ? comment.telefono : 'N/A'}</small>
        </div>
        <p class="mb-1 text-muted">${comment.cargo}, ${comment.gerencia} (${comment.area})</p>
        <p class="text-dark">${comment.comment}</p>
        <div class="text-right">
            <span class="reply-button text-success" data-id="${comment.id}" style="cursor:pointer;">
                <i class="fas fa-reply"></i> Ver y Responder
            </span>
        </div>
    </div>
</div>
        `;
                        $('#commentContainerCasos').append(commentHtml);
                    });


                                renderPaginationCasos(commentsDataCasos.length);
            }
                function populateKPIs() {

                    var casosAbierto = casosData.filter(caso => caso.Estado === 'Abierto').length;

                    var casosAtendidos = casosData.filter(caso => caso.Estado === 'Atendido').length;
                    var casosCerrados = casosData.filter(caso => caso.Estado === 'Cerrado').length;

                    $('#casosAbierto').text(casosAbierto);
                    $('#casosAtendidos').text(casosAtendidos);
                    $('#casosCerrados').text(casosCerrados);
                }

                function renderPaginationCasos(totalComments) {
                    var totalPages = Math.ceil(totalComments / commentsPerPage);
                    $('#commentPaginationCasos').empty();

                    for (var i = 1; i <= totalPages; i++) {
                        var activeClass = (i === currentPageCasos) ? 'active' : '';
                        var pageItem = `
            <li class="page-item ${activeClass}">
                <a class="page-link" href="#">${i}</a>
            </li>
        `;
                        $('#commentPaginationCasos').append(pageItem);
                    }
                }
                $(document).on('click', '#commentPaginationCasos .page-link', function (e) {
                    e.preventDefault();
                    currentPageCasos = parseInt($(this).text());
                    renderCommentsCasos();
                });
                $(document).on('submit', '#formRespuestaCasos', function (e) {
                    e.preventDefault();
                    var respuesta = $('#respuestaCasos').val();
                    alert('Respuesta enviada: ' + respuesta);
                    $('#commentModalCasos').modal('hide');
                });
                $('#viewAllCommentsCasos').click(function () {
                    var allComments = casosData.map(function (caso) {
                        return
                        ` <div class="comment">
                            <div class="user-image">
                                <img src="https://via.placeholder.com/50" alt="Usuario"/>
                            </div>
                                <div class="comment-content">
                                    <h6 class="font-weight-bold">${caso.NombreAutor}</h6>
                                    <p>${caso.Descripcion}</p>
                                </div>
                            </div>
                           ` ;
                }).join('');

                            $('#commentContentCasos').html(allComments);
                            $('#commentModalCasos').modal('show');
            });
            // $('#tablaTodosLosCasos').on('click', '.btnAtenderCaso', function () {
            //    var casoId = $(this).data('id');
            //    $('#CasoID').val(casoId);
            //    $('#modalAtenderCaso').modal('show');
            //});

            // Guardar atención del caso con AJAX
            $('#btnGuardarAtencion').click(function () {
                var formData = $('#formAtenderCaso').serialize();
                $.ajax({
                    url: '@Url.Action("AtenderCaso", "Helpdesk")',
                    type: 'POST',
                    data: formData,
                    success: function (response) {
                        if (response.success) {
                            Swal.fire('Éxito', response.message, 'success').then(function () {
                                location.reload();
                            });
                        } else {
                            Swal.fire('Error', response.message, 'error');
                        }
                    },
                    error: function () {
                        Swal.fire('Error', 'Hubo un problema al guardar la atención del caso.', 'error');
                    }
                });
            });



                 $('#btnGuardarAtencionCasos').click(function () {
                var formData = $('#formAtenderCasoCasos').serialize();
                $.ajax({
                    url: '@Url.Action("AtenderCaso", "Helpdesk")',
                    type: 'POST',
                    data: formData,
                    success: function (response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert(response.message);
                        }
                    },
                    error: function () {
                        alert('Hubo un problema al guardar la atención del caso.');
                    }
                });
                 });

        });

            function verDetalle(casoId) {
                    var casoId = $(this).data('id');
                $.ajax({
                    url: '@Url.Action("Details", "Helpdesk")/' + casoId,
                    type: 'GET',
                    success: function (response) {
                        var htmlContent = '<h5>Notas del Soporte</h5>';
                        htmlContent += '<p>' + (response.NotasCierre ? response.NotasCierre : 'Sin respuesta del soporte') + '</p>';
                        htmlContent += '<h5>Descripcion:</h5>';
                        htmlContent += '<p>' + (response.Descripcion ? response.Descripcion : 'Sin descripcion') + '</p>';
                        htmlContent += '<h5>Archivos Adjuntos</h5>';
                        if (response.DatosArchivo && response.DatosArchivo.length > 0) {
                            htmlContent += `
    <a href="data:image/webp;base64,${response.data}" data-fancybox="gallery">
        <img src="data:image/webp;base64,${response.data}" alt="${response.NombreArchivo}" style="max-width: 100%; height: auto;">
    </a><br>
`;
                        } else {
                            htmlContent += '<p>No hay archivos adjuntos.</p>';
                        }
                        $('#detalleCasoContent').html(htmlContent);
                        $('#modalVerDetalleCaso').modal('show');
                    },
                    error: function () {
                        Swal.fire('Error', 'Hubo un problema al cargar el detalle del caso.', 'error');
                    }
                });
                }

                // Función para manejar el evento de atender caso
                function atenderCaso(casoId) {
                    var casoId = $(this).data('id');
                    $('#CasoID').val(casoId);
                    $('#modalAtenderCaso').modal('show');
                }
    </script>
