    <script src="~/onlinejs/jquery.fancybox.min.js"></script>
    <script src="~/onlinejs/highcharts.js"></script>
    <script>
        var tabla_persona;

            $(document).ready(function () {
                var casosData = [];

                tabla_persona  =   $('#tablaTodosLosCasos').DataTable({
        "ajax": {
                                 "url": "@Url.Action("ObtenerCasosPaginados", "Helpdesk")",

            "type": "GET",
            "datatype": "json"
        },
        "columns": [
            {
                "data": "ID",
                "render": function (data, type, row) {
                    return `
                        <div class="btn-group">
                            <button type="button" class="btn btn-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <i class="fas fa-cogs"></i> Acciones
                            </button>
                            <div class="dropdown-menu">
                                <a class="dropdown-item" href="javascript:void(0);" onclick="verDetalle('${data}')">
                                    <i class="fas fa-eye"></i> Ver Detalle
                                </a>

                                ${row.Estado === "Abierto" || row.Estado === "En Proceso" ? `
                                    <a class="dropdown-item" href="javascript:void(0);" onclick="atenderCaso('${data}')">
                                        <i class="fas fa-edit"></i> Atender
                                    </a>
                                ` : ''}
                            </div>
                        </div>`;
                },
                "orderable": false,
                "searchable": false
            },
            { "data": "NombreAutor" },
            { "data": "Titulo" },
            { "data": "Estado" },
            { "data": "Prioridad" },
            {
                "data": "FechaCreacion",
                "render": function (data) {
                    return moment(data).format('DD/MM/YYYY');
                }
            },
            { "data": "GerenciaAutor" },
            { "data": "AreaResponsable" },
            { "data": "CargoResponsable" },
            { "data": "Correo" },
            { "data": "TelefonoResponsable" }
        ],  "dom": 'Blfrtip',
                "lengthMenu": [10, 20, 50, 100],
                "pageLength": 10,
                "language": {
                    "url": "@Url.Content("~/Scripts/datatable.es-ES.json")"
                },
                "responsive": true,
                "initComplete": function() {
                    $('#listTable tbody').on('click', '.dropdown-toggle', function(e) {
                        e.stopPropagation();
                        $(this).siblings('.dropdown-menu').toggleClass('show');
                    });
                    $(document).on('click', function(e) {
                        if (!$('.dropdown-toggle').is(e.target) && $('.dropdown-toggle').has(e.target).length === 0 && $('.show').has(e.target).length === 0) {
                            $('.dropdown-menu').removeClass('show');
                        }
                    });
                }
    });
                  function fetchCasosData() {
               return $.ajax({
        url: '@Url.Action("ObtenerCasos", "Helpdesk")', // Ajusta el nombre del controlador si es necesario
        method: 'GET',
        dataType: 'json',
        success: function (data) {
            casosData = data;
            populateKPIs();
            renderCommentsCasos();
            var casosFiltrados = filtrarCasosUltimoMes(casosData);
            renderChartCasos('graficoCasos', $('#chartTypeCasos').val(), casosFiltrados);
        },
        error: function (error) {
            console.error('Error al obtener datos:', error);
        }
    });
                }

                fetchCasosData();
            $('[data-fancybox="gallery"]').fancybox({
                buttons: [
                    "zoom",
                    "close"
                ],
                loop: false,
                protect: true
            });
            // Inicializar DataTable

            // Abrir modal para ver detalle del caso
            @*$('#tablaTodosLosCasos').on('click', '.btnVerDetalle', function () {
                var casoId = $(this).data('id');
                $.ajax({
                    url: '@Url.Action("Details", "Helpdesk")/' + casoId,
                    type: 'GET',
