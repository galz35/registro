@model List<Entities.ViewModels.ConsumptionView>
@{
    var grid = Html.DevExpress().GridView(settings =>
    {
        settings.Name = "gvCheck";

        settings.KeyFieldName = "IdCombustibleConsumoClaro";
        settings.CallbackRouteValues = new { Controller = "ConsumptionClaro", Action = "CheckPartial" };
        //settings.CustomBindingRouteValuesCollection.Add(GridViewOperationType.Paging, new { Controller = "Licenses", Action = "GridListRhPagingAction" });
        //settings.CustomBindingRouteValuesCollection.Add(GridViewOperationType.Filtering, new { Controller = "Licenses", Action = "GridListRhFilteringAction" });
        //settings.SettingsEditing.UpdateRowRouteValues = new { Controller = "ConsumptionClaro", Action = "UpdateLicenseRRHH" };
        settings.ClientSideEvents.SelectionChanged = "onSelectionChanged";
        settings.ClientSideEvents.BeginCallback = "onBeginCallback";
        settings.ClientSideEvents.Init = "OnInit";
        settings.ClientSideEvents.EndCallback = "OnEndCallback";


        settings.SettingsEditing.Mode = GridViewEditingMode.Inline;
        settings.SettingsBehavior.ConfirmDelete = true;
        settings.Width = Unit.Percentage(100);

        settings.SettingsBehavior.AllowFocusedRow = true;
        settings.Settings.ShowGroupPanel = false;
        settings.SettingsBehavior.AllowSelectByRowClick = true;
        settings.ControlStyle.Border.BorderWidth = 1;
        settings.Settings.ShowFooter = true;
        settings.KeyboardSupport = true;


        settings.EnableRowsCache = false;
        settings.Settings.VerticalScrollBarMode = ScrollBarMode.Visible;
        settings.Settings.VerticalScrollableHeight = 500;
        settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.HideDataCells;
        settings.SettingsAdaptivity.AllowOnlyOneAdaptiveDetailExpanded = true;
        settings.EditFormLayoutProperties.SettingsAdaptivity.AdaptivityMode = FormLayoutAdaptivityMode.SingleColumnWindowLimit;
        settings.EditFormLayoutProperties.SettingsAdaptivity.SwitchToSingleColumnAtWindowInnerWidth = 600;



        #region Paging
        settings.SettingsPager.Visible = true;
        settings.SettingsPager.PageSizeItemSettings.Visible = true;
        settings.SettingsPager.PageSizeItemSettings.Items = new string[] { "10", "20", "50", "100" };
        settings.SettingsPager.PageSize = 10;
        #endregion
        #region filtering
        settings.SettingsSearchPanel.CustomEditorName = "search";
        settings.Settings.ShowHeaderFilterButton = false;
        //settings.Settings.ShowFilterBar = GridViewStatusBarMode.Visible;

        settings.SettingsFilterControl.ViewMode = FilterControlViewMode.VisualAndText;
        settings.Settings.AutoFilterCondition = AutoFilterCondition.Contains;

        #endregion
        #region Sorting
        settings.TotalSummary.Add(DevExpress.Data.SummaryItemType.Count, "NombreEmpleado");
        settings.TotalSummary.Add(DevExpress.Data.SummaryItemType.Sum, "ValorCordobas");
        #endregion
        settings.Toolbars.Add(t =>
        {
            t.Enabled = true;
            t.Position = GridToolbarPosition.Top;
            t.EnableAdaptivity = true;

            //t.ItemAlign = GridToolbarItemAlign.Right;
            t.Items.Add(i =>
            {
                i.Command = GridViewToolbarCommand.Custom;
                i.Text = "Autorizar";
                i.Name = "Authorize";

            });
            t.Items.Add(i =>
            {
                i.Command = GridViewToolbarCommand.Custom;
                i.Text = "Denegar";
                i.Name = "Denied";
                i.BeginGroup = true;
                i.AdaptivePriority = 1;

            });

            t.Items.Add(i =>
            {
                i.Command = GridViewToolbarCommand.Custom;
                i.Text = "Refrescar";
                i.Name = "Refresh";
                i.Image.IconID = DevExpress.Web.ASPxThemes.IconID.ActionsRefresh16x16;
                i.BeginGroup = true;
                i.AdaptivePriority = 2;
            });

            t.Items.Add(i =>
            {
                i.BeginGroup = true;
                i.Alignment = MenuItemAlignment.Right;
                i.SetTemplateContent(c =>
                {
                    Html.DevExpress().ButtonEdit(s =>
                    {
                        s.Name = "search";
                        s.Properties.NullText = "Buscar..";
                        s.Properties.Buttons
                            .Add()
                            .Image.IconID = DevExpress.Web.ASPxThemes.IconID.FindFind16x16gray;

                    }).Render();
                });
            });

        });

        settings.ClientSideEvents.ToolbarItemClick = "onToolbarItemClick";
        #region Personalizacion de botones
        settings.CommandColumn.Visible = true;
        settings.CommandColumn.ButtonRenderMode = GridCommandButtonRenderMode.Image;

        settings.CommandColumn.ShowSelectCheckbox = true;
        settings.CommandColumn.SelectAllCheckboxMode = GridViewSelectAllCheckBoxMode.Page;


        settings.CommandColumn.Width = 10;
        #endregion

        settings.Columns.Add(c =>
        {
            c.Caption = " ";
            c.SetDataItemTemplateContent(tc =>
            {

                ViewContext.Writer.Write(

                    @Html.DevExpress().Button(p =>
                    {
                        p.Name = "btnViewVoucherBoss" + tc.KeyValue;
                        p.Text = "";
                        p.Width = 5;
                        p.EnableTheming = false;
                        p.Images.Image.Url = Url.Content("~/Content/Icons/Acrobat.png");
                        p.ImagePosition = ImagePosition.Left;
                        p.ToolTip = "Ver Voucher";


                        p.ClientSideEvents.Click = string.Format("function(s,e) {{ShowVoucher(s.name,'{0}'); }}", Url.Action("LoadSupport", "ConsumptionClaro", new { idConsumo = (tc as GridViewDataItemTemplateContainer).KeyValue }));
                    }).GetHtml()
                    );


            });


            c.Settings.AllowDragDrop = DefaultBoolean.False;
            c.Settings.AllowSort = DefaultBoolean.False;
            c.Width = 5;
        });



        settings.Columns.Add(col =>
        {
            col.FieldName = "NombreEmpleado";

            col.Caption = "Colaborador";
            col.Width = 20;
            col.AdaptivePriority = 1;
        });


        settings.Columns.Add(col =>
        {
            col.FieldName = "IdUnidad";

            col.Caption = "Unidad";

            col.Width = 10;
            col.AdaptivePriority = 2;
        });

        settings.Columns.Add(col =>
        {
            col.FieldName = "FechaRegistro";

            col.Caption = "Fecha";
            col.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
            col.ColumnType = MVCxGridViewColumnType.DateEdit;
            col.Width = 10;
            col.AdaptivePriority = 3;

        });


        settings.Columns.Add(col =>
        {
            col.FieldName = "CantidadLitros";

            col.Caption = "Cantidad";

            col.Width = 10;
            col.AdaptivePriority = 4;
            col.PropertiesEdit.DisplayFormatString = "n2";
        });




        settings.Columns.Add(col =>
        {
            col.FieldName = "PrecioLitros";

            col.Caption = "Precio(Lt)";
            col.Width = 10;
            col.AdaptivePriority = 5;
            col.PropertiesEdit.DisplayFormatString = "c";
        });
        settings.Columns.Add(col =>
        {
            col.FieldName = "ValorCordobas";

            col.Caption = "Monto Factura";
            col.Width = 15;
            col.AdaptivePriority = 6;
            col.PropertiesEdit.DisplayFormatString = "c";
        });
        settings.Columns.Add(col =>
        {
            col.FieldName = "Estacion";

            col.Caption = "Estación";
            col.Width = 20;
            col.AdaptivePriority = 7;
        });

        //settings.Columns.Add(col =>
        //{
        //    col.FieldName = "LicenseStatus";

        //    col.Caption = "Estado";
        //    col.Width = 30;
        //    col.AdaptivePriority = 11;
        //});


        settings.CellEditorInitialize = (s, e) =>
        {
            ((ASPxEdit)e.Editor).ValidationSettings.Display = Display.Dynamic;
        };

    });
    if (ViewData["EditError"] != null)
    {
        grid.SetEditErrorText((string)ViewData["EditError"]);
    }
}
@grid.Bind(Model).GetHtml()





