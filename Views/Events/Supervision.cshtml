@{
    ViewBag.Title = "Dashboard de Liga";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}

<style>
    :root {
        --blue-claro: #002f6c;
        --red-claro: #ef3829;
        --bg-body: #f1f5f9;
    }

    body {
        background-color: var(--bg-body);
        font-family: 'Inter', sans-serif;
    }

    .stat-card {
        border: none;
        border-radius: 12px;
        padding: 20px;
        background: #fff;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        border-left: 5px solid var(--blue-claro);
    }

        .stat-card.finalizados {
            border-left-color: #22c55e;
        }

        .stat-card.jugadores {
            border-left-color: var(--red-claro);
        }

    .stat-value {
        font-size: 1.8rem;
        font-weight: 800;
        display: block;
        color: #1e293b;
    }

    .stat-label {
        color: #64748b;
        font-size: 0.85rem;
        text-transform: uppercase;
        font-weight: 600;
    }

    .card-table {
        border: none;
        border-radius: 12px;
        background: #fff;
        box-shadow: 0 10px 15px rgba(0,0,0,0.05);
        padding: 25px;
        margin-bottom: 30px;
    }

    .status-pill {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
    }

        .status-pill.registro {
            background: #fef3c7;
            color: #92400e;
        }

        .status-pill.finalizado {
            background: #dcfce7;
            color: #166534;
        }

        .status-pill.lleno {
            background: #fee2e2;
            color: #991b1b;
        }

    .dt-button.buttons-excel {
        background-color: #10b981 !important;
        color: white !important;
        border-radius: 6px !important;
        border: none !important;
        font-weight: 600 !important;
        padding: 8px 16px !important;
        margin-bottom: 15px !important;
    }

        .dt-button.buttons-excel:hover {
            background-color: #059669 !important;
        }

    table.dataTable thead th {
        background-color: #f8fafc;
        color: #475569;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        border-bottom: 1px solid #e2e8f0;
    }

    .titulo-seccion {
        color: var(--blue-claro);
        font-weight: 700;
        margin-bottom: 15px;
        border-bottom: 2px solid #e2e8f0;
        padding-bottom: 10px;
    }
</style>

<div class="container-fluid mt-4" style="max-width: 1400px; margin-bottom: 50px;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-navy font-weight-bold m-0" style="color: var(--blue-claro);">
            <i class="fas fa-chart-line mr-2"></i> Dashboard de Inscripciones
        </h2>

        <div class="d-flex align-items-center">
            <label class="mr-2 font-weight-bold mb-0 text-secondary">Filtrar Año:</label>
            <select id="cbAnio" class="form-control" style="width: 100px; font-weight: 600;" onchange="recargarTablas()">
            </select>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4 mb-3 mb-md-0">
            <div class="stat-card">
                <span class="stat-value" id="totalEquipos">0</span>
                <span class="stat-label">Equipos Registrados</span>
            </div>
        </div>
        <div class="col-md-4 mb-3 mb-md-0">
            <div class="stat-card finalizados">
                <span class="stat-value" id="equiposCerrados">0</span>
                <span class="stat-label">Equipos Finalizados</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card jugadores">
                <span class="stat-value" id="totalJugadores">0</span>
                <span class="stat-label">Total Jugadores Inscritos</span>
            </div>
        </div>
    </div>

    <div class="card card-table">
        <h4 class="titulo-seccion"><i class="fas fa-users-cog mr-2"></i> Resumen de Equipos y Capacidad</h4>
        <div class="table-responsive">
            <table id="tablaResumen" class="table table-hover w-100">
                <thead>
                    <tr>
                        <th>Equipo</th>
                        <th>Disciplina</th>
                        <th>Estado</th>
                        <th class="text-center">Jugadores Actuales</th>
                        <th class="text-center">Límite Permitido</th>
                        <th class="text-center">Cupos Restantes</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>

    <div class="card card-table">
        <h4 class="titulo-seccion"><i class="fas fa-tshirt mr-2"></i> Detalle para Uniformes</h4>
        <div class="table-responsive">
            <table id="tablaSupervision" class="table table-hover w-100">
                <thead>
                    <tr>
                        <th>Equipo</th>
                        <th>Disciplina</th>
                        <th>Carnet</th>
                        <th>Jugador</th>
                        <th>Teléfono</th>
                        <th>Talla Uniforme</th>
                        <th>Zapato</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

@section scripts {
    <link href="~/onlinecss/jquery.fancybox.min.css" rel="stylesheet" />

    <script src="~/onlinejs/jquery-3.6.0.min.js"></script>
    <script src="~/onlinejs/jquery-ui.js"></script>
    <script src="~/onlinejs/bootstrap.bundle.min.js"></script>
    <script src="~/onlinejs/moment.min.js"></script>

    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>

    <script src="~/onlinejs/dataTables.responsive.min.js"></script>
    <script src="~/onlinejs/responsive.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.select.min.js"></script>

    <script src="~/onlinejs/jszip3.10.1.min.js"></script>
    <script src="~/onlinejs/dataTables.buttons.min.js"></script>
    <script src="~/onlinejs/buttons.bootstrap4.min.js"></script>
    <script src="~/onlinejs/buttons.html5.min.js"></script>

    <script src="~/Content/plugin/sweetalert2/sweetalert2.all.js"></script>
    <script src="~/onlinejs/loadingoverlay.min.js"></script>
    <script src="~/onlinejs/jquery.fancybox.min.js"></script>

    <script>
        var tablaJugadores, tablaResumen;

        $(document).ready(function() {
            var yearActual = new Date().getFullYear();
            var $cbAnio = $("#cbAnio");
            $cbAnio.empty();
            for (var y = yearActual; y >= 2024; y--) { $cbAnio.append(new Option(y, y)); }
            $cbAnio.val(yearActual);

            tablaResumen = $('#tablaResumen').DataTable({
                "data": [],
                "columns": [
                    { "data": "Equipo", "className": "font-weight-bold" },
                    { "data": "Disciplina" },
                    {
                        "data": "Estado",
                        "render": function(data) {
                            var clase = data === 'Finalizado' ? 'finalizado' : 'registro';
                            return `<span class="status-pill ${clase}">${data}</span>`;
                        }
                    },
                    { "data": "Jugadores", "className": "text-center font-weight-bold" },
                    { "data": "Limite", "className": "text-center text-secondary" },
                    {
                        "data": "Faltan",
                        "className": "text-center font-weight-bold",
                        "render": function(data) {
                            if(data <= 0) return `<span class="status-pill lleno">LLENO (0)</span>`;
                            return data;
                        }
                    }
                ],
                "dom": 'Bfrtip',
                "buttons": [{
                    extend: 'excelHtml5',
                    text: '<i class="fas fa-file-excel mr-1"></i> Exportar Capacidad de Equipos',
                    title: function() { return 'Resumen_Capacidad_Equipos_' + $("#cbAnio").val(); }
                }],
                "language": { "url": "//cdn.datatables.net/plug-ins/1.10.25/i18n/Spanish.json" }
            });

            tablaJugadores = $('#tablaSupervision').DataTable({
                "ajax": {
                    "url": '@Url.Action("GetListaSupervision", "Events")',
                    "dataSrc": ""
                },
                "columns": [
                    { "data": "Equipo", "className": "font-weight-bold" },
                    { "data": "Disciplina" },
                    { "data": "Carnet" },
                    { "data": "Jugador" },
                    { "data": "Telefono" },
                    // Asumo que tu API sigue devolviendo la propiedad "Camisa".
                    // Como en el registro guardamos la misma talla para ambos, basta con leer uno de ellos.
                    { "data": "Camisa", "className": "text-center font-weight-bold" },
                    { "data": "Zapatos", "className": "text-center font-weight-bold" }
                ],
                "dom": 'Bfrtip',
                "buttons": [{
                    extend: 'excelHtml5',
                    text: '<i class="fas fa-file-excel mr-1"></i> Exportar Tallas Uniformes',
                    title: function() { return 'Reporte_Uniformes_Liga_' + $("#cbAnio").val(); }
                }],
                "drawCallback": function(settings) {
                    procesarDatosYResumen(settings.json);
                },
                "language": { "url": "//cdn.datatables.net/plug-ins/1.10.25/i18n/Spanish.json" }
            });
        });

        function recargarTablas() {
            var yearSeleccionado = $("#cbAnio").val();
            var nuevaUrl = '@Url.Action("GetListaSupervision", "Events")?year=' + yearSeleccionado;
            tablaJugadores.ajax.url(nuevaUrl).load();
        }

        function procesarDatosYResumen(data) {
            if(!data || data.length === 0) {
                $("#totalEquipos, #equiposCerrados, #totalJugadores").text("0");
                tablaResumen.clear().draw();
                return;
            }

            var equiposObj = {};
            var finalizados = 0;

            data.forEach(function(row) {
                if (!equiposObj[row.Equipo]) {
                    equiposObj[row.Equipo] = {
                        Equipo: row.Equipo,
                        Disciplina: row.Disciplina,
                        Estado: row.EstadoEquipo,
                        Jugadores: 0
                    };
                    if (row.EstadoEquipo === 'Finalizado') { finalizados++; }
                }
                equiposObj[row.Equipo].Jugadores++;
            });

            var arrayResumen = [];
            for (var key in equiposObj) {
                var eq = equiposObj[key];
                var limite = 12;

                switch(eq.Disciplina) {
                    case 'Softball': limite = 18; break;
                    case 'Tenis de Mesa': limite = 5; break;
                    case 'Football Sala':
                    case 'Volibol':
                    case 'Basketball': limite = 12; break;
                }

                eq.Limite = limite;
                eq.Faltan = limite - eq.Jugadores;
                arrayResumen.push(eq);
            }

            $("#totalEquipos").text(arrayResumen.length);
            $("#equiposCerrados").text(finalizados);
            $("#totalJugadores").text(data.length);

            tablaResumen.clear().rows.add(arrayResumen).draw();
        }
    </script>
}