@{
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}

<!DOCTYPE html>

<html>
<head>

    <title>Eventos</title>

    <link href="@Url.Content("~/Content/css/jquery.dataTables.min.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/Content/css/bootstrap.min.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/Content/css/dataTables.bootstrap.min.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/Content/css/dataTables.bootstrap4.min.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/Content/css/responsive.dataTables.min.css")" rel="stylesheet" type="text/css" />
    <link href="@Url.Content("~/Content/css/responsive.bootstrap4.min.css")" rel="stylesheet" type="text/css" />

    <script src="@Url.Content("~/Scripts/js/jquery-3.3.1.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/js/jquery.dataTables.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/js/bootstrap.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/js/dataTables.bootstrap.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/js/dataTables.bootstrap4.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/js/dataTables.responsive.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/js/responsive.bootstrap4.min.js")" type="text/javascript"></script>
</head>

<body>
<div class="table-responsive">
    <table id="employeeTable" class="table table-striped table-bordered" style="width:100%">
        <thead>
        <tr>
            <th>Coordiandor</th>
            <th>Fecha</th>
            <th>Id</th>
            <th>Evento</th>

            <th></th>
        </tr>
        </thead>
    </table>
</div>


@section scripts{

    <script>
        $(document).ready(function() {
            $('#employeeTable').DataTable({
                "ajax": {
                    "url": "/Events/GetEventsJson",
                    "type": "GET",
                    //"dataSrc": "",
                    "dataType": "json",
                    
                    "responsive": "true"
                },
                "columns": [
                    { "data": "CoordinatorEmail", "autoWidth": true },
                    { "data": "EventDate", type: "date", render: function (value) {
                    if (value === null) return "";
                    var pattern = /Date\(([^)]+)\)/;//date format from server side
                    var results = pattern.exec(value);
                    var dt = new Date(parseFloat(results[1]));

                    return dt.getDate() + "/" + (dt.getMonth() + 1) + "/" + dt.getFullYear();
                }, "autoWidth": true
            },
                    { "data": "EventId" },
                    { "data": "EventName", "autoWidth": true }
                ],
                "language": {
                    "emptyTable": "No data found, Please click on <b>Add New</b> Button"
                }
            });


        });
    </script>
}

</body>

</html>
