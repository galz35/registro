@{
    ViewBag.Title = "Control de Plazas";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}
@{


    Entities.Employees employee = (Entities.Employees)Session["User"];
    //string imgPic = employee.Picture == null ? "~/Content/Icons/Add.png" : String.Format("data:image/jpg;base64", Convert.ToBase64String(employee.Picture));


}
<!-- CSS de DataTables, Bootstrap, Highcharts y Fancybox -->
<link href="~/onlinecss/jquery.fancybox.min.css" rel="stylesheet" />
<link href="~/onlinecss/highcharts.css" rel="stylesheet" />

<!-- Bootstrap Icons (Opcional, para mejores iconos) -->

<style>
    /* Estilos personalizados */
    body {
        background-color: #f4f6f9;
        color: #333333;
    }

    .card {
        background-color: #ffffff;
        border: none;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        margin-bottom: 30px;
        border-radius: 10px;
    }

    .card-header {
        background-color: #ffffff;
        color: #333333;
        border-bottom: none;
        border-top-left-radius: 10px;
        border-top-right-radius: 10px;
    }

    .card h6, .h3, .h6 {
        color: #333333;
    }
    .dropdown-menu {
        position: absolute !important; /* Asegura que el menú se posicione relativo al viewport */
        will-change: transform; /* Mejora el rendimiento al permitir cambios de posición */
        z-index: 1050; /* Coloca el menú por encima de otros elementos */
    }

    .table-responsive {
        overflow: visible; /* Permite que el contenido desborde fuera del contenedor de la tabla */
    }

    .card-body {
        position: relative; /* Asegura que el dropdown se posicione relativo al contenedor inmediato */
    }

    .kpi-card {
        background-color: #ffffff;
        color: #333333;
        border-left: 0.25rem solid #ff4d4d;
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

        .kpi-card .card-body {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

            .kpi-card .card-body .icon {
                font-size: 3em;
                opacity: 0.7;
                color: #ff4d4d;
                margin-top: 10px;
            }

    .animated {
        animation-duration: 1s;
        animation-fill-mode: both;
    }

    .fadeInUp {
        animation-name: fadeInUp;
    }

    .highcharts-background {
        fill: #ffffff;
    }

    .modal-dialog.modal-xl {
        max-width: 95% !important;
        width: 95% !important;
    }

    .modal-content {
        background-color: #ffffff;
        color: #333333;
        border-radius: 10px;
    }

    .chart-type-selector {
        margin-bottom: 15px;
    }

    .table-striped tbody tr:nth-of-type(odd) {
        background-color: #f9fafb;
    }

    .table tbody tr td {
        font-size: 0.9em;
        text-align: left;
    }

    .table thead th {
        background-color: #ff4d4d;
        color: white;
        text-transform: uppercase;
        text-align: center;
    }

    .progress {
        height: 20px;
    }

    .progress-bar {
        font-size: 0.9em;
        line-height: 20px;
    }

    table.display tbody tr:hover {
        background-color: #e2e8f0;
    }

    .dt-buttons .btn {
        margin-right: 5px;
    }

    .kpi-card:hover {
        box-shadow: 0 6px 8px rgba(0, 0, 0, 0.15);
        transform: translateY(-2px);
        transition: all 0.3s ease;
    }

    #graficoAcumuladoGerencia, #graficoAcumuladoPorGerenciaPie {
        height: 600px;
        margin: 0 auto;
    }

    #plazasTab .nav-link {
        color: black !important; /* Color de letra negro por defecto */
    }

        /* Opcional: Cambiar color al estar activo o en hover */
        #plazasTab .nav-link:hover,
        #plazasTab .nav-link.active {
            color: black !important; /* Cambia el color al azul estándar de Bootstrap o elige otro */
        }
</style>

<div class="container-fluid">
    <!-- Dashboard KPIs -->
    <!-- Gráficos de Acumulado por Gerencia -->


    <div class="nav-tabs-custom" style="@((employee.GERENCIA.Contains("RECURSOS HUMANOS") || employee.cargo.Contains("DIRECTOR PAIS")==true|| employee.GERENCIA.Contains("NI DIRECCION PAIS")) ? "" : "display:none;")">
        <ul class="nav nav-tabs" id="plazasTab" role="tablist">
            <li class="nav-item">
                <a class="nav-link active" href="#tab-acumulado" data-toggle="tab">Acumulado de Vacaciones</a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="#tab-porcentaje" data-toggle="tab">Avance en registro de Programación</a>
            </li>

        </ul>
        <div class="tab-content">
            <div class="tab-pane active" id="tab-acumulado">
                <div id="graficoAcumuladoGerenciaBar"></div>
            </div>

            <div class="tab-pane" id="tab-porcentaje">
