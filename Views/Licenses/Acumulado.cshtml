    <script>
        $(document).ready(function () {
            // Inicializar DataTable tablaPlazas
            var tablaPlazas = $('#tablaPlazas').DataTable({
                "ajax": {
                    "url": "@Url.Action("ObtenerGerentes", "Licenses")",
                    "type": "GET",
                    "datatype": "json",
                    "dataSrc": function (json) {
                        if (json.error) {
                            Swal.fire('Error', json.error, 'error');
                            return [];
                        }
                        return json.data;
                    }
                },
                "columns": [{
                    "data": null,
                    "render": function (data, type, row) {
                        return `
                        <div class="dropdown">
                            <button class="btn btn-secondary btn-sm dropdown-toggle" type="button" id="accionesMenu${row.Carnet}" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                Acciones
                            </button>

                            <div class="dropdown-menu" aria-labelledby="accionesMenu${row.Carnet}">
     <a class="dropdown-item ver-vacaciones" href="#" data-carnet="${row.Carnet}">
                                    <i class="fas fa-calendar-check"></i> Ver mis Vacaciones
                                </a>
                                <a class="dropdown-item ver-detalle" href="#" data-gerencia="${row.Gerencia}">
                                    <i class="fas fa-eye"></i> Ver acumulado de vacaciones por Gerencia
                                </a>

                                <a class="dropdown-item ver-vacaciones-gerencia" href="#" data-gerencia="${row.Gerencia}">
                                    <i class="fas fa-calendar-alt"></i> Ver vacaciones de equipo
                                </a>
            <a class="dropdown-item programacion-gerencia" href="#" data-gerencia="${row.Gerencia}">
            <i class="fas fa-calendar-plus"></i> Programacion de Vacaciones
        </a>
        <a class="dropdown-item programacion-detalle" href="#" data-gerencia="${row.Gerencia}">
            <i class="fas fa-calendar-check"></i>Vacaciones Pendientes de programar
        </a>
                            </div>
                        </div>`;
                    },
                    "orderable": false,
                    "searchable": false
                },
                    { "data": "Gerencia" },
                    { "data": "Nombre" },
                    { "data": "Carnet" },
                    { "data": "Cargo" },
                    {
                        "data": "AcumuladoGerente",
                        "render": $.fn.dataTable.render.number(',', '.', 2, '')
                    },
                    {
                        "data": "AcumuladoGerencia",
                        "render": $.fn.dataTable.render.number(',', '.', 2, '')
                    }

                ],
                "dom": 'Blfrtip',
                "lengthMenu": [10, 20, 50, 100],
                "pageLength": 10,
                "language": {
                    "url": "@Url.Content("~/Scripts/datatable.es-ES.json")"
                },
                "responsive": true,
                "order": [[5, 'desc']], // Ordenar por AcumuladoGerencia DESC

                "initComplete": function () {
                    // Opcional: agregar filtros al footer si lo deseas
                },
                "buttons": [
                    'copy', 'csv', 'excel', 'pdf', 'print'
                ]
            });
        $('#btnVerDetalle').on('click', function () {
    var gerencia = "nada";
    $('#detalleGerenciaModalLabel').text('Detalle General: Sin Gerencia Específica');

    // Mostrar loading usando SweetAlert2
    Swal.fire({
        title: 'Cargando...',
        allowOutsideClick: false,
        didOpen: () => {
            Swal.showLoading();
        }
    });

    // Obtener datos de empleados sin filtrar por gerencia
    $.ajax({
        url: '@Url.Action("ObtenerEmpleadosPorGerencia", "Licenses")',
        type: 'GET',
        data: { gerencia: gerencia },
        success: function (data) {
            if (data.error) {
                Swal.fire('Error', data.error, 'error');
                return;
            }

            // Construir la tabla de detalle
            var tablaDetalle = `
                <table id="tablaDetalleGerencia" class="table table-striped table-bordered" style="width:100%">
                    <thead>
                        <tr>
                            <th>Carnet</th>
                            <th>Nombre</th>
                            <th>Cargo</th>
                            <th>Área</th>
                            <th>Acumulado</th>
                        </tr>
                    </thead>
                    <tbody>
            `;

            data.data.forEach(function (item) {
                tablaDetalle += `
                    <tr>
                        <td>${item.Carnet}</td>
                        <td>${item.NombreCompleto}</td>
                        <td>${item.Cargo}</td>
                        <td>${item.Area}</td>
                        <td>${numeral(item.Acumulado).format('0,0.00')}</td>
                    </tr>
                `;
            });

            tablaDetalle += `
                    </tbody>
                </table>
            `;

            $('#detalleGerenciaContenido').html(tablaDetalle);

            // Inicializar DataTable en el modal
            $('#tablaDetalleGerencia').DataTable({
                "order": [[3, 'desc']],
                "language": {
                    "url": "@Url.Content("~/Scripts/datatable.es-ES.json")"
                },
                "responsive": true,
                "order": [[4, 'desc']],
                "dom": 'Bfrtip',
                "buttons": [
                    'copy', 'csv', 'excel', 'pdf', 'print'
                ]
            });

            // Cerrar el loading
            Swal.close();

            // Mostrar el modal
            $('#detalleGerenciaModal').modal('show');
        },
        error: function (xhr, status, error) {
            Swal.fire('Error', 'No se pudo obtener el detalle general.', 'error');
            console.error('Error en AJAX:', error);
        }
    });
});

