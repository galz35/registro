@{
    ViewBag.Title = "Aprobación de Vacaciones";
 }
<style>
    /* agranda todos los checkboxes de la tabla */
    #dataTable input.checkItem,
    #checkAll {
        transform: scale(1.5); /* 1.2–1.5 suele ser cómodo */
        margin: 4px; /* separa un poco del texto */
        cursor: pointer;
    }
</style>


<div class="container-fluid mt-4">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Aprobación Masiva de Vacaciones</h5dataTable
</div>
        <div class="card-body">
            <div class="mb-3">
                <!-- Botones de acción masiva (sin campo comentario, pues se quema en el controlador) -->
                <button class="btn btn-success" id="btnMassApprove">Aprobar Seleccionados</button>
                <button class="btn btn-danger" id="btnMassDeny">Denegar Seleccionados</button>
                <button class="btn btn-secondary" id="btnRefresh">Refrescar Lista</button>
                <!-- Botón para abrir modal de errores -->
                <button class="btn btn-warning" id="btnVerErrores">
                    <i class="fas fa-exclamation-triangle"></i> Ver ausencias con error
                </button>



            </div>
            <div class="table-responsive">
                <table id="dataTable" class="table table-striped table-bordered dt-responsive nowrap" width="100%">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th><input type="checkbox" id="checkAll" /></th>
                            <th>Acción</th>           <!-- ↓ quitamos las dos columnas anteriores -->
                            <th>Tipo</th>
                            <th>Fecha Inicio</th>
                            <th>Fecha Fin</th>

                            <th>Duración</th>
                            <th>Carnet</th>
                            <th>Nombre Completo</th>
                            <th>Gerencia</th>
                            <th>Hora Inicio</th>
                            <th>Hora Fin</th>
                            <th>Estado</th>
                            <th>Comentario</th>

                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="absenceEditModal" tabindex="-1" role="dialog" aria-labelledby="absenceEditModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="absenceEditModalLabel">Editar Vacación</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="absenceEditForm">
                    <input type="hidden" id="absenceEntryId" name="absenceEntryId" />
                    <!-- Datos de registro (solo lectura) -->
                    <div class="form-group">
                        <label for="editCarnet">Carnet</label>
                        <input type="text" class="form-control" id="editCarnet" readonly />
                    </div>
                    <div class="form-group">
                        <label for="editNombreCompleto">Nombre Completo</label>
                        <input type="text" class="form-control" id="editNombreCompleto" readonly />
                    </div>
                    <div class="form-group">
                        <label for="editComentario">Comentario</label>
                        <input type="text" class="form-control" id="editComentario" readonly />
                    </div>
                    <div class="form-group">
                        <label for="editEstado">Estado</label>
                        <input type="text" class="form-control" id="editEstado" readonly />
                    </div>
                    <!-- Campos editables -->
                    <div class="form-group">
                        <label for="newStartDate">Fecha de Inicio</label>
                        <input type="date" class="form-control" id="newStartDate" name="newStartDate" required />
                    </div>
                    <div class="form-group">
                        <label for="newEndDate">Fecha de Fin</label>
                        <input type="date" class="form-control" id="newEndDate" name="newEndDate" required />
                    </div>
                    <div class="form-group">
                        <label for="newStartTime">Hora de Inicio</label>
                        <input type="time" class="form-control" id="newStartTime" name="newStartTime" required />
                    </div>
                    <div class="form-group">
                        <label for="newEndTime">Hora de Fin</label>
                        <input type="time" class="form-control" id="newEndTime" name="newEndTime" required />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success" onclick="submitAbsenceEdit('approve')">Aprobar</button>
                <button type="button" class="btn btn-danger" onclick="submitAbsenceEdit('deny')">Denegar</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalHistorial" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Historial de ausencias</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div id="historialContent">
                    <div class="text-center"><i class="fas fa-spinner fa-spin"></i> Cargando...</div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="modalErrores" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title">Ausencias con error</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body" id="contenedorErrores">
                <div class="text-center">
                    <i class="fas fa-spinner fa-spin"></i> Cargando...
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Botón + modal (colócalo junto a tus botones actuales) -->
 

<div class="modal fade" id="modalPendYErr" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title">Ausencias pendientes (año pasado) y con error</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body" id="contenedorPendYErr">
                <div class="text-center"><i class="fas fa-spinner fa-spin"></i> Cargando...</div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/onlinejs/jquery-3.6.0.min.js"></script>
    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.buttons.min.js"></script>
