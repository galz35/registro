          // Función para procesar actualizaciones masivas, una por una, y actualizar el progreso
      function processMassUpdate(actionType) {
    var ids = getSelectedIDs().split(",");
    if (ids.length === 0 || ids[0] === "") {
        swal.fire("Advertencia", "Debe seleccionar al menos una ausencia.", "warning");
        return;
    }
    var total = ids.length;
    var processed = 0;
    var responses = [];

    // Abrir un SweetAlert2 con un indicador de carga personalizado
    Swal.fire({
        title: 'Procesando...',
        html: 'Procesando <b>0</b> de ' + total,
        allowOutsideClick: false,
        showConfirmButton: false,
        didOpen: () => {
            Swal.showLoading();
        }
    });

    function processNext() {
        if (ids.length === 0) {
            // Cuando se termina de procesar todos los registros, se cierra el swal y se muestra mensaje final.
            Swal.fire("Éxito", "Actualización masiva completada.", "success").then(function () {
                tablaVacations.ajax.reload();
            });
            return;
        }
        var id = ids.shift();
        $.ajax({
            url: '@Url.Action("UpdateAbsenceedit4", "Licenses")',
            type: "POST",
            data: { absenceId: id, actionType: actionType },
            success: function (result) {
                responses.push(result);
                processed++;
                // Si el resultado indica error, se muestra el mensaje durante 5 segundos
                if (result.status === "Error") {
                    Swal.fire({
                        title: "Error",
                        html: result.message,
                        icon: "error",
                        timer: 5000,
                        timerProgressBar: true,
                        showConfirmButton: true
                    });
                    // Se espera 5 segundos antes de continuar
                    setTimeout(processNext, 5000);
                }
                Swal.update({
                    html: 'Procesando <b>' + processed + '</b> de ' + total
                });
                setTimeout(processNext, 500); // Retardo de 0.5 s entre cada llamada
            },
            error: function () {
                processed++;
                Swal.update({
                    html: 'Procesando <b>' + processed + '</b> de ' + total
                });
                setTimeout(processNext, 500);
            }
        });
    }
    processNext();
}
        // Función para enviar actualización individual desde el modal
        function submitAbsenceEdit(actionType) {
            var absenceEntryId = $("#absenceEntryId").val();
            var newStartDate = $("#newStartDate").val();
            var newEndDate = $("#newEndDate").val();
            var newStartTime = $("#newStartTime").val();
            var newEndTime = $("#newEndTime").val();
            Swal.fire({
                title: 'Procesando...',
                html: 'Por favor espere...',
                allowOutsideClick: false,
                showConfirmButton: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            // Validar que las fechas sean válidas
            var startDate = moment(newStartDate, "YYYY-MM-DD");
            var endDate = moment(newEndDate, "YYYY-MM-DD");
            if (!startDate.isValid() || !endDate.isValid()) {
                swal.fire("Error!", "Una de las fechas ingresadas no es válida.", "error");
                return;
            }
            // Validar que la fecha de fin no sea anterior a la fecha de inicio
            if (endDate.isBefore(startDate)) {
                Swal.fire("Error!", "La fecha de fin no puede ser anterior a la fecha de inicio.", "error");
                return;
            }
            // Si es el mismo día, validar que la hora de fin no sea anterior a la hora de inicio
            if (startDate.isSame(endDate)) {
                var startTime = moment(newStartTime, "HH:mm");
                var endTime = moment(newEndTime, "HH:mm");
                if (!startTime.isValid() || !endTime.isValid()) {
                    swal.fire("Error!", "Una de las horas ingresadas no es válida.", "error");
                    return;
                }
                if (endTime.isBefore(startTime)) {
                    swal.fire("Error!", "La hora de fin no puede ser anterior a la hora de inicio.", "error");
                    return;
                }
            }
            $.ajax({
                url: '@Url.Action("UpdateAbsenceedit3", "Licenses")',
                type: "POST",
                data: {
                    absenceId: absenceEntryId,
                    actionType: actionType,
                    comment: "", // Sin comentario, ya está quemado en el controller
                    newStartDate: newStartDate,
                    newEndDate: newEndDate,
                    newStartTime: newStartTime,
                    newEndTime: newEndTime
                },
                success: function (result) {
                    Swal.close();
                    if (result.status == "OK" || result.status =="Advertencia") {
                        swal.fire("Éxito!", result.message, "success").then(function () {
                            $("#absenceEditModal").modal("hide");
                            tablaVacations.ajax.reload();
                        });
                    } else {
                        swal.fire("Error!", result.message, "error");
                    }
                },
                error: function () {
                    swal.fire("Error!", "Ocurrió un error al actualizar la ausencia.", "error");
                }
            });
        }
    </script>
