@model Entities.Licenses
@{
    Layout = "~/Views/Shared/_popupLayout.cshtml";
}
<style type="text/css">


    .memo * {
        text-transform: uppercase;
    }
</style>
<script type="text/javascript">
    function OnFileUploadComplete(s, e) {
        clientFileName.SetText(e.callbackData);
    }
 

    function OnInit(s, e) {
        AdjustSize();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            AdjustSize();
        });
    }
    function OnEndCallback(s, e) {
        AdjustSize();
    }
    function AdjustSize() {
        var height = document.documentElement.clientHeight;
        gvDetailAppointment.SetHeight(height - 100);
    }
     function GuardarCita(s, e) {
        // prevent the default event behaviour

        $.ajax({
            url: '@Url.Action("UpdateLicenseAttached")',
            type: "POST",
            data: $('#frmlicencia').serialize(),
            dataType: "json",
            traditional: true,
            cache: false,
            //contentType: "application/json; charset=utf-8",
            success: function (data) {
                $.LoadingOverlay("hide");
                if (data.status != "Error") {


                    swal({
                            title: "Exito!",
                            text: data.message,
                            icon: "success",
                            button: "Aceptar",
                        })
                        .then((willSaved) => {
                            if (willSaved) {
                                top.popEditAppointment.Hide();
                            }

                        });
                } else {
                    swal({
                        title: "Advertencia!",
                        text: data.message,
                        icon: "warning",
                        button: "Aceptar",
                    })
                    //swal("ERROR!", "Ocurrió un error en la transaccion, por favor corrija.", "error");
                }


            },

            beforeSend: function () {
                $.LoadingOverlay("show");
            },
            error: function (error) {
                $.LoadingOverlay("hide");
                swal("Error!", "Ocurrió un error en la transaccion, por favor corrija.", "error");
            }
        });
    }

</script>
@Html.Partial("RegisterEditPartial", Model)
