
@{
    ViewBag.Title = "Lista de Colaboradores";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}

<script type="text/javascript">
    function voz(mensaje) {
        vozHablar = new SpeechSynthesisUtterance(mensaje);
        window.speechSynthesis.speak(vozHablar);

    }
    function OnInit(s, e) {
        AdjustSize();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            AdjustSize();
        });
      
    }
    function OnEndCallback(s, e) {
        AdjustSize();
    }
    function AdjustSize() {
        var height = document.documentElement.clientHeight;
        gvEmployees.SetHeight(height-150);
    }
</script>
@Html.Action("EmployeesListPartial")
