@model Entities.MyEntities.LicenseParameters
@{
    Layout = "~/Views/Shared/_mainLayout.cshtml";
    ViewBag.Title = "Saldo de vacaciones";
}

<style type="text/css">
    .buttonsContainer {
        max-width: 300px;
        margin: 0 0 0 auto;
        text-align: right;
        padding-top: 12px;
    }

    .submitButton,
    .cancelButton {
        margin-bottom: 12px;
    }

    .cancelButton {
        margin-left: 8px;
    }

    .groupCaption {
        margin-top: -6px;
    }

    .clearPaddings {
        padding-top: 0;
        padding-bottom: 0;
    }
</style>

<script type="text/javascript">
    function OnAreaComboboxInit(s, e) {
        s.InsertItem(0, 'TODOS LOS COLABORADORES', 0);
    }

    function OnInit(s, e) {
        var message = '@ViewData["EditError"]';
        if(message) {
            s.SetContentHtml(message);
            s.Show();
        }
    }


</script><br />


<!DOCTYPE html>
<html>
<body>
    @using (Html.BeginForm("EmployeesBalanceReport", "Licenses", FormMethod.Post))
    {
        @Html.DevExpress().PopupControl(settings =>
   {
       settings.Theme = "Mulberry";
       settings.Name = "PopupControl";
       settings.HeaderText = "Selección de parametros";
       settings.ShowOnPageLoad = true;
       settings.CloseAction = CloseAction.CloseButton;
       settings.CloseOnEscape = true;
       settings.AllowDragging = false;
       settings.ShowFooter = true;
       settings.PopupHorizontalAlign = PopupHorizontalAlign.WindowCenter;
       settings.PopupVerticalAlign = PopupVerticalAlign.WindowCenter;
       settings.Width = 400;
       settings.SetFooterTemplateContent(c =>
       {
           @Html.DevExpress().FormLayout(formLayoutsettings =>
           {
               formLayoutsettings.Name = "footerFormLayout";
               formLayoutsettings.Width = Unit.Percentage(100);
               formLayoutsettings.ControlStyle.CssClass = "clearPaddings";
               formLayoutsettings.Styles.LayoutItem.CssClass = "clearPaddings";
               formLayoutsettings.Styles.LayoutGroup.CssClass = "clearPaddings";
               formLayoutsettings.Items.AddGroupItem(g =>
               {
                   g.GroupBoxDecoration = GroupBoxDecoration.None;
                   g.Paddings.Padding = Unit.Pixel(0);
                   g.Items.Add(i =>
                   {
                       i.ShowCaption = DefaultBoolean.False;
                   }).SetNestedContent(() =>
                   {
                       ViewContext.Writer.Write("<div class='buttonsContainer'>");
                       Html.DevExpress().Button(s =>
                       {
                           s.Name = "btnAcept";
                           s.Width = Unit.Pixel(100);
                           s.ControlStyle.CssClass = "submitButton";
                           s.Text = "Aceptar";
                           s.UseSubmitBehavior = true;
                       }).Render();
                       Html.DevExpress().Button(s =>
                       {
                           s.Name = "btnCancel";
                           s.Width = Unit.Pixel(100);
                           s.ControlStyle.CssClass = "cancelButton";
                           s.Text = "Cancelar";
                           s.UseSubmitBehavior = false;
                           s.ClientSideEvents.Click = "function(s, e){ PopupControl.Hide(); }";
                       }).Render();
                       ViewContext.Writer.Write("</div>");
                   });
               });
           }).Render();
       });

       settings.SetContent(() =>
       {
           @Html.DevExpress().FormLayout(formLayoutsettings =>
           {
               formLayoutsettings.Name = "detailFormLayout";
               formLayoutsettings.SettingsAdaptivity.AdaptivityMode = FormLayoutAdaptivityMode.SingleColumnWindowLimit;
               formLayoutsettings.SettingsAdaptivity.SwitchToSingleColumnAtWindowInnerWidth = 576;

               formLayoutsettings.Items.AddGroupItem(g =>
               {
                   g.Caption = "Saldo actual";
                   g.RowSpan = 2;
                   g.Paddings.Padding = Unit.Pixel(0);
                   g.Paddings.PaddingTop = Unit.Pixel(10);
                   g.GroupBoxDecoration = GroupBoxDecoration.HeadingLine;
                   g.GroupBoxStyle.Caption.Font.Bold = true;
                   g.GroupBoxStyle.Caption.Font.Size = 10;


                   g.Items.Add(m => m.PersonId, i =>
                   {
                       i.Caption = "Colaborador";
                       i.NestedExtension().ComboBox(de =>
                       {
                           de.Width = 200;
                           de.ShowModelErrors = true;
                           de.Properties.NullText = "SELECCIONE COLABORADOR";
                           de.Properties.ValidationSettings.Display = Display.Dynamic;
                           de.Properties.ValidationSettings.ErrorDisplayMode = ErrorDisplayMode.None;
                           de.Properties.DropDownStyle = DropDownStyle.DropDownList;
                           de.SelectedIndex = 0;
                           de.Properties.IncrementalFilteringMode = IncrementalFilteringMode.StartsWith;
                           de.Properties.TextField = "FullName";
                           de.Properties.ValueField = "Idhrms";
                           de.Properties.ValueType = typeof(int);
                           de.Properties.DataSource = slnRhonline.Models.Employees.GetEmployeesByRealBossLicenses();
                           de.Properties.ClientSideEvents.Init = " OnAreaComboboxInit";

                       });
                   });

                   g.Items.Add(m => m.CompanyId, i =>
                   {
                       i.Caption = "Empresa";
                       i.NestedExtension().ComboBox(de =>
                       {
                           de.Width = 200;
                           de.ShowModelErrors = true;
                           de.Properties.NullText = "SELECCIONE LA EMPRESA";
                           de.Properties.ValidationSettings.Display = Display.Dynamic;
                           de.Properties.ValidationSettings.ErrorDisplayMode = ErrorDisplayMode.None;
                           de.Properties.DropDownStyle = DropDownStyle.DropDownList;
                           de.SelectedIndex = 0;
                           de.Properties.IncrementalFilteringMode = IncrementalFilteringMode.StartsWith;
                           de.Properties.TextField = "CompanyName";
                           de.Properties.ValueField = "CompanyId";
                           de.Properties.ValueType = typeof(string);
                           de.Properties.DataSource = slnRhonline.Models.Company.GetCompanyByUser();

                           //de.CallbackRouteValues = new { Controller = "TypePermissions", Action = "GetTypePermissionsById", TextField = "DescriptionType", ValueField = "TypeId" };
                           //de.Properties.TextField = "DescriptionType";
                           //de.Properties.ValueField = "TypeId";
                           //de.Properties.ValueType = typeof(int);
                           //de.Properties.LoadDropDownOnDemand = true;
                           //de.Properties.DropDownStyle = DropDownStyle.DropDownList;
                           //de.Properties.ValidationSettings.ErrorDisplayMode = ErrorDisplayMode.ImageWithTooltip;
                           //de.Properties.ValidationSettings.Display = Display.Dynamic;
                           //de.ShowModelErrors = true;
                           //de.Width = 200;
                           //de.Properties.ClientSideEvents.BeginCallback = "TypePermissionBeginCallback";
                           //de.Properties.DataSource = slnRhonline.Models.Company.GetCompanyByUser();
                           //de.ReadOnly = true;

                       });
                   });

               });
           }).Render();
       });

   }).GetHtml()


    }

    @using (Html.BeginForm())
    {
        @Html.DevExpress().PopupControl(settingsPopup =>
        {
            settingsPopup.Name = "pc";
            settingsPopup.ShowOnPageLoad = false;
            settingsPopup.HeaderText = "Información";
            settingsPopup.PopupHorizontalAlign = PopupHorizontalAlign.WindowCenter;
            settingsPopup.PopupVerticalAlign = PopupVerticalAlign.WindowCenter;
            settingsPopup.CloseOnEscape = true;
            settingsPopup.Width = 300;
            //settingsPopup.Modal = true;
            settingsPopup.ClientSideEvents.Init = "OnInit";



            settingsPopup.SetContent(() =>
            {
                ViewContext.Writer.Write(ViewData["EditError"]);
            });
        }).GetHtml()


    }


</body>
</html>