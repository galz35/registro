<style>
    .grafico-container {
        width: 600px;
        height: 600px;
        margin: 0 auto; /* Centrar el gráfico */
        padding: 20px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        background-color: #fff;
        border-radius: 8px;
    }

    canvas {
        background-color: white; /* Asegura que el fondo sea blanco */
    }
    body {
        background-color: #f8f9fc;
    }

    .card-header {
        background-color: #dc3545 !important;
    }

    .nav-tabs .nav-link.active {
        background-color: #ffffff !important;
        border-color: #dc3545 #dc3545 #ffffff !important;
        color: #dc3545 !important;
    }

    .nav-tabs .nav-link {
        color: #6c757d !important;
    }

    .btn-primary {
        background-color: #dc3545;
        border-color: #dc3545;
    }

        .btn-primary:hover {
            background-color: #c82333;
            border-color: #bd2130;
        }

    .btn-secondary, .btn-info, .btn-success {
        margin-top: 20px;
    }

    .form-group {
        margin-bottom: 15px;
    }

    .tab-pane {
        display: none;
    }

        .tab-pane.active {
            display: block;
        }

    .star-rating {
        font-size: 2rem;
        color: gold;
    }

    /* Contenedor de las pestañas */
    .tabs-container {
        border: 1px solid #e0e0e0;
        border-radius: 5px;
    }

    /* Lista de pestañas */
    .tabs-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        background-color: #ffe6e6; /* Rojo pastel claro */
        border-bottom: 1px solid #e0e0e0;
    }

    /* Elementos de la pestaña */
    .tab-item {
        padding: 10px 20px;
        cursor: pointer;
        color: #b30000; /* Rojo oscuro */
        border-right: 1px solid #e0e0e0;
        font-weight: bold;
    }

        .tab-item:last-child {
            border-right: none;
        }

        /* Pestaña activa */
        .tab-item.active {
            color: #800000; /* Rojo más oscuro */
        }

    /* Contenido de las pestañas */
    /* Contenedor de las pestañas */
    .tabs-container {
        border: 1px solid #dcdcdc;
        border-radius: 5px;
        background-color: #f9f9f9; /* Gris muy claro */
    }

    /* Lista de pestañas */
    .tabs-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        background-color: #e6e6e6; /* Gris suave */
        border-bottom: 1px solid #dcdcdc;
    }

    .tab-item {
        padding: 10px 20px;
        cursor: pointer;
        color: #333; /* Letras negras */
        border-right: 1px solid #dcdcdc;
        font-weight: bold;
    }

        .tab-item:last-child {
            border-right: none;
        }

        .tab-item.active {
            background-color: #ffffff; /* Blanco */
            color: #000; /* Letras negras */
            border-bottom: 2px solid #007bff; /* Línea azul para indicar la pestaña activa */
        }

    /* Contenido de las pestañas */
    .tabs-content {
        padding: 20px;
    }

    .tab-content-item {
        display: none;
    }

        .tab-content-item.active {
            display: block;
        }

    /* Tabla de respuestas */
    .tabla-respuestas {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 15px;
    }

        .tabla-respuestas th, .tabla-respuestas td {
            border: 1px solid #dcdcdc;
            padding: 8px;
            color: #333; /* Letras negras */
        }

        .tabla-respuestas th {
            background-color: #e6e6e6; /* Gris suave */
            text-align: left;
        }

        .tabla-respuestas td {
            background-color: #fff; /* Blanco */
        }

    /* Promedio de respuestas */
    .promedio-respuestas {
        font-size: 16px;
        font-weight: bold;
        color: #333; /* Letras negras */
    }

    /* Resumen general */
    .promedio-general {
        text-align: center;
        margin-bottom: 20px;
        color: #333; /* Letras negras */
        background-color: #f2f2f2; /* Gris muy claro */
        padding: 10px;
        border-radius: 5px;
    }

    /* Ajustes adicionales */
    body {
        font-family: Arial, sans-serif;
        background-color: #f5f5f5; /* Fondo general en gris claro */
        color: #333; /* Letras negras */
    }

    .tab-item:hover {
        background-color: #dcdcdc; /* Gris claro al pasar el cursor */
    }

    .tabla-respuestas tr:nth-child(even) {
        background-color: #f9f9f9; /* Alternar colores en filas */
    }
</style>


<div id="wrapper">
    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            <div class="container-fluid">
                <div class="card shadow mb-4">
                    <div class="card-header">
                        <h4 class="m-0 text-white">Encuestas Paso a Paso</h4>
                    </div>
                    <div class="card-body">
                        <ul class="nav nav-tabs" id="encuestaTabs" role="tablist"></ul>
                        <div class="tab-content" id="encuestaContent"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
