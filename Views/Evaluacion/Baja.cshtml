        function crearArregloRespuestas(respuestas) {
            const arregloRespuestas = [];  // El arreglo que vamos a construir

            const respuestasAgrupadas = respuestas.reduce((acc, curr) => {
                const tab = curr.TabID;
                if (!acc[tab]) {
                    acc[tab] = [];
                }
                acc[tab].push(curr);
                return acc;
            }, {});

            // Recorrer las respuestas agrupadas por TabID
            Object.keys(respuestasAgrupadas).forEach(tabID => {
                const formularioID = parseInt(tabID.replace('content-', ''));
                const formulario = data[0].Procesos[0].Formularios.find(f => f.FormularioID === formularioID);

                respuestasAgrupadas[tabID].forEach(respuesta => {
                    const pregunta = formulario.Preguntas.find(p => p.PreguntaID === respuesta.PreguntaID);

                    // Construir objeto para cada respuesta
                    const respuestaObj = {
                        Proceso: data[0].Procesos[0].NombreProceso,  // Nombre del proceso (lo tomamos del primero por ahora)
                        FormularioID: formularioID,
                        PreguntaID: respuesta.PreguntaID,
                        TipoPregunta: pregunta ? pregunta.TipoPregunta : 'Desconocido',
                        TextoRespuesta: respuesta.Respuesta,
                        OpcionID: null,  // Inicialmente null, luego se puede ajustar según la lógica
                        Porcentaje: respuesta.Porcentaje || null,
                        PorcentajeReal: respuesta.PorcentajeReal || null,
                        Motivo: respuesta.Motivo || null
                    };

                    // Si la pregunta tiene opciones de respuesta (opción múltiple)
                    const opcion = data[0].Opciones.find(op => op.PreguntaIDs.includes(respuesta.PreguntaID));
                    if (opcion) {
                        respuestaObj.OpcionID = opcion.OpcionID;
                    }

                    // Agregar la respuesta al arreglo final
                    arregloRespuestas.push(respuestaObj);
                });
            });

            return arregloRespuestas;  // Retornar el arreglo
        }

