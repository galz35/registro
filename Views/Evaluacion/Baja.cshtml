        function crearGraficoOpcionMultiples6(respuestas) {
            // Limpia el contenedor si ya tiene contenido
             let canvas = document.getElementById('resumenChart');
            if (!canvas) {
                canvas = document.createElement('canvas');
                canvas.id = 'resumenChart';
                canvas.height = 50;
                document.getElementById('content-resumen').appendChild(canvas);
            }

            const ctx = canvas.getContext('2d');

            // Destruir gráfico anterior si existe
            if (window.myResumenChart) {
                window.myResumenChart.destroy();
            }
            const data = respuestas.map((respuesta, index) => ({
                pregunta: `Pregunta ${index + 1}`,
                valor: parseFloat(respuesta.Respuesta) || 0
            }));

            const width = 600;
            const height = 400;
            const margin = { top: 40, right: 20, bottom: 50, left: 40 };

            const svg = d3.select('#resumenChart')
                .append('svg')
                .attr('width', width)
                .attr('height', height);

            const x = d3.scaleBand()
                .domain(data.map(d => d.pregunta))
                .range([margin.left, width - margin.right])
                .padding(0.2);

            const y = d3.scaleLinear()
                .domain([0, 5])
                .nice()
                .range([height - margin.bottom, margin.top]);

            svg.append('g')
                .attr('fill', '#69b3a2')
                .selectAll('rect')
                .data(data)
                .join('rect')
                .attr('x', d => x(d.pregunta))
                .attr('y', d => y(d.valor))
                .attr('height', d => y(0) - y(d.valor))
                .attr('width', x.bandwidth())
                .on('mouseover', function () {
                    d3.select(this).attr('fill', '#40a69a');
                })
                .on('mouseout', function () {
                    d3.select(this).attr('fill', '#69b3a2');
                });

            svg.append('g')
                .attr('transform', `translate(0,${height - margin.bottom})`)
                .call(d3.axisBottom(x))
                .selectAll('text')
                .attr('transform', 'rotate(45)')
                .style('text-anchor', 'start');

            svg.append('g')
                .attr('transform', `translate(${margin.left},0)`)
                .call(d3.axisLeft(y));

            svg.append('text')
                .attr('x', width / 2)
                .attr('y', margin.top / 2)
                .attr('text-anchor', 'middle')
                .style('font-size', '16px')
                .text('Resultados por Pregunta (Barras Interactivas)');
        }
        function crearGraficoOpcionMultiples7(respuestas) {
            d3.select('#resumenChart').html('');

            const data = respuestas.map((respuesta, index) => ({
                pregunta: index + 1,
                valor: parseFloat(respuesta.Respuesta) || 0
            }));

            const width = 600;
            const height = 400;
            const margin = { top: 40, right: 20, bottom: 50, left: 50 };

            const svg = d3.select('#resumenChart')
                .append('svg')
                .attr('width', width)
                .attr('height', height);

            const x = d3.scaleLinear()
                .domain(d3.extent(data, d => d.pregunta))
                .range([margin.left, width - margin.right]);

            const y = d3.scaleLinear()
                .domain([0, 5])
                .range([height - margin.bottom, margin.top]);

            const line = d3.line()
                .x(d => x(d.pregunta))
                .y(d => y(d.valor))
                .curve(d3.curveMonotoneX);

            svg.append('path')
                .datum(data)
                .attr('fill', 'none')
                .attr('stroke', '#ff7f0e')
                .attr('stroke-width', 2)
                .attr('d', line);

            // Puntos interactivos
            svg.selectAll('dot')
                .data(data)
                .enter().append('circle')
                .attr('cx', d => x(d.pregunta))
                .attr('cy', d => y(d.valor))
                .attr('r', 5)
                .attr('fill', '#ff7f0e')
                .on('mouseover', function (event, d) {
                    tooltip.transition().duration(200).style('opacity', .9);
                    tooltip.html(`Pregunta ${d.pregunta}: ${d.valor}`)
                        .style('left', (event.pageX) + 'px')
                        .style('top', (event.pageY - 28) + 'px');
                })
                .on('mouseout', function () {
                    tooltip.transition().duration(500).style('opacity', 0);
                });

            // Ejes
            svg.append('g')
                .attr('transform', `translate(0,${height - margin.bottom})`)
                .call(d3.axisBottom(x).ticks(data.length));

            svg.append('g')
                .attr('transform', `translate(${margin.left},0)`)
                .call(d3.axisLeft(y));

            // Título
            svg.append('text')
                .attr('x', width / 2)
                .attr('y', margin.top / 2)
                .attr('text-anchor', 'middle')
                .style('font-size', '16px')
                .text('Tendencia de Resultados (Gráfico de Líneas)');

            // Tooltip
            const tooltip = d3.select('#resumenChart').append('div')
                .attr('class', 'tooltip')
                .style('opacity', 0);
        }
        function crearGraficoOpcionMultiples8(respuestas) {
            d3.select('#resumenChart').html('');

            const totalObtenido = respuestas.reduce((sum, r) => sum + (parseFloat(r.Respuesta) || 0), 0);
            const totalMaximo = respuestas.length * 5;
            const data = [
                { label: 'Obtenido', value: totalObtenido },
                { label: 'Restante', value: totalMaximo - totalObtenido }
            ];

            const width = 450;
            const height = 450;
            const radius = Math.min(width, height) / 2;

            const svg = d3.select('#resumenChart')
                .append('svg')
                .attr('width', width)
                .attr('height', height)
                .append('g')
                .attr('transform', `translate(${width / 2}, ${height / 2})`);

            const color = d3.scaleOrdinal()
                .domain(data.map(d => d.label))
                .range(['#66b3ff', '#c2c2c2']);

            const pie = d3.pie()
                .value(d => d.value);

            const data_ready = pie(data);

            svg.selectAll('path')
                .data(data_ready)
                .join('path')
                .attr('d', d3.arc()
                    .innerRadius(0)
                    .outerRadius(radius)
                )
                .attr('fill', d => color(d.data.label))
                .attr('stroke', 'white')
                .style('stroke-width', '2px');

            // Leyenda
            svg.selectAll('legend')
                .data(data)
                .enter()
                .append('text')
                .attr('x', (d, i) => -radius + 20)
                .attr('y', (d, i) => -radius + 20 + i * 20)
                .text(d => `${d.label}: ${d.value}`)
                .style('fill', d => color(d.label))
                .style('font-size', '14px');

            // Título
            svg.append('text')
                .attr('x', 0)
                .attr('y', -radius - 20)
                .attr('text-anchor', 'middle')
                .style('font-size', '16px')
                .text('Total Obtenido vs Restante');
        }
        function crearGraficoOpcionMultiples9(respuestas) {
            d3.select('#resumenChart').html('');

            const data = respuestas.map((respuesta, index) => ({
                id: index + 1,
                value: parseFloat(respuesta.Respuesta) || 0
            }));

            const diameter = 600;
            const color = d3.scaleOrdinal(d3.schemeCategory10);

            const bubble = d3.pack()
                .size([diameter, diameter])
                .padding(1.5);

            const root = d3.hierarchy({ children: data })
                .sum(d => d.value);

            bubble(root);

            const svg = d3.select('#resumenChart')
                .append('svg')
                .attr('width', diameter)
                .attr('height', diameter)
                .attr('class', 'bubble');

            const nodes = svg.selectAll('g')
                .data(root.children)
                .enter().append('g')
                .attr('transform', d => `translate(${d.x},${d.y})`);

            nodes.append('title')
                .text(d => `Pregunta ${d.data.id}: ${d.data.value}`);

            nodes.append('circle')
                .attr('r', d => d.r)
                .style('fill', d => color(d.data.id));

            nodes.append('text')
                .attr('dy', '.3em')
                .style('text-anchor', 'middle')
                .text(d => `P${d.data.id}`);
        }
        function crearGraficoOpcionMultiples10(respuestas) {
            d3.select('#resumenChart').html('');

            const data = respuestas.map((respuesta, index) => ({
                pregunta: index + 1,
                valor: parseFloat(respuesta.Respuesta) || 0
            }));

            const width = 600;
            const height = 100;
            const gridSize = Math.floor(width / data.length);
            const colors = ['#f7fbff', '#6baed6', '#2171b5'];

            const svg = d3.select('#resumenChart').append('svg')
                .attr('width', width)
                .attr('height', height);

            const colorScale = d3.scaleQuantile()
                .domain([0, 5])
                .range(colors);

            svg.selectAll('rect')
                .data(data)
                .enter().append('rect')
                .attr('x', (d, i) => i * gridSize)
                .attr('y', 0)
                .attr('width', gridSize)
                .attr('height', gridSize)
                .style('fill', d => colorScale(d.valor))
                .append('title')
                .text(d => `Pregunta ${d.pregunta}: ${d.valor}`);

            svg.selectAll('text')
                .data(data)
                .enter().append('text')
                .attr('x', (d, i) => i * gridSize + gridSize / 2)
                .attr('y', gridSize / 2)
                .attr('text-anchor', 'middle')
                .style('fill', '#fff')
                .text(d => d.valor);
        }


    </script>
}