        // Función para crear el modal y generar el gráfico
        function crearModalGrafico(formulario, respuestasFormulario) {
            const formularioID = formulario.FormularioID;

            // Verificar y crear el modal solo si no existe
            let modalExistente = document.getElementById(`modalGrafico${formularioID}`);
            if (!modalExistente) {
                // Crear elementos del modal
                const modal = document.createElement('div');
                modal.className = 'modal fade';
                modal.id = `modalGrafico${formularioID}`;
                modal.tabIndex = -1;
                modal.role = 'dialog';
                modal.setAttribute('aria-labelledby', `modalLabel${formularioID}`);
                modal.setAttribute('aria-hidden', 'true');

                const modalDialog = document.createElement('div');
                modalDialog.className = 'modal-dialog modal-lg';
                modalDialog.role = 'document';

                const modalContent = document.createElement('div');
                modalContent.className = 'modal-content';

                // Modal Header
                const modalHeader = document.createElement('div');
                modalHeader.className = 'modal-header';

                const modalTitle = document.createElement('h5');
                modalTitle.className = 'modal-title';
                modalTitle.id = `modalLabel${formularioID}`;
                modalTitle.innerText = `Resultados de ${formulario.TituloFormulario}`;

                const modalCloseButton = document.createElement('button');
                modalCloseButton.className = 'close';
                modalCloseButton.type = 'button';
                modalCloseButton.dataset.dismiss = 'modal';
                modalCloseButton.setAttribute('aria-label', 'Close');
                modalCloseButton.innerHTML = '<span aria-hidden="true">&times;</span>';

                modalHeader.appendChild(modalTitle);
                modalHeader.appendChild(modalCloseButton);

                // Modal Body
                const modalBody = document.createElement('div');
                modalBody.className = 'modal-body';

                // Crear o reutilizar el canvas para el gráfico
                let canvas = document.getElementById(`graficoFormulario${formularioID}`);
                if (!canvas) {
                    canvas = document.createElement('canvas');
                    canvas.id = `graficoFormulario${formularioID}`;
                    canvas.style.maxWidth = '100%';
                    modalBody.appendChild(canvas);
                }

                // Modal Footer
                const modalFooter = document.createElement('div');
                modalFooter.className = 'modal-footer';

                const closeButton = document.createElement('button');
                closeButton.className = 'btn btn-secondary';
                closeButton.type = 'button';
                closeButton.dataset.dismiss = 'modal';
                closeButton.innerText = 'Cerrar';

                modalFooter.appendChild(closeButton);

                // Armar el modal
                modalContent.appendChild(modalHeader);
                modalContent.appendChild(modalBody);
                modalContent.appendChild(modalFooter);
                modalDialog.appendChild(modalContent);
                modal.appendChild(modalDialog);

                // Agregar el modal al body
                document.body.appendChild(modal);

                // Generar el gráfico
                generarGraficoParaFormulario(formulario, respuestasFormulario, canvas);
            }
        }

        function getColor(index, total) {
            const hue = (index * (360 / total)) % 360; // Distribuye hues de manera uniforme
            return `hsla(${hue}, 70%, 50%, 0.6)`; // hsla para mayor flexibilidad en la transparencia
        }

        // Función para generar el gráfico para cada formulario
        function generarGraficoParaFormulario(formulario, respuestasFormulario, canvas) {
            const formularioID = formulario.FormularioID;
            const labels = [];
            const dataObtenido = [];
            const backgroundColors = [];
            const totalPreguntas = respuestasFormulario.length;

            respuestasFormulario.forEach((respuesta, index) => {
                const pregunta = formulario.Preguntas.find(p => p.PreguntaID === respuesta.PreguntaID);
                const preguntaTexto = pregunta ? pregunta.TextoPregunta : `Pregunta ${respuesta.PreguntaID}`;
                const valorNumerico = parseFloat(respuesta.Respuesta) || 0;

                labels.push(preguntaTexto);
                dataObtenido.push(valorNumerico);

                // Asignar colores vibrantes usando HSL para una distribución uniforme
                backgroundColors.push(getColor(index, totalPreguntas));
            });

            const ctx = canvas.getContext('2d');

            // Definir el tipo de gráfico: 'radar' o 'polarArea'
            const tipoGrafico =  'radar'; // Por defecto 'polarArea'

            // Establecer el fondo del canvas a blanco para una mejor visualización
            canvas.style.backgroundColor = 'white';

            // Destruir gráfico anterior si existe para evitar duplicados
            if (canvas.chartInstance) {
                canvas.chartInstance.destroy();
            }

            canvas.chartInstance = new Chart(ctx, {
                type: tipoGrafico,
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Puntaje Obtenido',
                        data: dataObtenido,
                        backgroundColor: 'rgba(54, 162, 235, 0.2)', // Color de relleno del área
                        borderColor: 'rgba(54, 162, 235, 1)', // Color del borde
                        pointBackgroundColor: backgroundColors, // Color de los puntos
                        pointBorderColor: '#fff', // Color del borde de los puntos
                        pointHoverBackgroundColor: '#fff', // Color del punto al pasar el cursor
                        pointHoverBorderColor: backgroundColors, // Color del borde al pasar el cursor
                        fill: true, // Rellenar el área del gráfico
                        lineTension: 0.1, // Suavidad de las líneas
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false, // Permitir que el gráfico ocupe todo el contenedor
                    rotation: -Math.PI / 2, // Rotación de -90 grados para alinear el primer punto en la parte superior
                    plugins: {
                        // Configuración del plugin Data Labels
                        datalabels: {
                            color: '#000', // Color de las etiquetas de datos
                            align: 'center',
                            anchor: 'center',
                            formatter: function (value, context) {
