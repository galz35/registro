                        backgroundColor: ['rgba(75, 192, 192, 0.2)', 'rgba(255, 99, 132, 0.2)'],
                        borderColor: ['rgba(75, 192, 192, 1)', 'rgba(255, 99, 132, 1)'],
                        borderWidth: 1
                    }]
                },
                options: {
                    scales: {
                        y: {
                            beginAtZero: true,
                            max: resumen.totalMaximo // El máximo será el puntaje total posible
                        }
                    }
                }
            });

            // Añadir un resumen textual debajo del gráfico
            const resumenTexto = document.createElement('p');
            resumenTexto.innerText = `Has obtenido un total de ${resumen.totalObtenido} puntos sobre un máximo posible de ${resumen.totalMaximo} puntos.`;
            document.getElementById('content-resumen').appendChild(resumenTexto);
