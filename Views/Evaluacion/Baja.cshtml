        function agregarTabResumen() {
            // Verificar si ya existe el tab-resumen y eliminarlo
            const existingTabLink = document.getElementById('tab-resumen');
            const existingTabPane = document.getElementById('content-resumen');

            if (existingTabLink) {
                existingTabLink.parentElement.remove(); // Eliminar el <li> contenedor del tab
            }

            if (existingTabPane) {
                existingTabPane.remove(); // Eliminar el contenido del tab
            }

            // Crear el nuevo tab-resumen
            const tabItem = document.createElement('li');
            tabItem.className = 'nav-item';

            const tabLink = document.createElement('a');
            tabLink.className = 'nav-link';
            tabLink.id = 'tab-resumen';
            tabLink.href = '#content-resumen';
            tabLink.setAttribute('data-toggle', 'tab');
            tabLink.setAttribute('role', 'tab');
            tabLink.setAttribute('aria-controls', 'content-resumen');
            tabLink.innerText = 'Resumen';

            tabItem.appendChild(tabLink);
            document.getElementById('encuestaTabs').appendChild(tabItem);

            // Crear el contenido del tab de resumen
            const tabPane = document.createElement('div');
            tabPane.className = 'tab-pane';
            tabPane.id = 'content-resumen';
            tabPane.setAttribute('role', 'tabpanel');
            tabPane.setAttribute('aria-labelledby', 'tab-resumen');

            let grafico = false;
            let estrella = false;

            // Verificar si en los formularios hay alguno que requiera gráfico o estrellas
            data[0].Procesos[0].Formularios.forEach(formulario => {
                if (formulario.grafico) {
                    grafico = true;
                }
                if (formulario.estrella) {
                    estrella = true;
                }
            });

            // Si hay gráfico o estrellas, añadir elementos al DOM
            if (estrella) {
                const starRating = document.createElement('div');
                starRating.className = 'star-rating text-center'; // Centramos las estrellas
                tabPane.appendChild(starRating);
            }

            if (grafico) {
