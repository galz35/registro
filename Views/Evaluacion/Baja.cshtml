        function capturarRespuestasUsuario() {
            const respuestas = [];

            preguntasRespuestas.forEach(item => {
                // Encuentra el texto de la pregunta
                const pregunta = data[0].Procesos[0].Formularios.find(f => f.Preguntas.some(p => p.PreguntaID === item.PreguntaID)).Preguntas.find(p => p.PreguntaID === item.PreguntaID);

                // Si es una tabla (pregunta abierta de varias filas)
                if (item.TipoInput === 'tabla') {
                    const table = document.getElementById(item.InputID);
                    if (table) {
                        const rows = table.querySelectorAll('tbody tr');
                        rows.forEach(row => {
                            const respuestaInput = row.querySelector(`input[name^="pregunta_${item.PreguntaID}_respuesta"]`);
                            const porcentajeInput = row.querySelector(`select[name^="pregunta_${item.PreguntaID}_porcentaje"]`);
                            const porcentajeRealInput = row.querySelector(`select[name^="pregunta_${item.PreguntaID}_porcentaje_real"]`);
                            const motivoInput = row.querySelector(`input[name^="pregunta_${item.PreguntaID}_motivo"]`);

                            const porcentaje = porcentajeInput ? parseInt(porcentajeInput.value) || 0 : 0;  // Si no hay valor, se pone 0
                            const porcentajeReal = porcentajeRealInput ? parseInt(porcentajeRealInput.value) || 0 : 0;  // Si no hay valor, se pone 0
                            console.log("Porcentaje:", porcentaje);
                            console.log("Porcentaje Real:", porcentajeReal);
                            respuestas.push({
                                PreguntaID: item.PreguntaID,
                                TextoPregunta: pregunta ? pregunta.TextoPregunta : `Pregunta ${item.PreguntaID}`, // Mostrar TextoPregunta
                                Respuesta: respuestaInput ? respuestaInput.value : 'No respondida',
                                Porcentaje: porcentajeInput ? porcentaje : 'No proporcionado',
                                PorcentajeReal: porcentajeRealInput ? porcentajeReal : 'No proporcionado',
                                Motivo: motivoInput ? motivoInput.value : 'No proporcionado',
                                TabID: item.TabID
                            });
                        });
                    }
                }
                // Si es una pregunta de opción múltiple
                else if (item.TipoInput === 'opcion_multiples_N') {
                    const checkboxes = document.querySelectorAll(`input[name="pregunta_${item.PreguntaID}"]:checked`);
                    const respuestasSeleccionadas = [];
                    checkboxes.forEach(checkbox => {
                        const opcionSeleccionada = data[0].Opciones.find(opcion => opcion.ValorOpcion === checkbox.value);

                        if (opcionSeleccionada) {
                            respuestasSeleccionadas.push(opcionSeleccionada.TextoOpcion);

                            //    respuestasSeleccionadas.push({
                            //       valor: checkbox.value,  // Valor de la opción
                            //       texto: opcionSeleccionada.TextoOpcion  // Texto de la opción
                            //   });
                        }
                        //   respuestasSeleccionadas.push(checkbox.value);
                    });
                    // Si la opción "Otros" está seleccionada, capturamos el texto del input de "Otros"
                    const inputOtros = document.getElementById(`pregunta_${item.PreguntaID}_otros_input`);
                    if (inputOtros && inputOtros.value.trim() !== '') {
                        respuestasSeleccionadas.push(`Otros: ${inputOtros.value}`);
                    }

                    respuestas.push({
                        PreguntaID: item.PreguntaID,
                        TextoPregunta: pregunta ? pregunta.TextoPregunta : `Pregunta ${item.PreguntaID}`,
                        Respuesta: respuestasSeleccionadas.join(', '),  // Unir todas las opciones seleccionadas
                        TabID: item.TabID
                    });
                }
                // Si es otro tipo de pregunta
                else if (item.TipoInput === 'opcion_multiples') {
                    const radios = document.getElementsByName(item.InputID);

                    // Encontrar el radio button que está seleccionado
                    let respuestaSeleccionada = 'No respondida';
                    radios.forEach(radio => {
                        if (radio.checked) {
                            respuestaSeleccionada = radio.value;  // Obtener el valor de la respuesta seleccionada
                        }
                    });

                    // Guardar la respuesta en el array
                    respuestas.push({
                        PreguntaID: item.PreguntaID,
                        TextoPregunta: pregunta ? pregunta.TextoPregunta : `Pregunta ${item.PreguntaID}`, // Mostrar TextoPregunta
                        Respuesta: respuestaSeleccionada,
                        TabID: item.TabID
                    });
                }
                // Si es un input normal (texto)
                else if (item.TipoInput === 'input') {
                    const input = document.getElementById(item.InputID);
                    const respuesta = input ? input.value : 'No respondida';
                    respuestas.push({
                        PreguntaID: item.PreguntaID,
                        TextoPregunta: pregunta ? pregunta.TextoPregunta : `Pregunta ${item.PreguntaID}`, // Mostrar TextoPregunta
                        Respuesta: respuesta,
                        TabID: item.TabID
                    });
                }
            });

            return respuestas;
        }



