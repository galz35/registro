                            font: {
                                size: 16, // Aumentar tamaño del título
                                weight: 'bold',
                                family: 'Arial, sans-serif'
                            },
                            color: '#000',
                            padding: {
                                top: 10,
                                bottom: 30
                            }
                        },
                        legend: {
                            display: false, // Ocultar leyenda en radar para claridad
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    const label = context.label || '';
                                    const value = context.parsed.r || 0;
                                    return `${label}: ${value}`;
