@using slnRhonline.Models

@{ ViewBag.Title = "Evaluación y Retroalimentación";
    List<Comp_Habilidades> habilidades = new List<Comp_Habilidades>();

    List<ObjetivoEvaluacion> objetivos = new List<ObjetivoEvaluacion>();
    objetivos = Session["objetivosEvaluacion"] as List<ObjetivoEvaluacion>;
    List<EvaluacionCicloViewModel> lstEmployees = Session["levaluaciontotalx"] as List<EvaluacionCicloViewModel>;
    habilidades = Session["Heva"] as List<Comp_Habilidades>;
    EvaluacionCicloViewModel evaluacion = new EvaluacionCicloViewModel();
    evaluacion = lstEmployees.FirstOrDefault();

     }

<h2>Evaluación y Retroalimentación</h2>
<style>

    
 
        .custom-nav-link:hover i {
            color: black !important;
        }

        .custom-nav-link i {
            color: white !important;
        }

    .custom-nav-link {
        color: black !important;
        display: flex;
        align-items: center;
        padding: 8px 12px;
        transition: background-color 0.3s, color 0.3s;
        background-color: transparent;
        border:none
    }

        .custom-nav-link:hover {
            color: black !important;
            background-color: white !important;
        } 

       
</style>
<div class="container">
    <div class="card shadow mb-4">
        <div class="card-body">
            <!-- Progress Bar -->
            <ul class="nav nav-pills mb-3" id="pills-tab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="custom-nav-link active" id="step1-tab" data-bs-toggle="pill" data-bs-target="#step1" type="button" role="tab" aria-controls="step1" aria-selected="true">1. Resultados</button>
                </li>

                <li class="nav-item" role="presentation">
                    <button class="custom-nav-link" id="step2-tab" data-bs-toggle="pill" data-bs-target="#step2" type="button" role="tab" aria-controls="step2" aria-selected="false">2. Objetivos</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="custom-nav-link" id="step3-tab" data-bs-toggle="pill" data-bs-target="#step3" type="button" role="tab" aria-controls="step3" aria-selected="false">3. Retroalimentación</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="custom-nav-link" id="step4-tab" data-bs-toggle="pill" data-bs-target="#step4" type="button" role="tab" aria-controls="step4" aria-selected="false">4. Evaluación Global</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="custom-nav-link" id="step5-tab" data-bs-toggle="pill" data-bs-target="#step5" type="button" role="tab" aria-controls="step5" aria-selected="false">5. Revisión</button>
                </li>
            </ul>

            <form id="evaluacionRetroForm">
                <div class="tab-content" id="pills-tabContent">
                    <!-- Paso 1: Evaluación Individual de Resultados -->
                    <div class="tab-pane fade show active" id="step1" role="tabpanel" aria-labelledby="step1-tab">
                        <h3>Evaluación Individual de Resultados</h3>

                        <div class="form-group mb-3">
                            <label for="periodo">Periodo a evaluar:</label>
                            <input type="text" class="form-control" id="periodo" name="periodo" value="@evaluacion.MesCiclo-@evaluacion.FechaInicio.Year" readonly>
                        </div>
                        <div class="form-group mb-3">
                            <label for="nombre-colaborador">Nombre del Colaborador:</label>
                            <input type="text" class="form-control" id="nombre-colaborador" name="nombre-colaborador" value="@evaluacion.colaborador" readonly>
                        </div>



                        <h4>Evaluación de Habilidades</h4>
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Habilidad</th>
                                    <th>Evaluación</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (habilidades != null && habilidades.Count > 0)
                                {
                                    for (int i = 0; i < habilidades.Count; i++)
                                    {
                    <tr>
                        <td>@habilidades[i].Habilidad</td>
                        <td>
                            <select class="form-control" name="habilidad@(i)" required>
                                <option value="">Seleccione...</option>
                                <option value="A" @(habilidades[i].Puntuacion == "A" ? "selected" : "")>A - Por debajo de lo requerido</option>
                                <option value="B" @(habilidades[i].Puntuacion == "B" ? "selected" : "")>B - Ligeramente por debajo de lo requerido</option>
                                <option value="C" @(habilidades[i].Puntuacion == "C" ? "selected" : "")>C - Igual que lo requerido</option>
                                <option value="D" @(habilidades[i].Puntuacion == "D" ? "selected" : "")>D - Mejor que lo requerido</option>
                                <option value="E" @(habilidades[i].Puntuacion == "E" ? "selected" : "")>E - Mucho mejor que lo requerido</option>
                            </select>
                        </td>
                    </tr>
 }
            }
            else
            {
                <tr>
                    <td colspan="2">No se han encontrado habilidades para este ciclo.</td>
                </tr>
}
                            </tbody>
                        </table>

                        <div class="d-flex justify-content-end">
                            <button type="button" class="btn btn-primary" id="nextToStep2">Siguiente</button>
                        </div>
                    </div>


                    <!-- Paso 3: Cumplimiento de Objetivos -->
                    <div class="tab-pane fade" id="step2" role="tabpanel" aria-labelledby="step2-tab">
                        <h3>Cumplimiento de Objetivos</h3>
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Objetivo</th>
                                    <th>% de Cumplimiento Esperado</th>
                                    <th>% de Cumplimiento Real</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (objetivos != null && objetivos.Count > 0)
                                {
                                    for (int i = 0; i < objetivos.Count; i++)
                                    {
                    <tr>
                        <td><input type="text" class="form-control" name="descripcionObjetivo@(i)" value="@objetivos[i].DescripcionObjetivo" readonly></td>
                        <td><input type="text" class="form-control" name="cumplimientoEsperado@(i)" value="@objetivos[i].PorcentajeCumplimientoEsperado" readonly></td>
                        <td>
                            <select class="form-control" name="cumplimientoReal@(i)" required>
                                <option value="">Seleccione...</option>
                                @for (int j = 0; j <= 100; j += 10)
                                {
                <option value="@j">@j%</option>}
                            </select>
                        </td>
                    </tr> }
                                }
                                else
                                {
                    <tr>
                        <td colspan="3">No se han encontrado objetivos para este ciclo.</td>
                    </tr>}
                            </tbody>
                        </table>
                        <div class="d-flex justify-content-between">
                            <button type="button" class="btn btn-secondary" id="backToStep2">Atrás</button>
                            <button type="button" class="btn btn-primary" id="nextToStep3">Siguiente</button>
                        </div>
                    </div>

                    <!-- Paso 4: Retroalimentación de la Evaluación de Habilidades -->
                    <div class="tab-pane fade" id="step3" role="tabpanel" aria-labelledby="step3-tab">
                        <h3>Retroalimentación de la Evaluación de Habilidades</h3>
                        <div class="form-group mb-3">
                            <label for="fortalezas">Fortalezas:</label>
                            <textarea class="form-control" id="fortalezas" name="fortalezas" rows="4" required></textarea>
                        </div>
                        <div class="form-group mb-3">
                            <label for="debilidades">Debilidades:</label>
                            <textarea class="form-control" id="debilidades" name="debilidades" rows="4" required></textarea>
                        </div>
                        <div class="form-group mb-3">
                            <label for="acciones">Acciones a Seguir:</label>
                            <textarea class="form-control" id="acciones" name="acciones" rows="4" required></textarea>
                        </div>
                        <div class="d-flex justify-content-between">
                            <button type="button" class="btn btn-secondary" id="backToStep3">Atrás</button>
                            <button type="button" class="btn btn-primary" id="nextToStep4">Siguiente</button>
                        </div>
                    </div>
                    <!-- Paso 2: Evaluación Global -->
                    <div class="tab-pane fade" id="step4" role="tabpanel" aria-labelledby="step4-tab">
                        <h3>Evaluación Global</h3>
                        <div class="form-group mb-3">
                            <label>Seleccione la opción que mejor describa el cumplimiento del empleado en su puesto:</label>
                            <select class="form-control" name="evaluacion-global" required>
                                <option value="">Seleccione...</option>
                                <option value="A">No cumple con lo requerido en el puesto</option>
                                <option value="B">Requiere de un mayor esfuerzo para cumplir con las responsabilidades de su puesto</option>
                                <option value="C">Cumple con lo requerido en el puesto de manera adecuada</option>
                                <option value="D">Cumple con lo requerido en el puesto de manera adecuada y propone mejoras que enriquecen los procesos de su área</option>
                            </select>
                        </div>
                        <div class="d-flex justify-content-between">
                            <button type="button" class="btn btn-secondary" id="backToStep1">Atrás</button>
                            <button type="button" class="btn btn-primary" id="nextToStep5">Siguiente</button>
                        </div>
                    </div>

                    <!-- Paso 5: Revisión y Envío -->
                    <div class="tab-pane fade" id="step5" role="tabpanel" aria-labelledby="step5-tab">
                        <h3>Revisión y Envío</h3>
                        <p>Por favor, revisa la información proporcionada antes de enviarla.</p>
                        <div class="card mb-3">
                            <div class="card-body">
                                <h5>Evaluación Individual de Resultados</h5>

                                <p><strong>Periodo:</strong> @evaluacion.MesCiclo-@evaluacion.FechaInicio.Year</p>
                                <p><strong>Nombre del Colaborador:</strong> @evaluacion.colaborador</p>
                                <p><strong>Fecha de Evaluación:</strong> <span id="review-fecha"></span></p>
                                <h6>Habilidades:</h6>
                                <ul id="review-habilidades"></ul>
                            </div>
                        </div>
                        <div class="card mb-3">
                            <div class="card-body">
                                <h5>Evaluación Global</h5>
                                <p><strong>Evaluación:</strong> <span id="review-evaluacion-global"></span></p>
                            </div>
                        </div>
                        <div class="card mb-3">
                            <div class="card-body">
                                <h5>Cumplimiento de Objetivos</h5>
                                <ul id="review-objetivos"></ul>
                            </div>
                        </div>
                        <div class="card mb-3">
                            <div class="card-body">
                                <h5>Retroalimentación</h5>
                                <p><strong>Fortalezas:</strong> <span id="review-fortalezas"></span></p>
                                <p><strong>Debilidades:</strong> <span id="review-debilidades"></span></p>
                                <p><strong>Acciones a Seguir:</strong> <span id="review-acciones"></span></p>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between">
                            <button type="button" class="btn btn-secondary" id="backToStep4">Atrás</button>
                            <button type="submit" class="btn btn-success">Enviar Evaluación</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
@section scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/js/select2.min.js"></script>

    <script src="~/Content/js2024/jquery.jeditable.min.js"></script>
    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.buttons.min.js"></script>
    <script src="~/onlinejs/buttons.html5.min.js"></script>
    <script src="~/onlinejs/buttons.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.select.min.js"></script>
    <script src="~/onlinejs/bootstrap.bundle.min.js"></script>
    <script src="~/onlinejs/bootstrap.min.js"></script>
    <script src="~/onlinejs/loadingoverlay.min.js"></script>
    <script src="~/onlinejs/dataTables.responsive.min.js"></script>
    <script src="~/Content/plugin/sweetalert2/sweetalert2.all.js"></script>
    <script src="~/onlinejs/moment.min.js"></script>
    <script src="~/onlinejs/jszip.min.js"></script>
    <script src="~/onlinejs/jquery-ui.js"></script>
    <script src="~/onlinejs/spin.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Navegación entre pasos
            document.getElementById('nextToStep2').addEventListener('click', function () {
                if (validateStep1()) {
                    var step2 = new bootstrap.Tab(document.querySelector('#step2-tab'));
                    step2.show();
                }
            });

            document.getElementById('backToStep1').addEventListener('click', function () {
                var step1 = new bootstrap.Tab(document.querySelector('#step1-tab'));
                step1.show();
            });

            document.getElementById('nextToStep3').addEventListener('click', function () {
                if (validateStep2()) {
                    var step3 = new bootstrap.Tab(document.querySelector('#step3-tab'));
                    step3.show();
                }
            });

            document.getElementById('backToStep2').addEventListener('click', function () {
                var step2 = new bootstrap.Tab(document.querySelector('#step2-tab'));
                step2.show();
            });

            document.getElementById('nextToStep4').addEventListener('click', function () {
                if (validateStep3()) {
                    var step4 = new bootstrap.Tab(document.querySelector('#step4-tab'));
                    step4.show();
                }
            });

            document.getElementById('backToStep3').addEventListener('click', function () {
                var step3 = new bootstrap.Tab(document.querySelector('#step3-tab'));
                step3.show();
            });

            document.getElementById('nextToStep5').addEventListener('click', function () {
                if (validateStep4()) {
                    populateReview();
                    var step5 = new bootstrap.Tab(document.querySelector('#step5-tab'));
                    step5.show();
                }
            });

            document.getElementById('backToStep4').addEventListener('click', function () {
                var step4 = new bootstrap.Tab(document.querySelector('#step4-tab'));
                step4.show();
            });

            // Validaciones por paso
            function validateStep1() {
                // Validar Fecha de Evaluación


                // Validar Evaluación de Habilidades
                var habilidadesCount = @habilidades.Count;
                for (var i = 0; i < habilidadesCount; i++) {
                    var select = document.getElementsByName('habilidad' + i)[0];
                    if (!select.value) {
                        alert('Por favor, selecciona una evaluación para todas las habilidades.');
                        return false;
                    }
                }
                return true;
            }

            function validateStep4() {
                var evaluacionGlobal = document.getElementsByName('evaluacion-global')[0].value;
                if (!evaluacionGlobal) {
                    alert('Por favor, selecciona una opción de evaluación global.');
                    return false;
                }
                return true;
            }

            function validateStep2() {
                var objetivosCount = @objetivos.Count;
                for (var i = 0; i < objetivosCount; i++) {
                    var select = document.getElementsByName('cumplimientoReal' + i)[0];
                    if (!select.value) {
                        alert('Por favor, selecciona el % de cumplimiento real para todos los objetivos.');
                        return false;
                    }
                }
                return true;
            }

            function validateStep3() {
                var fortalezas = document.getElementById('fortalezas').value.trim();
                var debilidades = document.getElementById('debilidades').value.trim();
                var acciones = document.getElementById('acciones').value.trim();

                if (!fortalezas || !debilidades || !acciones) {
                    alert('Por favor, completa todas las áreas de retroalimentación.');
                    return false;
                }
                return true;
            }

            // Población de la sección de revisión
          function populateReview() {
    // Habilidades definidas en orden
    const habilidades = [
        "Análisis y Solución de Problemas",
        "Relaciones Interpersonales",
        "Responsabilidad",
        "Trabajo bajo presión",
        "Actitud de Servicio",
        "Capacidad de Aprendizaje",
        "Trabajo en Equipo",
        "Iniciativa y Creatividad",
        "Conocimientos para el puesto",
        "Comunicación Verbal y Escrita",
        "Toma de Decisiones",
        "Administración",
        "Liderazgo",
        "Desarrollo de Personal"
    ];
              const evaluacionGlobalMap = {
                  "A": "No cumple con lo requerido en el puesto",
                  "B": "Requiere de un mayor esfuerzo para cumplir con las responsabilidades de su puesto",
                  "C": "Cumple con lo requerido en el puesto de manera adecuada",
                  "D": "Cumple con lo requerido en el puesto de manera adecuada y propone mejoras que enriquecen los procesos de su área"
              };
    // Habilidades
    var habilidadesList = document.getElementById('review-habilidades');
    habilidadesList.innerHTML = '';

    habilidades.forEach((habilidad, i) => {
        var puntuacion = document.getElementsByName('habilidad' + i)[0].value;
        var li = document.createElement('li');
        li.textContent = habilidad + ': ' + puntuacion;
        habilidadesList.appendChild(li);
    });
     // Evaluación Global
      var evaluacionGlobal = document.querySelector('select[name="evaluacion-global"]').value;

    //var evaluacionGlobal = document.querySebuenlector('input[name="evaluacion-global"]:checked').value;
              document.getElementById('review-evaluacion-global').innerText = evaluacionGlobalMap[evaluacionGlobal];

              //document.getElementById('review-evaluacion-global').innerText = evaluacionGlobalText;

    // Objetivos
    var objetivosList = document.getElementById('review-objetivos');
    objetivosList.innerHTML = '';
    @if (objetivos != null && objetivos.Count > 0)
    {
        for (int i = 0; i < objetivos.Count; i++)
        {
            <text>
                var descripcion = '@objetivos[i].DescripcionObjetivo';
                var esperado = '@objetivos[i].PorcentajeCumplimientoEsperado';
                var real = document.getElementsByName('cumplimientoReal@(i)')[0].value;
                var li = document.createElement('li');
                li.textContent = descripcion + ' - Esperado: ' + esperado + '%, Real: ' + real + '%';
                objetivosList.appendChild(li);
            </text>
        }
    }

    // Retroalimentación
    document.getElementById('review-fortalezas').innerText = document.getElementById('fortalezas').value;
    document.getElementById('review-debilidades').innerText = document.getElementById('debilidades').value;
    document.getElementById('review-acciones').innerText = document.getElementById('acciones').value;
}

            document.getElementById('evaluacionRetroForm').addEventListener('submit', function (e) {
                e.preventDefault();

                var evaluacionData = {
                    Periodo: document.querySelector('input[name="periodo"]').value,
                    NombreColaborador: document.querySelector('input[name="nombre-colaborador"]').value,
                    EvaluacionGlobal: document.querySelector('select[name="evaluacion-global"]').value,
                    Fortalezas: document.querySelector('textarea[name="fortalezas"]').value,
                    Debilidades: document.querySelector('textarea[name="debilidades"]').value,
                    AccionesASeguir: document.querySelector('textarea[name="acciones"]').value,
                    Habilidades: [],
                    Objetivos: []
                };

                const habilidadesCount = 14;
                for (var i = 0; i < habilidadesCount; i++) {
                    var habilidadElement = document.querySelector(`select[name="habilidad${i}"]`);
                    if (habilidadElement) {
                        var habilidad = {
                            Habilidad: habilidadElement.closest('tr').querySelector('td').textContent.trim(),
                            Puntuacion: habilidadElement.value
                        };
                        evaluacionData.Habilidades.push(habilidad);
                    }
                }

                const objetivosCount = 3;
                for (var j = 0; j < objetivosCount; j++) {
                    var objetivo = {
                        DescripcionObjetivo: document.querySelector(`input[name="descripcionObjetivo${j}"]`).value,
                        PorcentajeCumplimientoEsperado: parseInt(document.querySelector(`input[name="cumplimientoEsperado${j}"]`).value),
                        PorcentajeCumplimientoReal: parseInt(document.querySelector(`select[name="cumplimientoReal${j}"]`).value)
                    };
                    evaluacionData.Objetivos.push(objetivo);
                }

                // Enviar los datos al controlador
                $.ajax({
                    type: 'POST',
                    url: '/Evaluacion/guardarciclo',
                    data: evaluacionData,
                    success: function (response) {
                        Swal.fire('Éxito', 'La evaluación y retroalimentación han sido guardadas correctamente.', 'success')
                            .then(() => {
                                location.reload();
                            });
                    },
                    error: function (error) {
                        Swal.fire('Error', 'Hubo un problema al guardar la evaluación.', 'error');
                    }
                });

        });

    </script>
}
