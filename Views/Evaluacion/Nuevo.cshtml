        function agregarEstrellasResumenOpcionMultiples2(respuestas) {
            // Obtener solo los formularios con estrella o gráfico habilitado
            const formulariosConGraficoOEstrella = data[0].Procesos[0].Formularios
                .filter(formulario => formulario.grafico || formulario.estrella)
                .map(formulario => formulario.FormularioID);

            // Filtrar respuestas que pertenecen a esos formularios
            const respuestasFiltradas = respuestas.filter(r => {
                const formularioID = parseInt(r.TabID.replace('content-', '')); // Convertir el TabID al FormularioID
                return formulariosConGraficoOEstrella.includes(formularioID);
            });

            // Sumar solo las respuestas numéricas de formularios con gráfico o estrella
            const totalPorcentajeReal = respuestasFiltradas
                .reduce((sum, r) => {
                    const valorNumerico = parseFloat(r.Respuesta);  // Intentar convertir la respuesta a número
                    return sum + (isNaN(valorNumerico) ? 0 : valorNumerico); // Si es NaN, sumar 0, de lo contrario sumar el número
                }, 0);

            // Calcular el promedio basado en las respuestas filtradas
            const promedio = respuestasFiltradas.length > 0 ? totalPorcentajeReal / respuestasFiltradas.length : 0;

            // No redondeamos a un número entero para permitir medias estrellas
            const estrellas = promedio;

            // Generar las estrellas incluyendo medias
            const starRating = generarEstrellasConMedias(estrellas);

            // Limpiar el contenido anterior del contenedor del resumen
            const resumenContainer = document.getElementById('content-resumen');
            resumenContainer.innerHTML = ''; // Limpiar contenido anterior

            // Insertar las estrellas al inicio del contenedor de resumen
            resumenContainer.appendChild(starRating);
        }

        function agregarEstrellasResumenOpcionMultiples(respuestas) {
            // Sumar todas las respuestas que son válidas (numéricas)
            const totalPorcentajeReal = respuestas
                .reduce((sum, r) => {
                    const valorNumerico = parseFloat(r.Respuesta);  // Intentar convertir la respuesta a número
                    return sum + (isNaN(valorNumerico) ? 0 : valorNumerico); // Si es NaN, sumar 0, de lo contrario sumar el número
                }, 0);
            const promedio = respuestas.length > 0 ? totalPorcentajeReal / respuestas.length : 0;

            // No redondeamos a un número entero para permitir medias estrellas
            const estrellas = promedio;

            // Generar las estrellas incluyendo medias
            const starRating = generarEstrellasConMedias(estrellas);

            // Limpiar el contenido anterior del contenedor del resumen
            const resumenContainer = document.getElementById('content-resumen');
            resumenContainer.innerHTML = ''; // Limpiar contenido anterior

            // Insertar las estrellas al inicio del contenedor de resumen
            resumenContainer.appendChild(starRating);
        }


