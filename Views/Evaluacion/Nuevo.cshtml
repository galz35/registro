        function generarEstrellasConMedias(promedio) {
            const starRating = document.createElement('div');
            starRating.className = 'star-rating text-center';

            for (let i = 1; i <= 5; i++) {
                const star = document.createElement('i');

                // Si el valor de "i" es menor o igual al promedio, añadir una estrella completa
                if (i <= promedio) {
                    star.className = 'fas fa-star'; // Estrella completa
                }
                // Si la estrella actual está a media unidad del promedio, mostrar media estrella
                else if (i - 0.5 <= promedio) {
                    star.className = 'fas fa-star-half-alt'; // Media estrella
                }
                // En otro caso, mostrar estrella vacía
                else {
                    star.className = 'far fa-star'; // Estrella vacía
                }
                star.style.color = '#ffc107'; // Color dorado para las estrellas
                starRating.appendChild(star);
            }

            return starRating;
        }
