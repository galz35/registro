        function generarEstrellas(promedio) {
            const starRating = document.createElement('div');
            starRating.className = 'star-rating text-center'; // Centramos las estrellas

            for (let i = 1; i <= 5; i++) {
                const star = document.createElement('span');
                star.innerHTML = i <= promedio ? '⭐' : '☆'; // Usamos estrellas llenas y vacías según el promedio
                starRating.appendChild(star);
            }

            return starRating;
        }
        function calcularPromedioHabilidades(data) {
            const opcionesGlobales = data[0].Opciones;
            let total = 0;
            let count = 0;

            data[0].Procesos[0].Formularios[0].Preguntas.forEach(pregunta => {
                const opcionesPregunta = opcionesGlobales.filter(opcion => opcion.PreguntaIDs.includes(pregunta.PreguntaID));
                opcionesPregunta.forEach(opcion => {
                    if (opcion.ValorOpcion) {
                        total += parseFloat(opcion.ValorOpcion);
                        count++;
                    }
                });
            });

            return count > 0 ? total / count : 0; // Promedio dinámico
        }
        // Función para calcular el resumen de cada tab/pestaña
        function calcularResumenPorTab(data) {
            let resumenPorTab = [];

            data[0].Procesos.forEach(proceso => {
                proceso.Formularios.forEach(formulario => {
                    let totalObtenido = 0;
                    let totalMaximo = 0;
                    let nombreFormulario = formulario.TituloFormulario;

                    formulario.Preguntas.forEach(pregunta => {
                        // Calculamos el total de puntos para cada pregunta
                        const opciones = data[0].Opciones.filter(opcion => opcion.PreguntaIDs.includes(pregunta.PreguntaID));
                        opciones.forEach(opcion => {
                            if (opcion.ValorOpcion) {
                                totalObtenido += parseFloat(opcion.ValorOpcion);
                            }
                            totalMaximo += 5; // Suponemos que el valor máximo es 5
                        });
                    });

                    resumenPorTab.push({
                        nombreFormulario,
                        totalObtenido,
                        totalMaximo
                    });
                });
            });

            return resumenPorTab;
        }
