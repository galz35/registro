
@{
    ViewBag.Title = "Baja";
}

<style>
    body {
        background-color: #f8f9fc;
    }

    .card-header {
        background-color: #dc3545 !important;
    }

    .nav-tabs .nav-link.active {
        background-color: #ffffff !important;
        border-color: #dc3545 #dc3545 #ffffff !important;
        color: #dc3545 !important;
    }

    .nav-tabs .nav-link {
        color: #6c757d !important;
    }

    .btn-primary {
        background-color: #dc3545;
        border-color: #dc3545;
    }

        .btn-primary:hover {
            background-color: #c82333;
            border-color: #bd2130;
        }

    .btn-secondary, .btn-info, .btn-success {
        margin-top: 20px;
    }

    .form-group {
        margin-bottom: 15px;
    }

    .tab-pane {
        display: none;
    }

        .tab-pane.active {
            display: block;
        }

    .star-rating {
        font-size: 2rem;
        color: gold;
    }
</style>


<div id="wrapper">
    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            <div class="container-fluid">
                <div class="card shadow mb-4">
                    <div class="card-header">
                        <h4 class="m-0 text-white">Encuestas Paso a Paso</h4>
                    </div>
                    <div class="card-body">
                        <ul class="nav nav-tabs" id="encuestaTabs" role="tablist"></ul>
                        <div class="tab-content" id="encuestaContent"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section scripts {
    <script src="~/onlinejs/chart.js"></script>
    <script src="~/Content/js2024/jquery.jeditable.min.js"></script>
    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.buttons.min.js"></script>
    <script src="~/onlinejs/buttons.html5.min.js"></script>
    <script src="~/onlinejs/buttons.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.select.min.js"></script>
    <script src="~/onlinejs/bootstrap.bundle.min.js"></script>
    <script src="~/onlinejs/bootstrap.min.js"></script>
    <script src="~/onlinejs/loadingoverlay.min.js"></script>
    <script src="~/onlinejs/dataTables.responsive.min.js"></script>
    <script src="~/Content/plugin/sweetalert2/sweetalert2.all.js"></script>
    <script src="~/onlinejs/moment.min.js"></script>
    <script src="~/onlinejs/jszip.min.js"></script>
    <script src="~/onlinejs/jquery-ui.js"></script>
    <script src="~/onlinejs/spin.min.js"></script>
    <script>
        const elementosFormulario = [];  // Array para almacenar los IDs o names
        let resumenChartInstance = null;
        const preguntasRespuestas = [];
        function agregarPreguntaAlArray(preguntaID, inputID, tabID, tipoInput) {
            preguntasRespuestas.push({
                PreguntaID: preguntaID,
                InputID: inputID,   // El ID del input o tabla
                TabID: tabID,       // El ID del tab al que pertenece
                TipoInput: tipoInput // Puede ser 'tabla', 'input', o 'opcion_multiples'
            });
        }

        // Variable de prueba para decidir qué función utilizar (0 o 1)
        // Variable de prueba para decidir qué función utilizar (0 o 1)
        let usarCumplimientoObjetivosVacio = 0; // Cambia a 1 para usar la versión vacía
        let grafico = 0; // Cambia a 1 para usar la versión vacía
        let estrella = 0; // Cambia a 1 para usar la versión vacía
        const data = [];
        $(document).ready(function () {
             $.ajax({
                url: "@Url.Action("ObtenerDatosProceso2", "Evaluacion")", // Ruta a tu controlador
                method: 'GET',
                dataType: 'json',
                success: function (response) {
                    // Guardar los datos obtenidos en la variable global 'data'
                   // this.data = Array.isArray(response) ? response : [response];

                    data.length = 0; // Limpiar el array por si acaso
                    Array.isArray(response) ? data.push(...response) : data.push(response);

                    // Ahora que los datos están listos, puedes ejecutar la creación de encuestas
                    crearEncuestas( data);

                    // Si necesitas agregar otras funciones, las llamas aquí
                    // agregarTabResumen();
                    // agregarEstrellasResumenMejorado(data);
                    // mostrarRespuestasPorTab(data);
                    // crearGraficoResumenTotal(data);
                },
                error: function (xhr, status, error) {
                    console.error('Error al obtener los datos de la encuesta:', error);
                }
            });
        });
        // Función principal para crear las encuestas basadas en el JSON
        function crearEncuestas(data) {
            const encuestaTabs = document.getElementById('encuestaTabs');
            const encuestaContent = document.getElementById('encuestaContent');

            const formularios = data[0].Procesos[0].Formularios;

            formularios.forEach((formulario, index) => {
                // Crear pestañas
                crearPestaña(formulario, index, encuestaTabs);

                // Crear contenido de la pestaña
                const tabPane = document.createElement('div');
                tabPane.className = 'tab-pane';
                if (index === 0) tabPane.classList.add('active');
                tabPane.id = `content-${formulario.FormularioID}`;
                tabPane.setAttribute('role', 'tabpanel');
                tabPane.setAttribute('aria-labelledby', `tab-${formulario.FormularioID}`);

                // Crear formulario
                const form = document.createElement('form');
                form.setAttribute('data-formulario-id', formulario.FormularioID);

                // Verificar si es "Cumplimiento de Objetivos"
                if (formulario.TituloFormulario === "Cumplimiento de Objetivos") {
                    formulario.Preguntas.forEach(pregunta => {
                        const formGroup = document.createElement('div');
                        formGroup.className = 'form-group';

                        // Aquí decidimos qué función llamar según la variable
                        if (usarCumplimientoObjetivosVacio === 1) {
                            agregarPreguntaCumplimientoObjetivosvacio(pregunta, formGroup, tabPane.id);
                        } else {
                            agregarPreguntaCumplimientoObjetivos(pregunta, formGroup, tabPane.id);
                        }

                        form.appendChild(formGroup);
                    });
                } else {
                    // Crear preguntas para los demás formularios
                    formulario.Preguntas.forEach(pregunta => {
                        const formGroup = document.createElement('div');
                        formGroup.className = 'form-group';

                        // Añadir el tipo de pregunta adecuado
                        if (pregunta.TipoPregunta === 'opcion_multiples') {
                            agregarPreguntaOpcion(pregunta, formGroup, data[0].Opciones, tabPane.id);
                        } else if (pregunta.TipoPregunta === 'abierta_multiples') {
                            agregarPreguntaAbierta(pregunta, formGroup, tabPane.id);
                        }
                        else if (pregunta.TipoPregunta === 'opcion_multiples_N') {
                            agregarPreguntaOpcionMultiplesN(pregunta, formGroup, data[0].Opciones, tabPane.id);
                        } else if (pregunta.TipoPregunta === 'abierta') {
                            agregarPreguntaAbiertatexto(pregunta, formGroup, tabPane.id);
                        }
                        form.appendChild(formGroup);
                    });
                }

                // Botones de navegación
                agregarBotonesNavegacion(formulario, index, formularios, form);

                // Añadir el formulario al contenido de la pestaña
                tabPane.appendChild(form);
                encuestaContent.appendChild(tabPane);
            });
        }

        // Función para crear una pestaña (Tab)
        function crearPestaña(formulario, index, encuestaTabs) {
            const tabItem = document.createElement('li');
            tabItem.className = 'nav-item';

            const tabLink = document.createElement('a');
            tabLink.className = 'nav-link';
            if (index === 0) tabLink.classList.add('active');
            tabLink.id = `tab-${formulario.FormularioID}`;
            tabLink.href = `#content-${formulario.FormularioID}`;
            tabLink.setAttribute('data-toggle', 'tab');
            tabLink.setAttribute('role', 'tab');
            tabLink.setAttribute('aria-controls', `content-${formulario.FormularioID}`);
            tabLink.setAttribute('aria-selected', index === 0 ? 'true' : 'false');
            tabLink.innerText = formulario.TituloFormulario;

            tabItem.appendChild(tabLink);
            encuestaTabs.appendChild(tabItem);
        }

        // Función especial para manejar el formulario "Cumplimiento de Objetivos"
        function agregarPreguntaCumplimientoObjetivos(pregunta, formGroup, tabID) {
            const label = document.createElement('label');
            label.innerText = pregunta.TextoPregunta;
            formGroup.appendChild(label);

            const tableWrapper = document.createElement('div');
            tableWrapper.className = 'table-responsive';

            const table = document.createElement('table');
            table.className = 'table table-bordered';
            table.id = `table_pregunta_${pregunta.PreguntaID}`;
            elementosFormulario.push(pregunta.PreguntaID);  // Almacenamos el ID en el array

            const thead = document.createElement('thead');
            const headerRow = document.createElement('tr');

            const thRespuesta = document.createElement('th');
            thRespuesta.innerText = 'Respuesta';
            thRespuesta.disabled = false;
            headerRow.appendChild(thRespuesta);

            // Campo especial para "Porcentaje (%)"
            const thPorcentaje = document.createElement('th');
            thPorcentaje.innerText = 'Porcentaje (%)';
            headerRow.appendChild(thPorcentaje);

            // Campo para "Porcentaje Real (%)"
            const thPorcentajeReal = document.createElement('th');
            thPorcentajeReal.innerText = 'Porcentaje Real (%)';
            headerRow.appendChild(thPorcentajeReal);

            // Campo para "Motivo"
            const thMotivo = document.createElement('th');
            thMotivo.innerText = 'Motivo';
            headerRow.appendChild(thMotivo);

            thead.appendChild(headerRow);
            table.appendChild(thead);

            const tbody = document.createElement('tbody');
            agregarFilaCumplimientoObjetivos1(pregunta, tbody);

            table.appendChild(tbody);
            tableWrapper.appendChild(table);

            // const addRowBtn = document.createElement('button');
            // addRowBtn.type = 'button';
            //  addRowBtn.className = 'btn btn-sm btn-primary add-row';
            //  addRowBtn.innerHTML = '<i class="fas fa-plus-circle"></i> Agregar Respuesta';
            //  addRowBtn.onclick = () => agregarFilaCumplimientoObjetivos1(pregunta, tbody);

            agregarPreguntaAlArray(pregunta.PreguntaID, table.id, tabID, 'tabla');  // Solo una vez, no necesitas agregar por fila

            formGroup.appendChild(tableWrapper);
            // formGroup.appendChild(addRowBtn);
        }

        // Función especial vacía para manejar "Cumplimiento de Objetivos"
        function agregarPreguntaCumplimientoObjetivosvacio(pregunta, formGroup, tabID) {
            const label = document.createElement('label');
            label.innerText = pregunta.TextoPregunta;
            formGroup.appendChild(label);

            // Aquí mantenemos la estructura igual pero con una lógica vacía para prueba
            const tableWrapper = document.createElement('div');
            tableWrapper.className = 'table-responsive';

            const table = document.createElement('table');
            table.className = 'table table-bordered';
            table.id = `table_pregunta_vacio_${pregunta.PreguntaID}`;
            elementosFormulario.push(pregunta.PreguntaID);  // Almacenamos el ID en el array

            const thead = document.createElement('thead');
            const headerRow = document.createElement('tr');

            const thRespuesta = document.createElement('th');
            thRespuesta.innerText = 'Respuesta';
            headerRow.appendChild(thRespuesta);

            const thAcciones = document.createElement('th');
            thAcciones.innerText = 'Acciones';
            headerRow.appendChild(thAcciones);

            thead.appendChild(headerRow);
            table.appendChild(thead);

            const tbody = document.createElement('tbody');
            agregarFilaCumplimientoObjetivos2(pregunta, tbody);

            table.appendChild(tbody);
            tableWrapper.appendChild(table);

            const addRowBtn = document.createElement('button');
            addRowBtn.type = 'button';
            addRowBtn.className = 'btn btn-sm btn-primary add-row';
            addRowBtn.innerHTML = '<i class="fas fa-plus-circle"></i> Agregar Respuesta';
            addRowBtn.onclick = () => agregarFilaCumplimientoObjetivos2(pregunta, tbody);

            agregarPreguntaAlArray(pregunta.PreguntaID, table.id, tabID, 'tabla');  // Solo una vez, no necesitas agregar por fila

            formGroup.appendChild(tableWrapper);
            formGroup.appendChild(addRowBtn);
        }
        function agregarFilaCumplimientoObjetivos2(pregunta, tbody, tabID) {
            const row = document.createElement('tr');

            const tdRespuesta = document.createElement('td');
            const inputRespuesta = document.createElement('input');
            inputRespuesta.type = 'text';
            inputRespuesta.className = 'form-control';
            inputRespuesta.name = `pregunta_${pregunta.PreguntaID}_respuesta[]`;
            tdRespuesta.appendChild(inputRespuesta);
            row.appendChild(tdRespuesta);

            // Select para "Porcentaje (%)"
            const tdPorcentaje = document.createElement('td');
            const selectPorcentaje = document.createElement('select');
            selectPorcentaje.className = 'form-control';
            selectPorcentaje.name = `pregunta_${pregunta.PreguntaID}_porcentaje`;

            for (let i = 10; i <= 100; i += 10) {
                const option = document.createElement('option');
                option.value = i;
                option.innerText = `${i}%`;
                selectPorcentaje.appendChild(option);
            }

            tdPorcentaje.appendChild(selectPorcentaje);
            row.appendChild(tdPorcentaje);


            // Lógica para habilitar/deshabilitar "Motivo"


            // Botón para eliminar fila
            const tdAcciones = document.createElement('td');
            const removeBtn = document.createElement('span');
            removeBtn.className = 'remove-row';
            removeBtn.innerHTML = '<i class="fas fa-minus-circle"></i>';
            removeBtn.onclick = () => eliminarFila(row, tbody);
            tdAcciones.appendChild(removeBtn);
            row.appendChild(tdAcciones);

            tbody.appendChild(row);

        }
        // Función especial para agregar una fila en "Cumplimiento de Objetivos"
        function agregarFilaCumplimientoObjetivos1(pregunta, tbody, tabID) {
            const row = document.createElement('tr');

            const tdRespuesta = document.createElement('td');
            const inputRespuesta = document.createElement('input');
            inputRespuesta.type = 'text';
            inputRespuesta.className = 'form-control';
            inputRespuesta.name = `pregunta_${pregunta.PreguntaID}_respuesta[]`;
            inputRespuesta.disabled = false;
            tdRespuesta.appendChild(inputRespuesta);
            row.appendChild(tdRespuesta);

            // Select para "Porcentaje (%)"
            const tdPorcentaje = document.createElement('td');
            const selectPorcentaje = document.createElement('select');
            selectPorcentaje.className = 'form-control';
            selectPorcentaje.name = `pregunta_${pregunta.PreguntaID}_porcentaje`;

            for (let i = 10; i <= 100; i += 10) {
                const option = document.createElement('option');
                option.value = i;
                option.innerText = `${i}%`;
                selectPorcentaje.appendChild(option);
            }

            tdPorcentaje.appendChild(selectPorcentaje);
            row.appendChild(tdPorcentaje);

            // Input para "Porcentaje Real (%)"
            const tdPorcentajeReal = document.createElement('td');
            const inputPorcentajeReal = document.createElement('select');
            //inputPorcentajeReal.type = 'number';
            inputPorcentajeReal.className = 'form-control';
            inputPorcentajeReal.name = `pregunta_${pregunta.PreguntaID}_porcentaje_real`;
            for (let i = 10; i <= 100; i += 10) {
                const option = document.createElement('option');
                option.value = i;
                option.innerText = `${i}%`;
                inputPorcentajeReal.appendChild(option);
            }
            tdPorcentajeReal.appendChild(inputPorcentajeReal);
            row.appendChild(tdPorcentajeReal);

            // Input para "Motivo"
            const tdMotivo = document.createElement('td');
            const inputMotivo = document.createElement('input');
            inputMotivo.type = 'text';
            inputMotivo.className = 'form-control';
            inputMotivo.name = `pregunta_${pregunta.PreguntaID}_motivo[]`;
            inputMotivo.disabled = false;  // Inicialmente desactivado
            tdMotivo.appendChild(inputMotivo);
            row.appendChild(tdMotivo);

            // Lógica para habilitar/deshabilitar "Motivo"
            inputPorcentajeReal.addEventListener('input', function () {
                const porcentajeReal = parseInt(inputPorcentajeReal.value) || 0;
                const porcentajeSeleccionado = parseInt(selectPorcentaje.value) || 0;

                if (porcentajeReal < porcentajeSeleccionado) {
                    inputMotivo.disabled = false; // Habilitar motivo si el porcentaje real es menor
                } else {
                    inputMotivo.disabled = true;  // Deshabilitar motivo en otros casos
                }
            });

            // Botón para eliminar fila
            // const tdAcciones = document.createElement('td');
            // const removeBtn = document.createElement('span');
            // removeBtn.className = 'remove-row';
            // removeBtn.innerHTML = '<i class="fas fa-minus-circle"></i>';
            // removeBtn.onclick = () => eliminarFila(row, tbody);
            // tdAcciones.appendChild(removeBtn);
            // row.appendChild(tdAcciones);

            tbody.appendChild(row);
            preguntasRespuestas.push({
                PreguntaID: pregunta.PreguntaID,
                ElementoRespuestaID: inputRespuesta.name,  // Identificamos el campo de respuesta
                ElementoPorcentajeID: selectPorcentaje.name,  // Identificamos el select de porcentaje
                TabID: tabID
            });
        }
        function agregarPreguntaOpcion2(pregunta, formGroup, opcionesGlobales, tabID) {
            // Crear una fila con dos columnas usando clases de Bootstrap
            const formRow = document.createElement('div');
            formRow.className = 'form-row align-items-center mb-3'; // Añadido espacio entre las filas

            const labelCol = document.createElement('div');
            labelCol.className = 'col-md-4';
            const label = document.createElement('label');
            label.innerText = pregunta.TextoPregunta;
            label.style.whiteSpace = 'nowrap';  // Esto evitará que el texto del label se corte en múltiples líneas
            labelCol.appendChild(label);

            const selectCol = document.createElement('div');
            selectCol.className = 'col-md-8';
            const select = document.createElement('select');
            select.className = 'form-control';
            select.name = `pregunta_${pregunta.PreguntaID}`;
            select.id = `pregunta_${pregunta.PreguntaID}`;  // Añadimos un ID

            elementosFormulario.push(pregunta.PreguntaID);
            select.required = pregunta.Requerido;

            const emptyOption = document.createElement('option');
            emptyOption.value = '';
            emptyOption.innerText = 'Seleccione una opción';
            select.appendChild(emptyOption);

            const opcionesFiltradas = opcionesGlobales.filter(opcion => opcion.PreguntaIDs.includes(pregunta.PreguntaID));
            opcionesFiltradas.forEach(opcion => {
                const option = document.createElement('option');
                option.value = opcion.ValorOpcion;
                option.id = `opcion_${opcion.OpcionID}`;
                option.innerText = opcion.TextoOpcion;
                select.appendChild(option);
            });

            selectCol.appendChild(select);
            formRow.appendChild(labelCol);
            formRow.appendChild(selectCol);
            formGroup.appendChild(formRow);

            agregarPreguntaAlArray(pregunta.PreguntaID, select.id, tabID, 'opcion_multiples');
        }
        // Función para manejar preguntas de tipo opción múltiple
        function agregarPreguntaOpcion(pregunta, formGroup, opcionesGlobales, tabID) {

            const formRow = document.createElement('div');
            formRow.className = 'form-row align-items-center';

            const labelCol = document.createElement('div');
            labelCol.className = 'col-md-4';
            const label = document.createElement('label');
            label.innerText = pregunta.TextoPregunta;
            labelCol.appendChild(label);

            const selectCol = document.createElement('div');
            selectCol.className = 'col-md-8';
            const select = document.createElement('select');
            select.className = 'form-control';
            select.name = `pregunta_${pregunta.PreguntaID}`;
            select.id = `pregunta_${pregunta.PreguntaID}`;  // Añadimos un ID

            elementosFormulario.push(pregunta.PreguntaID);
            select.required = pregunta.Requerido;

            const emptyOption = document.createElement('option');
            emptyOption.value = '';
            emptyOption.innerText = 'Seleccione una opción';
            select.appendChild(emptyOption);

            const opcionesFiltradas = opcionesGlobales.filter(opcion => opcion.PreguntaIDs.includes(pregunta.PreguntaID));
            opcionesFiltradas.forEach(opcion => {
                const option = document.createElement('option');
                option.value = opcion.ValorOpcion;
                option.id = opcion.OpcionID;
                option.innerText = opcion.TextoOpcion;
                select.appendChild(option);
            });

            selectCol.appendChild(select);
            formRow.appendChild(labelCol);
            formRow.appendChild(selectCol);
            formGroup.appendChild(formRow);

            agregarPreguntaAlArray(pregunta.PreguntaID, select.id, tabID, 'opcion_multiples');

        }
        function agregarBotonesResumen() {
            const resumenContainer = document.getElementById('content-resumen');

            // Botón de Regresar
            const btnRegresar = document.createElement('button');
            btnRegresar.className = 'btn btn-secondary';
            btnRegresar.innerText = 'Regresar';
            btnRegresar.onclick = () => openTab(0);  // Regresar al primer tab
            resumenContainer.appendChild(btnRegresar);

            // Botón de Enviar
            const btnEnviar = document.createElement('button');
            btnEnviar.className = 'btn btn-primary ml-2';
            btnEnviar.innerText = 'Enviar Formulario';
            btnEnviar.onclick = () => enviarFormulario();
            resumenContainer.appendChild(btnEnviar);
        }
        // Función para manejar preguntas de tipo abierta_multiples
        function agregarPreguntaAbierta(pregunta, formGroup, tabID) {
            const label = document.createElement('label');
            label.innerText = pregunta.TextoPregunta;
            formGroup.appendChild(label);

            const tableWrapper = document.createElement('div');
            tableWrapper.className = 'table-responsive';

            const table = document.createElement('table');
            table.className = 'table table-bordered';
            table.id = `table_pregunta_${pregunta.PreguntaID}`;
            elementosFormulario.push(pregunta.PreguntaID);  // Almacenamos el ID en el array

            const thead = document.createElement('thead');
            const headerRow = document.createElement('tr');

            const thRespuesta = document.createElement('th');
            thRespuesta.innerText = 'Respuesta';
            headerRow.appendChild(thRespuesta);

            if (pregunta.RequierePorcentaje) {
                const thPorcentaje = document.createElement('th');
                thPorcentaje.innerText = 'Porcentaje (%)';
                headerRow.appendChild(thPorcentaje);
            }

            if (pregunta.RequierePorcentajeReal) {
                const thPorcentajeReal = document.createElement('th');
                thPorcentajeReal.innerText = 'Porcentaje Real (%)';
                headerRow.appendChild(thPorcentajeReal);
            }

            if (pregunta.RequiereMotivo) {
                const thMotivo = document.createElement('th');
                thMotivo.innerText = 'Motivo';
                headerRow.appendChild(thMotivo);
            }

            const thAcciones = document.createElement('th');
            thAcciones.innerText = 'Acciones';
            headerRow.appendChild(thAcciones);

            thead.appendChild(headerRow);
            table.appendChild(thead);

            const tbody = document.createElement('tbody');
            agregarFilaAbierta(pregunta, tbody);

            table.appendChild(tbody);
            tableWrapper.appendChild(table);

            const addRowBtn = document.createElement('button');
            addRowBtn.type = 'button';
            addRowBtn.className = 'btn btn-sm btn-primary add-row';
            addRowBtn.innerHTML = '<i class="fas fa-plus-circle"></i> Agregar Respuesta';
            addRowBtn.onclick = () => agregarFilaAbierta(pregunta, tbody);

            formGroup.appendChild(tableWrapper);
            formGroup.appendChild(addRowBtn);

            agregarPreguntaAlArray(pregunta.PreguntaID, table.id, tabID, 'tabla');

        }
        // Función para manejar preguntas de tipo abierta_multiples utilizando input en vez de tabla
        function agregarPreguntaAbiertatexto(pregunta, formGroup, tabID) {
            const label = document.createElement('label');
            label.innerText = pregunta.TextoPregunta;
            formGroup.appendChild(label);

            // Crear un input de texto para la respuesta abierta
            const inputRespuesta = document.createElement('input');
            inputRespuesta.type = 'text';
            inputRespuesta.className = 'form-control';
