                        label: 'Puntaje Obtenido',
                        data: totalObtenido,  // Valores de puntaje obtenido
                        backgroundColor: ['#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0'],
                        borderColor: ['#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0'],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,  // Hacer que el gráfico sea sensible al tamaño del contenedor
                    maintainAspectRatio: false,  // Para que se ajuste bien al tamaño dado
                    legend: {
                        position: 'top',  // Colocamos la leyenda en la parte superior
                    },
                    layout: {
                        padding: {
                            left: 20,
                            right: 20,
                            top: 10,
                            bottom: 10
                        }
                    }
                }
            });
        }

        function generarEstrellasBonitas(promedio) {
            const starRating = document.createElement('div');
            starRating.className = 'star-rating text-center'; // Centramos las estrellas

            for (let i = 1; i <= 5; i++) {
                const star = document.createElement('i');
                star.className = i <= promedio ? 'fas fa-star' : 'far fa-star'; // Usamos FontAwesome para estrellas
                star.style.color = '#ffc107'; // Color dorado para estrellas llenas
                starRating.appendChild(star);
            }

            return starRating;
        }
        function agregarEstrellasResumenMejorado(data) {
            const promedio = calcularPromedioHabilidades(data);
            const starRating = generarEstrellasBonitas(promedio);
            document.getElementById('content-resumen').prepend(starRating); // Agregar estrellas al inicio del resumen
        }
        // Función para mostrar el resumen detallado de cada tab
        function mostrarResumenPorTab(data) {
            const resumenPorTab = calcularResumenPorTab(data);

            const resumenContainer = document.getElementById('content-resumen');
            resumenPorTab.forEach(tab => {
                // Crear una sección para cada tab
                const tabResumen = document.createElement('div');
                tabResumen.className = 'tab-resumen';

                const titulo = document.createElement('h5');
                titulo.innerText = `Resumen de ${tab.nombreFormulario}`;
                tabResumen.appendChild(titulo);

                const descripcion = document.createElement('p');
                descripcion.innerText = `Obtuviste ${tab.totalObtenido} puntos de un máximo de ${tab.totalMaximo} puntos.`;
                tabResumen.appendChild(descripcion);

                // Añadir el resumen al contenedor del resumen
                resumenContainer.appendChild(tabResumen);
            });
        }

        function agregarEstrellasResumen(data) {
            const promedio = calcularPromedioHabilidades(data);
            const starRating = generarEstrellas(promedio);
            document.getElementById('content-resumen').prepend(starRating); // Agregar estrellas al inicio del resumen
        }


    </script>
}