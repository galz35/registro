                star.style.color = '#ffc107'; // Color dorado para estrellas llenas
                starRating.appendChild(star);
            }

            return starRating;
        }

        function crearGraficoResumenTotal2(respuestas) {
            const totalObtenido = respuestas
                .filter(r => !isNaN(parseInt(r.PorcentajeReal)))
                .reduce((sum, r) => sum + parseInt(r.PorcentajeReal || 0), 0);
            const totalMaximo = respuestas.length * 100;

            const canvas = document.getElementById('resumenChart');
            if (!canvas) {
                console.error('Canvas "resumenChart" no encontrado');
                return; // Detener si no existe el canvas
            }

            const ctx = canvas.getContext('2d');

            // Destruir gráfico anterior si existe
            if (window.myResumenChart) {
                window.myResumenChart.destroy();
            }

            // Crear nuevo gráfico
            window.myResumenChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Total Obtenido', 'Total Máximo'],
                    datasets: [{
                        label: 'Puntaje Total',
                        data: [totalObtenido, totalMaximo],
                        backgroundColor: ['rgba(75, 192, 192, 0.2)', 'rgba(255, 99, 132, 0.2)'],
                        borderColor: ['rgba(75, 192, 192, 1)', 'rgba(255, 99, 132, 1)'],
                        borderWidth: 1
                    }]
                },
                options: {
                    scales: {
                        y: {
                            beginAtZero: true,
                            max: totalMaximo
                        }
                    }
                }
            });
        }

        function capturarRespuestasOpcionMultiples() {
            const respuestas = [];

            preguntasRespuestas.forEach(item => {
                // Solo capturamos las respuestas del tipo 'opcion_multiples'
                if (item.TipoInput === 'opcion_multiples') {
                    const select = document.getElementById(item.InputID);
                    const respuesta = select ? select.value : 'No respondida';
                    const porcentajeReal = parseInt(respuesta) || 0; // Asegurarse de capturar correctamente el valor
                    respuestas.push({
                        PreguntaID: item.PreguntaID,
                        TextoPregunta: `Pregunta ${item.PreguntaID}`, // Nombre genérico para la pregunta
                        PorcentajeReal: porcentajeReal, // Guardamos el valor numérico de la respuesta
                    });
                }
            });

            return respuestas;
        }

        function crearGraficoOpcionMultiples(respuestas) {



            const totalObtenido = respuestas
                .reduce((sum, r) => {
                    const valorNumerico = parseFloat(r.Respuesta);  // Intentar convertir la respuesta a número
                    return sum + (isNaN(valorNumerico) ? 0 : valorNumerico); // Si es NaN, sumar 0, de lo contrario sumar el número
                }, 0);
            const formulariosConGraficoOEstrella = data[0].Procesos[0].Formularios
                .filter(formulario => formulario.grafico || formulario.estrella)
                .map(formulario => formulario.FormularioID);

            // Filtrar respuestas que pertenecen a esos formularios
            const respuestasFiltradas = respuestas.filter(r => {
                const formularioID = parseInt(r.TabID.replace('content-', '')); // Convertir el TabID al FormularioID
                return formulariosConGraficoOEstrella.includes(formularioID);
            });

            // Sumar solo las respuestas numéricas de formularios con gráfico o estrella

            // Calcular el promedio basado en las respuestas filtradas
            const promedio = respuestasFiltradas.length > 0 ? totalObtenido / respuestasFiltradas.length : 0;


            const totalMaximo = respuestasFiltradas.length * 5; // Asumimos que cada pregunta tiene un máximo de 100
            const diferencia = totalMaximo - totalObtenido;

            // Asegurarse de que el canvas esté en el DOM
            let canvas = document.getElementById('resumenChart');
            if (!canvas) {
                canvas = document.createElement('canvas');
                canvas.id = 'resumenChart';
                canvas.height = 50;
                document.getElementById('content-resumen').appendChild(canvas);
            }

            const ctx = canvas.getContext('2d');

            // Destruir gráfico anterior si existe
            if (window.myResumenChart) {
                window.myResumenChart.destroy();
            }

            // Crear nuevo gráfico
            window.myResumenChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Total Obtenido', 'Total Máximo', 'Diferencia'],
                    datasets: [{
                        label: 'Puntaje Total',
                        data: [totalObtenido, totalMaximo, diferencia],
                        backgroundColor: ['rgba(75, 192, 192, 0.2)', 'rgba(255, 99, 132, 0.2)', 'rgba(255, 206, 86, 0.2)'],
