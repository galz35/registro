        function calcularResumenTotal(data) {
            let totalObtenido = 0;
            let totalMaximo = 0;

            data[0].Procesos.forEach(proceso => {
                proceso.Formularios.forEach(formulario => {
                    formulario.Preguntas.forEach(pregunta => {
                        // Calculamos el total de puntos para cada pregunta
                        const opciones = data[0].Opciones.filter(opcion => opcion.PreguntaIDs.includes(pregunta.PreguntaID));
                        opciones.forEach(opcion => {
                            if (opcion.ValorOpcion) {
                                totalObtenido += parseFloat(opcion.ValorOpcion);
                            }
                            // Suponemos que el valor máximo es siempre 5
                            totalMaximo += 5;
                        });
                    });
                });
            });

            return { totalObtenido, totalMaximo };
        }
