                    });
                }
                // Si es otro tipo de pregunta
                else if (item.TipoInput === 'opcion_multiples') {
                    const select = document.getElementById(item.InputID);
                    const respuesta = select ? select.value : 'No respondida';
                    respuestas.push({
                        PreguntaID: item.PreguntaID,
