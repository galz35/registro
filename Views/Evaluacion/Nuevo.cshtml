        function validarPreguntasRequeridas(tabID) {
            let esValido = true;
            let preguntasFaltantes = [];

            // Filtrar las preguntas del tab específico
            const preguntasDelTab = preguntasRespuestas.filter(p => p.TabID === tabID);

            preguntasDelTab.forEach(pregunta => {
                // Obtenemos el elemento HTML correspondiente
                let elementoPregunta = document.getElementById(pregunta.InputID);

                // Si no se encuentra el elemento por ID, mostramos advertencia y continuamos
                if (!elementoPregunta) {
                    return;
                }

                // Buscamos en el JSON si la pregunta es requerida
                const preguntaJson = data[0].Procesos[0].Formularios
                    .flatMap(f => f.Preguntas)
                    .find(p => p.PreguntaID === pregunta.PreguntaID && p.Requerido);

                if (preguntaJson) {
                    // Primero determinamos el tipo de elemento (input, select, checkbox, etc.)
                    switch (elementoPregunta.tagName) {
                        case 'INPUT':
                            validarInput(elementoPregunta, preguntaJson, pregunta, preguntasFaltantes);
                            break;

                        case 'SELECT':
                            validarSelect(elementoPregunta, preguntaJson, preguntasFaltantes);
                            break;

                        case 'DIV': // Para el caso de checkbox o inputs múltiples dentro de un contenedor
                            validarCheckboxMultiple(elementoPregunta, preguntaJson, preguntasFaltantes);
                            break;

                        default:
                            console.log('Tipo de input no soportado');
                            break;
                    }
                }
            });

            if (preguntasFaltantes.length>0) {
                const mensaje = `Por favor, complete las siguientes preguntas obligatorias:\n - ${preguntasFaltantes.join('\n - ')}`;
                Swal.fire({
                    title: 'Error',
                    text: mensaje,
                    icon: 'warning',
                    confirmButtonText: 'Aceptar'
                });
                return false;
            }

            return esValido;
        }

        // Función para validar inputs de texto (tipo abierta)
        function validarInput(elemento, preguntaJson, pregunta, preguntasFaltantes) {
            switch (preguntaJson.TipoPregunta) {
                case 'abierta':
                    if (!elemento.value.trim()) {
                        preguntasFaltantes.push(preguntaJson.TextoPregunta);
                        mostrarError(elemento, 'Esta pregunta es obligatoria.');
                        return false;
                    } else {
                        quitarError(elemento);
                        return true;
                    }
                case 'abierta_multiples': // Para inputs múltiples
                    if (!elemento.value.trim()) {
                        preguntasFaltantes.push(preguntaJson.TextoPregunta);
                        mostrarError(elemento, 'Esta pregunta es obligatoria.');
                        return false;
                    } else {
                        quitarError(elemento);
                        return true;
                    }
                    break;
                default:
                    console.log('Tipo de pregunta no soportado en inputs');
                    break;
            }
        }

        // Función para validar selects
        function validarSelect(elemento, preguntaJson, preguntasFaltantes) {
            if (elemento.value === '') {
                preguntasFaltantes.push(preguntaJson.TextoPregunta);
                mostrarError(elemento, 'Debe seleccionar una opción.');
                return false;
            } else {
                quitarError(elemento);
                return true;
            }
        }

        // Función para validar opciones múltiples (checkboxes)
        function validarCheckboxMultiple(elemento, preguntaJson, preguntasFaltantes) {
            const checkboxes = document.getElementsByName(pregunta.InputID);
            const alMenosUnoMarcado = Array.from(checkboxes).some(checkbox => checkbox.checked);

            if (!alMenosUnoMarcado) {
                preguntasFaltantes.push(preguntaJson.TextoPregunta);
                mostrarError(checkboxes[0], 'Debe seleccionar al menos una opción.');
                return false;
            } else {
                quitarError(checkboxes[0]);
                return true;
            }
        }
        function mostrarError(pregunta, mensaje) {
            if (!pregunta) return;

            const errorSpan = document.createElement('span');
            errorSpan.className = 'text-danger';
            errorSpan.innerText = mensaje;

            if (!pregunta.closest('.form-group').querySelector('.text-danger')) {
                pregunta.closest('.form-group').appendChild(errorSpan);
            }
            pregunta.classList.add('is-invalid');  // Añadir clase de error visual
        }

        function quitarError(pregunta) {
            if (!pregunta) return;

            const errorSpan = pregunta.closest('.form-group').querySelector('.text-danger');
            if (errorSpan) {
                errorSpan.remove();
            }
            pregunta.classList.remove('is-invalid');  // Quitar clase de error visual
        }

        // Función que muestra el input de texto si se selecciona la opción "Otros"
        function toggleInputOtros(e, preguntaID) {
            const inputOtros = document.getElementById(`pregunta_${preguntaID}_otros_input`);
            if (e.target.id.includes('otros') && e.target.checked) {
                inputOtros.style.display = 'block';  // Mostrar input de texto
            } else if (e.target.id.includes('otros') && !e.target.checked) {
                inputOtros.style.display = 'none';  // Ocultar input de texto
            }
        }

