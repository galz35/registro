
@{
    ViewBag.Title = "Encurso";
}
<style>
    /* General styling */
    body {
        background-color: #f4f4f4;
        color: #333;
        font-family: 'Arial', sans-serif;
    }

    h2 {
        color: #b71c1c; /* Rojo oscuro */
        font-weight: bold;
    }

    /* Table styling */
    #employeeEvaluationsTable {
        font-size: 12px;
        background-color: #fff;
        border: 1px solid #ccc;
    }

        #employeeEvaluationsTable thead th {
            background-color: #333;
            color: #fff;
            font-size: 12px;
            font-weight: bold;
            text-align: center;
        }

        #employeeEvaluationsTable tbody td {
            font-size: 12px;
            color: #333;
            text-align: center;
        }

        #employeeEvaluationsTable tbody tr:nth-child(even) {
            background-color: #f9f9f9; /* Gris claro */
        }

        #employeeEvaluationsTable tbody tr:nth-child(odd) {
            background-color: #fff; /* Blanco */
        }

        #employeeEvaluationsTable tbody tr:hover {
            background-color: #e57373; /* Rojo claro al pasar el mouse */
            color: #fff;
        }

        #employeeEvaluationsTable tbody .btn {
            font-size: 12px;
            background-color: #b71c1c; /* Botones rojos */
            color: #fff;
            border: none;
        }

            #employeeEvaluationsTable tbody .btn:hover {
                background-color: #d32f2f; /* Rojo más claro al pasar el mouse */
            }

    /* Badge styling */
    .badge-warning {
        background-color: #ffcc00;
        color: #333;
    }

    .badge-primary {
        background-color: #b71c1c;
        color: #fff;
    }

    .badge-success {
        background-color: #2e7d32;
        color: #fff;
    }

    .badge-secondary {
        background-color: #757575;
        color: #fff;
    }

    /* Modal styling */
    .modal-header {
        background-color: #b71c1c; /* Rojo oscuro */
        color: #fff;
    }

    .modal-body {
        font-size: 12px;
        color: #333;
    }

    .modal-footer {
        background-color: #f4f4f4;
    }

    .btn-secondary {
        background-color: #757575;
        color: #fff;
        border: none;
    }

        .btn-secondary:hover {
            background-color: #9e9e9e;
        }
    /* Custom buttons */
    .btn-custom {
        background-color: #333;
        color: #fff;
        border: none;
        margin-right: 5px;
    }

        .btn-custom:hover {
            background-color: #555;
        }

    .btn-upload {
        background-color: #757575;
        color: #fff;
        border: none;
    }

        .btn-upload:hover {
            background-color: #9e9e9e;
        }
    .modal-custom-width {
        max-width: 95%; /* Ajusta el porcentaje o usa px (e.g., 800px) */
    }
     
</style>
<h2>Encurso</h2>


<div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
        <div class="container-fluid">
            <!-- Page Heading -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h5 class="m-0 font-weight-bold text-primary" style="color: #800 !important;">
                        Gestión de Evaluaciones
                    </h5>
                </div>

                <div class="card-body table-responsive">
                    <table id="employeeEvaluationsTable" class="table table-bordered table-hover display nowrap" style="width:100%">
                        <thead>
                            <tr>
                                <th>Empleado</th>
                                <th>Código</th>
                                <th>Fecha</th>
                                <th>Cargo Anterior</th>
                                <th>Cargo Actual</th>
                                <th>Gerencia Anterior</th>
                                <th>Gerencia Actual</th>
                                <th>Mes</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Se llenarán dinámicamente las filas -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="evaluationsModal" tabindex="-1" role="dialog" aria-labelledby="evaluationsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="evaluationsModalLabel">Evaluaciones del Empleado</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <!-- Aquí se cargará dinámicamente el contenido de las evaluaciones -->
                <div id="evaluationsContent"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/js/select2.min.js"></script>

    <script src="~/Content/js2024/jquery.jeditable.min.js"></script>
    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.buttons.min.js"></script>
    <script src="~/onlinejs/buttons.html5.min.js"></script>
    <script src="~/onlinejs/buttons.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.select.min.js"></script>
    <script src="~/onlinejs/bootstrap.bundle.min.js"></script>
    <script src="~/onlinejs/bootstrap.min.js"></script>
    <script src="~/onlinejs/loadingoverlay.min.js"></script>
    <script src="~/onlinejs/dataTables.responsive.min.js"></script>
    <script src="~/Content/plugin/sweetalert2/sweetalert2.all.js"></script>
    <script src="~/onlinejs/moment.min.js"></script>
    <script src="~/onlinejs/jszip.min.js"></script>
    <script src="~/onlinejs/jquery-ui.js"></script>
    <script src="~/onlinejs/spin.min.js"></script>

    <script>
        function getStatusIcon(status) {
            switch (status) {
                case 'Pendiente':
                    return '<i class="fas fa-hourglass-start"></i>';
                case 'En Proceso':
                    return '<i class="fas fa-spinner"></i>';
                case 'Finalizado':
                    return '<i class="fas fa-check-circle"></i>';
                default:
                    return '<i class="fas fa-question-circle"></i>';
            }
        }
        function enviarEvaluacion(idCiclo) {
            window.location.href = `/Evaluacion/EnviarEvaluacion?idCiclo=${idCiclo}`;
        }
        function enviarEvaluacion2(idCiclo) {
            window.location.href = `/Evaluacion/EnviarEvaluacion2?idCiclo=${idCiclo}`;
        }
        function evaluar(idCiclo) {
            window.location.href = `/Evaluacion/Evaluar?idCiclo=${idCiclo}`;
        }

        function descargarPDF(idCiclo) {
            window.location.href = `/Evaluacion/DescargarPDF?idCiclo=${idCiclo}`;
        }

        function subirPDF(idCiclo) {
            var formData = new FormData();
            var fileInput = document.getElementById('inputFile'); // Debes tener un input de tipo file en tu formulario
            formData.append('pdfFile', fileInput.files[0]);

            $.ajax({
                url: `/Evaluacion/SubirPDF?idCiclo=${idCiclo}`,
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (response) {
                    alert('PDF subido exitosamente');
                },
                error: function (error) {
                    alert('Error al subir el PDF');
                }
            });
        }
 $(document).ready(function () {
     $.LoadingOverlay("show");
      var groupedEvaluations = {};


var table = $('#employeeEvaluationsTable').DataTable({
    "ajax": {
        "url": "@Url.Action("EmployeesListjsontodox", "Evaluacion")",
        "type": "GET",
        "datatype": "json",
        "dataSrc": function (json) {
            var groupedData = [];
            groupedEvaluations = {};

            json.data.forEach(function (item) {
                if (!groupedEvaluations[item.CodigoEmpleado]) {
                    groupedEvaluations[item.CodigoEmpleado] = [];
                }
                groupedEvaluations[item.CodigoEmpleado].push(item);

                if (groupedData.every(d => d.CodigoEmpleado !== item.CodigoEmpleado)) {
                    groupedData.push(item);
                }
            });

            return groupedData;
        }
    },
    "columns": [{
        "data": null,
        "render": function (data, type, row) {
            return `<button class="btn btn-info btn-sm view-evaluations"
                            data-codigo="${row.CodigoEmpleado}">
                <i class="fas fa-eye"></i>
                        </button>`;
        }
    },
        { "data": "colaborador" },
        { "data": "CodigoEmpleado" },
        {
            "data": "FechaRegistro",
            "render": function (data) {
                return moment(data).format('DD-MM-YYYY');
            }
        },

        { "data": "Cargo" },
        { "data": "Cargo2" },
        { "data": "Gerencia" },
        { "data": "Gerencia2" },
        { "data": "CantidadMeses" },
        { "data": "EstadoEvaluacion" }

    ],
    "dom": 'Blfrtip',
    "lengthMenu": [10, 20, 50, 100],
    "pageLength": 10,
    "language": {
        "url": "@Url.Content("~/Scripts/datatable.es-ES.json")"
    },
    responsive: true
});

     $('#employeeEvaluationsTable tbody').on('click', 'button.view-evaluations', function () {
         var codigoEmpleado = $(this).data('codigo');
         var evaluations = groupedEvaluations[codigoEmpleado];

         var detailsHtml = `<table class="table table-sm table-borderless">
                    <thead>
                        <tr>
                            <th>Ciclo</th>
                            <th>Inicio</th>
                            <th>Estado</th>
                            <th>Nuevo Cargo</th>
                            <th>Nueva Gerencia</th>
                            <th>Porcentaje Real</th>
                            <th>Acciones</th> <!-- Nueva columna para botones -->
                        </tr>
                    </thead>
                    <tbody>`;

         evaluations.forEach(evaluation => {
             detailsHtml += `<tr style="background-color:${getStatusColor(evaluation.EstadoCiclo)}">
                        <td>${evaluation.MesCiclo}</td>
                        <td>${moment(evaluation.FechaRegistro).format('DD-MM-YYYY')}</td>
                        <td><span class="badge ${getStatusColor(evaluation.EstadoCiclo)}">${evaluation.EstadoCiclo}</span></td>
                        <td>${evaluation.Cargo2}</td>
                        <td>${evaluation.Gerencia2}</td>
                        <td>${evaluation.PorcentajeCumplimientoReal || 'N/A'}%</td>
                         <td>
                <button class="btn btn-primary btn-sm" onclick="enviarEvaluacion(${evaluation.IdCiclo})">Terminos</button>
                <button class="btn btn-primary btn-sm" onclick="enviarEvaluacion2(${evaluation.IdCiclo})">Objetivo</button>
                <button class="btn btn-success btn-sm" onclick="evaluar(${evaluation.IdCiclo})">Evaluar</button>
                <button class="btn btn-info btn-sm" onclick="descargarPDF(${evaluation.IdCiclo})">descargar pdf</button>
                <button class="btn btn-warning btn-sm" onclick="subirPDF(${evaluation.IdCiclo})">subir pdf</button>
            </td>
                    </tr>`;
         });

         detailsHtml += `</tbody></table>`;

         // Insertar el contenido en el modal
         $('#evaluationsContent').html(detailsHtml);
         $('#evaluationsModal').modal('show');
     });    

     function getStatusColor(status) {
         switch (status) {
             case 'Pendiente':
                 return 'badge-warning';
             case 'En Proceso':
                 return 'badge-primary';
             case 'Finalizado':
                 return 'badge-success';
             default:
                 return 'badge-secondary';
         }
     }

   
     $.LoadingOverlay("hide");
});

    </script>
}
