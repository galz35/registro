        // Función para convertir un base64 a Blob
function base64ToBlob(base64, mime) {
    var byteString = atob(base64.split(',')[1]);
    var ab = new ArrayBuffer(byteString.length);
    var ia = new Uint8Array(ab);
    for (var i = 0; i < byteString.length; i++) {
        ia[i] = byteString.charCodeAt(i);
    }
    return new Blob([ia], { type: mime });
}
        function validateImageSize(base64Image, threshold) {
            if (!base64Image.startsWith("data:image")) return true;
            var mime = base64Image.substring(5, base64Image.indexOf(";"));
            var blob = base64ToBlob(base64Image, mime);
            return blob.size <= threshold;
        }
// Función que comprime la imagen si su tamaño (Blob) supera 800KB
        function validateImageSize2(base64Str, maxSize = 1000000) {
            let stringLength = base64Str.length - 'data:image/png;base64,'.length;
            let sizeInBytes = 4 * Math.ceil(stringLength / 3) * 0.5624896334383812; // Estimación
            return sizeInBytes <= maxSize;
        }

