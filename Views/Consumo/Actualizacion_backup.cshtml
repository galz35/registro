                </div>
                <div class="card-body p-3">
                    <table id="listTable" class="table table-striped table-bordered table-hover display responsive nowrap" style="width:100%">
                        <thead>
                            <tr>
                                <th>Acción</th>
                                <th>Unidad</th>
                                <th>Modelo</th>
                                <th>Tipo</th>

                                <th>Nombre Empleado</th>
                                <th>Carnet</th>
                                <th>Nombre Área</th>
                                <th>Gerencia</th>
                                <th>Datos</th>
                            </tr>
                        </thead>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="actualizacionModal" class="modal fade" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Actualización de Datos</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <!-- Campo oculto para el Id del vehículo -->
                <input type="hidden" id="idVehiculo" value="" />
                <form id="formInspeccion">
                    <!-- 1. Quien tiene asignada y Conductores -->
                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label for="ReceivePersonIdDisplay">Quien tiene asignada</label>
                            <input list="ReceivePersonList" class="form-control" id="ReceivePersonIdDisplay"
                                   placeholder="Buscar responsable..." onblur="OnSelectedReceivePersonChanged()" autocomplete="off">
                            <datalist id="ReceivePersonList">
                                @foreach (var employee in slnRhonline.Data.Employee.GetAllEmployees2())
                                {
                                    <option data-value="@employee.CEDULA" value="@employee.NOMBRE_COMPLETO">@employee.NOMBRE_COMPLETO</option>
                                }
                            </datalist>
                            <input type="hidden" id="ReceivePersonIdHidden" name="ReceivePersonId">

                        </div>
                        <div class="form-group col-md-6">
                            <label for="conductoresInput">Conductores</label>
                            <input list="ConductoresList" class="form-control" id="conductoresInput" placeholder="Buscar conductor..." onblur="agregarConductorFromDatalist()" autocomplete="off">
                            <datalist id="ConductoresList">
                                @foreach (var employee in slnRhonline.Data.Employee.GetAllEmployees2())
                                {
                                    <option value="@employee.NOMBRE_COMPLETO @employee.CARNET" data-value="@employee.CEDULA"></option>
                                }
                            </datalist>
                            <div id="conductoresContainer" style="margin-top:5px;"></div>
                            <input type="hidden" id="conductoresHidden" name="Conductores">
                        </div>
                    </div>
                    <!-- 2. Departamento y Edificio -->
                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label for="departamento">Departamento</label>
                            <input type="text" id="departamento" list="listaDepartamentos" class="form-control" autocomplete="off" placeholder="Seleccione Departamento">
                            <datalist id="listaDepartamentos">
                                <!-- Se llenará dinámicamente -->
                            </datalist>
                        </div>
                        <div class="form-group col-md-6">
                            <label for="edificio">Edificio</label>
                            <input type="text" id="edificio" list="listaEdificios" class="form-control" autocomplete="off" placeholder="Seleccione Edificio">
                            <datalist id="listaEdificios">
                                <!-- Se llenará dinámicamente según el departamento seleccionado -->
                            </datalist>
                        </div>
                    </div>

                    <!-- 3. Domicilio y Teléfono -->
                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label>Lugar de estacionamiento</label>
                            <input type="text" autocomplete="off" id="domicilio" class="form-control" placeholder="Domicilio">
                        </div>
                        <div class="form-group col-md-6">
                            <label for="telefono">Teléfono</label>
                            <input type="text" autocomplete="off"
                                   id="telefono"
                                   class="form-control"
                                   placeholder="Teléfono"
                                   required
                                   maxlength="8"
                                   pattern="^[578][0-9]{7}$"
                                   oninput="this.value = this.value.replace(/[^0-9]/g, '')">
                        </div>
                    </div>
                    <!-- 4. Kilometraje y Prueba de Manejo -->
                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label for="kilometraje">Kilometraje</label>
                            <input type="number" id="kilometraje" autocomplete="off" class="form-control" placeholder="Kilometraje" min="0" oninput="if(this.value.length>8){this.value = this.value.slice(0,8);}">
                        </div>
                        <div class="form-group col-md-6">
                            <label>Prueba de Manejo</label>
                            <div class="custom-control custom-checkbox">
                                <input type="checkbox" class="custom-control-input" id="pruebaManejo">
                                <label class="custom-control-label" for="pruebaManejo">Confirmar si realizó prueba de manejo</label>
                            </div>
                        </div>
                    </div>
                    <!-- 5. Fotos de Licencia -->
                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label>Foto Licencia Frontal</label>
                            <input type="file" id="inputLicenciaFrontal" class="form-control-file" accept="image/*">
                            <div id="vistaLicenciaFrontal" class="mt-2 border" style="height: 200px; display:flex; align-items:center; justify-content:center;">
                                <span class="text-muted">Sin vista previa</span>
                            </div>
                        </div>
                        <div class="form-group col-md-6">
                            <label>Foto Licencia Posterior</label>
                            <input type="file" id="inputLicenciaPosterior" class="form-control-file" accept="image/*">
                            <div id="vistaLicenciaPosterior" class="mt-2 border" style="height: 200px; display:flex; align-items:center; justify-content:center;">
                                <span class="text-muted">Sin vista previa</span>
                            </div>
                        </div>
                    </div>
                    <!-- 6. Fotos de Inspección -->
                    <div class="form-group">
                        <label>Fotos de Inspección</label>
                        <div id="fotosGrid" class="row">
                            <div class="col-md-4 text-center mb-3">
                                <p>Frontal</p>
                                <div id="preview-Frontal" class="border" style="height: 100px; display:flex; align-items:center; justify-content:center; cursor:pointer;" data-parte="Frontal">
                                    <span class="text-muted">Sin foto</span>
                                </div>
                            </div>
                            <div class="col-md-4 text-center mb-3">
                                <p>Tablero</p>
                                <div id="preview-Tablero" class="border" style="height: 100px; display:flex; align-items:center; justify-content:center; cursor:pointer;" data-parte="Tablero">
                                    <span class="text-muted">Sin foto</span>
                                </div>
                            </div>
                            <div class="col-md-4 text-center mb-3">
                                <p>Lateral Izquierdo</p>
                                <div id="preview-LateralIzquierdo" class="border" style="height: 100px; display:flex; align-items:center; justify-content:center; cursor:pointer;" data-parte="Lateral Izquierdo">
                                    <span class="text-muted">Sin foto</span>
                                </div>
                            </div>
                            <div class="col-md-4 text-center mb-3">
                                <p>Lateral Derecho</p>
                                <div id="preview-LateralDerecho" class="border" style="height: 100px; display:flex; align-items:center; justify-content:center; cursor:pointer;" data-parte="Lateral Derecho">
                                    <span class="text-muted">Sin foto</span>
                                </div>
                            </div>
                            <div class="col-md-4 text-center mb-3">
                                <p>Trasero</p>
                                <div id="preview-Trasero" class="border" style="height: 100px; display:flex; align-items:center; justify-content:center; cursor:pointer;" data-parte="Trasero">
                                    <span class="text-muted">Sin foto</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button id="btnGuardarInspeccion" type="button" class="btn btn-primary">Guardar</button>
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
