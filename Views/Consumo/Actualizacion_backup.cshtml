            $("#vistaLicenciaPosterior").html("<span class='text-muted'>Sin vista previa</span>");
            $("#fotosGrid div[id^='preview-']").html("<span class='text-muted'>Sin foto</span>");
            $("#conductoresContainer").empty();
            $("#conductoresHidden").val("");
            $("#conductoresInput").val("");
            imagenes = {};

            // Habilitar controles y mostrar botón Guardar
