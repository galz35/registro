                <!-- Conductores en chips -->
                <div class="mb-4">
                    <h6 class="text-muted mb-2"><i class="fas fa-users mr-1"></i>Conductores</h6>
                    <div id="viewConductores" class="d-flex flex-wrap border rounded p-2" style="min-height:42px;">
                        <!-- chips -->
                    </div>
                </div>

                <!-- Licencias (siempre visibles) -->
                <div class="row mb-4">
                    <div class="col-md-6 mb-3">
                        <div class="card h-100">
                            <div class="card-header py-1 bg-info text-white text-center">Licencia Frontal</div>
                            <div id="viewLicenciaFrontal" class="h-100 d-flex align-items-center justify-content-center p-2">
                                <span class="text-muted">Sin foto</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="card h-100">
                            <div class="card-header py-1 bg-info text-white text-center">Licencia Posterior</div>
                            <div id="viewLicenciaPosterior" class="h-100 d-flex align-items-center justify-content-center p-2">
                                <span class="text-muted">Sin foto</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Fotos vehículo (grid 5) -->
                <h6 class="text-muted mb-2"><i class="fas fa-camera mr-1"></i>Fotos del Vehículo</h6>
                <div class="row" id="viewExtraFotos"></div>

            </div>

            <!-- FOOTER -->
            <div class="modal-footer">
                @if (emp.GERENCIA.Contains("SUBGERENCIA DE RECURSOS HUMANOS") || emp.SUBGERENCIA.Contains("SUBGERENCIA DE RECURSOS HUMANOS"))
                {
                    <button id="btnValidar" class="btn btn-success"><i class="fas fa-check mr-1"></i>Aprobar</button>
                    <button id="btnValidardenegarInspeccion" class="btn btn-danger"><i class="fas fa-times mr-1"></i>Denegar</button>
                }
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    <i class="fas fa-times-circle mr-1"></i>Cerrar
                </button>
            </div>
        </div>
    </div>
</div>
<div id="modalDenegarInspeccion" class="modal fade" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-danger">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="fas fa-times"></i> Denegar Inspección
                </h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <label for="motivoDenegacion" class="font-weight-bold">Motivo de Denegación:</label>
                <textarea id="motivoDenegacion" class="form-control" rows="4"
                          placeholder="Escriba el comentario o motivo..."></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    <i class="fas fa-times"></i> Cancelar
                </button>
                <button id="btnConfirmarDenegar" class="btn btn-danger">
                    <i class="fas fa-ban"></i> Denegar
                </button>
            </div>
        </div>
    </div>
</div>

