        // Asignar el valor seleccionado del datalist para "Quien tiene asignada"
        function OnSelectedReceivePersonChanged() {
            var input = $("#ReceivePersonIdDisplay");
            var selectedText = input.val().trim().toLowerCase();

            var match = $("#ReceivePersonList option").filter(function () {
                return $(this).val().trim().toLowerCase() === selectedText;
            }).first();

            if (match.length > 0) {
                var cedula = match.data("value"); // obtenés la cédula desde data-value
                $("#ReceivePersonIdHidden").val(cedula);
                input.removeClass("is-invalid").removeAttr("title");
            } else {
                $("#ReceivePersonIdHidden").val("");
                input.val("").addClass("is-invalid")
                    .attr("title", "Seleccione una opción válida de la lista")
                    .tooltip({ trigger: "manual" }).tooltip("show");

                setTimeout(function () {
                    input.tooltip("hide");
                }, 2500);
            }
        }




        // Agregar conductor desde el input con datalist
        function agregarConductorFromDatalist() {
            var input = $("#conductoresInput");
            var selectedText = input.val().trim().toLowerCase();

            var match = $("#ConductoresList option").filter(function () {
                return $(this).val().trim().toLowerCase() === selectedText;
            }).first();

            if (match.length > 0) {
                var cedula = match.data("value");
                if (cedula && !existeConductor(cedula)) {
                    agregarConductor(cedula, match.val()); // muestra nombre + carnet
                }
            } else {
                // Si no hay coincidencia, marcar en rojo y mostrar tooltip
                input.addClass("is-invalid")
                    .attr("title", "Seleccione un conductor válido").tooltip({ trigger: "manual" }).tooltip("show");

                setTimeout(() => input.tooltip("hide").removeClass("is-invalid"), 2500);
            }

            input.val("");
        }

        // Verificar si el conductor ya fue agregado
        function existeConductor(value) {
            var exists = false;
            $("#conductoresContainer span").each(function () {
                if ($(this).data("value") === value) {
                    exists = true;
                    return false;
                }
            });
            return exists;
        }

        // Agregar chip de conductor en el contenedor
        function agregarConductor(value, label) {
            var chip = $('<span class="badge badge-info mr-1 mb-1" style="cursor:pointer;">' + label + ' <i class="fas fa-times"></i></span>');
            chip.data("value", value);
            chip.click(function () {
                $(this).remove();
                actualizarConductoresHidden();
            });
            $("#conductoresContainer").append(chip);
            actualizarConductoresHidden();
        }

        // Actualizar el campo hidden de conductores con los valores seleccionados
        function actualizarConductoresHidden() {
            var arr = [];
            $("#conductoresContainer span").each(function () {
                arr.push($(this).data("value"));
            });
            $("#conductoresHidden").val(arr.join(","));
        }
