            $(".modal-title").text("Actualización de Datos");

            $("#actualizacionModal").modal("show").on("shown.bs.modal", function () {
                $("#ReceivePersonIdDisplay").focus();
            });
        }
        // Función para abrir el modal en modo edición (carga datos existentes en el formulario)
       function cargarFotosExtrasPorParte(idInspeccion) {
  const fotos = [];
  // tomar licencias ya cargadas
  const f1 = $("#viewLicenciaFrontal img").attr("src");
  const f2 = $("#viewLicenciaPosterior img").attr("src");
  fotos.push({ label: "Licencia Frontal", src: f1 });
  fotos.push({ label: "Licencia Posterior", src: f2 });

  const partes = ["Frontal", "Tablero", "LateralIzquierdo", "LateralDerecho", "Trasero"];
  let idx = 0;

  function next() {
    if (idx >= partes.length) {
      // renderizar carrusel
      const $ind = $("#carouselIndicators").empty();
      const $inn = $("#carouselInner").empty();
      fotos.forEach((f, i) => {
        $ind.append(`<li data-target="#photoCarousel" data-slide-to="${i}"${i===0?" class='active'":""}></li>`);
        $inn.append(`
          <div class="carousel-item${i===0?" active":""}">
            <img src="${f.src||''}" alt="${f.label}" class="d-block w-100"/>
            <div class="carousel-caption d-none d-md-block"><h5>${f.label}</h5></div>
          </div>`);
      });
      $.LoadingOverlay("hide");
      $("#visualizacionModal").modal("show");
      return;
    }
    const parte = partes[idx++];
    $.ajax({
      url: '@Url.Action("ObtenerFotoPorParte2025", "Consumo")',
      type: "GET",
