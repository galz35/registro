        function abrirPopup(modo, idVehiculo) {
            // Reiniciar formulario, previews y variables globales
            $("#idVehiculo").val(idVehiculo);
            $("#formInspeccion")[0].reset();
            $("#vistaLicenciaFrontal").html("<span class='text-muted'>Sin vista previa</span>");
            $("#vistaLicenciaPosterior").html("<span class='text-muted'>Sin vista previa</span>");
            $("#fotosGrid div[id^='preview-']").html("<span class='text-muted'>Sin foto</span>");
            $("#conductoresContainer").empty();
            $("#conductoresHidden").val("");
            $("#conductoresInput").val("");
            imagenes = {};

            if (modo === "editar") {
                // Habilitar todos los campos y mostrar el botón Guardar
                $("#formInspeccion").find("input, select, textarea").prop("disabled", false);
                $("#btnGuardarInspeccion").show();
                $(".modal-title").text("Actualización de Datos");
            } else if (modo === "visualizar") {
                // Deshabilitar todos los campos y ocultar el botón Guardar
                $("#formInspeccion").find("input, select, textarea").prop("disabled", true);
                $("#btnGuardarInspeccion").hide();
                $(".modal-title").text("Visualización de Inspección");
            }

            $("#actualizacionModal").modal("show").on("shown.bs.modal", function () {
                $("#ReceivePersonIdDisplay").focus();
            });
        }

        // Función para abrir el popup en modo edición (registro)
        function abrirPopupActualizacion(idVehiculo) {
        //    abrirPopup("editar", idVehiculo);
            $("#idVehiculo").val(idVehiculo);
