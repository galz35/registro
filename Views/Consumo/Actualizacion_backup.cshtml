function cargarFotosExtrasPorPartew(idInspeccion){
  const partes=["Frontal","Tablero","LateralIzquierdo","LateralDerecho","Trasero"];
  let html=""; let index=0;
  const next=()=>{
    if(index>=partes.length){
        $("#viewExtraFotos").html(html);
        $("#viewExtraFotos img, #viewLicenciaFrontal img, #viewLicenciaPosterior img").addClass("zoomable-img").off("click").on("click", function () {
            $("#imagenAmpliada").attr("src", $(this).attr("src"));
            $("#modalImagenGrande").modal("show");
        });
      $.LoadingOverlay("hide"); $("#visualizacionModal").modal("show"); return;
    }
    const parte=partes[index++];
    $.get('@Url.Action("ObtenerFotoPorParte2025","Consumo")',{idInspeccion,parte},res=>{
      html+=`
        <div class="col-sm-6 col-md-4 mb-3">
          <div class="card h-100 shadow-sm">
            <div class="card-header py-1 text-center">${parte}</div>
            <div class="card-body p-1 d-flex align-items-center justify-content-center">
              ${res.success && res.base64 ? `<img src="${res.base64}" class="img-fluid">` : "<span class='text-muted'>Sin foto</span>"}
            </div>
          </div>
        </div>`;
    },"json").always(next);
  };
  next();
}


 function abrirPopupEdicion(idVehiculo) {
    $.LoadingOverlay("show");

    $.ajax({
        url: '@Url.Action("ObtenerInspeccionDatos2025", "Consumo")',
        type: "GET",
        data: { idVehiculo: idVehiculo },
        dataType: "json",
        success: function (response) {
            if (response.success) {
                const data = response.data;
                $("#idVehiculo").val(data.IdVehiculo);
                $("#kilometraje").val(data.Kilometraje);
                $("#ReceivePersonIdDisplay").val(data.AsignadaA);
                $("#domicilio").val(data.Domicilio);
                $("#telefono").val(data.Telefono);
                $("#departamento").val(data.Departamento).trigger("change");
                $("#edificio").val(data.Edificio);

                $("#conductoresContainer").empty();
                $("#conductoresHidden").val("");
                if (data.ConductoresDetalle && data.ConductoresDetalle.length > 0) {
                    data.ConductoresDetalle.forEach(function (item) {
                        agregarConductor(item.CEDULA, item.NOMBRE_COMPLETO);
                    });
                }

                $(".modal-title").text("Edición de Datos");
                $("#btnGuardarInspeccion").off("click").on("click", function () {
                    editarRegistro(data.IdInspeccion);
                });

                // Control de carga: 1 para licencia + 5 partes = 6 cargas
                const partes = ["Frontal", "Tablero", "LateralIzquierdo", "LateralDerecho", "Trasero"];
                let totalCargas = 1 + partes.length;
                let cargasCompletadas = 0;

                function verificarFinCarga() {
                    cargasCompletadas++;
                    if (cargasCompletadas === totalCargas) {
                        $.LoadingOverlay("hide");
                        $("#actualizacionModal").modal("show");
                    }
                }

                // 1. Licencias
                $.ajax({
                    url: '@Url.Action("ObtenerLicenciaImagenes2025", "Consumo")',
                    type: "GET",
                    data: { idInspeccion: data.IdInspeccion },
                    dataType: "json",
                    success: function (resLic) {
                        if (resLic.success) {
                            if (resLic.frontal)
                                $("#vistaLicenciaFrontal").html("<img src='" + resLic.frontal + "' class='img-fluid' style='object-fit:cover; width:100%; height:100%;' />");
                            if (resLic.posterior)
                                $("#vistaLicenciaPosterior").html("<img src='" + resLic.posterior + "' class='img-fluid' style='object-fit:cover; width:100%; height:100%;' />");

                            imagenes["LicenciaFrontal"] = resLic.frontal;
                            imagenes["LicenciaPosterior"] = resLic.posterior;
                        }
                    },
                    complete: verificarFinCarga
                });

                // 2. Fotos por parte
                partes.forEach(function (parte) {
                    $.ajax({
                        url: '@Url.Action("ObtenerFotoPorParte2025", "Consumo")',
                        type: "GET",
                        data: { idInspeccion: data.IdInspeccion, parte: parte },
                        dataType: "json",
                        success: function (res) {
                            var idPreview = "preview-" + parte.replace(/\s/g, "");
                            if (res.success && res.base64) {
                                $("#" + idPreview).html("<img src='" + res.base64 + "' style='width:100%; height:100%; object-fit:cover;' />");
                                imagenes[parte] = res.base64;
                            } else {
                                $("#" + idPreview).html("<span class='text-muted'>Sin foto</span>");
                                imagenes[parte] = null;
                            }
                        },
                        complete: verificarFinCarga
                    });
                });
            } else {
                $.LoadingOverlay("hide");
                Swal.fire("Error", response.message, "error");
            }
        },
        error: function () {
            $.LoadingOverlay("hide");
            Swal.fire("Error", "Error al cargar datos.", "error");
        }
    });
}
