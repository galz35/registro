@{
    string url = Url.Action("CarsList", "Consumo");
    string url2 = Url.Action("Index", "Home");
}
<div class="breadcrumb-container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="@url2">
                    <span class="breadcrumb-box">
                        <i class="fas fa-home"></i> Home
                    </span>
                </a>
            </li>
            <li class="breadcrumb-item ">
                <a href="@url">
                    <span class="breadcrumb-box">
                        <i class="fas fa-users"></i> Lista unidad
                    </span>
                </a>
            </li>
            <li class="breadcrumb-item active">
                <a href="javascript:void(0);" onclick="location.reload();">
                    <span class="breadcrumb-box">
                        <i class="fas fa-burn"></i> Lista consumor
                    </span>
                </a>
            </li>
        </ol>
    </nav>
</div>
<div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
        <div class="container-fluid">

            <!-- Page Heading -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="m-0 font-weight-bold text-primary" style="color: #800 !important;">Lista</h5>

                        <div class="d-flex ms-auto">
                            <!-- Contenedor para los botones alineados a la izquierda -->
                            <a href="#" id="mostrarPopupBtn" onclick="cargarYMostrarPopup()" class="btn btn-primary btn-icon-split me-2">
                                <span class="icon text-white-50">
                                    <i class="fas fa-plus"></i>
                                </span>
                                <span class="text">Registrar Nuevo</span>
                            </a>
                            @*<a href="#" id="mostrarPopupBtn" onclick="VerDetalleEstados2()" class="btn btn-primary btn-icon-split">
                                <span class="icon text-white-50">
                                    <i class="fas fa-plus"></i>
                                </span>
                                <span class="text">Registrar voucher</span>
                            </a>*@
                        </div>
                    </div>
                </div>


                <div class="card-body p-3">

                    <table id="listTable" style="width:100%"
                           class="table table-striped  table-bordered table-hover display responsive nowrap">
                        <thead>
                            <tr>
                                <th>Acciones</th>
                                <th>Fecha Registro</th>
                                <th># Referencia</th>
                                <th>Unidad</th>
                                <th>Proveedor</th>

                                <th>Cantidad(lts)</th>
                                <th>Valor C$</th>
                                <th>Estado</th>

                            </tr>
                        </thead>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>
<div class="modal fade" id="voucherModal" tabindex="-1" role="dialog" aria-labelledby="voucherModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <!-- Cabecera del Modal -->
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="voucherModalLabel"><i class="fas fa-file-alt mr-2"></i> Escanear Vouchers</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <!-- Cuerpo del Modal -->
            <div class="modal-body">
                <!-- Formulario para seleccionar archivos -->
                <form id="voucherForm" enctype="multipart/form-data">
                    <div class="form-group">
                        <label for="voucherFile">Seleccione imágenes de vouchers:</label>
                        <!-- Input para seleccionar múltiples archivos de imagen -->
                        <input type="file" class="form-control-file" id="voucherFile" name="files" multiple onchange="previewImages(event)">
                        <!-- Advertencia sobre los requisitos de las imágenes -->
                        <h6 class="text-warning mt-2">
                            Advertencia: Use solo vouchers donde el texto sea claro y legible. Evite fondos con letras adicionales o elementos como papel, teclado o cualquier texto que no sea del voucher.
                        </h6>
                    </div>
                </form>

                <!-- Contenedor para previsualizar las imágenes seleccionadas -->
                <div class="text-center my-3">
                    <div id="imagePreviewContainer" class="d-flex flex-wrap justify-content-center"></div>
                </div>

                <!-- Contenedor para mostrar el estado del procesamiento -->
                <div id="loading" style="display:none;" class="text-left">
                    <h5>Estado del Procesamiento:</h5>
                    <ul id="processingStatus" class="list-group">
                        <!-- Los mensajes de estado se añadirán aquí dinámicamente -->
                    </ul>
                </div>
            </div>

            <!-- Pie del Modal -->
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    <i class="fas fa-times"></i> Cerrar
                </button>
                <button type="button" class="btn btn-primary" id="uploadVoucherBtn">
                    <i class="fas fa-upload"></i> Subir y Procesar
                </button>
            </div>
        </div>
    </div>
</div>



<div id="popConsumo">
    @using (Html.BeginForm("GuardarConsumo", "Consumo", FormMethod.Post, new { id = "frmEditConsumo" }))
    {


        @Html.DevExpress().PopupControl(settings =>
   {
       settings.Theme = "Mulberry";
       settings.Name = "popEditarConsumo";
       settings.HeaderText = "Edición de consumo";
       settings.SettingsAdaptivity.MaxWidth = Unit.Pixel(700);
       settings.SettingsAdaptivity.Mode = PopupControlAdaptivityMode.Always;
       settings.SettingsAdaptivity.VerticalAlign = PopupAdaptiveVerticalAlign.WindowCenter;
       settings.ShowOnPageLoad = false;
       settings.CloseAction = CloseAction.CloseButton;
       settings.CloseOnEscape = true;
       settings.AllowDragging = false;
       settings.ResizingMode = ResizingMode.Postponed;
       settings.ScrollBars = ScrollBars.Auto;
       settings.ShowFooter = true;
       settings.PopupHorizontalAlign = PopupHorizontalAlign.WindowCenter;
       settings.PopupVerticalAlign = PopupVerticalAlign.WindowCenter;
       settings.Styles.Content.Paddings.Padding = 0;
       settings.Styles.Content.Paddings.PaddingTop = 12;
       settings.Modal = true;
       //settings.ClientSideEvents.PopUp = "OnPopupInit";

       settings.SetFooterTemplateContent(c =>
       {
           @Html.DevExpress().FormLayout(formLayoutsettings =>
           {
               formLayoutsettings.Name = "footerFormLayout";
               formLayoutsettings.Width = Unit.Percentage(100);
               formLayoutsettings.ControlStyle.CssClass = "clearPaddings";
               formLayoutsettings.Styles.LayoutItem.CssClass = "clearPaddings";
               formLayoutsettings.Styles.LayoutGroup.CssClass = "clearPaddings";
               formLayoutsettings.Items.AddGroupItem(g =>
               {
                   g.GroupBoxDecoration = GroupBoxDecoration.None;
                   g.Paddings.Padding = Unit.Pixel(0);
                   g.Items.Add(i =>
                   {
                       i.ShowCaption = DefaultBoolean.False;
                   }).SetNestedContent(() =>
                   {
                       ViewContext.Writer.Write("<div class='buttonsContainer'>");
                       Html.DevExpress().Button(s =>
                       {
                           s.Name = "btnAceptar";
                           s.Width = Unit.Pixel(100);
                           s.ControlStyle.CssClass = "submitButton";

                           //s.RenderMode = ButtonRenderMode.Link;
                           s.Text = "Aceptar";
                           s.UseSubmitBehavior = false;
                           s.ClientSideEvents.Click = "function(s, e) { GuardarConsumo2(); }";
                       }).Render();
                       Html.DevExpress().Button(s =>
                       {
                           s.Name = "btnCancelar";
                           s.Width = Unit.Pixel(100);
                           s.ControlStyle.CssClass = "cancelButton";
                           s.RenderMode = ButtonRenderMode.Danger;
                           s.Text = "Cancelar";
                           s.UseSubmitBehavior = false;
                           s.ClientSideEvents.Click = "function(s, e){ popEditarConsumo.Hide(); }";
                       }).Render();
                       ViewContext.Writer.Write("</div>");
                   });
               });
           }).Render();
       });

       settings.SetContent(() =>
       {




           @Html.DevExpress().FormLayout(s =>
           {
               s.SettingsAdaptivity.AdaptivityMode = FormLayoutAdaptivityMode.SingleColumnWindowLimit;
               s.SettingsAdaptivity.SwitchToSingleColumnAtWindowInnerWidth = 600;
               s.Name = "frmEditVoucher";
               s.RequiredMarkDisplayMode = RequiredMarkMode.None;
               s.Width = Unit.Percentage(100);

               s.ColumnCount = 2;

               s.Items.Add(i =>
               {
                   i.Name = "IdCombustibleConsumoClaro";
                   i.Caption = "IdCombustibleConsumoClaro";
                   i.ClientVisible = false;
                   i.NestedExtensionType = FormLayoutNestedExtensionItemType.TextBox;
                   i.Width = Unit.Percentage(100);
               });

               s.Items.Add(i =>
               {
                   i.Name = "FechaRegistro";
                   i.Caption = "Fecha";
                   i.NestedExtensionType = FormLayoutNestedExtensionItemType.DateEdit;

               });

               s.Items.Add(i =>
               {
                   i.FieldName = "IdUnidad";
                   i.Caption = "Unidad";
                   i.NestedExtension().ComboBox(c =>
                   {
                       //s.CallbackRouteValues = new { Controller = "ExtraPlan", Action = "GetAssigmnentCarsByManagement", TextField = "IdUnidad", ValueField = "IdUnidad" };
                       c.Properties.TextField = "IdUnidad";
                       c.Properties.ValueField = "IdUnidad";
                       c.Properties.ValueType = typeof(string);
                       //s.Properties.LoadDropDownOnDemand = true;
                       c.Properties.DropDownStyle = DropDownStyle.DropDownList;
                       c.Properties.IncrementalFilteringMode = IncrementalFilteringMode.Contains;
                       c.Properties.ValidationSettings.ErrorDisplayMode = ErrorDisplayMode.ImageWithTooltip;
                       c.Properties.ValidationSettings.Display = Display.Dynamic;
                       c.ShowModelErrors = true;
                       c.Width = Unit.Percentage(100);
                       c.Properties.DataSource = slnRhonline.Data.Consumo.ObtenerListaUnidades(string.Empty);
                       c.Properties.Columns.Add("IdUnidad", "Unidad", 50);
                       c.Properties.Columns.Add("Saldo", "Saldo", 50);



                   });
               });


               s.Items.Add(i =>
               {
                   i.Name = "IdVoucher";
                   i.Caption = "No.Referencia";
                   i.NestedExtensionType = FormLayoutNestedExtensionItemType.TextBox;
               });
               s.Items.Add(i =>
               {
                   i.Name = "CantidadLitros";
                   i.Caption = "Litros";
                   i.NestedExtensionType = FormLayoutNestedExtensionItemType.SpinEdit;
               });
               s.Items.Add(i =>
               {
                   i.Name = "ValorCordobas";
                   i.Caption = "Monto";
                   i.NestedExtensionType = FormLayoutNestedExtensionItemType.SpinEdit;
               });
               s.Items.Add(i =>
               {
                   i.Name = "OdometroInicial";
                   i.Caption = "Odometro";
                   i.NestedExtensionType = FormLayoutNestedExtensionItemType.SpinEdit;
               });


               s.Items.Add(i =>
               {
                   i.FieldName = "IdTipoCombustible";
                   i.Caption = "Combustible";
                   i.NestedExtension().ComboBox(c =>
                   {
                       //s.CallbackRouteValues = new { Controller = "ExtraPlan", Action = "GetAssigmnentCarsByManagement", TextField = "IdUnidad", ValueField = "IdUnidad" };
                       c.Properties.TextField = "Descripcion";
                       c.Properties.ValueField = "IdCatalogo";
                       c.Properties.ValueType = typeof(string);
                       //s.Properties.LoadDropDownOnDemand = true;
                       c.Properties.DropDownStyle = DropDownStyle.DropDownList;
                       c.Properties.IncrementalFilteringMode = IncrementalFilteringMode.Contains;
                       c.Properties.ValidationSettings.ErrorDisplayMode = ErrorDisplayMode.ImageWithTooltip;
                       c.Properties.ValidationSettings.Display = Display.Dynamic;
                       c.ShowModelErrors = true;
                       c.Width = Unit.Percentage(100);
                       c.Properties.DataSource = slnRhonline.Data.CatalogoSiaf.GetGasById("07"); ;




                   });
               });
               s.Items.Add(i =>
               {
                   i.Name = "Estacion";
                   i.Caption = "Estación";
                   i.NestedExtensionType = FormLayoutNestedExtensionItemType.TextBox;
               });

               s.Items.Add(i =>
               {
                   i.Name = "Municipio";
                   i.Caption = "Municipio";
                   i.NestedExtensionType = FormLayoutNestedExtensionItemType.TextBox;
               });

               s.Items.Add(i =>
               {
                   i.FieldName = "IdDepartamento";
                   i.Caption = "Departamento";
                   i.NestedExtension().ComboBox(c =>
                   {
                       c.Properties.TextField = "Descripcion";
                       c.Properties.ValueField = "IdCatalogo";
                       c.Properties.ValueType = typeof(string);
                       c.Properties.DataSource = slnRhonline.Data.CatalogoSiaf.GetDepartmentById("02");
                       c.Properties.ValidationSettings.ErrorDisplayMode = ErrorDisplayMode.ImageWithTooltip;
                       c.Properties.ValidationSettings.Display = Display.Dynamic;
                       c.ShowModelErrors = true;
                       c.Width = Unit.Percentage(100);
                       c.Properties.DropDownStyle = DropDownStyle.DropDownList;


                   });
               });

           }).Render();



       });



       settings.ClientSideEvents.CloseUp = "function(s, e){ ASPxClientEdit.ClearEditorsInContainer(null, '', true); }";

   }).GetHtml()

    }

</div>

