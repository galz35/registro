                 p.EnableTheming = false;

                 p.Images.Image.Url = Url.Content("~/Content/Icons/Edit.png");
                 p.ImagePosition = ImagePosition.Left;
                 p.ToolTip = "Editar registro";

                 p.ClientSideEvents.Click = string.Format("function(s,e) {{ShowEditExtraPlan(s.name,'{0}'); }}", Url.Action("EditExtraPlan", "Consumo", new { idExtraPlan = (tc as GridViewDataItemTemplateContainer).KeyValue }));


             }).GetHtml()
