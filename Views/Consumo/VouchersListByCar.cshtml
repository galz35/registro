function AdjustSize() {
    var height = document.documentElement.clientHeight;
    gvVouchers.SetHeight(height - 150);

}
function NuevoConsumo(s, e) {

    var unidad = $('#unidad').html().trim();  // //document.getElementById("unidad").innerHTML;
    var defaultDate = new Date();
    FechaRegistro.SetValue(defaultDate);
    IdUnidad.SetValue(unidad);
    //IdUnidad.SetValue(unidad.trim());
    IdCombustibleConsumoClaro.SetValue(-1);
    popEditarConsumo.Show();

}
        function EditarConsumo(dato) {
             var key = dato;
    $.ajax({

        url: '@Url.Action("EditarConsumoPorUnidad")',
        type: "GET",
        data: { idCombustibleConsumo: key },
        contentType: "application/json; charset=utf-8",
        dataType: "Json",
        traditional: true,
        beforeSend: function () {//We add this before send to disable the button once we submit it so that we prevent the multiple click
            $.LoadingOverlay("show");
        },
        success: function (result) {
            $.LoadingOverlay("hide");
            if (result.status != "Error") {
                var jsonDate = result.data.FechaRegistro;
                var normalDate = new Date(parseInt(jsonDate.replace("/Date(", "").replace(")/")));
                IdCombustibleConsumoClaro.SetValue(key);
                IdVoucher.SetValue(result.data.IdVoucher);
                FechaRegistro.SetValue(normalDate);
                IdUnidad.SetValue(result.data.IdUnidad);
                CantidadLitros.SetValue(result.data.CantidadLitros);
                ValorCordobas.SetValue(result.data.ValorCordobas);
                IdDepartamento.SetValue(result.data.IdDepartamento);
                OdometroInicial.SetValue(result.data.OdometroInicial);
                IdTipoCombustible.SetValue(result.data.IdTipoCombustible);
                Estacion.SetValue(result.data.Estacion);
                Municipio.SetValue(result.data.Municipio);
                //Habilitar Controles
                HabilitarControles();
                //Mostrar popup
                popEditarConsumo.Show();
            } else {
                swal.fire("Advertencia!", result.data, "warning");
            }
       },
        error: function (result) {
            $.LoadingOverlay("hide");
            swal.fire("Error", "Ha ocurrido un error en la transaccion", "error");
        }
    });
}
function HabilitarControles() {
    IdVoucher.SetReadOnly(false);
    FechaRegistro.SetReadOnly(false);
    IdUnidad.SetReadOnly(true);
    CantidadLitros.SetReadOnly(false);
    ValorCordobas.SetReadOnly(false);
    IdDepartamento.SetReadOnly(false);
    Municipio.SetReadOnly(false);
    OdometroInicial.SetReadOnly(false);
    IdTipoCombustible.SetReadOnly(false);
    Estacion.SetReadOnly(false);

    btnAceptar.SetEnabled(true);
    btnCancelar.SetEnabled(true);
}
function InhabilitarControles() {
    IdVoucher.SetReadOnly(true);
    FechaRegistro.SetReadOnly(true);
    IdUnidad.SetReadOnly(true);
    CantidadLitros.SetReadOnly(true);
    ValorCordobas.SetReadOnly(true);
    IdDepartamento.SetReadOnly(true);
    Municipio.SetReadOnly(true);
    OdometroInicial.SetReadOnly(true);
    IdTipoCombustible.SetReadOnly(true);
    Estacion.SetReadOnly(true);

    btnAceptar.SetEnabled(false);
    btnCancelar.SetEnabled(false);
}

function GuardarConsumo(s, e) {
    var x = document.getElementById("popConsumo");

    $.ajax({
        url: '@Url.Action("GuardarConsumoPorUnidad")',
        type: "POST",
        data: $('#frmEditConsumo').serialize(),
        dataType: "json",
        traditional: true,
        cache: false,
        //contentType: "application/json; charset=utf-8",
        success: function (data) {
            if (data.status != "Error") {
                popEditarConsumo.Hide();
                swal.fire({
                    title: "Exito!",
                    text: data.message,
                    icon: "success",
                    confirmButtonText: "Aceptar",
                })
                    .then((willSaved) => {
                        if (willSaved) {
                            tabla_persona.ajax.reload();
                        }

                    });
            }
            else {
                x.style.display = "none";
                swal.fire({
                    title: "Advertencia!",
                    text: data.message,
                    icon: "warning",
                    confirmButtonText: "Aceptar",
                })
                    .then((willSaved) => {
                        if (willSaved) {
                            x.style.display = "block";

                        }

                    });
            }


        },
        error: function () {
            swal.fire("Error!", "Ocurrió un error en la transaccion, por favor verifique los datos o consulte con el administrador de la plataforma.", "error");
        }
    });
}


