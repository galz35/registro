        function VerDetalleEstados(data) {

            $('#popupContainer').modal('show');

        // Carga los datos JSON utilizando una solicitud AJAX
        $.ajax({
            url: '@Url.Action("ConsumoStateConsultjson", "Consumo")',
            data: { idConsumo: data }, // Reemplaza 'tuIdConsumo' con el valor correcto
            type: 'GET',
            dataType: 'json',
            success: function (data) {
                // Llena la tabla con los datos JSON
                popupTable.clear().rows.add(data.data).draw();
            },
            error: function (error) {
                console.error(error);
            }
        });

}

