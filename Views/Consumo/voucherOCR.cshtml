            $('#voucherFile').on('change', function (event) {
                const files = event.target.files; // Obtiene los archivos seleccionados
                const validTypes = ['image/jpeg', 'image/png', 'image/webp']; // Tipos de archivos permitidos
                const maxSize = 5 * 1024 * 1024; // Tamaño máximo permitido (5MB)
                const maxFiles = 10; // Límite de archivos que se pueden seleccionar

                // Verifica si el número de archivos excede el límite
                if (files.length > maxFiles) {
                    Swal.fire('Error', `No puede seleccionar más de ${maxFiles} archivos.`, 'error');
                    $(this).val(''); // Limpia la selección de archivos
                    $('#imagePreviewContainer').empty(); // Limpia las previsualizaciones
                    return;
                }

                // Itera sobre cada archivo para validar tipo y tamaño
                for (let i = 0; i < files.length; i++) {
                    const file = files[i];
                    if (!validTypes.includes(file.type)) {
                        Swal.fire('Error', `El archivo ${file.name} tiene un tipo no permitido. Solo se permiten archivos JPEG, PNG o WebP.`, 'error');
                        $(this).val(''); // Limpia la selección de archivos
                        $('#imagePreviewContainer').empty(); // Limpia las previsualizaciones
                        return;
                    }
                    if (file.size > maxSize) {
                        Swal.fire('Error', `El archivo ${file.name} excede el tamaño máximo permitido de 5MB.`, 'error');
                        $(this).val(''); // Limpia la selección de archivos
                        $('#imagePreviewContainer').empty(); // Limpia las previsualizaciones
                        return;
                    }
                }

                // Si todos los archivos son válidos, muestra las previsualizaciones
                previewImages(event);
            });

