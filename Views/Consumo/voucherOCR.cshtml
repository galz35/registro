         $(document).ready(function () {
            function parseCustomDate(dateString) {
                if (!dateString || dateString === '0001-01-01T00:00:00') {
                    return 'N/A';
                }

                // Regex para detectar el formato /Date(ticks)/
                var dateRegex = /\/Date\((\d+)\)\//;
                var match = dateString.match(dateRegex);
                if (match) {
                    var milliseconds = parseInt(match[1], 10);
                    var date = moment(milliseconds);
                    if (!date.isValid()) {
                        return 'Fecha inválida';
                    }
                    return date.locale('es').format('LLL'); // Formato legible en español
                }

                // Fallback: Intentar parsear como una cadena de fecha estándar
                var parsedDate = moment(dateString, moment.ISO_8601, true);
                if (!parsedDate.isValid()) {
                    return 'Fecha inválida';
                }
                return parsedDate.locale('es').format('LLL'); // Formato legible en español
            }
