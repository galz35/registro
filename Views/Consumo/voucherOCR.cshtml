         $('#uploadVoucherBtn').click(function () {
    const files = $('#voucherFile')[0].files; // Obtiene los archivos seleccionados

    // Verifica si hay archivos seleccionados
    if (!files.length) {
        Swal.fire('Advertencia', 'No ha seleccionado ningún archivo.', 'warning');
        return;
    }

    let resultados = []; // Array para almacenar los resultados de cada archivo
    let procesados = 0; // Contador de archivos procesados

    // Muestra el overlay de carga y limpia mensajes anteriores
    $('#loading').show();
    $('#processingStatus').empty();
    $.LoadingOverlay("show", {
        image: "",
        text: "Procesando imágenes... 0 de " + files.length
    });
    $('#uploadVoucherBtn').prop('disabled', true); // Deshabilita el botón para evitar múltiples clics

    // Función recursiva para procesar cada archivo uno por uno
    function procesarArchivo(index) {
        // Verifica si todos los archivos han sido procesados
        if (index >= files.length) {
            // Oculta el overlay de carga
            $.LoadingOverlay("hide");
            $('#loading').hide();
            // Muestra un resumen de los resultados
            mostrarResumen(resultados);
            $('#uploadVoucherBtn').prop('disabled', false); // Habilita el botón nuevamente
            return;
        }

        const file = files[index]; // Archivo actual a procesar
        let formData = new FormData();
        formData.append('file', file); // Añade el archivo al FormData

        // Añade un mensaje indicando que se está procesando el archivo
        $('#processingStatus').append(`<li class="list-group-item">Procesando archivo ${index + 1} de ${files.length}: <strong>${file.name}</strong></li>`);

        // Realiza la solicitud AJAX para procesar el archivo
        $.ajax({
            url: '@Url.Action("ProcesarVoucher2025", "Consumo")', // URL de la acción del controlador que procesa el archivo
            type: 'POST',
            data: formData,
            contentType: false, // Indica que no se debe establecer el tipo de contenido
            processData: false, // Indica que no se debe procesar los datos
            success: function (response) {
                // Verifica si la respuesta fue exitosa
                if (response.success) {
                    // Añade el resultado exitoso al array de resultados
                    resultados.push({ archivo: file.name, exito: true, mensaje: 'Procesado correctamente', data: response.data });
                    // Añade un mensaje de éxito en la lista de estado
                    $('#processingStatus').append(`<li class="list-group-item list-group-item-success">Éxito: ${file.name} fue procesado correctamente.</li>`);
                } else {
                    // Añade el resultado con error al array de resultados
                    resultados.push({ archivo: file.name, exito: false, mensaje: response.data });
                    // Añade un mensaje de error en la lista de estado
                    $('#processingStatus').append(`<li class="list-group-item list-group-item-danger">Error: ${file.name} - ${response.data}</li>`);
                }
            },
            error: function () {
                // Añade un resultado de error al array de resultados en caso de fallo en la solicitud
                resultados.push({ archivo: file.name, exito: false, mensaje: 'Error al procesar el archivo.' });
                // Añade un mensaje de error en la lista de estado
                $('#processingStatus').append(`<li class="list-group-item list-group-item-danger">Error: ${file.name} - Error al procesar el archivo.</li>`);
            },
            complete: function () {
                procesados++; // Incrementa el contador de archivos procesados
                // Actualiza el texto del overlay para reflejar el progreso actual
                $.LoadingOverlay("text", "Procesando imágenes... " + procesados + " de " + files.length);
                // Espera 5 segundos antes de procesar el siguiente archivo
                setTimeout(function () {
                    procesarArchivo(index + 1); // Llama a la función para el siguiente archivo
                }, 5000); // 5000 milisegundos = 5 segundos
            }
        });
    }

    // Inicia el procesamiento con el primer archivo (índice 0)
    procesarArchivo(0);
});

            function mostrarResumen(resultados) {
                // Filtra los resultados exitosos y los que tuvieron errores
                let exitos = resultados.filter(r => r.exito);
                let errores = resultados.filter(r => !r.exito);

                let resumenHtml = '<h3>Resumen de la carga</h3>';

                // Añade una sección para los archivos procesados correctamente
                if (exitos.length) {
                    resumenHtml += '<h4>Archivos procesados correctamente:</h4><ul>';
                    exitos.forEach(r => {
                        resumenHtml += `<li>${r.archivo}</li>`;
                    });
                    resumenHtml += '</ul>';
                }

                // Añade una sección para los archivos que tuvieron errores
                if (errores.length) {
                    resumenHtml += '<h4>Archivos con errores:</h4><ul>';
                    errores.forEach(r => {
                        resumenHtml += `<li>${r.archivo}: ${r.mensaje}</li>`;
                    });
                    resumenHtml += '</ul>';
                }

                // Muestra el resumen utilizando SweetAlert2
                Swal.fire({
                    title: 'Resultados de la carga',
                    html: resumenHtml,
                    icon: 'info',
                    width: '600px',
                    confirmButtonText: 'Aceptar'
                }).then(() => {
                    // Después de cerrar el resumen, limpia el formulario y actualiza la interfaz
                    $('#voucherFile').val(''); // Limpia la selección de archivos
                    $('#imagePreviewContainer').empty(); // Limpia las previsualizaciones de imágenes
                    $('#processingStatus').empty(); // Limpia la lista de estados
                    $('#voucherModal').modal('hide'); // Cierra el modal
                    // Recarga la tabla de datos para reflejar los cambios (asegúrate de tener definida la variable 'tabla_persona')
                    recargarTabla();
                });
            }         // Ejemplo de evento que carga y muestra el PopupControl (vincúlalo a un botón u otro elemento)

      });
