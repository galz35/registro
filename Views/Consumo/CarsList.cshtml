@model List<Entities.ViewModels.VistaUnidadesConsumo>
@{
    ViewBag.Title = "Lista de Unidades";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}

@section scripts {
    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>
    <script src="~/onlinejs/bootstrap.bundle.min.js"></script>
    <script src="~/onlinejs/loadingoverlay.min.js"></script>
    <script src="~/Content/plugin/sweetalert2/sweetalert2.all.js"></script>
    <script src="~/onlinejs/moment.min.js"></script>
    <!-- No se usa autocomplete de jQuery UI para conductores, se usa datalist -->
    <script>
        // Configurar DataTable para la lista de unidades
        var tabla_persona;
        $(document).ready(function () {
            $.LoadingOverlay("show");
            tabla_persona = $('#listTable').DataTable({
                "ajax": {
                    "url": "@Url.Action("CarsListPartialjson", "Consumo")",
                    "type": "GET",
                    "datatype": "json"
                },
                "columns": [
                    {
                        "data": "IdUnidad",
                        "render": function (data) {
                            var url = '@Url.Action("VouchersListByCar", "Consumo", new { idUnidad = "IdUnidad" })';
                            url = url.replace("IdUnidad", data);
                            return `
                                <div class="btn-group">
                                    <button type="button" class="btn btn-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                        <i class="fas fa-cogs"></i> Solicitudes
                                    </button>
                                    <div class="dropdown-menu">
                                        <a class="dropdown-item" href="${url}"><i class="fas fa-gas-pump"></i> Consumo</a>
                                        <a class="dropdown-item" href="${url.replace("VouchersListByCar", "TransfersList")}"><i class="fas fa-exchange-alt"></i> Traslados</a>
                                        <a class="dropdown-item" href="${url.replace("VouchersListByCar", "ExtraPlanList")}"><i class="fas fa-plus-circle"></i> Extra Plan</a>
    <a class="dropdown-item"
   href="javascript:void(0)"
   onclick="abrirDetalleMovimientos('${data}')">
   <i class="fas fa-file-alt"></i> Ver Movimientos
</a>
 
                                    </div>
                                </div>
                            `;
                        },
                        "orderable": true,
                        "searchable": true,
                        "width": "150px"
                    },
                    { "data": "IdUnidad" },
                    { "data": "TotalAsignacion" },
                    { "data": "TotalTraslado" },
                    { "data": "TotalExtraPlan" },
                    { "data": "TotalConsumo" },
                    { "data": "Saldo" },
                    { "data": "NombreEmpleado" },
                    { "data": "NombreArea" }
                ],
                "dom": 'Blfrtip',
                "lengthMenu": [10, 20, 50, 100],
                "pageLength": 10,
                "language": {
                    "url": "@Url.Content("~/Scripts/datatable.es-ES.json")"
                },
                responsive: true,
                initComplete: function () {
                    $('#listTable tbody').on('click', '.dropdown-toggle', function (e) {
                        e.stopPropagation();
                        $(this).siblings('.dropdown-menu').toggleClass('show');
                    });
                    $(document).on('click', function (e) {
                        if (!$('.dropdown-toggle').is(e.target) && $('.dropdown-toggle').has(e.target).length === 0 && $('.show').has(e.target).length === 0) {
                            $('.dropdown-menu').removeClass('show');
                        }
                    });
                }
            });
            $.LoadingOverlay("hide");
        });

        // POPUP: Actualización de Datos (Registro/Edición)
        function abrirPopupActualizacion(idVehiculo) {
            $("#idVehiculo").val(idVehiculo);
            $("#formInspeccion")[0].reset();
            $("#vistaLicencia").html("Sin vista previa");
            $("#fotosGrid div[id^='preview-']").html("Sin foto");
            // Limpiar conductores: vaciar contenedor y hidden
            $("#conductoresContainer").empty();
            $("#conductoresHidden").val("");
            $("#conductoresInput").val("");
            imagenes = {};
            $("#actualizacionModal").modal("show");
        }
        function abrirDetalleMovimientos(idUnidad) {
    $('#detalleModal').modal('show');

    $('#tablaDetalle').DataTable({
        destroy: true,                                  // reinicia la tabla
        ajax: {
            url: '@Url.Action("DetalleMovimientoJson","Consumo")',
            type: 'GET',
            data: { idUnidad: idUnidad },
            datatype: 'json'
        },
        columns: [
            { data: 'Fecha' },
            { data: 'Movimiento' },
            { data: 'Debito',  className: 'text-right' },
            { data: 'Credito', className: 'text-right' },
            { data: 'SaldoCombustible', className: 'text-right' }
        ],
        order: [[0, 'asc']],                           // más antiguo arriba
        language: { url: '@Url.Content("~/Scripts/datatable.es-ES.json")' }
    });
}
        // POPUP: Visualización de Inspección (Solo Lectura)
        function abrirPopupVisualizacion(idVehiculo) {
            $.LoadingOverlay("show");
            $.ajax({
                url: '@Url.Action("ObtenerInspeccion", "Consumo")',
                type: "GET",
                data: { idVehiculo: idVehiculo },
                dataType: "json",
                success: function (response) {
                    $.LoadingOverlay("hide");
                    if (response.success) {
                        $("#viewKilometraje").text(response.data.Kilometraje);
                        $("#viewUbicacion").text(response.data.Ubicacion);
                        $("#viewAsignadaA").text(response.data.AsignadaA);
                        $("#viewConductores").text(response.data.Conductores);
                        $("#viewNombreCompleto").text(response.data.NombreCompleto);
                        $("#viewDomicilio").text(response.data.Domicilio);
                        $("#viewTelefono").text(response.data.Telefono);
                        $("#viewPlantelAsignado").text(response.data.PlantelAsignado);
                        if(response.data.FotoLicenciaBase64)
                            $("#viewLicencia").html("<img src='" + response.data.FotoLicenciaBase64 + "' style='width:100%; height:100%; object-fit:cover;' />");
                        else
                            $("#viewLicencia").html("Sin foto");
                        $("#viewPruebaManejo").text(response.data.PruebaManejo ? "Sí" : "No");
                        for(var parte in response.data.Imagenes){
                            $("#view-" + parte.replace(/\s/g, "")).html("<img src='" + response.data.Imagenes[parte] + "' style='width:100%; height:100%; object-fit:cover;' />");
                        }
                        $("#visualizacionModal").modal("show");
                    } else {
                        Swal.fire("Error", response.message, "error");
                    }
                },
                error: function () {
                    $.LoadingOverlay("hide");
                    Swal.fire("Error", "Ocurrió un error inesperado.", "error");
                }
            });
        }

        // Objeto para almacenar imágenes de inspección
        var imagenes = {};
        var parteActual = null;
        var imagenTemporal = null;

        // Al hacer clic en un contenedor de foto del formulario se abre un input file
        $("#fotosGrid div[data-parte]").click(function () {
            parteActual = $(this).data("parte");
            var input = $("<input type='file' accept='image/*' style='display:none;' />");
            $("body").append(input);
            input.change(function (e) {
                if (e.target.files && e.target.files[0]) {
                    var reader = new FileReader();
                    reader.onload = function (evt) {
                        imagenTemporal = evt.target.result;
                        $("#preview-" + parteActual.replace(/\s/g, "")).html("<img src='" + imagenTemporal + "' style='width:100%; height:100%; object-fit:cover;' />");
                        imagenes[parteActual] = imagenTemporal;
                    };
                    reader.readAsDataURL(e.target.files[0]);
                }
                input.remove();
            });
            input.click();
        });

        // Cargar la foto de licencia y mostrar vista previa
        $("#inputLicencia").change(function (e) {
            if (e.target.files && e.target.files[0]) {
                var reader = new FileReader();
                reader.onload = function (evt) {
                    $("#vistaLicencia").html("<img src='" + evt.target.result + "' style='width:100%; height:100%; object-fit:cover;' />");
                };
                reader.readAsDataURL(e.target.files[0]);
            }
        });

        // Función para asignar el valor seleccionado del datalist para "Quien tiene asignada"
        function OnSelectedReceivePersonChanged() {
            var selectedText = $("#ReceivePersonIdDisplay").val();
            var option = $("#ReceivePersonList option").filter(function() {
                return $(this).text().trim() === selectedText.trim();
            }).first();
            var value = option.data("value") || "";
            $("#ReceivePersonIdHidden").val(value);
        }

        // Función para agregar conductor desde el input con datalist para conductores
        function agregarConductorFromDatalist() {
            var input = $("#conductoresInput");
            var selectedText = input.val();
            var option = $("#ConductoresList option").filter(function(){
                return $(this).text().trim() === selectedText.trim();
            }).first();
            var value = option.data("value") || "";
            if(value && !existeConductor(value)){
                agregarConductor(value, selectedText);
            }
            input.val("");
        }

        // Verifica si el conductor ya fue agregado
        function existeConductor(value) {
            var exists = false;
            $("#conductoresContainer span").each(function(){
                if ($(this).data("value") === value) {
                    exists = true;
                    return false;
                }
            });
            return exists;
        }

        // Función para agregar un chip de conductor en el contenedor
        function agregarConductor(value, label) {
            var chip = $('<span class="badge badge-info mr-1 mb-1" style="cursor:pointer;">' + label + ' <i class="fas fa-times"></i></span>');
            chip.data("value", value);
            chip.click(function(){
                $(this).remove();
                actualizarConductoresHidden();
            });
            $("#conductoresContainer").append(chip);
            actualizarConductoresHidden();
        }

        // Actualiza el campo hidden de conductores con los valores seleccionados, separados por coma
        function actualizarConductoresHidden() {
            var arr = [];
            $("#conductoresContainer span").each(function(){
                arr.push($(this).data("value"));
            });
            $("#conductoresHidden").val(arr.join(","));
        }

        // Guardar la inspección mediante AJAX
        $("#btnGuardarInspeccion").click(function () {
            var conductoresArr = $("#conductoresHidden").val().split(",").filter(function(v){ return v !== ""; });
            var inspeccionData = {
                IdVehiculo: $("#idVehiculo").val(),
                Kilometraje: $("#kilometraje").val(),
                Ubicacion: $("#ubicacion").val(),
                // "Quien tiene asignada" se obtiene del input con datalist
                ReceivePersonId: $("#ReceivePersonIdHidden").val(),
                AsignadaA: $("#ReceivePersonIdDisplay").val(),
                Conductores: conductoresArr,
                // Se omite el campo "Nombre Completo" ya que no se usa para conductores múltiples
                NombreCompleto: "",
                Domicilio: $("#domicilio").val(),
                Telefono: $("#telefono").val(),
                PlantelAsignado: $("#plantelAsignado").val(),
                FotoLicenciaBase64: $("#vistaLicencia img").attr("src") || "",
                PruebaManejo: $("#pruebaManejo").is(":checked"),
                Estado: "Activo",
                Imagenes: imagenes
            };

            $.LoadingOverlay("show");
            $.ajax({
                url: '@Url.Action("ActualizarDatos", "Consumo")',
                type: "POST",
                data: JSON.stringify(inspeccionData),
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                success: function (response) {
                    $.LoadingOverlay("hide");
                    if (response.success) {
                        Swal.fire("Éxito", response.message, "success");
                        $("#actualizacionModal").modal("hide");
                        tabla_persona.ajax.reload();
                    } else {
                        Swal.fire("Error", response.message, "error");
                    }
                },
                error: function () {
                    $.LoadingOverlay("hide");
                    Swal.fire("Error", "Ocurrió un error inesperado.", "error");
                }
            });
        });
    </script>

    <!-- JavaScript adicional para manejo de datalist y chips en Conductores -->
    <script>
        // Función para agregar conductor desde el input con datalist para conductores
        function agregarConductorFromDatalist() {
            var input = $("#conductoresInput");
            var selectedText = input.val();
            var option = $("#ConductoresList option").filter(function () {
                return $(this).text().trim() === selectedText.trim();
            }).first();
            var value = option.data("value") || "";
            if (value && !existeConductor(value)) {
                agregarConductor(value, selectedText);
            }
            input.val("");
        }

        // Verifica si el conductor ya fue agregado
        function existeConductor(value) {
            var exists = false;
            $("#conductoresContainer span").each(function () {
                if ($(this).data("value") === value) {
                    exists = true;
                    return false;
                }
            });
            return exists;
        }

        // Función para agregar un chip de conductor en el contenedor
        function agregarConductor(value, label) {
            var chip = $('<span class="badge badge-info mr-1 mb-1" style="cursor:pointer;">' + label + ' <i class="fas fa-times"></i></span>');
            chip.data("value", value);
            chip.click(function () {
                $(this).remove();
                actualizarConductoresHidden();
            });
            $("#conductoresContainer").append(chip);
            actualizarConductoresHidden();
        }

        // Actualiza el campo hidden de conductores con los valores seleccionados, separados por coma
        function actualizarConductoresHidden() {
            var arr = [];
            $("#conductoresContainer span").each(function () {
                arr.push($(this).data("value"));
            });
            $("#conductoresHidden").val(arr.join(","));
        }

        // Función para asignar el valor seleccionado del datalist para "Quien tiene asignada"
        function OnSelectedReceivePersonChanged() {
            var selectedText = $("#ReceivePersonIdDisplay").val();
            var option = $("#ReceivePersonList option").filter(function () {
                return $(this).text().trim() === selectedText.trim();
            }).first();
            var value = option.data("value") || "";
            $("#ReceivePersonIdHidden").val(value);
        }
    </script>

}

<div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
        <div class="container-fluid">
            <!-- Page Heading -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Lista de Unidades</h6>
                </div>
                <div class="card-body p-3">
                    <table id="listTable" class="table table-striped table-bordered table-hover display responsive nowrap" style="width:100%">
                        <thead>
                            <tr>
                                <th>Acción</th>
                                <th>Unidad</th>
                                <th>Asignación</th>
                                <th>Traslados</th>
                                <th>Extra Plan</th>
                                <th>Consumo</th>
                                <th>Saldo</th>
                                <th>Nombre Empleado</th>
                                <th>Nombre Área</th>
                            </tr>
                        </thead>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="actualizacionModal" class="modal fade" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Actualización de Datos</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <!-- Campo oculto para el Id del vehículo -->
                <input type="hidden" id="idVehiculo" value="" />
                <form id="formInspeccion">
                    <!-- 1. Quien tiene asignada -->
                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label for="ReceivePersonIdDisplay">Quien tiene asignada</label>
                            <input list="ReceivePersonList" class="form-control" id="ReceivePersonIdDisplay" placeholder="Buscar responsable..." onchange="OnSelectedReceivePersonChanged()">
                            <datalist id="ReceivePersonList">
                             
                            </datalist>
                            <input type="hidden" id="ReceivePersonIdHidden" name="ReceivePersonId">
                        </div>
                        <!-- 2. Conductores -->
                        <div class="form-group col-md-6">
                            <label for="conductoresInput">Conductores</label>
                            <input list="ConductoresList" class="form-control" id="conductoresInput" placeholder="Buscar conductor..." onchange="agregarConductorFromDatalist()">
                            <datalist id="ConductoresList">
                              
                            </datalist>
                            <div id="conductoresContainer" style="margin-top:5px;"></div>
                            <input type="hidden" id="conductoresHidden" name="Conductores">
                        </div>
                    </div>
                    <!-- 3. Kilometraje -->
