    <script>
        var tabla_persona;
        var popupTable;
        var TransferList = {
            CargarTraslados: function () {
                tabla_persona.ajax.reload();

            }
        };



        var MostrarSweetAlert = function (mensaje) {
            swal.fire({
                title: "Mensaje",
                text: mensaje,
                icon: "success",
                confirmButtonText: "Aceptar"
            });
        }

      $(document).ready(function () {
         $.LoadingOverlay("show");
          tabla_persona = $('#listTable').DataTable({
            "ajax": {
                "url": "@Url.Action("TransfersListjson", "Consumo")",
                "type": "GET",
                "datatype": "json"
            },
           "columns": [
               {
                   "data": "IdCombustibleTraslado",

                   "render": function (data, type, full, meta) {
                       var codigo = data.replace('TRS-', '');

                   return `
                <div class="btn-group">
                    <button type="button" class="btn btn-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                        <i class="fas fa-cogs"></i> Acciones
                    </button>
                    <div class="dropdown-menu">
                        <a class="dropdown-item" href="javascript:void(0);" onclick="VerDetalleEstados('${codigo}')"><i class="fas fa-eye"></i> Ver Estado</a>
                        <a class="dropdown-item" href="javascript:void(0);" onclick="AnularTraslado('${codigo}')"><i class="fas fa-ban"></i> Anular</a>
                        <a class="dropdown-item" href="javascript:void(0);" onclick="EditarTraslado('${codigo}')"><i class="fas fa-edit"></i> Editar</a>
                    </div>
                </div>
            `;
               },
                   "orderable": true,
                   "searchable": true,
                   "width": "150px"
           },
                { "data": "IdCombustibleTraslado" },

                {
                    "data": "FechaTraslado",
                    "render": function (data) {
                        return moment(data).format('DD/MM/YYYY');
                    }
                },                { "data": "TotalCantidadSolicitada" },
                { "data": "TotalCantidadAutorizada" },


                 {
            "data": "Estado",
            "createdCell": function (td, cellData, rowData, row, col) {
                var color = ""; // Inicializa el color en blanco

                // Verifica si el valor de cellData contiene la palabra "registrado"
                if (cellData.toLowerCase().includes("registra")) {
                    color = "#fdfd96"; // Amarillo para valores que contienen "registrado"
                } else if (cellData.toLowerCase().includes("autorizado")) {
                    color = "##77dd77"; // Verde para "autorizado"
                } else if (cellData.toLowerCase().includes("anulad")) {
                    color = "##ff6961"; // Rojo para "denegado"
                } else {
                    color = "#ADD8E6"; // Azul para cualquier otro estado
                }

                $(td).css('color', color); // Establece el color de fondo
            } }
           ],

            "dom": 'Blfrtip',
            "lengthMenu": [10, 20, 50, 100],
            "pageLength": 10,
            "language": {
                "url": "@Url.Content("~/Scripts/datatable.es-ES.json")"
            },
            "responsive": true,
            "initComplete": function () {
                $('#listTable tbody').on('click', '.dropdown-toggle', function (e) {
                    e.stopPropagation();
                    $(this).siblings('.dropdown-menu').toggleClass('show');
                });
                $(document).on('click', function (e) {
                    if (!$('.dropdown-toggle').is(e.target) && $('.dropdown-toggle').has(e.target).length === 0 && $('.show').has(e.target).length === 0) {
                        $('.dropdown-menu').removeClass('show');
                    }
                });
            }
        });


          $.LoadingOverlay("hide");
            popupTable = $('#popupTable').DataTable({
              columns: [

                  { data: 'NombreEmpleado' },
                  { data: 'Hora' },
                  {
                      data: 'FechaInsercion',
                      render: function (data) {
                          return moment(data).format('DD/MM/YYYY');
                      }
                  },

                  { data: 'Estado' },
               ] ,

    "language": {
        "url": "@Url.Content("~/Scripts/datatable.es-ES.json")"
    },
    "responsive": true ,
          });
         $("#btnAceptar").on("click", function (e) {
             e.preventDefault(); // Previene el comportamiento predeterminado del botón
             GuardarConsumo2();
         });



            // Ejemplo de evento que carga y muestra el PopupControl (vincúlalo a un botón u otro elemento)

      });
     function OnInit(s, e) {
        AdjustSize();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            AdjustSize();
        });
    }
    function OnEndCallback(s, e) {
        AdjustSize();
    }
      function cargarYMostrarPopup() {
     popEditarConsumo.Show();
        }
    function AdjustSize() {
        var height = document.documentElement.clientHeight;
        gvTraslado.SetHeight(height - 150);
    }


    function EditarTraslado(datos2) {

        var key = datos2;
        var idAccion = "Editar";
    var url=   '@Url.Action("EditarTraslado", "Traslados", new { idTraslado = "0" })'.replace("0", datos2);



        $.ajax({
            url: '@Url.Action("ValidarTraslado")',
            type: "POST",
            data: { idTraslado: key, tipoEdicion:idAccion },
            dataType: "json",
            traditional: true,
            cache: false,
            //contentType: "application/json; charset=utf-8",
            success: function (data) {
                if (data.status != "Error") {
                    popEditarTraslado.SetContentUrl(url);
                    popEditarTraslado.ShowAtElementByID(datos2);
                } else {
                    swal.fire("Advertencia!", data.message, "warning");
                }


            },
            error: function () {
                alert("An error has occured!!!");
            }
        });
        } function cerrar() {
            $('#popupContainer').modal('hide');

        }
         function EditarTraslado2(datos2) {

        var key = datos2;
        var idAccion = "Nuevo";
    var url=   '@Url.Action("EditarTraslado", "Traslados", new { idTraslado = "0" })';



        $.ajax({
            url: '@Url.Action("ValidarTraslado")',
            type: "POST",
            data: { idTraslado: key, tipoEdicion:idAccion },
            dataType: "json",
            traditional: true,
            cache: false,
            //contentType: "application/json; charset=utf-8",
            success: function (data) {
                if (data.status != "Error") {
                    popEditarTraslado.SetContentUrl(url);
                    popEditarTraslado.ShowAtElementByID(datos2);
                } else {
                    swal.fire("Advertencia!", data.message, "warning");
                }


            },
            error: function () {
                alert("An error has occured!!!");
            }
        });
    }
        function CargarTraslados() {
            tabla_persona.ajax.reload();
    }

    function AnularTraslado(datos2) {

        var key = datos2;

        $.ajax({
            url: '@Url.Action("AnularTraslado")',
            type: "POST",
            data: { idTraslado: key },
            dataType: "json",
            traditional: true,
            cache: false,
            //contentType: "application/json; charset=utf-8",
            success: function (data) {
                if (data.status != "Error") {
                    swal.fire({
                            title: "Exito!",
                            text: data.message,
                            icon: "success",
                            confirmButtonText: "Aceptar",
                        })
                        .then((willSaved) => {
                            if (willSaved) {
                                CargarTraslados();

                            }

                        });
                } else {
                    swal.fire("Advertencia!", data.message, "warning");
                }


            },
            error: function () {
                alert("An error has occured!!!");
            }
        });
    }
        function OnPopupCloseUp(s, e) {
            CargarTraslados();

        }
        function cargarYMostrarPopup() {
            popEditarConsumo.Show();
        }

        function VerDetalleEstados(data) {

            $('#popupContainer').modal('show');

        // Carga los datos JSON utilizando una solicitud AJAX
        $.ajax({
            url: '@Url.Action("TrasladosStateConsultjson", "Consumo")',
            data: { idTraslado: data }, // Reemplaza 'tuIdConsumo' con el valor correcto
            type: 'GET',
            dataType: 'json',
            success: function (data) {
                // Llena la tabla con los datos JSON
                popupTable.clear().rows.add(data.data).draw();
            },
            error: function (error) {
                console.error(error);
            }
        });

}

    </script>
}
