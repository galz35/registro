@model Entities.ViewModels.VistaIncidencias

@{ Layout = "~/Views/Shared/_popupLayout.cshtml"; }



<style type="text/css">


    .memo * {
        text-transform: uppercase;
    }
</style>
<script>

    function GuardarIncidencia(s, e) {
        // prevent the default event behaviour

        $.ajax({
            url: '@Url.Action("GuardarIncidencia")',
            type: "POST",
            data: $('#frmIncidencia').serialize(),
            dataType: "json",
            traditional: true,
            cache: false,
            //contentType: "application/json; charset=utf-8",
            success: function (data) {
                if (data.status != "Error") {
                    swal({
                            title: "Exito!",
                            text: data.message,
                            icon: "success",
                            button: "Aceptar",
                        })
                        .then((willSaved) => {
                            if (willSaved) {
                                top.popEditarIncidencia.Hide();
                            }

                        });
                } else {
                    swal({
                        title: "Error!",
                        text: data.message,
                        icon: "error",
                        button: "Aceptar",
                    })
                    //swal("ERROR!", "Ocurrió un error en la transaccion, por favor corrija.", "error");
                }


            },
            error: function () {
                alert("Ocurrió un error en la transaccion.!!!");
            }
        });
    }


</script>

