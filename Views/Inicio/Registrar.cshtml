<style>

    /* Contenedor con márgenes */
    .div-con-margen {
        margin: 30px !important; /* margen superior, derecho, inferior e izquierdo */
    }

    /* Tabs de encabezado */
    .header-tabs {
        margin-bottom: 20px !important;
        text-align: center !important;
    }

        .header-tabs button {
            padding: 10px 20px !important;
            cursor: pointer !important;
            background-color: #e74c3c !important; /* Rojo impactante */
            color: #fff !important; /* Texto blanco */
            border: none !important;
            border-radius: 5px !important;
            margin-right: 10px !important;
            transition: background-color 0.3s ease !important;
        }

            .header-tabs button:hover {
                background-color: #c0392b !important; /* Rojo más oscuro al pasar el ratón */
            }

    /* Estilos globales del cuerpo */
    body {
        font-family: Arial, sans-serif !important;
        margin: 0 !important;
        padding: 0 !important;
        background-color: #ecf0f1 !important; /* Gris muy claro */
        color: #333 !important; /* Texto oscuro */
    }

    /* Titulares y párrafos */
