    <script>
        var tabladata;
var tablatienda;
var tablaproducto;

$(document).ready(function () {
    $.LoadingOverlay("show");

    // Validar formulario
    $("#form").validate({
        rules: {
            Nombre: "required",
            Descripcion: "required"
        },
        messages: {
            Nombre: "(*)",
            Descripcion: "(*)"
        },
        errorElement: 'span'
    });

    // Obtener equipo mediante AJAX (reemplaza fetch)
    $.ajax({
        url: '@Url.Action("Obtenerequipo", "Events")',
        type: 'GET',
        contentType: 'application/json; charset=utf-8',
        dataType: 'json',
        success: function (data) {
            if (data.data && data.data.Nombre && data.data.Nombre.length > 0) {
                $("#txtRuc").val(data.data.Nombre);       // Asigna el nombre del equipo
                $("#txtRuc2").val(data.data.fullnombre);    // Asigna el nombre completo
                $("#txtRuc3").val(data.data.estado);        // Asigna el estado
                $("#txtRuc4").val(data.data.rg);            // Asigna el RG
                $("#cbdisciplina").val(data.data.Disciplina);// Asigna la disciplina

                // Deshabilitar controles
                $("#cbdisciplina, #txtRuc, #btnBuscarTienda")
                    .prop("disabled", true)
                    .css("background", "silver");

                if (data.data.rg !== "ok" || data.data.estado === "F") {
                    $("#btnBuscarTienda2, #btnAsignar")
                        .prop("disabled", true)
                        .css("background", "silver");
                    if (data.data.estado === "F") {
                        swal("Mensaje!", "Guardado : Ya esta finalizado", "success");
                        $("#txtNombre, #txtCodigo").prop("disabled", true);
                    }
                }
            } else {
                $("#btnBuscarTienda2, #btnAsignar, #txtCodigo")
                    .prop("disabled", true)
                    .css("background", "silver");
            }
        },
        error: function (err) {
            console.error('Error en la solicitud AJAX:', err);
            $("#btnBuscarTienda2, #btnAsignar, #txtCodigo")
                .prop("disabled", true)
                .css("background", "silver");
        }
    });

    // Inicializar DataTable para productos
    tablaproducto = $('#tbProducto').DataTable({
        "ajax": {
            "url": '@Url.Action("Obtener", "Events")',
            "type": "GET",
            "datatype": "json"
        },
        "columns": [
            {
                "data": "carnet",
                "render": function (data, type, row, meta) {
                    return "<button class='btn btn-sm btn-primary ml-2' type='button' onclick='productoSelect(" +
                        JSON.stringify(row) +
                        ")'><i class='fas fa-check'></i></button>";
                },
                "orderable": false,
                "searchable": false,
                "width": "90px"
            },
            { "data": "carnet" },
            { "data": "nombre" },
            { "data": "gerente" }
        ],
        "language": {
            "url": '@Url.Content("~/js/datatable_spanish.json")'
        },
        responsive: true
    });

    // Inicializar DataTable para equipo
    tabladata = $('#tbdata').DataTable({
        "ajax": {
            "url": '@Url.Action("Obtenerequipo2", "Events")',
            "type": "GET",
            "datatype": "json"
        },
        "columns": [
            { "data": "carnet" },
            { "data": "nombre" },
            { "data": "gerencia" },
            { "data": "sexo" },
            { "data": "telefono" },
            {
                "data": "iddliga",
                "render": function (data, type, row, meta) {
                    return "<button class='btn btn-danger btn-sm ml-2' type='button' onclick='eliminar(" +
                        data +
                        ")'><i class='fa fa-trash'></i></button>";
                },
                "orderable": false,
                "searchable": false,
                "width": "80px"
            }
        ],
        dom: 'Blfrtip',
        "language": {
            "url": '@Url.Content("~/js/datatable_spanish.json")'
        },
        responsive: true,
        buttons: [
            {
                extend: 'excel',
                className: 'buttons-excel'
            },
            {
                extend: 'pdf',
                className: 'buttons-excel'
            }
        ]
    });

    $.LoadingOverlay("hide");
});
 function cargartodo() {
    fetch('@Url.Action("Obtenerequipo", "Events")')  // Realiza la petición GET
        .then(response => {
            if (!response.ok) {
                throw new Error("Error en la respuesta de la red: " + response.statusText);
            }
            return response.json();  // Convierte la respuesta a JSON
        })
        .then(data => {
            if (data.data && data.data.Nombre && data.data.Nombre.length > 0) {
                $("#txtRuc").val(data.data.Nombre);
                $("#txtRuc2").val(data.data.fullnombre);
                $("#txtRuc3").val(data.data.estado);
                $("#txtRuc4").val(data.data.rg);
                $("#cbdisciplina").val(data.data.Disciplina);
                $("#cbdisciplina, #txtRuc, #btnBuscarTienda")
                    .prop("disabled", true)
                    .css("background", "silver");
                if (data.data.rg !== "ok") {
                    $("#btnBuscarTienda2, #btnAsignar")
                        .prop("disabled", true)
                        .css("background", "silver");
                }
            } else {
                $("#btnBuscarTienda2, #btnAsignar, #txtCodigo")
                    .prop("disabled", true)
                    .css("background", "silver");
            }
        })
        .catch(error => {
            console.error('Error en la solicitud fetch:', error);
            $("#btnBuscarTienda2, #btnAsignar, #txtCodigo")
                .prop("disabled", true)
                .css("background", "silver");
        });
}


function mostrarSeleccion() {
    var comboBox = document.getElementById("cbdisciplina");
    var seleccion = comboBox.options[comboBox.selectedIndex].text;
    swal("Mensaje!", "Seleccionaste: " + seleccion, "warning");
}

function Guardardiciplina() {
    swal({
        title: "Mensaje",
        text: "¿Desea crear equipo?",
        type: "success",
        showCancelButton: true,
        confirmButtonText: "Si",
        confirmButtonColor: "green",
        cancelButtonText: "No",
        closeOnConfirm: true
    }, function () {
        var comboBox = document.getElementById("cbdisciplina");
        var seleccion = comboBox.options[comboBox.selectedIndex].text;
        var camposvacios = false;
        var tel = $("#txtNombre").val();
        if (seleccion === "" || $("#txtRuc").val() === "")
            camposvacios = true;
        if (!camposvacios) {
            var $data = {
                oPersona: {
                    Nombre: $("#txtRuc").val(),
                    Disciplina: seleccion,
                    Telefono: tel
                }
            };
            $.ajax({
                url: "@Url.Action("Guardar", "Events")",
                type: "POST",
                data: JSON.stringify($data),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (data) {
                    if (data.resultado === "OK") {
                        alert("Su equipo se ha registrado");
                        window.location.href = "https://recursoshumanosni/RHOnline/Events/Registrar";
                    } else {
                        alert(data.resultado);
                        window.location.href = "https://recursoshumanosni/RHOnline/Events/Registrar";
                    }
                },
                error: function (error) {
                    console.log(error);
                }
            });
        } else {
            swal("Mensaje!", "Es necesario completar todos los campos", "warning");
        }
    });
}

function mostrarAlerta(mensaje, tipo) {
    alert(mensaje);
}

function Guardardiciplinaf() {
    swal({
        title: "Mensaje",
        text: "¿Desea finaliza el equipo?",
        type: "success",
        showCancelButton: true,
        confirmButtonText: "Si",
        confirmButtonColor: "green",
        cancelButtonText: "No",
        closeOnConfirm: true
    }, function () {
        var comboBox = document.getElementById("cbdisciplina");
        var seleccion = comboBox.options[comboBox.selectedIndex].text;
        var $data = {
            oPersona: {
                Nombre: $("#txtRuc").val(),
                Disciplina: seleccion
            }
        };
        // Llamada AJAX comentada para finalizar el equipo

        $.ajax({
            url: "@Url.Action("Guardarf", "Events")",
            type: "POST",
            data: JSON.stringify($data),
            dataType: "json",
            contentType: "application/json; charset=utf-8",
            success: function (data) {
                if (data.resultado === "Se a finalizado el equipo") {
                    swal("Mensaje!", "Se a finalizado la inscripcion", "success");
                    window.location.href = "https://recursoshumanosni/RHOnline/Events/Registrar";
                } else {
                    alert(data.resultado);
                    window.location.href = "https://recursoshumanosni/RHOnline/Events/Registrar";
                }
            },
            error: function (error) {
                console.log(error);
            }
        });

    });
}

