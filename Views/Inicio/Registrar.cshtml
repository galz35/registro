function asignarProducto() {
    swal({
        title: "Mensaje",
        text: "¿Desea asignar jugador al equipo?",
        type: "success",
        showCancelButton: true,
        confirmButtonText: "Si",
        confirmButtonColor: "green",
        cancelButtonText: "No",
        closeOnConfirm: true
    }, function () {
        if ($("#txtCodigo").val() === "" || $("#txtNombre").val() === "") {
            swal("Mensaje!", "Es necesario completar todos los campos", "warning");
            return;
        }
        var $data = {
            oPersona: {
                Nombre: $("#txtCodigo").val(),
                Disciplina: $("#txtNombre").val()
            }
        };
        $.ajax({
            url: '@Url.Action("Guardar2", "Events")',
            type: "POST",
            data: JSON.stringify($data),
            dataType: "json",
            contentType: "application/json; charset=utf-8",
            success: function (data) {
                if (data.resultado === "ok") {
                    swal("Mensaje!", "registro guardado ", "success");
                    $("#txtNombre, #txtCodigo").val("");
                    tabladata.ajax.reload();
                } else {
                    alert(data.resultado);
                }
            },
            error: function (error) {
                console.log(error);
            }
        });
    });
}

function eliminar($id) {
    var estado = $("#txtRuc3").val();
    var rg = $("#txtRuc4").val();
    if (estado !== "fin" && rg === "ok") {
        swal({
            title: "Mensaje",
            text: "¿Desea eliminar la asignación?",
            type: "warning",
            showCancelButton: true,
            confirmButtonText: "Si",
            confirmButtonColor: "#DD6B55",
            cancelButtonText: "No",
            closeOnConfirm: true
        }, function () {
            $.ajax({
                url: '@Url.Action("Guardar3", "Events")' + "?id=" + $id,
                type: "GET",
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                success: function (data) {
                    if (data.resultado) {
                        tabladata.ajax.reload();
                    } else {
                        swal("Mensaje", "No se pudo eliminar la asignación?", "warning");
                    }
                },
                error: function (error) {
                    console.log(error);
                }
            });
        });
    }
}

