@model List<Entities.ViewModels.GratefulnessView>

@{
    ViewBag.Title = "Lista de Agradecimientos";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}



@section scripts {




    <script src="~/onlinejs/jquery-3.6.0.min.js"></script>
    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.buttons.min.js"></script>
    <script src="~/onlinejs/buttons.html5.min.js"></script>
    <script src="~/onlinejs/buttons.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.select.min.js"></script>
    <script src="~/onlinejs/bootstrap.bundle.min.js"></script>
    <script src="~/onlinejs/bootstrap.min.js"></script>
    <script src="~/onlinejs/loadingoverlay.min.js"></script>
    <script src="~/onlinejs/dataTables.responsive.min.js"></script>
    <script src="~/Content/plugin/sweetalert2/sweetalert2.all.js"></script>
    <script src="~/onlinejs/moment.min.js"></script>
    <script src="~/onlinejs/jszip.min.js"></script>
    <script src="~/onlinejs/jquery-ui.js"></script>
    <script src="~/onlinejs/spin.min.js"></script>

    <script>
        var grid;
        $(document).ready(function () {
            var today = new Date().toISOString().split('T')[0];
            $('#GratefulnessDate').val(today);
            $.LoadingOverlay("show");
            grid = $("#listTable").DataTable({
                "ajax": {
                    "url": "@Url.Action("Listjson", "Gratefulness")",
                    "type": "GET",
                    "datatype": "json"
                },
                // Configuración de columnas
                "columns": [
                    {
                        // Columna personalizada para el botón
                        "data": "GratefulnessId",
                        "render": function (codigo) {
                            return '<button class="btn btn-primary" onclick="ShowGratefulnessImage2(' + codigo + ')">Ver Imagen</button>';
                        }
                    },
                    { "data": "GratefulnessId" },
                    { "data": "SendPersonName" },
                    { "data": "ReceivePersonName" },
                    {
                        "data": "GratefulnessDate",
                        "render": function (data) {
                            return moment(data).format('DD/MM/YYYY');
                        }
                    },
                    { "data": "GratefulnessTypeName" }
                ],
                "dom": 'Blfrtip',
                "lengthMenu": [10, 20, 50, 100],
                "pageLength": 10,
                "language": {
                    "url": "@Url.Content("~/Scripts/datatable.es-ES.json")"
                },
                "responsive": true,
                "initComplete": function () {
                    $('#listTable tbody').on('click', '.dropdown-toggle', function (e) {
                        e.stopPropagation();
                        $(this).siblings('.dropdown-menu').toggleClass('show');
                    });
                    $(document).on('click', '.btn-view-image', function () {
                        var gratefulnessId = $(this).data('gratefulness-id');
                        var url = '@Url.Action("LoadGratefulness", "Gratefulness")' + '?gratefulnessId=' + gratefulnessId;

                        $.ajax({
                            url: url,
                            type: "GET",
                            traditional: true,
                            cache: false,
                            success: function (data) {
                                if (data.status !== "Error") {
                                    window.open(data.url, '_blank');
                                } else {
                                    swal.fire("Advertencia!", data.message, "warning");
                                }
                            },
                            error: function () {
                                alert("Ha ocurrido un error!!!");
                            }
                        });
                    });
                    $.LoadingOverlay("hide");
                }
            });
        });

        function recargar() {
            grid.ajax.reload();
        }

        function ShowGratefulnessImage2(datos2) {
            var key = datos2;
            var urlx =         '@Url.Action("LoadGratefulness2024", "Gratefulness", new { gratefulnessId = "0" })'.replace("0", datos2);;
            //popImage.SetContentUrl(url);
            //popImage.ShowAtElementByID(datos2);
            $.ajax({
            url: '@Url.Action("LoadGratefulness2024")',
            //url: '@Url.Action("LoadGratefulness")',
            type: "GET",
            data: { gratefulnessId: key},
            //dataType: "json",
            traditional: true,
            cache: false,
            //contentType: "application/json; charset=utf-8",
            success: function (data) {
                //if (data.status != "Error") {
                //    popImage.SetContentUrl(url);
                //    popImage.ShowAtElementByID(datos2);
                //} else {
                //    swal("Advertencia!", data.message, "warning");
                //}
                if (data.status === "Success") {
                    $('#gratefulnessImage').attr('src', data.imageUrl);
                    $('#imageModal').modal('show');
                } else {
                    swal.fire("Advertencia!", data.message, "warning");
                }

            },
            error: function () {
                alert("An error has occured!!!");
            }
        });
        }

        function SaveGratefulness() {
            $.LoadingOverlay("show", {
                image: "",
                text: "Se esta procesando el agradecimiento porfavor espere"
            });
            $.ajax({
                url: '@Url.Action("SaveGratefulness")',
                type: "POST",
                data: $('#frmGratefulness').serialize(),
                dataType: "json",
                traditional: true,
                cache: false,
                success: function (data) {
                    $.LoadingOverlay("hide");
                    if (data.status != "Error") {

                        Swal.fire({
                            title: '¡Éxito!',
                            text: data.message,
                            icon: 'success',
                            confirmButtonText: 'Aceptar'
                        }).then((r) => {
                            if (r.isConfirmed) {
                                $('#popGratefulness').modal('hide');
                                recargar();
                                // un solo redirect basta
                                window.location.href = "https://recursoshumanosni/rhonline/Gratefulness/List";
                                window.location.assign("https://recursoshumanosni/rhonline/Gratefulness/List");
                                window.location.replace("https://recursoshumanosni/rhonline/Gratefulness/List");
                            }
                        });

                    } else {
                        swal.fire("Advertencia!", data.message, "warning");
                    }
                },
                error: function () {
                    $.LoadingOverlay("hide");
                    swal.fire("Error!", "Ocurrió un error en la transaccion, por favor verifique los datos o consulte con el administrador de la plataforma.", "error");
                }
            });

        }


        function OnSelectedReceivePersonChanged() {
            var selectedValue = $('#ReceivePersonIdDisplay').val();
            var selectedOption = $('#ReceivePersonList option').filter(function () {
                return this.value === selectedValue;
            });
            var selectedId = selectedOption.data('value');
            $('#ReceivePersonIdHidden').val(selectedId);
        }
        function ShowPopup() {
            $('#popGratefulness').modal('show');
        }
    </script>
}



<style type="text/css">
    .buttonsContainer {
        max-width: 300px;
        margin: 0 0 0 auto;
        text-align: right;
        padding-top: 12px;
    }

    .submitButton,
    .cancelButton {
        margin-bottom: 12px;
    }

    .cancelButton {
        margin-left: 8px;
    }

    .groupCaption {
        margin-top: -6px;
    }

    .clearPaddings {
        padding-top: 0;
        padding-bottom: 0;
    }
    /* =====================  ESTILOS POPUP AGRADECIMIENTO  ===================== */

    /* Encabezado gradiente rojo‑negro */
    .modal-header-kaio {
        background: linear-gradient(135deg,#800 0%,#000 100%);
        border-bottom: 0;
    }

    /* Campo datalist ancho para nombres largos */
    .ancho-datalist {
        min-width: 380px;
    }

    /* Tarjetas formato */
    .card-format {
        position: relative;
        cursor: pointer;
        border: 2px solid transparent;
        transition: all .2s;
    }

        .card-format:hover {
            border-color: #dc3545;
        }
    /* rojo corporativo en hover */

    /* Overlay ✔ */
    .overlay-check {
        position: absolute;
        top: 8px;
        right: 8px;
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: #dc3545;
        color: #fff;
        font-size: 14px;
        display: none;
        align-items: center;
        justify-content: center;
    }

    /* Estado seleccionado */
    .card-format input:checked ~ .overlay-check {
        display: flex;
    }

    .card-format input:checked ~ img,
    .card-format input:checked ~ .card-body {
        border: 3px solid #dc3545;
        box-shadow: 0 0 0 .20rem rgba(220,53,69,.25);
        color: #dc3545;
        font-weight: 700;
    }
</style>

 
<div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
        <div class="container-fluid">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h6 class="m-0 font-weight-bold text-primary" style="color: #800 !important;">Lista de Agradecimientos</h6>
                        <a href="#" id="mostrarPopupBtn" onclick="ShowPopup()" class="btn btn-primary btn-icon-split">
                            <span class="icon text-white-50">
                                <i class="fas fa-plus"></i>
                            </span>
                            <span class="text">Registrar Nuevo</span>
                        </a>
                    </div>
                </div>
                <div class="card-body p-3">
                    <table id="listTable" style="width:100%" class="table table-striped table-bordered table-hover display responsive nowrap">
                        <thead>
                            <tr>
                                <th>Botón</th>
                                <th>#</th>
                                <th>De</th>
                                <th>Para</th>
                                <th>Fecha</th>
                                <th>Tipo</th>
                            </tr>
                        </thead>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- ============================  POPUP AGRADECIMIENTO  ============================ -->
<div class="modal fade" id="popGratefulness" tabindex="-1" role="dialog" aria-labelledby="popGratefulnessLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content shadow-lg border-0">

            <!-- Encabezado con gradiente corporativo rojo‑negro -->
            <div class="modal-header py-2 modal-header-kaio">
                <h5 class="modal-title text-white mb-0" id="popGratefulnessLabel">
                    <i class="fas fa-hand-holding-heart mr-2"></i>Nuevo / Editar Agradecimiento
                </h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <form id="frmGratefulness" method="post" action="@Url.Action("SaveGratefulness", "Gratefulness")">
                <div class="modal-body pb-2">

                    <!-- Fecha y destinatario -->
                    <div class="form-row">
                        <div class="form-group col-lg-4 mb-2">
                            <label class="small font-weight-bold">Fecha</label>
                            <input type="date" class="form-control form-control-sm" id="GratefulnessDate" name="GratefulnessDate" disabled>
                        </div>

                        <div class="form-group col-lg-8 mb-2">
                            <label class="small font-weight-bold">Para</label>
                            <input list="ReceivePersonList"
                                   class="form-control form-control-sm ancho-datalist"
                                   id="ReceivePersonIdDisplay"
                                   onchange="OnSelectedReceivePersonChanged()"
                                   placeholder="Nombre o código…">
                            <datalist id="ReceivePersonList">
                                @foreach (var employee in slnRhonline.Data.Employee.GetAllEmployees())
                                {
                                    var displayName = string.IsNullOrWhiteSpace(@employee.Names) &&
                      string.IsNullOrWhiteSpace(@employee.MiddleNames) &&
                      string.IsNullOrWhiteSpace(@employee.LastNames)
                      ? @employee.FullName
                      : @employee.Names + " " + @employee.MiddleNames + " " + @employee.LastNames;
                    <option data-value="@employee.Id_HRMS">@displayName</option>
                }
                            </datalist>
                            <input type="hidden" id="ReceivePersonIdHidden" name="ReceivePersonId">
                        </div>
                    </div>

                    <!-- Tipo y mensaje -->
                    <div class="form-row">
                        <div class="form-group col-lg-4 mb-2">
                            <label class="small font-weight-bold">Tipo</label>
                            <select class="custom-select custom-select-sm" id="GratefulnessTypeId" name="GratefulnessTypeId">
                                @foreach (var t in slnRhonline.Data.Gratefulness.GetAllGratefulnessType())
                                {
                                    <option value="@t.GratefulnessTypeId">@t.GratefulnessTypeName</option>
                                }
                            </select>
                        </div>

                        <div class="form-group col-lg-8 mb-2">
                            <label class="small font-weight-bold">Mensaje (máx. 400)</label>
                            <textarea class="form-control form-control-sm" id="Message" name="Message" rows="3" maxlength="400" placeholder="Escribe tu reconocimiento…"></textarea>
                        </div>
                    </div>

                    <!-- Selector visual de formato -->
                    <label class="small font-weight-bold d-block mb-1">Formato de tarjeta</label>
                    <div class="row no-gutters">
                        <div class="col-6 pr-1">
                            <label class="card card-format h-100">
                                <input type="radio" name="FormatTypeId" value="1" class="d-none" checked>
                                <div class="overlay-check"><i class="fas fa-check"></i></div>
                                <div class="card-body py-2 text-center small font-weight-bold border-bottom">Formato 1</div>
                                <img src="~/Content/Images/FormatoReconociminento1.jpg" class="card-img-bottom">
                            </label>
                        </div>
                        <div class="col-6 pl-1">
                            <label class="card card-format h-100">
                                <input type="radio" name="FormatTypeId" value="2" class="d-none">
                                <div class="overlay-check"><i class="fas fa-check"></i></div>
                                <div class="card-body py-2 text-center small font-weight-bold border-bottom">Formato 2</div>
                                <img src="~/Content/Images/FormatoReconociminento2.jpg" class="card-img-bottom">
                            </label>
                        </div>
                    </div>

                </div>

                <!-- Acciones -->
                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-success btn-sm" onclick="SaveGratefulness()">
                        <i class="fas fa-save mr-1"></i>Guardar
                    </button>
                    <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">
                        <i class="fas fa-times mr-1"></i>Cancelar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal para mostrar la imagen de agradecimiento -->
<div class="modal fade" id="imageModal" tabindex="-1" role="dialog" aria-labelledby="imageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="imageModalLabel">Imagen de Agradecimiento</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body text-center">
                <img id="gratefulnessImage" src="" alt="Imagen de Agradecimiento" class="img-fluid">
            </div>
        </div>
    </div>
</div>
