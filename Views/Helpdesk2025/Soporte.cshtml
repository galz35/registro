@* Views/Helpdesk2025/TodosLosCasos.cshtml *@
@{ ViewBag.Title = "Todos los Casos";
                Layout = "~/Views/Shared/_mainLayout.cshtml"; }

<!-- Fancybox / Buttons DataTables (export Excel) -->
<link href="~/onlinecss/jquery.fancybox.min.css" rel="stylesheet" />

@* =========================================================
    ESTILOS (solo presentación)
    ========================================================= *@
<link href="~/onlinecss/style-helpdesk.css" rel="stylesheet" />


@* =========================================================
    CONTENIDO
    ========================================================= *@
<div id="helpdeskPage" class="container-fluid">

    <!-- Header + botones -->
    <div class="d-flex align-items-center justify-content-between">
        <div class="d-flex">
            <button id="btnResumenSoporte" class="btn btn-outline-primary my-3 mr-2" style="display:none">
                <i class="fas fa-users-cog mr-1"></i> Resumen por Soporte
            </button>
            <button id="btnAdminSoportes" class="btn btn-outline-dark my-3 mr-2" style="display:none">
                <i class="fas fa-tools mr-1"></i> Administrar Soportes
            </button>
        </div>
    </div>

    <!-- KPIs globales -->
    <!-- KPIs globales -->
    <div class="row" id="kpiRow">
        <div class="col">
            <div class="card shadow mb-4 kpi-btn" data-estado="Pendiente" style="border-left:.25rem solid #e11d48; cursor:pointer;">
                <div class="card-body d-flex justify-content-between">
                    <div>
                        <div class="text-uppercase mb-1" style="color:#e11d48 !important;">Pendientes</div>
                        <div class="h5 mb-0 font-weight-bold" id="kpiPend">0</div>
                    </div>
                    <div class="icon kpi-icon-pend" style="font-size:2rem;"><i class="fas fa-book-open"></i></div>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card shadow mb-4 kpi-btn" data-estado="Asignado" style="border-left:.25rem solid #6b7280; cursor:pointer;">
                <div class="card-body d-flex justify-content-between">
                    <div>
                        <div class="text-uppercase mb-1" style="color:#2563eb !important;">Asignados</div>
                        <div class="h5 mb-0 font-weight-bold" id="kpiAsig">0</div>
                    </div>
                    <div class="icon kpi-icon-asig" style="font-size:2rem;"><i class="fas fa-user-tag"></i></div>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card shadow mb-4 kpi-btn" data-estado="En Proceso" style="border-left:.25rem solid #f59e0b; cursor:pointer;">
                <div class="card-body d-flex justify-content-between">
                    <div>
                        <div class="text-uppercase mb-1" style="color:#f59e0b !important;">En Proceso</div>
                        <div class="h5 mb-0 font-weight-bold" id="kpiProc">0</div>
                    </div>
                    <div class="icon kpi-icon-proc" style="font-size:2rem;"><i class="fas fa-tasks"></i></div>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card shadow mb-4 kpi-btn" data-estado="Cerrado" style="border-left:.25rem solid #10b981; cursor:pointer;">
                <div class="card-body d-flex justify-content-between">
                    <div>
                        <div class="text-uppercase mb-1" style="color:#10b981 !important;">Cerrados</div>
                        <div class="h5 mb-0 font-weight-bold" id="kpiCerr">0</div>
                    </div>
                    <div class="icon kpi-icon-cerr" style="font-size:2rem;"><i class="fas fa-check-circle"></i></div>
                </div>
            </div>
        </div> <div class="col">
            <div class="card shadow mb-4 kpi-btn" data-estado="Cancelado"
                 style="border-left:.25rem solid #6b7280; cursor:pointer;">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <!-- título y contador -->
                        <div class="text-uppercase mb-1" style="color:#6b7280; font-weight:800;">Cancelados</div>
                        <div class="h5 mb-0 font-weight-bold" id="kpicancelar">0</div>
                    </div>
                    <!-- ícono distinto para Cancelados -->
                    <div class="icon" style="font-size:2rem; color:#6b7280;">
                        <i class="fas fa-ban"></i>
                    </div>
                </div>
            </div>

        </div>
    </div>


    <!-- Tabs por estado -->
    <div class="hd-tabs mb-3 d-none">
        <ul class="nav nav-tabs" id="estadoTabs" role="tablist" style="border:0 !important;">
            <li class="nav-item"><a class="hd-tablink active" data-estado="Pendiente" href="#" role="tab">Pendiente <span class="badge badge-light" id="bPend">0</span></a></li>
            <li class="nav-item"><a class="hd-tablink" data-estado="Asignado" href="#" role="tab">Asignado  <span class="badge badge-light" id="bAsig">0</span></a></li>
            <li class="nav-item"><a class="hd-tablink" data-estado="En Proceso" href="#" role="tab">En Proceso <span class="badge badge-light" id="bProc">0</span></a></li>
            <li class="nav-item"><a class="hd-tablink" data-estado="Cerrado" href="#" role="tab">Cerrado   <span class="badge badge-light" id="bCerr">0</span></a></li>
            <li class="nav-item"><a class="hd-tablink" data-estado="Cancelado" href="#" role="tab">Cancelado <span class="badge badge-light" id="bCanc">0</span></a></li>
        </ul>
    </div>

    <!-- Tabla principal -->
    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow">
                <div class="card-header py-3 d-flex align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold">Listado de Reportes</h6>
                    <!-- Botones export -->
                    <div id="exportMainWrap"></div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table id="tablaTodosLosCasos" class="table table-striped table-bordered" style="width:100%">
                            <thead>
                                <tr>
                                    <th>Acciones</th>
                                    <th>Solicitante</th>
                                    <th>Afectado</th>
                                    <th>Título</th>
                                    <th>Tipo</th>
                                    <th>Subtipo</th>
                                    <th>Soporte</th>
                                    <th>Estado</th>
                                    <th>Prioridad</th>
                                    <th>Fecha Creacion</th>
                                    <th>Fecha Finalización</th>
                                    <th>Tiempo</th>
                                </tr>
                                <tr class="filters">
                                    <th></th>
                                    <th><input type="text" class="form-control form-control-sm" placeholder="Filtrar solicitante" /></th>
                                    <th><input type="text" class="form-control form-control-sm" placeholder="Filtrar afectado" /></th>
                                    <th><input type="text" class="form-control form-control-sm" placeholder="Filtrar título" /></th>
                                    <th><input type="text" class="form-control form-control-sm" placeholder="Filtrar tipo" /></th>
                                    <th><input type="text" class="form-control form-control-sm" placeholder="Filtrar subtipo" /></th>
                                    <th><input type="text" class="form-control form-control-sm" placeholder="Filtrar soporte" /></th>
                                    <th>
                                        <select id="fEstado" class="form-control form-control-sm">
                                            <option value="">(Todos)</option>
                                        </select>
                                    </th>
                                    <th>
                                        <select id="fPrioridad" class="form-control form-control-sm">
                                            <option value="">(Todas)</option>
                                        </select>
                                    </th>
                                    <th>
                                        <div class="d-flex align-items-center">
                                            <input type="text" id="minDate" class="form-control form-control-sm" placeholder="Desde dd/mm/aaaa" style="min-width:140px" />
                                        </div>
                                    </th>
                                    <!-- Estas dos columnas nuevas (Fecha Finalización y Tiempo) de momento no tienen filtros -->
                                    <th></th>
                                    <th></th>
                                </tr>
                            </thead>

                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ============ Modales ============ -->
    <!-- Soporte 360° -->
    @* =========================================================
        MODALES
        ========================================================= *@
    <div class="modal fade" id="soporte360" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-xl soporte360-dialog" role="document">
            <div class="modal-content soporte360-content">
                <!-- HEADER -->
                <div class="modal-header soporte360-header">
                    <div class="w-100">
                        <div class="d-flex flex-wrap align-items-start justify-content-between">
                            <div class="mr-3" style="flex:1 1 auto; min-width:240px;">
                                <div class="d-flex align-items-center mb-2">
                                    <h5 class="modal-title mb-0 mr-2">
                                        Panel de Soporte y su casos
                                    </h5>
                                    <span class="badge badge-soft-dark">Vista Analítica</span>
                                </div>

                                <!-- Selector de Subgerencia / Soporte -->
                                <div class="form-group mb-2">
                                    <label class="small text-muted mb-1 font-weight-bold">
                                        Subgerencia / Soporte
                                    </label>
                                    <select id="ddlSoporteSel" class="form-control form-control-sm soporte360-soporteSel">
                                        <!-- Se llena dinámicamente -->
                                    </select>
                                </div>

                                <!-- Chips estados -->
                                <div id="chipsEstados" class="chipsEstadosWrap mb-2">
                                    <!-- se rellena dinámicamente -->
                                </div>
                            </div>

                            <!-- KPIs por soporte -->
                            <div class="text-right soporte360-kpis " style="flex:0 0 auto; min-width:260px;">
                                <div class="small text-muted mb-1 font-weight-bold d-none" id="lblSoporteSel">
                                    Seleccione un soporte
                                </div>
                                <div class="d-flex flex-wrap justify-content-end kpi-badges d-none">
                                    <span class="badge badge-light border mr-1 mb-1">
                                        Pend:
                                        <b id="kpiSPend">0</b>
                                    </span>
                                    <span class="badge badge-light border mr-1 mb-1">
                                        Asig:
                                        <b id="kpiSAsig">0</b>
                                    </span>
                                    <span class="badge badge-light border mr-1 mb-1">
                                        Proc:
                                        <b id="kpiSProc">0</b>
                                    </span>
                                    <span class="badge badge-light border mb-1">
                                        Cerr:
                                        <b id="kpiSCerr">0</b>
                                    </span>
                                </div>

                                <!-- Botones export -->
                                <div class="text-right mt-2">
                                    <div id="exportSupWrap"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="button" class="close ml-2" data-dismiss="modal"><span>&times;</span></button>
                </div>

                <!-- BODY -->
                <div class="modal-body soporte360-body">
                    <div class="soporte360-layout">
                        <!-- LEFT: Tabla de casos -->
                        <div class="soporte360-left">
                            <div class="table-responsive table-wrapper-360">
                                <table id="tablaSoporteCasos" class="table table-sm table-bordered" style="width:100%;">
                                    <thead>
                                        <tr>
                                            <th>Solicitante</th>
                                            <th>Afectado</th>
                                            <th>Título</th>
                                            <th>Tipo</th>
                                            <th>Subtipo</th>
                                            <th>Estado</th>
                                            <th>Prioridad</th>
                                            <th>Fecha</th>
                                            <th class="dt-center">Ver</th>
                                        </tr>
                                        <tr class="filtersSup">
                                            <th><input type="text" class="form-control form-control-sm" placeholder="Solicitante" /></th>
                                            <th><input type="text" class="form-control form-control-sm" placeholder="Afectado" /></th>
                                            <th><input type="text" class="form-control form-control-sm" placeholder="Título" /></th>
                                            <th><input type="text" class="form-control form-control-sm" placeholder="Tipo" /></th>
                                            <th><input type="text" class="form-control form-control-sm" placeholder="Subtipo" /></th>
                                            <th><input type="text" class="form-control form-control-sm" placeholder="Estado" /></th>
                                            <th><input type="text" class="form-control form-control-sm" placeholder="Prioridad" /></th>
                                            <th><input type="text" class="form-control form-control-sm" placeholder="dd/mm/aaaa" /></th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                </table>
                            </div>
                        </div>

                        <!-- RIGHT: Detalle del caso -->
                        <div class="soporte360-right">
                            <div class="detalleCard">
                                <div class="d-flex align-items-start justify-content-between mb-2">
                                    <div class="mr-2">
                                        <div class="h6 mb-0" id="dvTitulo">Selecciona un caso</div>
                                        <small class="text-muted" id="dvFecha"></small>
                                    </div>
                                    <div id="dvEstadoPill"></div>
                                </div>

                                <div id="dvMeta" class="mb-3 small"></div>

                                <div id="dvHS" class="mb-3"></div>

                                <div class="mb-2 font-weight-bold text-uppercase detailSectionTtl">Descripción</div>
                                <div id="dvDesc" class="mb-3 detalle-desc">—</div>

                                <div class="mb-2 font-weight-bold text-uppercase detailSectionTtl">Adjunto</div>
                                <div id="dvAdj" class="mb-3"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- FOOTER -->
                <div class="modal-footer soporte360-footer">
                    <small class="text-muted mr-auto">
                        Tip: Cambie el soporte arriba, filtre por estado con los chips y exporte Excel a la derecha.
                    </small>
                    <button class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Cerrar Caso -->
    <div class="modal fade" id="modalCerrar" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header"><h5 class="modal-title">Cerrar Caso</h5><button type="button" class="close" data-dismiss="modal"><span>&times;</span></button></div>
                <div class="modal-body">
                    <div id="detalleCasoContentCasosx" class="mb-3"></div>
                    <form id="formCerrar" enctype="multipart/form-data">
                        <input type="hidden" id="CasoIDCasos" name="CasoID" />
                        <div class="form-group">
                            <label for="NotasCierreCasos">Notas de Cierre</label>
                            <textarea class="form-control" id="NotasCierreCasos" name="NotasCierre" rows="3" required></textarea>
                        </div>

                        <div class="form-group mt-3">
                            <label class="font-weight-bold">Evidencia de Cierre (opcional)</label>
                            <div id="dropZoneCierre" class="dropzone-cierre">
                                <div class="drop-inner-cierre">
                                    <strong style="color:#0f172a;">Arrastra aquí tu archivo</strong> o búscalo manualmente<br>
                                    <span style="font-size: .75rem;">Imágenes (.jpg, .png) y Documentos (.pdf, .doc, .xls)</span><br>
                                    <span style="font-size: .75rem; font-weight:600;">Máx. 1 archivo · 10 MB</span>
                                </div>
                                <input type="file" class="fileInput-cierre" id="AdjuntoEvidencia" name="AdjuntoEvidencia" accept=".jpg,.jpeg,.png,.webp,.pdf,.doc,.docx,.xls,.xlsx" />
                            </div>
                            <div id="previewsCierreWrap"></div>
                        </div>

                        @Html.AntiForgeryToken()
                    </form>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                    <button id="btnGuardarCierre" class="btn btn-success">Cerrar caso</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Cancelar Caso -->
    <div class="modal fade" id="modalCancelar" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header"><h5 class="modal-title">Cancelar Caso</h5><button type="button" class="close" data-dismiss="modal"><span>&times;</span></button></div>
                <div class="modal-body">
                    <form id="formCancelar">
                        <input type="hidden" id="CasoIDCancel" name="CasoID" />
                        <div class="form-group">
                            <label for="MotivoCancel">Motivo</label>
                            <textarea class="form-control" id="MotivoCancel" name="Motivo" rows="3" required></textarea>
                        </div>
                        @Html.AntiForgeryToken()
                    </form>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                    <button id="btnGuardarCancel" class="btn btn-danger">Confirmar Cancelación</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Asignar / Reasignar Caso -->
    <div class="modal fade" id="modalAsignar" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header"><h5 class="modal-title">Asignar / Reasignar Caso</h5><button type="button" class="close" data-dismiss="modal"><span>&times;</span></button></div>
                <div class="modal-body">
                    <form id="formAsignar">
                        <input type="hidden" id="CasoIDAsignar" name="CasoID" />
                        <div class="form-group">
                            <label for="SoporteIDSelect">Soporte</label>
                            <select id="SoporteIDSelect" name="SoporteID" class="form-control" required></select>
                        </div>
                        <div class="form-group">
                            <label for="NotaAsignar">Nota / Comentario</label>
                            <textarea class="form-control" id="NotaAsignar" name="Nota" rows="3"></textarea>
                        </div>
                        @Html.AntiForgeryToken()
                    </form>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                    <button id="btnGuardarAsignacion" class="btn btn-primary">Guardar Asignación</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Ficha Persona -->
    <div class="modal fade" id="modalPersona" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header"><h5 class="modal-title">Ficha de Persona</h5><button type="button" class="close" data-dismiss="modal"><span>&times;</span></button></div>
                <div class="modal-body">
                    <div class="d-flex align-items-center mb-3">
                        <img id="personaFoto" class="avatar mr-3" src="#" alt="Foto" style="width:120px;height:120px;border-radius:50%;object-fit:cover;border:2px solid #e5e7eb;background:#f3f4f6;display:none" />
                        <div>
                            <div id="personaNombre" class="h5 mb-0">—</div>
                            <div id="personaCargo" class="text-muted">—</div>
                        </div>
                    </div>
                    <div class="kv"><span class="k" style="width:120px;font-weight:700;color:#374151;display:inline-block;">Carnet:</span>   <span id="personaCarnet" class="v">—</span></div>
                    <div class="kv"><span class="k" style="width:120px;font-weight:700;color:#374151;display:inline-block;">Correo:</span>   <span id="personaCorreo" class="v">—</span></div>
                    <div class="kv"><span class="k" style="width:120px;font-weight:700;color:#374151;display:inline-block;">Área:</span>     <span id="personaArea" class="v">—</span></div>
                    <div class="kv"><span class="k" style="width:120px;font-weight:700;color:#374151;display:inline-block;">Gerencia:</span> <span id="personaGerencia" class="v">—</span></div>
                    <div class="kv"><span class="k" style="width:120px;font-weight:700;color:#374151;display:inline-block;">Teléfono:</span> <span id="personaTelefono" class="v">—</span></div>
                    <div id="personaFotoError" class="text-warning small mt-2" style="display:none;"></div>
                </div>
                <div class="modal-footer"><button class="btn btn-secondary" data-dismiss="modal">Cerrar</button></div>
            </div>
        </div>
    </div>

    <!-- Admin Soportes -->
    <div class="modal fade" id="modalSoporte" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-xl" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        Administrador de Soportes
                        <small class="text-muted d-block" id="subTitleSoporte">Alta/edición, activar/desactivar y permisos por tipo/subtipo</small>
                    </h5>
                    <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <!-- IZQUIERDA: búsqueda, datos soporte, tabla -->
                        <div class="col-md-7 border-right">
                            <div class="card-lite">
                                <div class="card-title">Vincular desde empleados (emp2024)</div>
                                <div class="form-row">
                                    <div class="form-group col-md-8 mb-2">
                                        <label class="mb-1">Buscar por nombre o correo</label>
                                        <div class="input-group">
                                            <input type="text" id="txtBuscarEmp" class="form-control" placeholder="Ej. Ana Pérez o ana.perez">
                                            <div class="input-group-append"><button class="btn btn-outline-secondary" type="button" id="btnBuscarEmp"><i class="fas fa-search"></i></button></div>
                                        </div>
                                        <div class="hint mt-1">Opcional: selecciona y llenaremos los campos de soporte.</div>
                                    </div>
                                    <div class="form-group col-md-4 mb-2">
                                        <label class="mb-1">Resultados</label>
                                        <select id="EmpleadoSel" class="form-control"></select>
                                    </div>
                                </div>
                            </div>

                            <div class="card-lite">
                                <div class="card-title">Datos del soporte</div>
                                <div class="form-row">
                                    <div class="form-group col-md-6">
                                        <label for="SoporteIDSoporteID" class="mb-1">SoporteID <span class="hint">(sugerido: correo)</span></label>
                                        <input type="text" id="SoporteID" name="SoporteID" class="form-control" required>
                                    </div>
                                    <div class="form-group col-md-6">
                                        <label for="Email" class="mb-1">Email</label>
                                        <input type="email" id="Email" name="Email" class="form-control" required>
                                    </div>
                                    <div class="form-group col-md-6">
                                        <label for="Nombre" class="mb-1">Nombre</label>
                                        <input type="text" id="Nombre" name="Nombre" class="form-control" required>
                                    </div>
                                    <div class="form-group col-md-6">
                                        <label for="Area" class="mb-1">Área</label>
                                        <input type="text" id="Area" name="Area" class="form-control" placeholder="Ej. RRHH, Servicios Generales">
                                    </div>
                                    <div class="form-group col-md-6 d-flex align-items-center">
                                        <div class="custom-control custom-switch mt-4">
                                            <input type="checkbox" class="custom-control-input" id="Activo" checked>
                                            <label class="custom-control-label" for="Activo">Activo</label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="card-lite">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="card-title mb-0">Soportes registrados</div>
                                    <div class="d-flex align-items-center">
                                        <div class="input-group input-group-sm mr-2" style="max-width: 280px;">
                                            <input type="text" id="txtBuscarSoporte" class="form-control" placeholder="Filtrar por nombre/correo">
                                            <div class="input-group-append"><button class="btn btn-outline-secondary" id="btnBuscarSoporte"><i class="fas fa-search"></i></button></div>
                                        </div>
                                        <button type="button" class="btn btn-primary btn-sm" id="btnNuevoSoporteModal">
                                            <i class="fas fa-user-plus mr-1"></i> Nuevo
                                        </button>                                    </div>
                                </div>

                                <div class="table-responsive mt-2" style="max-height: 420px; overflow:auto;">
                                    <table class="table table-sm table-bordered mb-0" id="tblSoportes">
                                        <thead class="thead-light">
                                            <tr><th>Nombre</th><th>Correo</th><th>Activo</th><th style="width:75px;">Acción</th></tr>
                                        </thead>
                                        <tbody></tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- DERECHA: árbol tipos/subtipos -->
                        <div class="col-md-5">
                            <form id="formSoporte">
                                <div class="panel-title">Permisos (Tipo/Subtipo)</div>
                                <div id="permTree" class="border rounded p-2" style="max-height:380px; overflow:auto;"></div>
                                <div class="hint mt-2">
                                    Marca <strong>“Todos los subtipos”</strong> para atender cualquiera.<br />
                                    Si marcas subtipos individuales, no selecciones “Todos”.
                                </div>
                            </form>

                            <!-- NUEVA SECCIÓN: Visibilidad entre Soportes -->
                            <div class="card-lite mt-3">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="card-title mb-0">Ver casos de…</div>
                                    <button class="btn btn-link btn-sm p-0" type="button"
                                            data-toggle="collapse" data-target="#panelVisibilidadSoportes"
                                            aria-expanded="true" aria-controls="panelVisibilidadSoportes">
                                        <i class="fas fa-chevron-down"></i>
                                    </button>
                                </div>

                                <div id="panelVisibilidadSoportes" class="collapse show">
                                    <div class="mb-2 small text-muted">
                                        Define qué otros soportes puede visualizar el soporte actual.
                                    </div>

                                    <div class="mb-2">
                                        <span class="small text-muted mr-1">Soporte actual (Viewer):</span>
                                        <span id="lblViewerChip" class="chip">—</span>
                                    </div>

                                    <div class="form-row align-items-end mb-2">
                                        <div class="form-group col-8">
                                            <label class="mb-1" for="txtTargetId">Soporte (Target)</label>
                                            <input type="text"
                                                   id="txtTargetId"
                                                   class="form-control form-control-sm"
                                                   placeholder="Carnet o correo del soporte" />
                                        </div>
                                        <div class="form-group col-4">
                                            <button type="button"
                                                    id="btnAddVis"
                                                    class="btn btn-rojo btn-sm btn-block mt-3">
                                                <i class="fas fa-user-plus mr-1"></i> Agregar permiso
                                            </button>
                                        </div>
                                    </div>

                                    <div class="table-responsive" style="max-height:220px; overflow:auto;">
                                        <table id="tblVisibilidad" class="table table-sm table-bordered mb-0">
                                            <thead>
                                                <tr>
                                                    <th>Soporte (Target)</th>
                                                    <th style="width:70px;">Quitar</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @* se llena por JS *@
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                    <button type="button" id="btnGuardarSoporte" class="btn btn-primary">Guardar</button>
                </div>
            </div>
        </div>
    </div>

</div> <!-- /#helpdeskPage -->
<!-- Modal: añade data-action y type="button" para evitar submits raros -->
<div class="modal fade" id="modalRecategorizar" tabindex="-1" role="dialog" aria-hidden="true" data-action="@Url.Action("RecategorizarCaso","Helpdesk2025")">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-tags mr-2"></i>Recategorizar Caso</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <form id="formRecateg" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="CasoIDRecateg" name="CasoID" />
                    <div class="form-group">
                        <label class="mb-1" for="TipoIDRecateg">Tipo</label>
                        <select id="TipoIDRecateg" name="TipoCasoID" class="form-control" required></select>
                    </div>
                    <div class="form-group">
                        <label class="mb-1" for="SubtipoIDRecateg">Subtipo</label>
                        <select id="SubtipoIDRecateg" name="SubtipoCasoID" class="form-control" required></select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <button id="btnGuardarRecateg" type="button" class="btn btn-primary">
                    <i class="fas fa-save mr-1"></i> Guardar cambios
                </button>
            </div>
        </div>
    </div>
</div>

