            /* ====== Adjuntos (CLIENTE → en Crear) ====== */
            var archivosSeleccionados = [];       // ← arreglo propio para manejar add/remove
            var objectUrls = [];                  // ← liberar memoria de previews
            var LIMITE_ARCHIVOS = 10;
            var LIMITE_MB = 10;

            function esImagenByName(name){ return /\.(jpe?g|png|webp)$/i.test(name||''); }
            function esPdfByName(name){ return /\.pdf$/i.test(name||''); }
            function esDocByName(name){ return /\.(docx?|rtf)$/i.test(name||''); }
            function esXlsByName(name){ return /\.(xlsx?|csv)$/i.test(name||''); }

            // Renderiza previews del arreglo archivosSeleccionados
            function renderPreviews(){
                // revocar urls previas
                for(var i=0;i<objectUrls.length;i++){ URL.revokeObjectURL(objectUrls[i]); }
                objectUrls = [];

                var $wrap = $('#previewsWrap').empty();
                for(var i=0;i<archivosSeleccionados.length;i++){
                    var f = archivosSeleccionados[i];
                    var isImg = esImagenByName(f.name);
                    var url = URL.createObjectURL(f);
                    objectUrls.push(url);

                    if(isImg){
                        // imagen → miniatura + fancybox
                        var item = ''+
                          '<a href="'+url+'" data-fancybox="pvGaleria" data-caption="'+(f.name||'')+'">'+
                            '<div class="pv-chip">'+
                                '<img src="'+url+'" alt="'+(f.name||'')+'"/>'+
                                '<button type="button" class="pv-del" data-idx="'+i+'">&times;</button>'+
                                '<span class="pv-name">'+(f.name||'')+'</span>'+
                            '</div>'+
                          '</a>';
                        $wrap.append(item);
                    } else {
                        // doc → chip con icono
                        var icon = '<i class="far fa-file-alt" style="font-size:24px;color:#4B5563"></i>';
                        if(esPdfByName(f.name)) icon = '<i class="far fa-file-pdf" style="font-size:24px;color:#DC2626"></i>';
                        else if(esDocByName(f.name)) icon = '<i class="far fa-file-word" style="font-size:24px;color:#9CA3AF"></i>';
                        else if(esXlsByName(f.name)) icon = '<i class="far fa-file-excel" style="font-size:24px;color:#10b981"></i>';

                        var item2 = ''+
                            '<div class="pv-chip">'+
                                icon+
                                '<button type="button" class="pv-del" data-idx="'+i+'">&times;</button>'+
                                '<span class="pv-name">'+(f.name||'')+'</span>'+
                            '</div>';
                        $wrap.append(item2);
                    }
                }
            }

            // Agrega archivos al arreglo controlando duplicados/límites
            function agregarArchivosArchArray(fileList){
                var agregados = 0;
                for(var i=0;i<fileList.length;i++){
                    var f = fileList[i];
                    var mb = (f.size || 0) / (1024*1024);
                    if(mb > LIMITE_MB){
                        Swal.fire('Límite','"'+(f.name||'archivo')+'" excede '+LIMITE_MB+' MB.','warning');
                        continue;
                    }
                    if(archivosSeleccionados.length >= LIMITE_ARCHIVOS){
                        Swal.fire('Límite','Máximo '+LIMITE_ARCHIVOS+' archivos.','info');
                        break;
                    }
                    // evitar duplicados por nombre+size+lastModified
                    var dup = false;
                    for(var j=0;j<archivosSeleccionados.length;j++){
                        var x=archivosSeleccionados[j];
                        if(x.name===f.name && x.size===f.size && x.lastModified===f.lastModified){ dup=true; break; }
                    }
                    if(dup) continue;

                    archivosSeleccionados.push(f);
                    agregados++;
                }
                if(agregados>0) renderPreviews();
            }

            // Quitar archivo por índice del arreglo
            $(document).on('click', '.pv-del', function(){
                var idx = parseInt($(this).data('idx'), 10);
                if(isNaN(idx)) return;
                archivosSeleccionados.splice(idx, 1);
                renderPreviews();
            });

            $('#btnLimpiarArchivos').on('click', function(){
                archivosSeleccionados = [];
                $('#archivos').val('');
                renderPreviews();
            });

            // Input file → agregar
            $('#archivos').on('change', function(e){
                var files = e.target.files || [];
                if(files.length>0) agregarArchivosArchArray(files);
                // limpiar input para permitir volver a seleccionar mismos nombres si se quitó
                $('#archivos').val('');
            });

            // Drag & Drop en dropzone
            var $dz = $('#fileDropZone');
            $dz.on('dragover', function(e){ e.preventDefault(); e.stopPropagation(); $dz.addClass('dragover'); });
            $dz.on('dragleave dragend drop', function(e){ $dz.removeClass('dragover'); });
            $dz.on('drop', function(e){
                e.preventDefault(); e.stopPropagation();
                var dt = e.originalEvent.dataTransfer;
                if(dt && dt.files && dt.files.length>0){ agregarArchivosArchArray(dt.files); }
            });

