        /* =========================================================
           Analítica Soporte 360
           ======================================================== */
        function cargarAnalitica() {
            const estados = ['Pendiente', 'Asignado', 'En Proceso', 'Cerrado', 'Cancelado'];
            const reqs = estados.map(function (e) {
                return $.getJSON('@Url.Action("ObtenerCasosPorEstado","Helpdesk2025")', { estado: e });
            });

            $.when.apply($, reqs).done(function () {
                const args = (arguments.length === 1 ? [arguments] : arguments);
                const all = [];
                for (let i = 0; i < args.length; i++) {
                    const r = args[i][0];
                    if (r && r.success && Array.isArray(r.data)) {
                        all.push.apply(all, r.data.map(function (x) {
                            var obj = $.extend({}, x);
                            obj.__Estado = estados[i];
                            return obj;
                        }));
                    }
                }
                __analitica.all = all;
            });
        }

        function buildSoporteDropdown(soportesAgrupados) {
            const $ddl = $('#ddlSoporteSel').empty();

            soportesAgrupados.forEach(function (g) {
                if (g.Subgerencia) {
                    const $optgroup = $('<optgroup/>').attr('label', 'Subgerencia: ' + g.Subgerencia);
                    g.Items.forEach(function (it) {
                        $optgroup.append(
                            $('<option/>').val(it.Key).text(it.Nombre + (it.Area ? ' - ' + it.Area : ''))
                        );
                    });
                    $ddl.append($optgroup);
                } else {
                    g.Items.forEach(function (it) {
                        $ddl.append(
                            $('<option/>').val(it.Key).text(it.Nombre + (it.Area ? ' - ' + it.Area : ''))
                        );
                    });
                }
            });

            if (!_soporteSel && soportesAgrupados.length && soportesAgrupados[0].Items.length) {
                _soporteSel = soportesAgrupados[0].Items[0].Key;
            }

            if (_soporteSel) $ddl.val(_soporteSel);
        }

