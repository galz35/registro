        /* =========================================================
           Utilidades generales
           ======================================================== */

        // =========================================================
        //  HELPERS / UTILIDADES
        // =========================================================
        function _esc(s) {
            return String(s || '').replace(/[&<>"']/g, function (m) {
                return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[m];
            });
        }

        function parseNetDate(v) {
            if (!v) return null;
            if (typeof v === 'string' && v.indexOf('/Date(') === 0) {
                return new Date(parseInt(v.match(/\d+/)[0], 10));
            }
            return new Date(v);
        }
        function fechaDisp(v) {
            const d = parseNetDate(v);
            return d ? moment(d).format('DD/MM/YYYY') : '-';
        }
        function fechaKey(v) {
            const d = parseNetDate(v);
            return d ? moment(d).format('YYYYMMDD') : '00000000';
        }
        function normEstado(v) {
            if (!v) return 'Pendiente';
            if (v === 'Abierto') return 'Pendiente';
            return v;
        }
        function pill(v) {
            v = normEstado(v);
            if (v === 'Pendiente') return '<span class="pill pill-pend">Pendiente</span>';
            if (v === 'Asignado') return '<span class="pill pill-asig">Asignado</span>';
            if (v === 'En Proceso') return '<span class="pill pill-proc">En Proceso</span>';
            if (v === 'Cerrado') return '<span class="pill pill-close">Cerrado</span>';
            if (v === 'Cancelado') return '<span class="pill pill-canc">Cancelado</span>';
            return v || '-';
        }
        const rankEstado = {
            'Pendiente': 0,
            'Asignado': 1,
            'En Proceso': 2,
            'Cerrado': 3,
            'Cancelado': 4
        };
        function normTxt(s) {
            return (s || '').toString()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .toLowerCase()
                .trim();
        }
        function getSubgerenciaFromRow(c) {
            return c.SUBGERENTE || c.Subgerencia || c.SubGerencia || c.SubGerenciaNombre || c.Fgerencia || '';
        }

        // MIME helpers adjuntos
        function esImagenMime(mime, nombre) {
            mime = (mime || '').toLowerCase();
            if (mime.indexOf('image/') === 0) return true;
            var n = (nombre || '').toLowerCase();
            return n.endsWith('.jpg') || n.endsWith('.jpeg') || n.endsWith('.png') || n.endsWith('.gif') || n.endsWith('.webp');
        }
        function esPDFMime(mime, nombre) {
            mime = (mime || '').toLowerCase();
            if (mime === 'application/pdf') return true;
            var n = (nombre || '').toLowerCase();
            return n.endsWith('.pdf');
        }

        function getEstadoBadgeClasses(estado) {
            estado = normEstado(estado);
            if (estado === 'Pendiente') return 'badgePend';
            if (estado === 'Asignado') return 'badgeAsig';
            if (estado === 'En Proceso') return 'badgeProc';
            if (estado === 'Cerrado') return 'badgeCerr';
            if (estado === 'Cancelado') return 'badgeCanc';
            return 'badgePend';
        }
        function getEstadoText(estado) {
            return normEstado(estado || '');
        }

        /* =========================================================
           Sub-estado + Chat de notas
           ======================================================== */

        // Cargar dropdown de subestados y fijar valor original
        function cargarDropdownSubEstados(casoId, seleccionadoId) {
            var $ddl = $('#ddlSubEstado_' + casoId);
            if (!$ddl.length) return;

            $ddl.empty().append('<option value="">-- Etapa / Sub-estado --</option>');

            $.get('@Url.Action("ObtenerSubEstados","Helpdesk2025")', function (r) {
                if (!r || !r.success || !r.data) return;

                var selStr = (seleccionadoId != null) ? String(seleccionadoId) : '';
                $.each(r.data, function (i, item) {
                    var val = String(item.SubEstadoID);
                    var sel = (val === selStr) ? 'selected' : '';
                    $ddl.append('<option value="' + val + '" ' + sel + '>' + item.Nombre + '</option>');
                });

                var fijo = $ddl.val() || '';
                $ddl.data('original', fijo);
            });
        }

        // Cargar historial de notas del chat
        function cargarNotasChat(idCaso) {
            const $box = $('#chatContainer_' + idCaso);
            if (!$box.length) return;

            $box.html('<div class="text-center text-muted small mt-5"><i class="fas fa-circle-notch fa-spin"></i> Cargando...</div>');

            $.post('@Url.Action("ObtenerNotas","Helpdesk2025")', { id: idCaso }, function (r) {
                if (!r || !r.success) {
                    $box.html('<div class="text-danger small text-center">Error al cargar chat.</div>');
                    return;
                }

                const notas = Array.isArray(r.data) ? r.data : [];
                if (!notas.length) {
                    $box.html('<div class="text-center text-muted small mt-5">No hay notas. Inicia la conversación.</div>');
                    return;
                }

                $box.empty();
                for (var i = 0; i < notas.length; i++) {
                    var n = notas[i] || {};
                    var autor = _esc(n.AutorNombre || 'Sistema');
                    var msg = _esc(n.Mensaje || '');
                    var fecha = _esc(n.FechaStr || '');

                    var soyAdmin = (window._yo && _yo.EsAdmin) ? true : false;
                    var miNombre = (window._yo && _yo.Nombre) ? String(_yo.Nombre) : '';
                    var esMio = (autor === miNombre) || (autor === 'Yo') || (autor === 'Soporte' && soyAdmin);

                    var clase = esMio ? 'chat-me' : 'chat-other';

                    $box.append(
                        '<div class="chat-bubble ' + clase + '">' +
                        '<span class="chat-author">' + autor + '</span>' +
                        '<div class="chat-text">' + msg.replace(/\n/g, '<br>') + '</div>' +
                        '<div class="chat-meta">' + fecha + '</div>' +
                        '</div>'
                    );
                }
                $box.scrollTop($box[0].scrollHeight);
            }, 'json').fail(function () {
                $box.html('<div class="text-danger small text-center">Error de conexión.</div>');
            });
        }

        // Enviar nota + opcionalmente actualizar subestado
        window.enviarNotaChat = function (idCaso) {
            const $txt = $('#txtChat_' + idCaso);
            let msj = ($txt.val() || '').trim();
            if (!msj.length) { $txt.focus(); return; }

            const $ddl = $('#ddlSubEstado_' + idCaso);
            const nuevoSub = $ddl.length ? ($ddl.val() || '') : '';
            const origSub = $ddl.length ? ($ddl.data('original') || '') : '';

            const $btn = $('button[onclick="enviarNotaChat(' + idCaso + ')"]');

            $txt.prop('disabled', true);
            $btn.prop('disabled', true);
            $.LoadingOverlay('show');
            if ($ddl.length && !nuevoSub) {
                $.LoadingOverlay('hide');
                $txt.prop('disabled', false);
                $btn.prop('disabled', false);

                Swal.fire(
                    'Seleccione un estado',
                    'Antes de enviar la nota, seleccione en qué etapa / estado está el caso.',
                    'info'
                );

                $ddl.focus(); // 👈 lleva el foco al combo
                return;
            }

            function finOK(prefijo) {
                $.LoadingOverlay('hide');
                $txt.val('').prop('disabled', false).focus();
                $btn.prop('disabled', false);
                cargarNotasChat(idCaso);
                if ($ddl.length && nuevoSub) {
                    $ddl.data('original', nuevoSub);
                }
                const Toast = Swal.mixin({
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 2000
                });
                Toast.fire({
                    icon: 'success',
                    title: (nuevoSub && nuevoSub !== origSub)
                        ? 'Subestado y nota guardados'
                        : 'Nota guardada'
                });
            }

            function finError(msg) {
                $.LoadingOverlay('hide');
                $txt.prop('disabled', false);
                $btn.prop('disabled', false);
                Swal.fire('Error', msg || 'No se pudo guardar', 'error');
            }

            const enviarNota = function (etiqueta) {
                const payload = {
                    casoId: idCaso,
                    mensaje: (etiqueta ? '[' + etiqueta + '] ' : '') + msj
                };
                $.post('@Url.Action("AgregarNotaUsuario","Helpdesk2025")', payload, function (r2) {
                    if (!r2 || !r2.success) {
                        finError((r2 && r2.message) || 'No se pudo guardar la nota.');
                        return;
                    }
                    finOK(etiqueta ? '[' + etiqueta + ']' : '');
                }).fail(function () {
                    finError('Error de conexión al guardar la nota.');
                });
            };

            // Si cambió subestado, primero actualizamos subestado
            if ($ddl.length && nuevoSub && nuevoSub !== origSub) {
                $.post('@Url.Action("ActualizarSubEstadoCaso","Helpdesk2025")', {
                    casoId: idCaso,
                    subEstadoId: nuevoSub
                }, function (r1) {
                    if (!r1 || !r1.success) {
                        finError((r1 && r1.message) || 'No se pudo actualizar el subestado.');
                        return;
                    }
                    const txtSel = $ddl.find('option:selected').text() || '';
                    enviarNota(txtSel);
                       $.post('@Url.Action("NotificarNotaCaso","Helpdesk2025")', {
                           casoId: idCaso, estado: txtSel,
                           mensaje: msj
        }).always(function () {
            // Éxito visual del chat (aunque el correo falle)
            finOK(etiqueta ? '[' + etiqueta + ']' : '');
        }).fail(function () {
            Swal.fire(
                'Nota guardada',
                'La nota se guardó, pero hubo un problema al enviar el correo.',
                'warning'
            );
        });

                }).fail(function () {
                    finError('Error de conexión al actualizar el subestado.');
                });
            } else {
                enviarNota('');
            }
        };

        // Crear nuevo subestado al vuelo
        window.nuevoSubEstado = function (casoId) {
            var existentes = [];
            $('#ddlSubEstado_' + casoId + ' option').each(function () {
                var t = $(this).text();
                if (t && t !== 'Cargando...' && t !== '-- Etapa / Sub-estado --') {
                    existentes.push(t.toLowerCase());
                }
            });

            Swal.fire({
                title: 'Nueva Etapa / Sub-estado',
                html:
                    '<div class="text-left">' +
                    '<p class="text-muted small mb-2">Se agregará al catálogo global.</p>' +
                    '<input type="text" id="inpNE" class="swal2-input" placeholder="Ej: En Taller Externo" style="width:calc(100% - 2rem)">' +
                    '<div id="errNE" class="text-danger small mt-1" style="display:none;"></div>' +
                    '<div class="d-flex justify-content-end mt-2">' +
                    '<button type="button" class="btn btn-outline-secondary mr-2" id="btnNE_Cancelar">Cancelar</button>' +
                    '<button type="button" class="btn btn-success" id="btnNE_Guardar"><i class="fas fa-save mr-1"></i>Guardar y usar</button>' +
                    '</div>' +
                    '</div>',
                showConfirmButton: false,
                didOpen: function () {
                    function guardar() {
                        var nombre = ($('#inpNE').val() || '').trim();
                        if (!nombre.length) {
                            $('#errNE').text('Escribe un nombre.').show();
                            return;
                        }
                        if (existentes.indexOf(nombre.toLowerCase()) > -1) {
                            $('#errNE').text('Ese nombre ya existe.').show();
                            return;
                        }
                        $('#errNE').hide();
                        $('#btnNE_Guardar,#btnNE_Cancelar').prop('disabled', true);
                        $.LoadingOverlay('show');

                        $.post('@Url.Action("CrearSubEstado","Helpdesk2025")', { nombre: nombre }, function (r) {
                            $.LoadingOverlay('hide');
                            if (!r || !r.success) {
                                $('#btnNE_Guardar,#btnNE_Cancelar').prop('disabled', false);
                                $('#errNE').text((r && r.message) || 'No se pudo crear.').show();
                                return;
                            }
                            Swal.close();
                            cargarDropdownSubEstados(casoId, r.id);
                            setTimeout(function () {
                                var $ddl = $('#ddlSubEstado_' + casoId);
                                $ddl.val(String(r.id));
                                $ddl.data('original', ''); // fuerza cambio
                            }, 250);
                            const Toast = Swal.mixin({
                                toast: true,
                                position: 'top-end',
                                showConfirmButton: false,
                                timer: 2000
                            });
                            Toast.fire({ icon: 'success', title: 'Sub-estado creado' });
                        }).fail(function () {
                            $.LoadingOverlay('hide');
                            $('#btnNE_Guardar,#btnNE_Cancelar').prop('disabled', false);
                            $('#errNE').text('Error de conexión.').show();
                        });
                    }


        // =========================================================
        //  EVENTOS UI
        // =========================================================
                    $('#btnNE_Guardar').on('click', guardar);
                    $('#btnNE_Cancelar').on('click', function () { Swal.close(); });
                    $('#inpNE').on('keydown', function (e) { if (e.keyCode === 13) guardar(); });
                    setTimeout(function () { $('#inpNE').focus(); }, 120);
                }
            });
        };

