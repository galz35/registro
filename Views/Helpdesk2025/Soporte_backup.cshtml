@* Views/Helpdesk2025/TodosLosCasos.cshtml *@
@{ ViewBag.Title = "Todos los Casos";
                Layout = "~/Views/Shared/_mainLayout.cshtml"; }

<!-- Fancybox / Buttons DataTables (export Excel) -->
<link href="~/onlinecss/jquery.fancybox.min.css" rel="stylesheet" />

@* =========================================================
    ESTILOS (solo presentación)
    ========================================================= *@
<style>
    /* =========================================================
     0. Z-index global / layout base
     ========================================================= */
    .swal2-container {
        z-index: 5000 !important;
    }

    /* Quitamos el martillo que dañaba todo.
     Dejamos solo color base del contenedor, SIN afectar hijos */
    #helpdeskPage {
        color: #111827;
    }

    /* Ajuste de z-index de modales bootstrap */
    .modal {
        z-index: 4000;
    }

    .modal-backdrop {
        z-index: 3500;
    }

    /* =========================================================
     1. Botones Excel (main y soporte360)
     ========================================================= */
    #helpdeskPage #exportMainWrap .dt-buttons .buttons-excel.buttons-html5.btn-secondary,
    #helpdeskPage #exportSupWrap .dt-buttons .buttons-excel.buttons-html5.btn-secondary {
        background-color: #10b981 !important; /* verde */
        border-color: #10b981 !important;
        color: #fff !important;
        border-radius: 8px !important;
        font-weight: 600 !important;
        font-size: .8rem !important;
        line-height: 1rem !important;
        padding: .45rem .75rem !important;
        display: inline-flex !important;
        align-items: center !important;
        box-shadow: 0 4px 10px rgba(16,185,129,.3) !important;
        outline: none !important; /* quita borde gris en focus */
    }

        #helpdeskPage #exportMainWrap .dt-buttons .buttons-excel.buttons-html5.btn-secondary span,
        #helpdeskPage #exportMainWrap .dt-buttons .buttons-excel.buttons-html5.btn-secondary i,
        #helpdeskPage #exportSupWrap .dt-buttons .buttons-excel.buttons-html5.btn-secondary span,
        #helpdeskPage #exportSupWrap .dt-buttons .buttons-excel.buttons-html5.btn-secondary i {
            color: #fff !important;
        }

        #helpdeskPage #exportMainWrap .dt-buttons .buttons-excel.buttons-html5.btn-secondary:hover,
        #helpdeskPage #exportSupWrap .dt-buttons .buttons-excel.buttons-html5.btn-secondary:hover {
            background-color: #0ea472 !important;
            border-color: #0ea472 !important;
            box-shadow: 0 6px 14px rgba(16,185,129,.4) !important;
            color: #fff !important;
        }

    /* =========================================================
     2. Texto, links, tablas, cards generales
     ========================================================= */

    /* links */
    #helpdeskPage a {
        color: #1d4ed8;
    }

        #helpdeskPage a:hover {
            color: #1e40af;
            text-decoration: none;
        }

    /* scroll tablas */
    #helpdeskPage .table-responsive {
        overflow-x: auto !important;
        overflow-y: visible !important;
    }

    #helpdeskPage .dataTables_wrapper .row {
        overflow: visible !important;
    }

    /* card base */
    #helpdeskPage .card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        margin-bottom: 24px;
    }

    #helpdeskPage .card-header {
        background: #f8fafc;
        border-bottom: 1px solid #e5e7eb;
        color: #0f172a;
    }

    /* filas alternas tabla */
    #helpdeskPage .table-striped tbody tr:nth-of-type(odd) {
        background: #f8fafc;
    }
    /* --- Dropzone para Cerrar Caso --- */
    .dropzone-cierre {
        border: 2px dashed #94a3b8;
        border-radius: 12px;
        background: #f8fafc;
        padding: 16px;
        position: relative;
        text-align: center;
        transition: all 0.2s ease;
    }

        .dropzone-cierre.dragover {
            border-color: #10b981;
            background: #ecfdf5;
        }

    .drop-inner-cierre {
        font-size: .85rem;
        color: #475569;
        line-height: 1.2rem;
    }

    .fileInput-cierre {
        width: 100%;
        background: #fff;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        padding: .5rem .75rem;
        font-size: .8rem;
        margin-top: .75rem;
        cursor: pointer;
    }

    #previewsCierreWrap {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 10px;
        justify-content: center;
    }
    /* thead tablas */
    #helpdeskPage .table thead th {
        background: #eef2f7;
        color: #111827;
    }

    /* filtros fila 2 tabla principal */
    #helpdeskPage #tablaTodosLosCasos thead tr.filters th {
        background: #f3f4f6 !important;
        vertical-align: middle;
    }

        #helpdeskPage #tablaTodosLosCasos thead tr.filters th .form-control {
            height: calc(1.8125rem + 2px);
        }

    /* filtros fila 2 tabla soporte360 */
    #helpdeskPage #tablaSoporteCasos thead tr.filtersSup th {
        background: #f3f4f6 !important;
        vertical-align: middle;
    }

        #helpdeskPage #tablaSoporteCasos thead tr.filtersSup th .form-control {
            height: calc(1.8125rem + 2px);
        }

    /* dropdown flotante Acciones (fix z-index sobre DataTable) */
    #helpdeskPage .dropdown-menu._float {
        z-index: 3000;
    }

    /* =========================================================
     3. Chips/Pills de estado en tablas y en detalle
     ========================================================= */
    #helpdeskPage .pill {
        display: inline-block;
        padding: .20rem .55rem;
        border-radius: 999px;
        color: #fff !important;
        font-weight: 700;
        font-size: .85rem;
    }

    #helpdeskPage .pill-pend {
        background: #e11d48;
    }

    #helpdeskPage .pill-asig {
        background: #2563eb;
    }

    #helpdeskPage .pill-proc {
        background: #f59e0b;
        color: #111827 !important;
    }

    #helpdeskPage .pill-close {
        background: #10b981;
    }

    #helpdeskPage .pill-canc {
        background: #6b7280;
    }

    /* =========================================================
     4. Tabs de estado (Pendiente / Asignado / ...)
     ========================================================= */
    #helpdeskPage .hd-tabs {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 0 12px;
    }

        #helpdeskPage .hd-tabs .hd-tablink {
            display: inline-block;
            border: 0;
            border-bottom: 3px solid transparent;
            margin: 0 .25rem;
            padding: .75rem 1rem;
            color: #475569;
            font-weight: 800;
            text-decoration: none !important;
            background: transparent !important;
        }

            #helpdeskPage .hd-tabs .hd-tablink.active {
                color: #111827;
                border-bottom-color: #2563eb !important;
                background: linear-gradient(to bottom,#f8fafc,transparent) !important;
            }

            #helpdeskPage .hd-tabs .hd-tablink .badge {
                margin-left: .35rem;
            }

    /* =========================================================
     5. KPIs fila superior (cards horizontales arriba de la tabla)
     ========================================================= */
    #kpiRow {
        display: flex;
        flex-wrap: nowrap;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        gap: 12px;
        margin-bottom: 1rem;
    }

        #kpiRow > .col {
            flex: 0 0 260px !important;
            max-width: 260px !important;
        }

    #helpdeskPage .kpi-icon-pend {
        color: #e11d48;
    }

    #helpdeskPage .kpi-icon-asig {
        color: #2563eb;
    }

    #helpdeskPage .kpi-icon-proc {
        color: #f59e0b;
    }

    #helpdeskPage .kpi-icon-cerr {
        color: #10b981;
    }

    /* =========================================================
     6. Vista Soporte 360° (modal fullscreen style)
     ========================================================= */

    /* Dialog ocupa viewport */
    .soporte360-dialog {
        max-width: 100vw;
        width: 100%;
        margin: 0;
        height: 100vh;
        display: flex;
        align-items: stretch;
    }

    /* Contenedor general del contenido del modal 360 */
    .soporte360-content {
        border-radius: 0;
        width: 100%;
        max-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    /* Header del modal 360 */
    .soporte360-header {
        background: #f8fafc;
        border-bottom: 1px solid #e5e7eb;
        padding: 16px 20px;
    }

    .badge-soft-dark {
        background: #e5e7eb;
        color: #1f2937 !important;
        font-weight: 600;
        border-radius: 999px;
        font-size: .7rem;
        padding: .35rem .5rem;
        line-height: 1;
    }

    /* Select Soporte */
    .soporte360-soporteSel {
        border-radius: 10px;
        font-size: .9rem;
    }

    /* Chips de estado dentro Soporte360 */
    #chipsEstados .estado-chip {
        display: inline-flex;
        align-items: center;
        padding: 6px 10px;
        border: 1px solid #e5e7eb;
        border-radius: 999px;
        margin: 0 8px 8px 0;
        cursor: pointer;
        font-weight: 600;
        background: #fff;
        font-size: .8rem;
        line-height: 1.1rem;
        color: #111827;
    }

        #chipsEstados .estado-chip.active {
            background: #111827 !important;
            color: #fff !important;
            border-color: #111827 !important;
        }

        #chipsEstados .estado-chip .count {
            margin-left: 6px;
            font-weight: 700;
            font-size: .8rem;
        }

    /* KPI badges (mini contadores Pend / Asig / Proc / Cerr) */
    .soporte360-kpis .kpi-badges {
        display: flex;
        flex-wrap: wrap;
        justify-content: end;
    }

        .soporte360-kpis .kpi-badges .kpi-badge {
            display: inline-flex;
            align-items: center;
            font-size: .8rem;
            font-weight: 600;
            line-height: 1.1rem;
            border-radius: 8px;
            padding: .35rem .5rem;
            min-width: 70px;
            justify-content: center;
            box-shadow: 0 4px 10px rgba(0,0,0,.08);
            margin-right: .25rem;
            margin-bottom: .25rem;
            border: 0;
            color: #fff !important;
            text-shadow: 0 1px 2px rgba(0,0,0,.3);
        }

        .soporte360-kpis .kpi-badges .kpi-badge-pend {
            background-color: #e11d48;
            box-shadow: 0 4px 10px rgba(225,29,72,.4);
        }

        .soporte360-kpis .kpi-badges .kpi-badge-asig {
            background-color: #2563eb;
            box-shadow: 0 4px 10px rgba(37,99,235,.4);
        }

        .soporte360-kpis .kpi-badges .kpi-badge-proc {
            background-color: #f59e0b;
            color: #111827 !important;
            text-shadow: none;
            box-shadow: 0 4px 10px rgba(245,158,11,.4);
        }

        .soporte360-kpis .kpi-badges .kpi-badge-cerr {
            background-color: #10b981;
            box-shadow: 0 4px 10px rgba(16,185,129,.4);
        }

    /* Body del modal soporte360 */
    .soporte360-body {
        flex: 1 1 auto;
        min-height: 0;
        padding: 0 20px 20px 20px;
        background: #fff;
    }

    /* Layout interno: tabla izq / detalle der */
    .soporte360-layout {
        display: grid;
        grid-template-columns: minmax(0, 70%) minmax(280px, 30%);
        grid-gap: 20px;
        height: 100%;
        min-height: 0;
    }

    /* LEFT (tabla casos) */
    .soporte360-left {
        min-height: 0;
        display: flex;
        flex-direction: column;
    }

    .table-wrapper-360 {
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        background: #fff;
        box-shadow: 0 10px 20px rgba(0,0,0,.03);
        padding: 12px;
        min-height: 0;
        flex: 1 1 auto;
        overflow: hidden;
    }

        .table-wrapper-360 .table-responsive {
            max-height: calc(100vh - 240px);
            overflow-y: auto;
            overflow-x: auto;
        }

    #tablaSoporteCasos thead th {
        background: #eef2f7;
        position: sticky;
        top: 0;
        z-index: 2;
    }

    #tablaSoporteCasos thead tr.filtersSup th {
        background: #f3f4f6 !important;
        vertical-align: middle;
        position: sticky;
        top: 33px;
        z-index: 1;
    }

    #tablaSoporteCasos .dt-center {
        text-align: center;
    }

    /* RIGHT (detalle caso seleccionado en 360) */
    .soporte360-right {
        min-height: 0;
        display: flex;
        flex-direction: column;
    }

    .detalleCard {
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        background: #fff;
        box-shadow: 0 10px 20px rgba(0,0,0,.03);
        padding: 16px;
        min-height: 0;
        flex: 1 1 auto;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        overflow-y: auto;
    }

        .detalleCard .detalle-desc {
            white-space: pre-line;
            word-break: break-word;
        }

        .detalleCard .detailSectionTtl {
            font-size: .7rem;
            color: #6b7280;
            letter-spacing: .03em;
        }

        .detalleCard #dvMeta,
        .detalleCard #dvHS,
        .detalleCard #dvDesc,
        .detalleCard #dvAdj {
            font-size: .85rem;
        }

    /* Pills dentro del detalle derecho */
    #soporte360 .pill {
        font-size: .78rem;
        padding: .15rem .5rem;
    }

    /* Footer modal 360 */
    .soporte360-footer {
        background: #fafafa;
        border-top: 1px solid #e5e7eb;
        padding: 12px 20px;
        font-size: .8rem;
    }

    /* Banner HS genérico reutilizable */
    #helpdeskPage .hs-box {
        padding: 12px;
        border: 1px dashed #f59e0b;
        background: #fff7ed;
        border-radius: 10px;
    }

        #helpdeskPage .hs-box .title {
            font-weight: 800;
            color: #b45309;
            margin-bottom: 6px;
        }

    /* RIGHT PANEL DETALLE (det360-*) usado dentro del panel derecho de soporte360 */
    .det360-bodyScroll {
        overflow-y: auto;
        max-height: calc(100vh - 260px);
        padding-right: 4px;
    }

    @@edia(max-height:700px) {
        .det360-bodyScroll {
            max-height: calc(100vh - 220px);
        }
    }

    .det360-head {
        border-bottom: 1px solid #e5e7eb;
        margin-bottom: 12px;
    }

    .det360-title {
        font-size: .9rem;
        line-height: 1.25rem;
        font-weight: 600;
        color: #0f172a;
        display: flex;
        flex-wrap: wrap;
        align-items: flex-start;
        gap: .4rem;
        margin-bottom: .35rem;
        word-break: break-word;
    }

    .det360-caseId {
        font-size: .7rem;
        line-height: 1rem;
        font-weight: 600;
        color: #475569;
        background: #f1f5f9;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        padding: 2px 6px;
    }

    .det360-metaRow {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 8px;
    }

    .det360-metaItem {
        font-size: .7rem;
        line-height: 1rem;
        color: #475569;
        font-weight: 500;
    }

    .det360-metaLabel {
        color: #6b7280;
        font-weight: 400;
        margin-bottom: 2px;
        text-transform: uppercase;
        letter-spacing: .03em;
    }

    .det360-metaValue {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        font-weight: 600;
        color: #111827;
        font-size: .8rem;
        line-height: 1.1rem;
    }

    .det360-prio {
        color: #fff;
        border-radius: 6px;
        padding: 2px 6px;
        font-size: .7rem;
        line-height: 1rem;
        font-weight: 600;
    }

    /* badge mini de estado */
    .det360-badge {
        display: inline-flex;
        align-items: center;
        padding: 2px 8px;
        border-radius: 999px;
        font-size: .7rem;
        line-height: 1rem;
        font-weight: 700;
        color: #fff !important;
        box-shadow: 0 2px 4px rgba(0,0,0,.1);
    }

    .det360-badge-pend {
        background: #e11d48;
    }

    .det360-badge-asig {
        background: #2563eb;
    }

    .det360-badge-proc {
        background: #f59e0b;
        color: #111827 !important;
    }

    .det360-badge-cerr {
        background: #10b981;
    }

    .det360-badge-canc {
        background: #6b7280;
    }

    /* tarjetas info dentro del panel derecho */
    .det360-secCard {
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        background: #fff;
        box-shadow: 0 10px 20px rgba(0,0,0,.03);
        margin-bottom: 16px;
    }

    .det360-secHeader {
        background: #f8fafc;
        border-bottom: 1px solid #e5e7eb;
        padding: 8px 12px;
        font-size: .7rem;
        line-height: 1rem;
        font-weight: 700;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: .03em;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .det360-secHeader i {
            font-size: .8rem;
            color: #475569;
        }

    .det360-secBody {
        padding: 12px;
        font-size: .8rem;
        line-height: 1.2rem;
        color: #1f2937;
    }

    .det360-rowPair {
        display: flex;
        flex-wrap: wrap;
        margin: 0 -6px;
    }

        .det360-rowPair + .det360-rowPair {
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px solid #e5e7eb;
        }

    .det360-kv {
        flex: 1 1 50%;
        min-width: 140px;
        padding: 0 6px 12px;
    }

    .det360-kvLabel {
        font-size: .65rem;
        line-height: .9rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .03em;
        margin-bottom: 2px;
    }

    .det360-kvValue {
        font-size: .8rem;
        line-height: 1.1rem;
        font-weight: 500;
        color: #111827;
        word-break: break-word;
    }

    /* descripción caja detalle 360 */
    .det360-descBox {
        border: 1px solid #e5e7eb;
        background: #fff;
        border-radius: 10px;
        padding: 10px;
        font-size: .8rem;
        line-height: 1.2rem;
        color: #1f2937;
        max-height: 25vh;
        overflow-y: auto;
        white-space: pre-line;
        word-break: break-word;
    }

    /* tarjeta HS riesgo */
    .det360-hsCard {
        border: 2px solid #f59e0b;
        background: #fff7ed;
        border-radius: 12px;
        box-shadow: 0 12px 24px rgba(251,146,60,.15);
        margin-bottom: 16px;
    }

    .det360-hsHeader {
        background: rgba(251,146,60,.08);
        border-bottom: 1px dashed #f59e0b;
        padding: 8px 12px;
        font-size: .7rem;
        line-height: 1rem;
        font-weight: 700;
        color: #b45309;
        text-transform: uppercase;
        letter-spacing: .03em;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .det360-hsHeader i {
            font-size: .8rem;
            color: #b45309;
        }

    .det360-hsBody {
        padding: 12px;
        font-size: .75rem;
        line-height: 1.1rem;
        color: #78350f;
    }

    .det360-hsGrid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(140px,1fr));
        gap: 12px;
    }

    .det360-hsLabel {
        font-size: .6rem;
        line-height: .9rem;
        font-weight: 600;
        text-transform: uppercase;
        color: #92400e;
        margin-bottom: 2px;
        letter-spacing: .03em;
    }

    .det360-hsValue {
        font-size: .75rem;
        line-height: 1rem;
        font-weight: 500;
        color: #78350f;
        word-break: break-word;
    }

    /* adjuntos bloque derecho */
    .det360-secTitle {
        font-size: .75rem;
        font-weight: 700;
        line-height: 1rem;
        text-transform: uppercase;
        color: #475569;
        letter-spacing: .03em;
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 10px;
    }

        .det360-secTitle i {
            font-size: .8rem;
            color: #475569;
        }

    .det360-attachWrap {
        display: flex;
        flex-wrap: wrap;
        margin: -6px;
    }

    .det360-attachItem {
        margin: 6px;
        border-radius: 10px;
        border: 2px solid #e5e7eb;
        background: #f3f4f6;
        width: 70px;
        height: 70px;
        overflow: hidden;
        cursor: pointer;
        box-shadow: 0 6px 14px rgba(0,0,0,.06);
    }

        .det360-attachItem img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .det360-attachNote {
        font-size: .65rem;
        line-height: .9rem;
        color: #6b7280;
        margin-top: 4px;
    }

    /* Responsive soporte360 */
    @@media(max-width: 992px) {
        .soporte360-layout {
            grid-template-columns: 1fr;
            grid-template-rows: auto auto;
        }

        .soporte360-right {
            order: -1; /* detalle primero */
        }

        .table-wrapper-360 .table-responsive {
            max-height: calc(60vh);
        }
    }

    /* =========================================================
     7. Modal "Administrar Soportes"
     ========================================================= */
    #helpdeskPage #modalSoporte .modal-content {
        border-radius: 14px;
        overflow: hidden;
    }

    #helpdeskPage #modalSoporte .modal-header {
        background: #f8fafc;
        border-bottom: 1px solid #e5e7eb;
    }

    #helpdeskPage #modalSoporte .modal-title {
        font-weight: 700;
    }

    #helpdeskPage #modalSoporte #subTitleSoporte {
        font-weight: 400;
        font-size: .85rem;
    }

    #helpdeskPage #modalSoporte .panel-title {
        font-weight: 700;
        font-size: .95rem;
        color: #111827;
        margin-bottom: .5rem;
    }

    #helpdeskPage #modalSoporte .hint {
        font-size: .8rem;
        color: #6b7280 !important;
    }

    #helpdeskPage #modalSoporte .card-lite {
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        background: #fff;
        padding: 12px;
        margin-bottom: 12px;
    }

