                const key = c.SoporteID ? String(c.SoporteID) : '__UNASSIGNED__';
                return String(key) === String(_soporteSel);
            });

            const cont = { 'Pendiente': 0, 'Asignado': 0, 'En Proceso': 0, 'Cerrado': 0 };
            arr.forEach(function (c) {
                const e = normEstado(c.__Estado || c.Estado);
                if (cont[e] != null) cont[e]++;
