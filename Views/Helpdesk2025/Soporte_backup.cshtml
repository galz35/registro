        $('#TipoIDRecateg').off('change').on('change', function () {
            var id = $(this).val();
            var $sub = $('#SubtipoIDRecateg');
            $sub.empty();
            if (!id) {
                $sub.append(new Option('Seleccione tipo primero', ''));
                return;
            }
            $.getJSON('@Url.Action("GetSubtiposCaso","Helpdesk2025")', { tipoCasoId: id }, function (r) {
                $sub.append(new Option('Seleccione...', ''));
                if (r && r.success) {
                    for (var i = 0; i < r.data.length; i++) {
                        var s = r.data[i];
                        $sub.append(new Option(s.Nombre, s.SubtipoCasoID));
                    }
                }
            });
        });

        function cargarTiposRecateg(preselectTipoId) {
            var $tipo = $('#TipoIDRecateg');
            $tipo.empty().append(new Option('Cargando...', ''));

            $.getJSON('@Url.Action("GetTiposCaso","Helpdesk2025")', function (r) {
                $tipo.empty().append(new Option('Seleccione...', ''));
                if (r && r.success) {
                    for (var i = 0; i < r.data.length; i++) {
                        var t = r.data[i];
                        $tipo.append(new Option(t.Nombre, t.TipoCasoID));
                    }
                    if (preselectTipoId) {
                        $tipo.val(String(preselectTipoId));
                    }
                    $tipo.trigger('change');
                }
            });
        }

        function abrirRecategorizar(casoId, tipoIdActual, subtipoIdActual) {
            $('#CasoIDRecateg').val(casoId);
            $('#SubtipoIDRecateg').empty().append(new Option('Seleccione...', ''));

            cargarTiposRecateg(tipoIdActual);

            $('#modalRecategorizar').one('shown.bs.modal', function () {
                if (subtipoIdActual) {
                    setTimeout(function () {
                        $('#SubtipoIDRecateg').val(String(subtipoIdActual));
                    }, 150);
                }
            });

            $('#modalRecategorizar').modal('show');
        }

        $(document).on('click', '#btnGuardarRecateg', function () {
            var $btn = $(this);
            var url = $('#modalRecategorizar').data('action');
            var token = $('#formRecateg input[name="__RequestVerificationToken"]').val();

            var casoId = parseInt($('#CasoIDRecateg').val(), 10);
            var tipoId = parseInt($('#TipoIDRecateg').val(), 10);
            var subtipoId = parseInt($('#SubtipoIDRecateg').val(), 10);

            if (!casoId || !tipoId || !subtipoId) {
                Swal.fire('Validación', 'Seleccione Tipo y Subtipo.', 'warning');
                return;
            }

            $btn.prop('disabled', true);
            $.LoadingOverlay("show", { image: "", text: "Guardando..." });

            $.ajax({
                url: url,
                type: 'POST',
                dataType: 'json',
                headers: { 'RequestVerificationToken': token },
                data: {
                    __RequestVerificationToken: token,
                    casoId: casoId,
                    tipoId: tipoId,
                    subtipoId: subtipoId
                }
            }).done(function (r) {
                if (r && r.success) {
                    $('#modalRecategorizar').modal('hide');
                    if (typeof cargarKPIs === 'function') cargarKPIs();
                    if (typeof cargarPorEstado === 'function') cargarPorEstado(_estadoActual);
                    if (typeof cargarAnalitica === 'function') cargarAnalitica();
                    Swal.fire('Éxito', 'Categoría actualizada.', 'success');
                } else {
                    Swal.fire('Error', (r && r.message) || 'No se pudo guardar.', 'error');
                }
            }).fail(function (jqXHR) {
                Swal.fire('Error', 'Error ' + (jqXHR.status || 0) + ' - ' + (jqXHR.statusText || 'Fallo de red'), 'error');
            }).always(function () {
                $.LoadingOverlay("hide");
                $btn.prop('disabled', false);
            });
        });

        // Inicio

