        function renderAdjuntoThumb(a, galId) {
            var mime = (a.TipoArchivo || '').toLowerCase();
            var nombre = a.NombreArchivo || 'archivo';
            var b64 = a.data || '';
            var url = a.UrlDescarga || '';

            if (esImagenMime(mime, nombre) && b64) {
                var src = 'data:' + (mime || 'image/webp') + ';base64,' + b64;
                return (
                    '<a href="' + src + '" data-fancybox="' + galId + '" class="attachItem2" title="' + nombre + '">' +
                    '<img src="' + src + '" alt="' + nombre + '"/>' +
                    '</a>'
                );
            }

            if (!url && b64) {
                var fallbackMime = mime || 'application/octet-stream';
                url = 'data:' + fallbackMime + ';base64,' + b64;
            }

            var icon = '<i class="far fa-file-alt" style="font-size:28px; margin-bottom:4px; color:#4B5563;"></i>';
            if (esPDFMime(mime, nombre)) {
                icon = '<i class="far fa-file-pdf" style="font-size:28px; margin-bottom:4px; color:#DC2626;"></i>';
            }

            return (
                '<a href="' + (url || '#') + '" ' + (url ? 'target="_blank" rel="noopener"' : '') +
                ' class="attachItem2 d-flex flex-column justify-content-center align-items-center text-center" ' +
                ' style="text-decoration:none;">' +
                icon +
                '<div style="font-size:.65rem; line-height:1rem; color:#374151; word-break:break-word; padding:0 4px;">' +
                nombre +
                '</div>' +
                '</a>'
            );
        }

