        function renderPermTree() {
            const $root = $('#permTree').empty();
            if (!_arbolPerm.length) {
                $root.html('<div class="text-muted">Sin datos</div>');
                return;
            }

            const mapa = {};
            (_permisosActuales || []).forEach(function (p) {
                if (!mapa[p.TipoCasoID]) mapa[p.TipoCasoID] = { todos: false, subs: new Set() };
                if (p.SubtipoCasoID == null) mapa[p.TipoCasoID].todos = true;
                else mapa[p.TipoCasoID].subs.add(p.SubtipoCasoID);
            });

            const $ul = $('<ul class="list-unstyled mb-0"></ul>');

            _arbolPerm.forEach(function (t) {
                const tid = t.TipoCasoID;
                const idTodos = nodeIdTodos(tid);

                const $li = $('<li class="mb-2"></li>');

                const $header = $(
                    '<div class="d-flex align-items-center">' +
                    '<strong class="mr-2">' + t.Nombre + '</strong>' +
                    '<input type="checkbox" class="mr-1 chkTodos" id="' + idTodos + '" data-tipo="' + tid + '">' +
                    '<label for="' + idTodos + '" class="mb-0">Todos los subtipos</label>' +
                    '</div>'
                );

                const $subs = $('<div class="ml-4 mt-2"></div>');
                if (t.Subtipos && t.Subtipos.length) {
                    const $u2 = $('<ul class="list-unstyled mb-1"></ul>');
                    t.Subtipos.forEach(function (s) {
                        const idSub = nodeIdSub(s.SubtipoCasoID);
                        const $li2 = $(
                            '<li class="mb-1">' +
                            '<input type="checkbox" class="mr-1 chkSub" id="' + idSub + '" data-tipo="' + tid + '" data-sub="' + s.SubtipoCasoID + '">' +
                            '<label for="' + idSub + '" class="mb-0">' + s.Nombre + '</label>' +
                            '</li>'
                        );
                        $u2.append($li2);
                    });
                    $subs.append($u2);
                } else {
                    $subs.append('<div class="text-muted">Sin subtipos</div>');
                }

                const m = mapa[tid];
                if (m && m.todos) {
                    $header.find('.chkTodos').prop('checked', true);
                    $subs.find('input.chkSub').prop('checked', false).prop('disabled', true);
                } else if (m) {
                    $subs.find('input.chkSub').each(function () {
                        const sid = parseInt($(this).data('sub'), 10);
                        if (m.subs.has(sid)) $(this).prop('checked', true);
                    });
                }

                $header.find('.chkTodos').on('change', function () {
                    const on = $(this).is(':checked');
                    $subs.find('input.chkSub').prop('disabled', on);
                    if (on) $subs.find('input.chkSub').prop('checked', false);
                });

                $li.append($header, $subs);
                $ul.append($li);
            });

            $root.append($ul);
        }

        function leerPermisosSeleccionados() {
            const out = [];
            _arbolPerm.forEach(function (t) {
                const tid = t.TipoCasoID;
                if ($('#' + nodeIdTodos(tid)).is(':checked')) {
                    out.push({ TipoCasoID: tid, SubtipoCasoID: null });
                    return;
                }
                (t.Subtipos || []).forEach(function (s) {
                    if ($('#' + nodeIdSub(s.SubtipoCasoID)).is(':checked')) {
                        out.push({ TipoCasoID: tid, SubtipoCasoID: s.SubtipoCasoID });
                    }
                });
            });
            return out;
        }

