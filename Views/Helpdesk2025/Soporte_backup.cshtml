        function nodeIdTodos(tid) { return 'pt_todos_' + tid; }
        function nodeIdSub(sid) { return 'pt_sub_' + sid; }

        function cargarArbolTipos(cb) {
            if (_arbolPerm.length > 0) { cb && cb(); return; }
            $.getJSON('@Url.Content("~/Helpdesk2025/ArbolTipoSubtipo")', function (r) {
                if (r && r.success) {
                    _arbolPerm = r.data || [];
                    cb && cb();
