        function renderSoporte360() {
            const all = __analitica.all || [];

            const soporteMap = {};
            all.forEach(function (c) {
                const est = normEstado(c.__Estado || c.Estado);
                const key = c.SoporteID ? String(c.SoporteID) : '__UNASSIGNED__';
                const nombre = c.SoporteID ? (c.Nombresoport || '—') : 'Pendiente asignar';
                const area = c.AreaSoporte || c.Area || '';
                const subg = getSubgerenciaFromRow(c) || 'Sin subgerencia';

                if (!soporteMap[key]) {
                    soporteMap[key] = {
                        Key: key,
                        SoporteID: c.SoporteID || '',
                        Nombre: nombre,
                        Area: area || '',
                        Subgerencia: subg || 'Sin subgerencia',
                        Pendiente: 0, Asignado: 0, EnProceso: 0, Cerrado: 0
                    };
                }

                if (est === 'Pendiente') soporteMap[key].Pendiente++;
                else if (est === 'Asignado') soporteMap[key].Asignado++;
                else if (est === 'En Proceso') soporteMap[key].EnProceso++;
                else if (est === 'Cerrado') soporteMap[key].Cerrado++;
            });

            _soportesCache = soporteMap;

            const gruposPorSubg = {};
            $.each(soporteMap, function (k, s) {
                const sg = s.Subgerencia || 'Sin subgerencia';
                if (!gruposPorSubg[sg]) gruposPorSubg[sg] = [];
                gruposPorSubg[sg].push(s);
            });

            $.each(gruposPorSubg, function (k, list) {
                list.sort(function (a, b) {
                    const ca = a.Pendiente + a.Asignado + a.EnProceso + a.Cerrado;
                    const cb = b.Pendiente + b.Asignado + b.EnProceso + b.Cerrado;
                    return cb - ca;
                });
            });

            const soportesAgrupados = Object.keys(gruposPorSubg).sort().map(function (subgName) {
                return {
                    Subgerencia: (subgName === 'Sin subgerencia') ? null : subgName,
                    Items: gruposPorSubg[subgName]
                };
            });

            buildSoporteDropdown(soportesAgrupados);

            $('#ddlSoporteSel').off('change').on('change', function () {
                _soporteSel = $(this).val();
                _estadoChip = 'Pendiente';
                actualizarVistaSoporteActual();
                cargarTablaSoporteCasos();
            });

            if (!dtSup) initTablaSoporte360();
            actualizarVistaSoporteActual();
            cargarTablaSoporteCasos();
        }

        function abrirSoporte360() {
            if (!(__analitica.all || []).length) {
                $.LoadingOverlay('show', { image: "", text: "Preparando resumen..." });
                cargarAnalitica();
                setTimeout(function () {
                    $.LoadingOverlay('hide');
                    renderSoporte360();
                    $('#soporte360').modal('show');
                }, 450);
            } else {
                renderSoporte360();
                $('#soporte360').modal('show');
            }
        }

