                    '<div class="text-muted" style="font-size:.8rem;">Sin adjuntos.</div>'
                );
            }
            var thumbs = '';
            for (var i = 0; i < adj.length; i++) thumbs += renderAdjuntoThumb(adj[i], galId);
            return (
                '<div class="det360-secTitle"><i class="fas fa-paperclip"></i> Adjuntos</div>' +
                '<div class="det360-attachWrap">' + thumbs + '</div>' +
                '<div class="det360-attachNote">Imágenes: click para ampliar • Documentos: abrir/descargar</div>'
            );
        }

