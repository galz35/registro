            const q = ($('#txtBuscarSoporte').val() || '').trim();
            $('#tblSoportes tbody').html('<tr><td colspan="4" class="text-center text-muted">Cargando...</td></tr>');

            $.getJSON('@Url.Content("~/Helpdesk2025/Admin_ListarSoportes")', { q: q }, function (r) {
                if (!(r && r.success)) {
                    $('#tblSoportes tbody').html('<tr><td colspan="4" class="text-center text-danger">No se pudo listar soportes.</td></tr>');
                    return;
                }
                const arr = r.data || [];
                const $tb = $('#tblSoportes tbody').empty();
                if (!arr.length) {
                    $tb.append('<tr><td colspan="4" class="text-center text-muted">Sin soportes configurados.</td></tr>');
                    return;
                }

                arr.forEach(function (s) {
                    const badge = s.Activo ? '<span class="badge badge-success">Sí</span>' : '<span class="badge badge-secondary">No</span>';
                    const btns =
                        '<div class="btn-group btn-group-sm">' +
                        '<button class="btn btn-outline-primary" onclick="adminEditar(\'' + s.SoporteID + '\')"><i class="fas fa-edit"></i></button>' +
                        '<button class="btn ' + (s.Activo ? 'btn-outline-danger' : 'btn-outline-success') + '" onclick="adminToggle(\'' + s.SoporteID + '\',' + (!s.Activo) + ')">' +
                        '<i class="fas ' + (s.Activo ? 'fa-user-slash' : 'fa-user-check') + '"></i></button>' +
                        '</div>';

                    $tb.append(
                        '<tr>' +
                        '<td>' + (s.Nombre || '-') + '</td>' +
                        '<td>' + (s.Email || '-') + '</td>' +
                        '<td class="text-center">' + badge + '</td>' +
                        '<td class="text-center">' + btns + '</td>' +
                        '</tr>'
                    );
                });
            }).fail(function () {
                $('#tblSoportes tbody').html('<tr><td colspan="4" class="text-center text-danger">Fallo de red.</td></tr>');
            });
        }

        window.adminEditar = function (soporteID) {
            _adminSoporteSel = soporteID;
            $('#formSoporte')[0].reset();
            $('#EmpleadoSel').empty();

            $.getJSON('@Url.Content("~/Helpdesk2025/Admin_ObtenerSoporte")', { id: soporteID }, function (r) {
                if (!(r && r.success)) {
                    Swal.fire('Error', r.message || 'No se pudo obtener.', 'error');
                    return;
                }
                const s = r.data;
                $('#SoporteID').val(s.SoporteID);
                $('#Email').val(s.Email);
                $('#Nombre').val(s.Nombre);
                $('#Area').val(s.Area || '');
                $('#Activo').prop('checked', !!s.Activo);

                _permisosActuales = (s.Permisos || []).map(function (p) {
                    return { TipoCasoID: p.TipoCasoID, SubtipoCasoID: p.SubtipoCasoID };
                });

                cargarArbolTipos(function () {
                    renderPermTree();
                });

                setViewerSoporte(s.SoporteID, $('#Nombre').val() || s.SoporteID);
            }).fail(function () {
                Swal.fire('Error', 'Fallo de red al obtener.', 'error');
            });
        };

        window.adminToggle = function (soporteID, activo) {
            $.post('@Url.Content("~/Helpdesk2025/Admin_ToggleSoporte")', { id: soporteID, activo: activo })
                .done(function (r) {
                    if (r && r.success) {
                        cargarSoportes();
                        Swal.fire('OK', 'Estado actualizado.', 'success');
                    } else {
                        Swal.fire('Error', r.message || 'No se pudo cambiar estado.', 'error');
                    }
                }).fail(function () {
                    Swal.fire('Error', 'Fallo de red al cambiar estado.', 'error');
                });
        };

        $('#btnBuscarEmp').on('click', function () {
            const q = ($('#txtBuscarEmp').val() || '').trim();
            if (!q) {
                $('#EmpleadoSel').empty().append(new Option('Escribe algo para buscar', ''));
                return;
            }
            $('#EmpleadoSel').empty().append(new Option('Buscando...', ''));
            $.getJSON('@Url.Action("BuscarEmpleados","Helpdesk2025")', { q: q }, function (r) {
                const arr = (r && r.data) || [];
                $('#EmpleadoSel').empty().append(new Option('Seleccione...', ''));
                arr.forEach(function (e) {
                    $('#EmpleadoSel').append(
