     $('#btnNuevoSoporteModal').off('click').on('click', function (e) {
    e.preventDefault();

    // 1) TOMA lo que haya en pantalla AHORITA (antes de limpiar)
    var req = {
        SoporteID: ($('#SoporteID').val() || '').trim(),
        Email:     ($('#Email').val() || '').trim(),
        Nombre:    ($('#Nombre').val() || '').trim(),
        Area:      ($('#Area').val() || '').trim(),
        Activo:    $('#Activo').is(':checked'),
        EsAdmin:   false,
        EsSuper:   false,
        Permisos:  (typeof leerPermisosSeleccionados === 'function')
                    ? leerPermisosSeleccionados()
                    : []
    };

    // Si está vacío, entonces "Nuevo" solo limpia (modo crear)
    if (!req.SoporteID && !req.Email && !req.Nombre && !req.Area && (!req.Permisos || req.Permisos.length === 0)) {
        $('#SoporteID').val('');
        $('#Email').val('');
        $('#Nombre').val('');
        $('#Area').val('');
        $('#Activo').prop('checked', true);
        window._adminSoporteSel = null;

        if (typeof limpiarPermisosSeleccionados === 'function') {
            limpiarPermisosSeleccionados();
        } else {
            $('#permTree').find('input[type="checkbox"]').prop('checked', false);
        }

        $('#lblViewerChip').text('—');
        $('#txtTargetId').val('');
        $('#tblVisibilidad tbody').empty();
        return;
    }

    // Validaciones del Controller
    if (!req.SoporteID || !req.Email || !req.Nombre) {
        Swal.fire('Atención', 'SoporteID, Email y Nombre son obligatorios.', 'warning');
        return;
    }
    if (!req.Permisos || req.Permisos.length === 0) {
        Swal.fire('Atención', 'Debe seleccionar al menos un permiso.', 'warning');
        return;
    }

    var token = $('input[name="__RequestVerificationToken"]').val();

    // 2) GUARDA lo actual
    $.ajax({
        url: '@Url.Content("~/Helpdesk2025/Admin_GuardarSoporte")',
        type: 'POST',
        data: JSON.stringify(req),
        contentType: 'application/json; charset=utf-8',
        dataType: 'json',
        headers: token ? { 'RequestVerificationToken': token } : {}
    })
    .done(function (r) {
        if (r && (r.success === true || r.success === 1 || r.success === "1")) {
            Swal.fire('Éxito', 'Soporte guardado. Listo para crear uno nuevo.', 'success');

            if (typeof cargarSoportes === 'function') cargarSoportes();
            window._adminSoporteSel = req.SoporteID;

            // 3) YA GUARDÓ -> LIMPIA PARA "NUEVO"
            $('#SoporteID').val('');
            $('#Email').val('');
            $('#Nombre').val('');
            $('#Area').val('');
            $('#Activo').prop('checked', true);

            window._adminSoporteSel = null;

            if (typeof limpiarPermisosSeleccionados === 'function') {
                limpiarPermisosSeleccionados();
            } else {
                $('#permTree').find('input[type="checkbox"]').prop('checked', false);
            }

            $('#lblViewerChip').text('—');
            $('#txtTargetId').val('');
            $('#tblVisibilidad tbody').empty();

            // enfoca primer campo
            $('#SoporteID').focus();
        } else {
            Swal.fire('Error', (r && r.message) ? r.message : 'No se pudo guardar.', 'error');
        }
    })
    .fail(function (xhr) {
        console.log('STATUS:', xhr.status);
        console.log('RESPONSE:', xhr.responseText);
        Swal.fire('Error', 'Fallo al guardar (ver consola).', 'error');
    });
});
 $('#btnGuardarSoporte').off('click').on('click', function (e) {
