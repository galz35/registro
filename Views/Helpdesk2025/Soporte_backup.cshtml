            const btnAsignar = ( (est === 'Pendiente' || est === 'Asignado' || est === 'En Proceso'))
                ? '<a class="dropdown-item" href="#" onclick="abrirAsignar(\'' + row.ID + '\',\'' + (row.TipoCasoID || '') + '\',\'' + (row.SubtipoCasoID || '') + '\')">' +
                '<i class="fas fa-user-tag mr-2"></i> ' + (est === 'Asignado' ? 'Reasignar' : 'Asignar') + '</a>'
                : '';

            const btnRecategorizar = est === 'Pendiente'
                ? '<a class="dropdown-item" href="#" onclick="abrirRecategorizar(\'' + row.ID + '\',\'' + (row.TipoCasoID || '') + '\',\'' + (row.SubtipoCasoID || '') + '\')">' +
                '<i class="fas fa-tags mr-2"></i> Recategorizar</a>'
                : '';

            const btnAtender = (est === 'Pendiente' || est === 'Asignado')
                ? '<a class="dropdown-item text-primary" href="#" onclick="atender(\'' + row.ID + '\')">' +
                '<i class="fas fa-play mr-2"></i> Atender</a>'
                : '';

            const btnCerrar = ((canAdmin || assignedToMe) && est === 'En Proceso')
