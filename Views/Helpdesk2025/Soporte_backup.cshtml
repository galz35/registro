        $('#AdjuntoEvidencia').on('change', function (e) {
            var files = e.target.files;
            if (files && files.length > 0) {
                var f = files[0];

                // Validación de peso (10 MB)
                if (f.size > 10 * 1024 * 1024) {
                    Swal.fire('Archivo muy pesado', 'El archivo excede el límite de 10 MB.', 'warning');
                    $(this).val('');
                    $('#previewsCierreWrap').empty();
                    archivoCierreSel = null;
                    return;
                }

                archivoCierreSel = f;
                renderPreviewCierre(f);
            }
        });
        function renderPreviewCierre(f) {
            if (objUrlCierre) URL.revokeObjectURL(objUrlCierre);
            var $wrap = $('#previewsCierreWrap').empty();

            var isImg = esImagenMime(f.type, f.name);
            objUrlCierre = URL.createObjectURL(f);

            var innerHtml = '';
            if (isImg) {
                innerHtml = '<img src="' + objUrlCierre + '" alt="' + f.name + '"/>';
            } else {
                var icon = '<i class="far fa-file-alt" style="font-size:26px;color:#4B5563"></i>';
                if (esPDFMime(f.type, f.name)) icon = '<i class="far fa-file-pdf" style="font-size:26px;color:#DC2626"></i>';
                else if (f.name.indexOf('.doc') > -1) icon = '<i class="far fa-file-word" style="font-size:26px;color:#9CA3AF"></i>';
                else if (f.name.indexOf('.xls') > -1) icon = '<i class="far fa-file-excel" style="font-size:26px;color:#10b981"></i>';
                innerHtml = icon;
            }

            var htmlChip =
                '<div class="pv-chip mt-2" style="width:100px; height:100px;">' +
                innerHtml +
                '<button type="button" class="pv-del" id="btnQuitarCierre">&times;</button>' +
                '<span class="pv-name" title="' + f.name + '">' + f.name + '</span>' +
                '</div>';

            $wrap.append(htmlChip);
        }
        $(document).on('click', '#btnQuitarCierre', function () {
            archivoCierreSel = null;
            $('#AdjuntoEvidencia').val(''); // Limpia el input real
            $('#previewsCierreWrap').empty();
            if (objUrlCierre) URL.revokeObjectURL(objUrlCierre);
        });

        // Drag & Drop visual effects
        var $dzCierre = $('#dropZoneCierre');
        $dzCierre.on('dragover', function (e) { e.preventDefault(); e.stopPropagation(); $(this).addClass('dragover'); });
        $dzCierre.on('dragleave dragend drop', function (e) { $(this).removeClass('dragover'); });
        $dzCierre.on('drop', function (e) {
            e.preventDefault(); e.stopPropagation();
            var dt = e.originalEvent.dataTransfer;
            if (dt && dt.files && dt.files.length > 0) {
                // Asignamos el archivo al input real para que el FormData lo tome
                document.getElementById('AdjuntoEvidencia').files = dt.files;
                $('#AdjuntoEvidencia').trigger('change');
            }
        });
