    <script src="~/onlinejs/moment.min.js"></script>

    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.responsive.min.js"></script>
    <script src="~/onlinejs/responsive.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.buttons.min.js"></script>
    <script src="~/onlinejs/buttons2.bootstrap4.min.js"></script>
    <script src="~/onlinejs/jszip3.10.1.min.js"></script>
    <script src="~/onlinejs/buttons.html5.min.js"></script>

    <script src="~/Content/plugin/sweetalert2/sweetalert2.all.js"></script>
    <script src="~/onlinejs/loadingoverlay.min.js"></script>
    <script src="~/onlinejs/jquery.fancybox.min.js"></script>

    <script>

        // =========================================================
        //  CONFIGURACIÓN / VARIABLES GLOBALES
        // =========================================================
        /* =========================================================
           Estado global
           ======================================================== */
        let _yo = { EsAdmin: false, EsSuper: false, Carnet: null };

        // =========================================================
        //  TABLA (DataTables) / CARGA PRINCIPAL
        // =========================================================
        let dt = null;           // DataTable principal
        let dtSup = null;        // DataTable Soporte 360
        let _estadoActual = 'Pendiente';
        let __analitica = { all: [] };
        let _soporteSel = null;        // soporte seleccionado en 360
        let _estadoChip = 'Pendiente'; // chip activo en 360
        let _adminSoporteSel = null;   // soporte seleccionado en Admin Soportes
