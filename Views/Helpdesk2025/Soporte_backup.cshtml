        function parseDMY(s) {
            if (!s) return null;
            const p = s.split('/');
            if (p.length !== 3) return null;
            const d = new Date(parseInt(p[2], 10), parseInt(p[1], 10) - 1, parseInt(p[0], 10));
            return isNaN(d.getTime()) ? null : d;
        }

        $.fn.dataTable.ext.search.push(function (settings, data) {
            if (!dt || settings.nTable !== $('#tablaTodosLosCasos')[0]) return true;
            const min = parseDMY($('#minDate').val());
            const d = parseDMY(data[9]); // col Fecha creación

            if (!min) return true;
            if (!d) return false;
            if (min && d < min) return false;
            return true;
        });

        function poblarSelectsFromApi(api) {
            $('#fEstado').find('option:not(:first)').remove();
            $('#fPrioridad').find('option:not(:first)').remove();

            api.column(7).data().unique().sort().each(function (v) {
                v = (v || '').toString().replace(/<[^>]*>/g, '').trim();
                if (v) $('#fEstado').append(new Option(v, v));
            });
            api.column(8).data().unique().sort().each(function (v) {
                v = (v || '').toString().trim();
                if (v) $('#fPrioridad').append(new Option(v, v));
            });
        }
        function repoblarSelects() {
            if (!dt) return;
            poblarSelectsFromApi(dt);
