                        api.column(7).search(
                            val ? '^' + $.fn.dataTable.util.escapeRegex(val) + '$' : '',
                            true, false
                        ).draw();
                    });

                    $('#fPrioridad').on('change', function () {
                        const val = this.value;
                        api.column(8).search(
                            val ? '^' + $.fn.dataTable.util.escapeRegex(val) + '$' : '',
                            true, false
                        ).draw();
                    });

                    $('#minDate').on('change keyup', function () {
                        api.draw();
                    });

                    poblarSelectsFromApi(api);
                }
            });
        }

        /* =========================================================
           Carga por estado
           ======================================================== */
        function cargarPorEstado(estado) {
            _estadoActual = estado;
            $.getJSON('@Url.Action("ObtenerCasosPorEstado","Helpdesk2025")', { estado: estado }, function (r) {
                if (!(r && r.success)) {
                    Swal.fire('Error', r.message || 'No se pudo cargar.', 'error');
                    return;
                }
                const data = r.data || [];
