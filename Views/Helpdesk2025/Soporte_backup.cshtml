   // JS: ya solo usas la propiedad Etiqueta que viene del backend
function cargarVisibilidad() {
    if (!_adminSoporteSel) {
        $('#tblVisibilidad tbody').empty();
        return;
    }

    $('#tblVisibilidad tbody').html('<tr><td colspan="2" class="text-center text-muted">Cargando…</td></tr>');

    $.getJSON('@Url.Action("Admin_Visibilidad_Listar","Helpdesk2025")',
        { viewerId: _adminSoporteSel }, function (r) {
            const $tb = $('#tblVisibilidad tbody').empty();
            if (!(r && r.success)) {
                $tb.html('<tr><td colspan="2" class="text-danger text-center">Error</td></tr>');
                return;
            }
            const arr = r.data || [];
            if (!arr.length) {
                $tb.html('<tr><td colspan="2" class="text-center text-muted">Sin permisos</td></tr>');
                return;
            }

            arr.forEach(function (x) {
                const nom = x.Etiqueta || '-';
                $tb.append(
                    '<tr>' +
                        '<td>' + nom + '</td>' +
                        '<td class="text-center">' +
                            '<button class="btn btn-sm btn-outline-danger" onclick="quitarVis(' + x.Id + ')">' +
                                '<i class="fas fa-times"></i>' +
                            '</button>' +
                        '</td>' +
                    '</tr>'
                );
            });
        }).fail(function () {
            $('#tblVisibilidad tbody').html('<tr><td colspan="2" class="text-danger text-center">Fallo de red</td></tr>');
        });
}


        $('#btnAddVis').on('click', function () {
            const target = ($('#txtTargetId').val() || '').trim();
            if (!_adminSoporteSel) {
                Swal.fire('Atención', 'Seleccione primero el soporte (Viewer).', 'warning');
                return;
            }
            if (!target) return;
            if (String(target).toLowerCase() === String(_adminSoporteSel).toLowerCase()) {
                Swal.fire('Atención', 'No puedes agregarte a ti mismo.', 'info');
                return;
            }

            const formData = new FormData();
            formData.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());
            formData.append('viewerId', _adminSoporteSel);
            formData.append('targetId', target);

            $.ajax({
                url: '@Url.Action("Admin_Visibilidad_Agregar","Helpdesk2025")',
                method: 'POST',
                data: formData,
                processData: false,
                contentType: false
            }).done(function (r) {
                if (r && r.success) {
                    $('#txtTargetId').val('');
                    cargarVisibilidad();
                    if (r.duplicated) {
                        Swal.fire({
                            toast: true, position: 'top-end', icon: 'info',
                            title: 'Ya existía', timer: 1600, showConfirmButton: false
                        });
                    } else {
                        Swal.fire({
                            toast: true, position: 'top-end', icon: 'success',
                            title: 'Agregado', timer: 1200, showConfirmButton: false
                        });
                    }
                } else {
                    Swal.fire('Error', (r && r.message) || 'No se pudo agregar', 'error');
                }
            }).fail(function () {
                Swal.fire('Error', 'Fallo de red', 'error');
            });
        });

        function quitarVis(id) {
            const formData = new FormData();
            formData.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());
            formData.append('id', id);

            $.ajax({
                url: '@Url.Action("Admin_Visibilidad_Quitar","Helpdesk2025")',
                method: 'POST',
                data: formData,
                processData: false,
                contentType: false
            }).done(function (r) {
                if (r && r.success) {
                    cargarVisibilidad();
                } else {
                    Swal.fire('Error', (r && r.message) || 'No se pudo quitar', 'error');
                }
            }).fail(function () {
                Swal.fire('Error', 'Fallo de red', 'error');
            });
        }

        $('#modalSoporte').on('shown.bs.modal', function () {
            const sId = $('#SoporteID').val();
            if (sId) {
                setViewerSoporte(sId, $('#Nombre').val() || sId);
            } else {
                $('#lblViewerChip').text('—');
                $('#tblVisibilidad tbody').empty();
            }
        });

        $('#SoporteID').on('change', function () {
            const sId = ($(this).val() || '').trim();
            if (!sId) {
                _adminSoporteSel = null;
                $('#lblViewerChip').text('—');
                $('#tblVisibilidad tbody').empty();
                return;
            }
            setViewerSoporte(sId, $('#Nombre').val() || sId);
        });

