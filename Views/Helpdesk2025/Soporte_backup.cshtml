        function cargarTablaSoporteCasos() {
            if (!dtSup) return;

            const all = __analitica.all || [];
            const arr = all
                .filter(function (c) {
                    const key = c.SoporteID ? String(c.SoporteID) : '__UNASSIGNED__';
                    return String(key) === String(_soporteSel);
