            const s = _soportesCache[_soporteSel];
            if (!s) {
                $('#lblSoporteSel').text('Seleccione un soporte');
                return;
            }
            let lbl = s.Nombre || '';
            if (s.Area) lbl += ' · ' + s.Area;
            if (s.Subgerencia) lbl += ' · ' + s.Subgerencia;
            $('#lblSoporteSel').text(lbl || 'Seleccione un soporte');
        }

        function renderChipsEstados() {
            const all = __analitica.all || [];
            const arr = all.filter(function (c) {
                const key = c.SoporteID ? String(c.SoporteID) : '__UNASSIGNED__';
                return String(key) === String(_soporteSel);
            });

            const cont = { 'Pendiente': 0, 'Asignado': 0, 'En Proceso': 0, 'Cerrado': 0 };
            arr.forEach(function (c) {
                const e = normEstado(c.__Estado || c.Estado);
                if (cont[e] != null) cont[e]++;
            });

            const chips = [
                { k: 'Pendiente', txt: 'Pendiente' },
                { k: 'Asignado', txt: 'Asignado' },
                { k: 'En Proceso', txt: 'En Proceso' },
                { k: 'Cerrado', txt: 'Cerrado' }
            ];

            const $chips = $('#chipsEstados').empty();
            chips.forEach(function (ch) {
                const $c = $(
                    '<div class="estado-chip ' + (_estadoChip === ch.k ? 'active' : '') + '" data-est="' + ch.k + '">' +
                    ch.txt + ' <span class="count">' + (cont[ch.k] || 0) + '</span></div>'
                );
                $c.on('click', function () {
                    $('#chipsEstados .estado-chip').removeClass('active');
                    $(this).addClass('active');
                    _estadoChip = $(this).data('est');
                    cargarTablaSoporteCasos();
                    limpiarVisorDetalle();
