                $('#EmpleadoSel').empty().append(new Option('Error al buscar', ''));
            });
        });

        $('#EmpleadoSel').on('change', function () {
            const v = $(this).val();
            if (!v) return;
            try {
                const e = JSON.parse(v);
                $('#SoporteID').val(e.Correo || '');
                $('#Email').val(e.Correo || '');
                $('#Nombre').val(e.Nombre || '');
                $('#Area').val(e.Area || '');
            } catch (e) { }
        });

        $('#btnAdminSoportes').on('click', function () {
            _adminSoporteSel = null;
