@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}
 
<head>

    <meta name="viewport" content="width=device-width,  user-scalable=no, maximum-scale=1.0, minimum-scale=1.0">
    <script src="~/onlinejs/jquery-3.6.0.min.js"></script>
   

    <script type="text/javascript" src="~/Scripts/js/Chart.min.js"></script>
    <script type="text/javascript" src="~/Scripts/js/bootstrap.min.js"></script>
    @section scripts {
        <script>

         $(document).ready(function () {
        // Llamada AJAX para obtener el managementId
        $.ajax({
            url: '@Url.Action("GetManagementIdAsync", "Home")',
            type: 'GET',
            success: function (managementId) {
                // Ahora puedes utilizar el managementId en tu lógica JavaScript
                console.log('Management ID:', managementId);
            },
            error: function () {
                console.error('Error al obtener el managementId.');
            }
        });
             async function cargarEmpleadosAsync() {
                 try {
                     const response = await fetch('/Home/GetempleadolistAsync');
                     if (response.ok) {
                         const data = await response.json();
                         // Ahora puedes usar "data" en tu vista
                         console.log(data);
                     } else {
                         console.error('Error al cargar los empleados');
                     }
                 } catch (error) {
                     console.error('Error en la solicitud fetch:', error);
                 }
             }

             // Llama a la función para cargar empleados después de que se cargue la página
             cargarEmpleadosAsync();
    });

        </script>
        <script type="text/javascript">
    var labels_e = [];
    var types_e = [];
    var values_e = [];
    var colors_e = [];

    var labels_d = [];
    var types_d = [];
    var values_d = [];
    var colors_d = [];

    $.ajax({
        type: "POST",
        url:'@Url.Action("GetChartExpensesExecutedAssignment", "Home")',
        contentType: "application/json; charset=utf-8",
        dataType: "json",
        success: function (data) {
            $.each(data, function (key, val) {

                if (val.Type === 'Ejecutado') {
                    labels_e.push(val.PeriodId);
                    types_e.push(val.Type);
                    values_e.push(val.Amount);
                    colors_e.push('rgba(255, 0, 0, 1)')
                } else {
                    labels_d.push(val.PeriodId);
                    types_d.push(val.Type);
                    values_d.push(val.Amount);
                    colors_d.push('rgba(54, 162, 235, 1)')
                }
            });
            var ctx = document.getElementById("chartExpenseExeAsig");
            var chartExpenseExeAsig = new Chart(ctx, {
                type: 'horizontalBar',
                data: {
                    // labels: ['Red', 'Blue', 'Yellow', 'Green', 'Purple', 'Orange'],
                    labels: labels_d,
                    datasets: [{
                        label: 'Disponible',
                        // data: [12, 19, 3, 5, 2, 3],
                        data: values_d,
                        backgroundColor: colors_d
                    },
                    {
                        label: 'Ejecutado',
                        data: values_e,
                        backgroundColor: colors_e
                    }

                    ]
                },
                options: {
                    responsive: true,
                    title: { display: true, text: 'Asignacion vs Ejecucion de Viáticos' },
                    legend: { position: 'bottom' },
                    scales: {
                        yAxes: [{
                            stacked: true,
                            ticks: {
                                beginAtZero: true
                            }
                        }],
                        xAxes: [{ stacked: true }],
                    }
                }
            });

        }
    });
        </script>
        <script type="text/javascript">
    var labels_eh = [];
    var types_eh = [];
    var values_eh = [];
    var colors_eh = [];

    var labels_dh = [];
    var types_dh = [];
    var values_dh = [];
    var colors_dh = [];

    $.ajax({
        type: "POST",
        url: '@Url.Action("GetChartExtraTimeExecutedAssignment", "Home")', /* "/Home/GetChartExtraTimeExecutedAssignment",*/
        contentType: "application/json; charset=utf-8",
        dataType: "json",
        success: function (data) {
            $.each(data, function (key, val) {
                console.log(val);
                if (val.Type === 'Ejecutadas') {
                    labels_eh.push(val.PeriodId);
                    types_eh.push(val.Type);
                    values_eh.push(val.Hours);
                    colors_eh.push('rgba(255, 0, 0, 1)')
                } else {
                    labels_dh.push(val.PeriodId);
                    types_dh.push(val.Type);
                    values_dh.push(val.Hours);
                    colors_dh.push('rgba(54, 162, 235, 1)')
                }
            });
            var ctxx = document.getElementById("budgetExtraTime");
            var budgetExtraTime = new Chart(ctxx, {
                type: 'horizontalBar',
                data: {
                    // labels: ['Red', 'Blue', 'Yellow', 'Green', 'Purple', 'Orange'],
                    labels: labels_dh,
                    datasets: [{
                        label: 'Disponible',

                        data: values_dh,
                        backgroundColor: colors_dh
                    },
                    {
                        label: 'Ejecutado',
                        data: values_eh,
                        backgroundColor: colors_eh
                    }

                    ]
                },
                options: {
                    responsive: true,
                    title: { display: true, text: 'Asignacion vs Ejecucion de Horas Extras' },
                    legend: { position: 'bottom' },
                    scales: {
                        yAxes: [{
                            stacked: true,
                            ticks: {
                                beginAtZero: true
                            }
                        }],
                        xAxes: [{ stacked: true }],
                    }
                }
            });

        }
    });
        </script>
    }
</head>




<body>

    <div>

        <canvas id="chartExpenseExeAsig"> </canvas>

    </div>

    <div>
        <canvas id="budgetExtraTime">  </canvas>
    </div>



</body>


