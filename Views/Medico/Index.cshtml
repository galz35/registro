@* =========================================
    VISTA — Chequeo de Bienestar (NO-COVID)
    - Colores por paso, sin azules
    - Header grande y blanco
    - Envío sin checkbox de confirmación
    - Resumen modal al guardar
    ========================================= *@
@{
    ViewBag.Title = "Chequeo de Bienestar";
    var urlEmpleado = Url.Action("ApiEmpleadoActual", "Medico");
    var urlChk = Url.Action("VerificarEncuestaHoy", "Medico");
    var urlGuardar = Url.Action("Guardar", "Medico");
}
<div class="container-fluid mt-3">
    <div class="d-flex align-items-center justify-content-between mb-2">
        <h1 class="h5 m-0 text-gray-800"><i class="fas fa-stethoscope"></i> Chequeo de Bienestar</h1>
        <div class="small text-muted" id="panelEmpleado">Cargando…</div>
    </div>

    <div class="card shadow-sm border-0">
        <!-- Header temático -->
        <div id="cardHeader" class="card-header py-3 theme-red">
            <div class="d-flex align-items-center justify-content-between">
                <span class="header-time" id="stepTime">2–3 min</span>
                <div class="w-50">
                    <div class="progress bg-dark" style="height:8px;margin:0;">
                        <div id="bar" class="progress-bar" role="progressbar" style="width:0%"></div>
                    </div>
                    <div class="header-step" id="lblPaso">Paso 1/4 — Tu estado hoy</div>
                </div>
            </div>
            <div id="stepGuide" class="step-guide">Cuéntanos cómo te sientes hoy. Si todo está bien, puedes finalizar rápido.</div>
        </div>

        <div class="card-body p-3">
            <form id="formEncuesta" autocomplete="off">
                @Html.AntiForgeryToken()

                <!-- Hidden backend -->
                <input type="hidden" name="Ruta" />
                <input type="hidden" name="Modalidad" />
                <input type="hidden" name="AptoLaboral" />
                <input type="hidden" name="AlergiasActivas" />
                <input type="hidden" name="Triage" />
                <input type="hidden" name="DatosExtraJSON" />

                <!-- PASO 1 -->
                <div class="step" data-step="1">
                    <div class="q">
                        <div class="q-text"><i class="fas fa-face-smile"></i> ¿Cómo te sientes hoy?</div>
                        <div class="chips" data-field="Motivo">
                            <span class="chip" data-ruta="bien">Me siento bien</span>
                            <span class="chip" data-ruta="consulta">Tengo alguna molestia</span>
                        </div>
                    </div>

                    <div class="q">
                        <div class="q-text"><i class="fas fa-briefcase"></i> ¿Dónde trabajas hoy?</div>
                        <div class="chips" data-field="ModalidadChip">
                            <span class="chip">Oficina</span><span class="chip">Remoto</span><span class="chip">Vacaciones</span>
                        </div>
                    </div>

                    <div id="wrapFinRapido" class="q q-full" style="display:none;">
                        <div class="q-text mb-2"><i class="fas fa-check-circle"></i> Antes de cerrar, ¿tu área cuenta con…?</div>
                        <div class="chips chips-multi" data-field="Insumos">
                            <span class="chip">Mascarilla</span><span class="chip">Alcohol gel</span>
                            <span class="chip">Toallas</span><span class="chip">Botiquín</span><span class="chip">Ninguno</span>
                        </div>
                        <div class="mt-2 q-stack">
                            <label class="label-min mb-1">Nota (opcional)</label>
                            <textarea class="form-control form-control-sm" rows="2" name="Comentario" maxlength="500" placeholder="Comentario opcional…"></textarea>
                        </div>
                    </div>
                </div>

                <!-- PASO 2 -->
                <div class="step" data-step="2" data-route="consulta" style="display:none;">
                    <div class="q q-full">
                        <div class="q-text"><i class="fas fa-sitemap"></i> ¿En qué parte del cuerpo?</div>
                        <div id="chipsCategorias" class="chips chips-multi"></div>
                    </div>

                    <div class="q q-full">
                        <div class="q-text"><i class="fas fa-notes-medical"></i> Tus síntomas</div>
                        <div id="chipsSintomasPorCat" class="chips"></div>
                        <small class="text-muted d-block mt-1"><i class="fas fa-hand-point-up"></i> Toca para agregar o quitar. No se duplican.</small>
                    </div>

                    <div id="detallesSintomas" class="q-full"></div>

                    <div class="q q-full">
                        <div class="q-text"><i class="fas fa-heart-pulse"></i> Cosas a vigilar</div>
                        <div class="chips chips-multi" id="chipsUrg">
                            <span class="chip" data-urg="DolorPecho">Dolor en el pecho</span>
                            <span class="chip" data-urg="FaltaAire">Falta de aire</span>
                            <span class="chip" data-urg="DesmayoConfusion">Desmayo o confusión</span>
                            <span class="chip" data-urg="DebilidadBrusca">Debilidad/entumecimiento repentino</span>
                            <span class="chip" data-urg="RigidezCuelloIntensa">Rigidez intensa en el cuello</span>
                            <span class="chip" data-urg="Sangrado">Sangrado que no cede</span>
                            <span class="chip" data-urg="FiebreMuyAlta">Temperatura muy alta</span>
                            <span class="chip" data-urg="NoPuedeApoyar">No puedes apoyar el pie/pierna</span>
                        </div>
                    </div>
                </div>

                <!-- PASO 3 -->
                <div class="step" data-step="3" style="display:none;">
                    <div class="q">
                        <div class="q-text"><i class="fas fa-leaf"></i> ¿Tienes alergia activa hoy?</div>
                        <!-- OJO: sin data-toggle="buttons" ni btn-group-toggle -->
                        <div class="btn-toggle btn-group" data-field="AlergiasActivas">
                            <label class="btn btn-pill btn-outline-success"><i class="fas fa-check"></i> Sí</label>
                            <label class="btn btn-pill btn-outline-secondary"><i class="fas fa-times"></i> No</label>
                        </div>
                        <div class="mt-2 q-stack" id="wrapAlergia" style="display:none;">
                            <label class="label-min mb-1">¿A qué?</label>
                            <input class="form-control form-control-sm" name="AlergiasDescripcion" maxlength="200" placeholder="Describe tu alergia (opcional)" />
                        </div>
                    </div>

                    <div class="q">
                        <div class="q-text"><i class="fas fa-moon"></i> ¿Cómo dormiste?</div>
                        <div class="chips" data-field="Sueno"><span class="chip">Bien</span><span class="chip">Regular</span><span class="chip">Mal</span><span class="chip">Prefiero no decir</span></div>
                    </div>

                    <div class="q">
                        <div class="q-text"><i class="fas fa-glass-water"></i> ¿Te has hidratado hoy?</div>
                        <div class="chips" data-field="Hidratacion"><span class="chip">Sí</span><span class="chip">Poco</span><span class="chip">Aún no</span></div>
                    </div>

                    <div class="q">
                        <div class="q-text"><i class="fas fa-user-check"></i> ¿Estás en condiciones de trabajar?</div>
                        <div class="btn-toggle btn-group" data-field="AptoLaboral">
                            <label class="btn btn-pill btn-outline-success"><i class="fas fa-check"></i> Sí</label>
                            <label class="btn btn-pill btn-outline-secondary"><i class="fas fa-times"></i> Prefiero reposo</label>
                        </div>
                    </div>
                </div>

                <!-- PASO 4 -->
                <div class="step" data-step="4" style="display:none;">
                    <div class="q">
                        <div class="q-text"><i class="fas fa-first-aid"></i> ¿Tu área cuenta con…?</div>
                        <div class="chips chips-multi" data-field="Insumos">
                            <span class="chip">Mascarilla</span><span class="chip">Alcohol gel</span>
                            <span class="chip">Toallas</span><span class="chip">Botiquín</span><span class="chip">Ninguno</span>
                        </div>
                    </div>

                    <div class="q q-full q-stack">
                        <label class="label-min mb-1"><i class="fas fa-comment-medical"></i> Nota (opcional)</label>
                        <textarea class="form-control form-control-sm" rows="3" name="Comentario" maxlength="500" placeholder="Agregar comentario o detalle…"></textarea>
                    </div>

                    <div class="q-full d-flex flex-wrap align-items-center justify-content-between">
                        <div class="text-muted">Progreso: <span id="pct">0%</span></div>
                        <div>
                            <button id="btnEnviar" type="submit" class="btn btn-success px-4">Enviar</button>
                        </div>
                    </div>
                </div>

                <!-- Navegación -->
                <div class="d-flex justify-content-between mt-3 nav-global">
                    <button type="button" id="btnPrevTop" class="btn btn-light" disabled>← Anterior</button>
                    <button type="button" id="btnNextTop" class="btn btn-dark">Siguiente →</button>
                </div>
            </form>
        </div>
    </div>
</div>

<link href="~/onlinecss/flatpickr.min.css" rel="stylesheet" />
<style>
    :root {
        --rojo: #b30000;
        --rojo2: #ff4343;
        --negro: #111;
        --gris: #f6f7fb;
        --gris2: #e9ecf2;
        --blanco: #fff;
        --verde: #60d394;
        --naranja: #f39c12;
        --pizarra: #555;
        --pizarra2: #888;
        --oscuro: #1a1a1a;
    }
    /* tamaños y colores del header */
    .header-time {
        color: #fff;
        font-weight: 800;
        font-size: 1.2rem
    }

    .header-step {
        color: #fff;
        font-weight: 900;
        font-size: 1.25rem;
        margin-top: 6px
    }

    .step-guide {
        color: #fff;
        opacity: .98;
        font-size: 1.05rem;
        margin-top: 4px
    }

    .progress-bar {
        background: var(--verde);
        transition: width .2s ease;
    }

    .card {
        border-radius: 16px;
    }

    #cardHeader {
        position: relative;
        border-top-left-radius: 16px;
        border-top-right-radius: 16px;
    }

        #cardHeader.theme-red {
            background: linear-gradient(135deg,#b30000,#ff4343);
        }

        #cardHeader.theme-slate {
            background: linear-gradient(135deg,#444,#777);
        }

        #cardHeader.theme-green {
            background: linear-gradient(135deg,#3b7,#8fdcb3);
        }

        #cardHeader.theme-dark {
            background: linear-gradient(135deg,#1a1a1a,#333);
        }

    /* bloques */
    .q {
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: center;
        grid-column-gap: 10px;
        padding: 12px 14px;
        background: var(--gris);
        border-radius: 12px;
        margin-bottom: 10px;
    }

    .q-text {
        font-weight: 800;
        margin-right: 8px;
    }

    .q-full {
        grid-column: 1 / -1;
    }

    .q-stack {
        grid-template-columns: 1fr !important;
    }

    .label-min {
        font-weight: 800;
        font-size: 1rem
    }

    /* chips y toggles */
    .chips .chip {
        display: inline-block;
        padding: .5rem .9rem;
        border-radius: 999px;
        background: #fff;
        border: 2px solid #dcdcdc;
        margin: 3px;
        cursor: pointer;
        font-weight: 800;
        user-select: none;
    }

        .chips .chip.active {
            border-color: var(--naranja);
            background: #ffe9c7;
            color: #111;
        }

    .chips-multi .chip.active {
        border-color: #aaa;
        background: #eee;
        color: #111;
    }

    .btn-pill {
        padding: .5rem 1rem;
        border-width: 2px;
        border-radius: 999px;
        font-weight: 800;
    }

    .btn-toggle .btn-outline-success.active, .btn-toggle .btn-outline-success:focus {
        background: var(--verde);
        color: #111;
        border-color: var(--verde);
    }

    .btn-toggle .btn-outline-secondary.active, .btn-toggle .btn-outline-secondary:focus {
        background: #e5e5e5;
        color: #111;
    }

    #btnNextTop {
        background: var(--oscuro);
        color: #fff;
        border: 0
    }

    /* tarjetas síntoma */
    .det-sintoma {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 12px;
        margin: 12px 0;
    }

    .det-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 8px;
    }

        .det-head .ttl {
            font-weight: 900
        }

        .det-head .rm {
            font-size: .9rem;
            border: 0;
            background: #ffe9e9;
            color: #7b241c;
            border-radius: 8px;
            padding: 4px 8px;
            cursor: pointer
        }

    .det-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(170px,1fr));
        grid-gap: 10px;
        margin-bottom: 8px;
    }

    .range-wrap {
        display: flex;
        align-items: center;
        gap: 8px
    }

    .det-notas textarea {
        width: 100%;
        min-height: 70px;
        resize: vertical
    }

    /* responsive */
    @@media (max-width:576px) {
        .q {
            grid-template-columns: 1fr;
        }
    }
</style>

@section scripts{
    <!-- librerías locales (usa solo bundle de bootstrap: ya trae Popper) -->
    <script src="~/onlinejs/jquery-3.6.0.min.js"></script>
    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.buttons.min.js"></script>
    <script src="~/onlinejs/buttons.html5.min.js"></script>
    <script src="~/onlinejs/buttons.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.select.min.js"></script>
    <script src="~/onlinejs/bootstrap.bundle.min.js"></script>
    <!-- quita esta si la tenías: <script src="~/js/popper.min.js"></script> -->
    <!-- quita también bootstrap.min.js para evitar doble init -->
    <script src="~/onlinejs/loadingoverlay.min.js"></script>
    <script src="~/onlinejs/dataTables.responsive.min.js"></script>
    <script src="~/Content/plugin/sweetalert2/sweetalert2.all.js"></script>
    <script src="~/onlinejs/moment.min.js"></script>
    <script src="~/onlinejs/jszip.min.js"></script>
    <script src="~/onlinejs/jquery-ui.js"></script>
    <script src="~/onlinejs/spin.min.js"></script>
    <script src="~/onlinejs/flatpickr.js"></script>

    <script>
// ===== Estado global =====
var urlEmpleado='@urlEmpleado', urlChk='@urlChk', urlGuardar='@urlGuardar';
var empleado=null, step=1, totalSteps=4, ruta=null;
var seleccionados=new Set();
var stepNames=['Tu estado hoy','¿Qué te molesta?','Hábitos y alergias','Revisión y envío'];
var stepHelps=[
  'Cuéntanos cómo te sientes hoy. Si todo está bien, puedes finalizar rápido.',
  'Elige la zona y luego los síntomas. Puedes quitar tocando de nuevo.',
  'Marca si tienes alergias hoy y cuéntanos sobre sueño e hidratación.',
  'Revisa tus datos, agrega una nota si deseas y envía tu registro.'
];
var themes={1:'theme-red',2:'theme-slate',3:'theme-green',4:'theme-dark'};

// Loader
function showLoader(msg){ $.LoadingOverlay("show",{image:"",fontawesome:"fa fa-circle-notch fa-spin",background:"rgba(0,0,0,.2)",size:18,text:msg||"Cargando..."}); }
function hideLoader(){ $.LoadingOverlay("hide"); }
function setBool(field,val){ $('[name="'+field+'"]').val(val?'true':'false'); }
function get(o,ks){ for(var i=0;i<ks.length;i++){ var k=ks[i]; if(o && o[k]!=null) return o[k]; } return ""; }

// ===== Catálogo =====
var catalogo=[ /* (igual que versión anterior, abreviado aquí por espacio) */
  { cat:"General", sintomas:[{key:"fiebreSensacion",label:"Siento el cuerpo caliente (temperatura)"},{key:"escalofrios",label:"Escalofríos"},{key:"cansancio",label:"Cansancio inusual"},{key:"pocoApetito",label:"Poco apetito"}]},
  { cat:"Cabeza y cuello", sintomas:[{key:"dolorCabeza",label:"Dolor de cabeza"},{key:"mareo",label:"Mareo o vértigo"},{key:"rigidezCuello",label:"Cuello rígido"},{key:"debilidadEntum",label:"Debilidad o entumecimiento"},{key:"visionDoble",label:"Veo doble o borroso"}]},
  { cat:"Oídos, nariz y garganta", sintomas:[{key:"dolorOido",label:"Dolor de oído"},{key:"zumbido",label:"Zumbido en oído (tinnitus)"},{key:"bajaAudicion",label:"Escucho menos de lo normal"},{key:"secrecionOido",label:"Salida de líquido del oído"},{key:"dolorGarganta",label:"Dolor de garganta"},{key:"tos",label:"Tos"},{key:"congestion",label:"Nariz tapada"},{key:"estornudos",label:"Estornudos"}]},
  { cat:"Ojos", sintomas:[{key:"ojoIrritado",label:"Ojos irritados o secos"},{key:"dolorOcular",label:"Dolor en los ojos"},{key:"visionBorrosa",label:"Visión borrosa"}]},
  { cat:"Dientes y encías", sintomas:[{key:"dolorDiente",label:"Dolor de diente"},{key:"sensibilidadDental",label:"Sensibilidad dental"}]},
  { cat:"Respirar", sintomas:[{key:"faltaAire",label:"Me falta el aire"},{key:"dolorToracicoResp",label:"Me duele el pecho al respirar"}]},
  { cat:"Latidos y pecho", sintomas:[{key:"dolorPecho",label:"Dolor o presión en el pecho"},{key:"palpitaciones",label:"Latidos rápidos o irregulares"}]},
  { cat:"Estómago e intestinos", sintomas:[{key:"nausea",label:"Náusea"},{key:"vomito",label:"Vómito"},{key:"diarrea",label:"Diarrea"},{key:"dolorEstomacal",label:"Dolor o ardor de estómago"},{key:"dolorAbdominal",label:"Dolor en el abdomen"}]},
  { cat:"Al orinar", sintomas:[{key:"dolorOrinar",label:"Arde o duele al orinar"},{key:"orinaFrecuente",label:"Orino con mucha frecuencia"},{key:"sangreOrina",label:"Veo sangre en la orina"}]},
  { cat:"Músculos y articulaciones", sintomas:[{key:"dolorCuello",label:"Dolor de cuello"},{key:"dolorEspalda",label:"Dolor de espalda"},{key:"dolorHombro",label:"Dolor de hombro"},{key:"dolorCodo",label:"Dolor de codo"},{key:"dolorMunecaMano",label:"Dolor de muñeca o mano"},{key:"dolorCadera",label:"Dolor de cadera"},{key:"dolorRodilla",label:"Dolor de rodilla"},{key:"dolorTobillo",label:"Dolor de tobillo"},{key:"dolorPie",label:"Dolor de pie"},{key:"dolorOseo",label:"Dolor de huesos (general)"},{key:"rigidezArticular",label:"Rigidez en articulaciones"},{key:"hinchazonArticular",label:"Articulación hinchada"}]},
  { cat:"Piel", sintomas:[{key:"erupcion",label:"Ronchas o erupción"},{key:"picazon",label:"Picazón"},{key:"heridaInfectada",label:"Herida inflamada o con pus"}]},
  { cat:"Ánimo y estrés", sintomas:[{key:"ansiedad",label:"Ansiedad o tensión"},{key:"tristeza",label:"Tristeza o desánimo"},{key:"insomnio",label:"Dificultad para dormir"}]}
];

// ===== UI =====
function applyTheme(n){
  var $h=$("#cardHeader");
  $h.removeClass('theme-red theme-slate theme-green theme-dark').addClass(themes[n]||'theme-red');
  $("#stepGuide").text(stepHelps[n-1]||'');
  $("#lblPaso").text('Paso '+n+'/'+totalSteps+' — '+stepNames[n-1]);
}
function progress(){
  var pct=Math.min(100, Math.round((step/totalSteps)*100));
  $('#bar').css('width',pct+'%'); $('#pct').text(pct+'%');
  $('#btnPrevTop').prop('disabled', step===1);
  $('#btnNextTop').toggle(step<totalSteps);
  applyTheme(step);
}
function showStep(n){
  step=n;
  $('.step').each(function(){
    var r=$(this).attr('data-route');
    if(r && r!==ruta){ $(this).hide(); return; }
    $(this).toggle(parseInt($(this).data('step'))===n);
  });
  progress();
}

function renderCategorias(){
  var html=''; catalogo.forEach(function(c){ html+='<span class="chip" data-cat="'+c.cat+'">'+c.cat+'</span>'; });
  $('#chipsCategorias').html(html);
}
function renderSintomasSeleccionables(){
  var selCats=$('#chipsCategorias .chip.active').map(function(){return $(this).data('cat');}).get();
  var html='';
  catalogo.forEach(function(c){
    if(selCats.length===0 || selCats.indexOf(c.cat)>=0){
      html+='<div class="mb-1"><span class="label-min">'+c.cat+'</span></div>';
      c.sintomas.forEach(function(s){
        var activeClass = seleccionados.has(s.key) ? ' active' : '';
        html+='<span class="chip'+activeClass+'" data-sym="'+s.key+'" data-cat="'+c.cat+'">'+s.label+'</span>';
      });
      html+='<div style="height:6px"></div>';
    }
  });
  $('#chipsSintomasPorCat').html(html);
}

function detalleTemplate(symKey, symLabel){
  var lateralKeys=['dolorHombro','dolorCodo','dolorMunecaMano','dolorCadera','dolorRodilla','dolorTobillo','dolorPie','dolorOido','ojoIrritado','dolorOcular','visionBorrosa','bajaAudicion','secrecionOido','hinchazonArticular'];
  var tieneLado = lateralKeys.indexOf(symKey)>=0;
  return `
    <div class="det-sintoma" id="det-${symKey}">
      <div class="det-head">
        <div class="ttl">${symLabel}</div>
        <button type="button" class="rm" data-remove="${symKey}"><i class="fas fa-xmark"></i> Quitar</button>
      </div>
      <div class="det-grid">
        ${tieneLado?`
        <div><div class="label-min">¿En qué lado?</div>
          <div class="chips" data-field="lat-${symKey}">
            <span class="chip">Izquierdo</span><span class="chip">Derecho</span><span class="chip">Ambos</span>
          </div>
        </div>`:''}
        <div>
          <div class="label-min">¿Cuánto molesta? (0–10)</div>
          <div class="range-wrap"><input class="form-control-range" type="range" min="0" max="10" value="5" data-field="sev-${symKey}"><span class="s-badge" id="sev-${symKey}-val">5</span></div>
        </div>
        <div>
          <div class="label-min">¿Desde cuándo?</div>
          <div class="chips" data-field="dur-${symKey}">
            <span class="chip">Horas</span><span class="chip">Días</span><span class="chip">Semanas</span><span class="chip">Meses</span>
          </div>
        </div>
        <div>
          <div class="label-min">¿Con qué frecuencia?</div>
          <div class="chips" data-field="cnt-${symKey}">
            <span class="chip">Ocasional</span><span class="chip">A ratos</span><span class="chip">Frecuente</span>
          </div>
        </div>
      </div>
      <div class="q q-full q-stack" style="background:#fff;border:1px dashed #e5e7eb">
        <label class="label-min mb-1">¿Algo lo provoca o mejora?</label>
        <div class="chips chips-multi" data-field="trg-${symKey}">
          <span class="chip">Esfuerzo</span><span class="chip">Comida</span><span class="chip">Frío/Calor</span>
          <span class="chip">Estrés</span><span class="chip">Reposo mejora</span><span class="chip">Medicamento ayuda</span>
        </div>
      </div>
      <div class="det-notas q-stack">
        <label class="label-min mb-1">Descripción breve (opcional)</label>
        <textarea class="form-control form-control-sm" data-field="nt-${symKey}" maxlength="300" placeholder="Describe el síntoma con tus palabras…"></textarea>
      </div>
    </div>`;
}

// Triage simple
function calcTriage(){
  var urgente=$('#chipsUrg .chip.active').length>0;
  var intensos=0;
  $('#detallesSintomas input[type=range][data-field^="sev-"]').each(function(){
    var v=parseInt($(this).val()||'0',10); if(v>=7) intensos++;
  });
  var nivel='VERDE'; if(urgente){ nivel='ROJO'; } else if(intensos>=2){ nivel='AMARILLO'; }
  if(nivel==='ROJO'){ setBool('AptoLaboral', false); }
  $('[name="Triage"]').val(nivel);
  return nivel;
}

// === Interacciones ===
$(document).on('click','.chips:not(.chips-multi) .chip',function(){
  var $wrap=$(this).closest('.chips'); $wrap.find('.chip').removeClass('active'); $(this).addClass('active');
  if($wrap.data('field')==='Motivo'){
    ruta=$(this).data('ruta')||null; $('[name="Ruta"]').val(ruta||'');
    if(ruta==='bien'){ $('#wrapFinRapido').slideDown(150); setBool('AptoLaboral',true); }
    else{ $('#wrapFinRapido').slideUp(150); }
  }
  if($wrap.data('field')==='ModalidadChip'){ $('[name="Modalidad"]').val($(this).text().trim()); }
  progress();
});

$(document).on('click','.chips-multi .chip',function(){
  var $c=$(this);
  if($c.text().trim()==='Ninguno'){ $c.addClass('active').siblings().removeClass('active'); }
  else{ $c.toggleClass('active'); $c.siblings('.chip:contains("Ninguno")').removeClass('active'); }
  if($c.closest('#chipsCategorias').length){ renderSintomasSeleccionables(); }
  if($c.closest('#chipsUrg').length){   }
});

$('#chipsSintomasPorCat').on('click','.chip',function(){
  var $s=$(this), key=$s.data('sym'), label=$s.text().trim();
  if(seleccionados.has(key)){
    seleccionados.delete(key); $s.removeClass('active'); $('#det-'+key).remove();
  }else{
    seleccionados.add(key); $s.addClass('active');
    if(!document.getElementById('det-'+key)){ $('#detallesSintomas').append(detalleTemplate(key,label)); }
  }
 });

$('#detallesSintomas').on('click','.rm',function(){
  var key=$(this).data('remove'); seleccionados.delete(key); $('#det-'+key).remove();
  $('#chipsSintomasPorCat .chip[data-sym="'+key+'"]').removeClass('active');
 });

$(document).on('input change','input[type=range][data-field^="sev-"]',function(){
  $('#'+$(this).data('field')+'-val').text(this.value);  
});

$(document).on('click','.btn-group[data-field] .btn',function(){
  var $g=$(this).closest('.btn-group'), field=$g.data('field');
  var si=$(this).text().trim().indexOf('Sí')===0;
  $g.find('.btn').removeClass('active'); $(this).addClass('active');
  if(field==='AlergiasActivas'){ $('#wrapAlergia').toggle(si); setBool('AlergiasActivas',si); }
  if(field==='AptoLaboral'){ setBool('AptoLaboral',si); }
});

// Navegación
function goNext(){
  if(!ruta){
    var c=$('.chips[data-field="Motivo"] .chip.active'); ruta=c.data('ruta')||null; $('[name="Ruta"]').val(ruta||'');
    if(!ruta){ Swal.fire("Aviso","Selecciona cómo te sientes hoy para continuar.","info"); return; }
  }
  if(step===1 && ruta==='bien'){ showStep(4); return; }
  if(ruta==='consulta' && step===2){  }
  if(step<totalSteps) showStep(step+1);
}
$('#btnNextTop').on('click',goNext);
$('#btnPrevTop').on('click',function(){ if(step>1) showStep(step-1); });

// Build JSON + Resumen
function chipsSel(sel){ return $(sel+' .chip.active').map(function(){return $(this).text().trim();}).get(); }
function buildDatosExtraJSON(){
  var detalles={};
  $('#detallesSintomas .det-sintoma').each(function(){
    var id=this.id.replace('det-',''); var o={};
    var sev=$('input[data-field="sev-'+id+'"]').val(); if(sev!=null) o.Intensidad=parseInt(sev||'0',10);
    var lat=$('.chips[data-field="lat-'+id+'"] .chip.active').text().trim(); if(lat) o.Lado=lat;
    var dur=$('.chips[data-field="dur-'+id+'"] .chip.active').text().trim(); if(dur) o.Duracion=dur;
    var cnt=$('.chips[data-field="cnt-'+id+'"] .chip.active').text().trim(); if(cnt) o.Frecuencia=cnt;
    var trg=$('.chips[data-field="trg-'+id+'"] .chip.active').map(function(){return $(this).text().trim();}).get(); if(trg.length) o.Desencadenantes=trg;
    var nt=$('[data-field="nt-'+id+'"]').val(); if(nt) o.Notas=nt;
    detalles[id]=o;
  });

  var extras={
    Ruta:$('[name="Ruta"]').val()||null,
    Modalidad:$('[name="Modalidad"]').val()||null,
    Categorias:$('#chipsCategorias .chip.active').map(function(){return $(this).data('cat');}).get(),
    Sintomas:$('#chipsSintomasPorCat .chip.active').map(function(){return $(this).text().trim();}).get(),
    SintomasKeys:Array.from(seleccionados),
    Detalles:detalles,
    Alergia:{Activa:$('[name="AlergiasActivas"]').val()||null,Descripcion:$('[name="AlergiasDescripcion"]').val()||null},
    Habitos:{Sueno:chipsSel('.chips[data-field="Sueno"]')[0]||null,Hidratacion:chipsSel('.chips[data-field="Hidratacion"]')[0]||null},
    Insumos:chipsSel('.chips[data-field="Insumos"]')
  };
  $('[name="DatosExtraJSON"]').val(JSON.stringify(extras));
  return extras;
}
function makeResumenHTML(extras, data){
  function li(title,val){ if(!val|| (Array.isArray(val)&&!val.length)) return ''; return `<li><b>${title}:</b> ${ Array.isArray(val)? val.join(', ') : (''+val) }</li>`; }
  var sintomas = (extras.Sintomas||[]).length? `<ul>${extras.Sintomas.map(function(s){return '<li>'+s+'</li>';}).join('')}</ul>` : '<i>Sin síntomas reportados</i>';
  var detHtml='';
  if(extras.Detalles){
    detHtml = Object.keys(extras.Detalles).map(function(k){
      var d=extras.Detalles[k]||{}; var parts=[];
      if(d.Lado) parts.push('Lado: '+d.Lado);
      if(d.Intensidad!=null) parts.push('Intensidad: '+d.Intensidad+'/10');
      if(d.Duracion) parts.push('Duración: '+d.Duracion);
      if(d.Frecuencia) parts.push('Frecuencia: '+d.Frecuencia);
      if(d.Desencadenantes && d.Desencadenantes.length) parts.push('Desencadenantes: '+d.Desencadenantes.join(', '));
      if(d.Notas) parts.push('Notas: '+d.Notas);
      return '<li><b>'+k+'</b> — '+parts.join(' · ')+'</li>';
    }).join('');
    if(detHtml) detHtml = '<ul>'+detHtml+'</ul>';
  }
  var html = '<div style="text-align:left"><h6 style="margin:0 0 6px 0">Resumen de tu registro</h6><ul>'
    + li('Ruta', extras.Ruta)
    + li('Modalidad', extras.Modalidad)
    + li('Apto laboral', (data.AptoLaboral==='true'?'Sí':(data.AptoLaboral==='false'?'No':'')))
     + li('Alergia activa', (extras.Alergia && extras.Alergia.Activa ? (extras.Alergia.Activa==='true'?'Sí':'No') : ''))
    + li('Detalle alergia', extras.Alergia && extras.Alergia.Descripcion)
    + li('Sueño', extras.Habitos && extras.Habitos.Sueno)
    + li('Hidratación', extras.Habitos && extras.Habitos.Hidratacion)
    + li('Insumos', extras.Insumos)
    + li('Comentario', data.Comentario)
    + '</ul><b>Síntomas seleccionados:</b><div>'+sintomas+'</div>'+(detHtml?('<b>Detalles:</b>'+detHtml):'')+'</div>';
  return html;
}

