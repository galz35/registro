// Submit (envía token en BODY)
$('#formEncuesta').on('submit', async function(e){
  e.preventDefault();
  var extras=buildDatosExtraJSON();
  var data={}, com=$('[name="Comentario"]').val();
  ['Ruta','Modalidad','AptoLaboral','AlergiasActivas','AlergiasDescripcion','Triage','DatosExtraJSON']
    .forEach(function(n){ var v=$('[name="'+n+'"]').val(); if(v!==undefined && v!=="") data[n]=v; });
  if(com) data.Comentario=com;

  // token como campo del form (MVC clásico)
  var token=$('input[name="__RequestVerificationToken"]').val();
  data.__RequestVerificationToken = token;

  showLoader("Enviando…");
  $.ajax({
    url: urlGuardar,
    type: 'POST',
    data: data,
    dataType: 'json' // fuerza parse JSON y evita 'Unexpected token <' si todo OK
  })
  .done(function(res){
    hideLoader();
    if(res && res.ok){
      var resumenHTML = makeResumenHTML(extras, data);
      Swal.fire({ icon:'success', title:'¡Registro guardado!', html:resumenHTML, width: 700 })
        .then(function(){ location.reload(); });
    }else{
      Swal.fire('Error', (res && res.mensaje) ? res.mensaje : 'No se pudo guardar','error');
    }
  })
  .fail(function(xhr){
    hideLoader();
    // si el servidor devolvió HTML de error, lo verás aquí
    var msg = (xhr && xhr.responseJSON && xhr.responseJSON.mensaje) ? xhr.responseJSON.mensaje : (xhr.statusText || 'Error inesperado');
    Swal.fire('Error', msg, 'error');
  });
});
