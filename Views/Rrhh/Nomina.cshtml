
@{
    ViewBag.Title = "Nomina";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}

 
<!-- Bootstrap Datepicker CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-datepicker@1.10.0/dist/css/bootstrap-datepicker.min.css">

<!-- jQuery (required by Bootstrap Datepicker) -->
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<!-- Bootstrap Datepicker JavaScript -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap-datepicker@1.10.0/dist/js/bootstrap-datepicker.min.js"></script>




<div class="card shadow-sm mt-2">
    <div class="card-body p-3">
        <h6 class="card-title font-weight-bold text-primary"> Reporte Consolidado hora extra por periodo</h6>
        <hr class="mt-1 mb-1" />
        <div class="form-row align-items-end">
            @using (Html.BeginForm("Nomina2", "Rrhh", FormMethod.Get, new { @class = "form-horizontal col-md-8", id = "submitForm" }))
            {<div class="form-row align-items-end ">

                    <div class="col-md-4">
                        <label class="form-text font-weight-bold">Seleccione el periodo:</label>
                        <input type="text" autocomplete="off" placeholder="Seleccione el año" id="datepicker" name="fechafin" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <button type="submit" id="btnSave" name="comando" value="Save" class="btn btn-block btn-success"><i class="fas fa-cloud-download-alt"></i> Generar resumen Excel</button>

                    </div>

                    <div class="col-md-4">
                        <button type="submit" id="btnSave2" name="comando" value="Save2" class="btn btn-block btn-success"><i class="fas fa-cloud-download-alt"></i> Generar detalle Excel</button>

                    </div>
                </div>
            }




        </div>
    </div>
    <div class="card-body p-3">
        <h6 class="card-title font-weight-bold text-primary"> Reporte detalle de hora extra por periodo</h6>
        <hr class="mt-1 mb-1" />
        <div class="form-row align-items-end">
            @using (Html.BeginForm("Nomina3", "Rrhh", FormMethod.Get, new { @class = "form-horizontal col-md-8", id = "submitForm" }))
            {<div class="form-row align-items-end ">

                    <div class="col-md-4">
                        <label class="form-text font-weight-bold">Seleccione el periodo:</label>
                        <input type="text" autocomplete="off" placeholder="Seleccione el año" id="datepicker2" name="fechafin2" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <button type="submit" id="btnSave" name="comando" value="Save" class="btn btn-block btn-success"><i class="fas fa-cloud-download-alt"></i> Generar Excel</button>

                    </div>


                </div>
            }




        </div>
    </div>
</div>
@section scripts{
    <script>
        $("#datepicker").datepicker({
            format: "yyyy-mm",
            viewMode: "months",
            minViewMode: "months"
        });
        $("#datepicker2").datepicker({
            format: "yyyy-mm",
            viewMode: "months",
            minViewMode: "months"
        });

    </script>

}