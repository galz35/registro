@model IEnumerable<WebApp.Controllers.RRhhController.Empleado>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="mb-4">Usuarios Activos</h1>

<table id="tblUsuarios" class="table table-striped table-sm">
    <thead class="thead-dark">
        <tr><th>ID</th><th>Nombre</th><th>Correo</th><th>Cargo</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var e in Model)
        {
            <tr>
                <td>@e.IdHcm</td>
                <td>@e.NombreCompleto</td>
                <td>@e.Correo</td>
                <td>@e.Cargo</td>
                <td>
                    <button class="btn btn-primary btn-sm editar"
                            data-id="@e.IdHcm"
                            data-nombre="@e.NombreCompleto">
                        <i class="fas fa-edit"></i> Menús
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- ==========  MODAL  ========== -->
<div class="modal fade" id="modalMenus" tabindex="-1">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title">Editar menús – <span id="lblNombre"></span></h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body" id="divChecks"><!-- checkboxes dinámicos --></div>
            <div class="modal-footer p-2">
                <button class="btn btn-secondary btn-sm" data-dismiss="modal">Cerrar</button>
                <button class="btn btn-success btn-sm" id="btnGuardar">Guardar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <script>
$(function(){
    const tabla = $('#tblUsuarios').DataTable();

    /*------ abrir modal --------*/
    let currentUser = 0;
    $('#tblUsuarios').on('click','.editar', function(){
        currentUser = $(this).data('id');
        $('#lblNombre').text($(this).data('nombre')+" (ID:"+currentUser+")");
        $('#divChecks').empty();
        $.getJSON('@Url.Action("MenusUsuario")',{userId:currentUser})
            .done(r=>{ r.menus.forEach(m=>{
                    const chk=`<div class="form-check">
                                 <input class="form-check-input" type="checkbox"
                                        value="${m.Id}" id="m${m.Id}"
                                        ${r.asignados.includes(m.Id)?'checked':''}>
                                 <label class="form-check-label" for="m${m.Id}">${m.MenuText}</label>
                               </div>`;
                    $('#divChecks').append(chk);
                 });
                 $('#modalMenus').modal('show');
            })
            .fail(()=>Swal.fire('Error','No se pudieron cargar los menús','error'));
    });

    /*------ guardar --------*/
    $('#btnGuardar').click(function(){
        const seleccion = $('#divChecks input:checked').map((i,x)=>x.value).get();
        $.post('@Url.Action("GuardarMenus")',
               { userId:currentUser, menuIds:seleccion },
               res=>{
                   $('#modalMenus').modal('hide');
                   Swal.fire(res.ok?'Éxito':'Error', res.msg ,
                             res.ok?'success':'error');
               });
    });
});
    </script>
}
