@* Views/Rrhh/EmpleadosVWEF.cshtml *@
@{
   
    var hoy = DateTime.Today.ToString("yyyy-MM-dd");
    var min2024 = "2024-01-01";
}
<style>
    :root {
        --rojo: #e11d48;
        --rojo-osc: #b91c1c;
        --negro: #0f0f10;
        --gris: #f5f6f8;
        --borde: #e5e7eb;
        --verde: #8bd3a3;
        --blanco: #fff;
    }

    .page-wrap {
        padding: 1.25rem;
    }

    .card {
        border: 0;
        border-radius: 18px;
        box-shadow: 0 12px 24px rgba(0,0,0,.08);
        background: var(--blanco);
        overflow: hidden;
    }

    .card-header {
        padding: 1rem 1.25rem;
        border: 0;
        background: linear-gradient(100deg,var(--rojo) 0%, #ff4d6d 50%, #ff8787 100%);
        color: var(--blanco);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .card-title {
        margin: 0;
        font-weight: 800;
        letter-spacing: .3px
    }

    .toolbar {
        display: flex;
        gap: .5rem;
        align-items: center;
        flex-wrap: wrap
    }

    .filter-chip {
        display: flex;
        align-items: center;
        gap: .4rem;
        background: var(--blanco);
        border: 1px solid rgba(255,255,255,.6);
        padding: .4rem .6rem;
        border-radius: 999px;
        box-shadow: 0 2px 10px rgba(0,0,0,.06)
    }

        .filter-chip input[type="date"] {
            border: 0;
            background: transparent;
            outline: none
        }

    .btn-ghost {
        border: 1px solid rgba(255,255,255,.9);
        color: var(--blanco);
        background: transparent;
        border-radius: 10px;
        padding: .35rem .7rem
    }

        .btn-ghost:hover {
            background: rgba(255,255,255,.15)
        }

    .card-body {
        padding: 1rem 1.25rem
    }

    .table thead th {
        white-space: nowrap;
        background: var(--gris);
        border-bottom: 2px solid var(--borde)
    }

    .dataTables_wrapper .dt-buttons .btn {
        border: 1px solid var(--borde) !important;
        border-radius: 10px !important;
        background: var(--blanco) !important;
        color: var(--negro) !important;
        font-weight: 700 !important
    }

    .dataTables_filter input {
        border-radius: 10px;
        border: 1px solid var(--borde);
        padding: .45rem .8rem
    }

    table.dataTable tbody tr:hover {
        background: #fff6f8
    }

    .badge-tip {
        font-size: .75rem;
        background: var(--verde);
        color: #0b5d2a;
        border: 1px solid #6bc28a;
        border-radius: 8px;
        padding: .15rem .4rem
    }
</style>

<div class="page-wrap">
    <div class="card">
        <div class="card-header">
            <h5 class="card-title">Contrataciones</h5>
            <div class="toolbar">
                <span class="badge-tip">Rango por <b>Fecha Ingreso</b></span>
                <div class="filter-chip">
                    <small>Desde</small>
                    <input type="date" id="fDesde" min="@min2024" max="@hoy" value="@min2024" />
                </div>
                <div class="filter-chip">
                    <small>Hasta</small>
                    <input type="date" id="fHasta" min="@min2024" max="@hoy" value="@hoy" />
                </div>
                <button type="button" id="btnFiltrar" class="btn-ghost">Filtrar</button>
                <button type="button" id="btnLimpiar" class="btn-ghost">Reiniciar</button>
            </div>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table id="tablaEmpleados" class="table table-bordered table-hover display nowrap" style="width:100%">
                    <thead>
                        <tr>
                            <th>Carnet</th>
                            <th>Nombre</th>
                            <th>Correo</th>
                            <th>Cargo</th>
                            <th>Empresa</th>
                            <th>Cédula</th>
                            <th>Departamento</th>
                            <th>Ubicación</th>
                            <th>Fecha Ingreso</th>
                            <th>Fecha Fin</th>
                            <th>Coordinación</th>
                            <th>Gerencia</th>
                            <th>Subgerencia</th>
                            <th>Teléfono</th>
                            <th>Teléf. Jefe</th>
                            <th>Jefe Inmediato</th>
                            <th>Correo Jefe</th>
                            <th>Cargo Jefe</th>
                            <th>Carnet Jefe</th>
                            <th>Correo Subgerente</th>
                            <th>Subgerente</th>
                            <th>Correo Gerente</th>
                            <th>Gerente</th>
                            <th>Carnet Gerente</th>
                            <th>Organización</th>
                            <th>Área</th>
                            <th>Dirección</th>
                            <th>Ciudad</th>
                            <th>Departamento (dir)</th>
                            <th>Género</th>
                            <th>Estado Civil</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section scripts{
    <script src="~/onlinejs/jquery-3.6.0.min.js"></script>
    <script src="~/onlinejs/bootstrap.bundle.min.js"></script>
    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.buttons.min.js"></script>
    <script src="~/onlinejs/buttons.bootstrap4.min.js"></script>
    <script src="~/onlinejs/jszip.min.js"></script>
    <script src="~/onlinejs/buttons.html5.min.js"></script>
    <script src="~/onlinejs/dataTables.responsive.min.js"></script>
    <script src="~/onlinejs/loadingoverlay.min.js"></script>

    <script>
  $(function(){
    // límites duros (no ir más atrás de 2024 ni más allá de hoy)
    var min2024 = '2024-01-01';
    var hoy = '@hoy';

    $('#fDesde').attr({ min: min2024, max: hoy });
    $('#fHasta').attr({ min: min2024, max: hoy });

    function clampDates(){
      var d = $('#fDesde').val() || min2024;
      var h = $('#fHasta').val() || hoy;
      if (d < min2024) d = min2024;
      if (h > hoy) h = hoy;
      if (h < d) h = d;
      $('#fDesde').val(d);
      $('#fHasta').val(h);
    }

    var dt = $('#tablaEmpleados').DataTable({
      ajax:{
        url:'@Url.Action("ListaCandidatosJsoncontratado", "Rrhh")',
        type:'GET',
        dataType:'json',
        beforeSend:function(){ $.LoadingOverlay("show"); },
        data:function(d){
          clampDates();
          d.desde = $('#fDesde').val();
          d.hasta = $('#fHasta').val();
        },
        dataSrc:function(json){ return (json && (json.data||[])) || []; },
        complete:function(){ $.LoadingOverlay("hide"); }
      },
      columns:[
        { data:'carnet' },{ data:'nombre_completo' },{ data:'correo' },{ data:'cargo' },{ data:'empresa' },
        { data:'cedula' },{ data:'Departamento' },{ data:'Nombreubicacion' },
        { data:'fechaingreso', render:function(v){ return v||''; } },
        { data:'fechabaja',    render:function(v){ return v||''; } },
        { data:'oDEPARTAMENTO' },{ data:'OGERENCIA' },{ data:'oSUBGERENCIA' },
        { data:'telefono' },{ data:'telefonojefe' },{ data:'nom_jefe1' },{ data:'correo_jefe1' },{ data:'cargo_jefe1' },{ data:'carnet_jefe1' },
        { data:'SUBGERENTECORREO' },{ data:'SUBGERENTE' },{ data:'GERENTECORREO' },{ data:'GERENTE' },{ data:'GERENTECARNET' },
        { data:'organizacion' },{ data:'primernivel' },
        { data:'EmpAddressLine1' },{ data:'EmpCity' },{ data:'EmpRegion2' },{ data:'EmpGender' },{ data:'EmpMaritalStatus' }
      ],
      order:[[8,'desc']], // Fecha Ingreso DESC
      dom:'Blfrtip',
      buttons:[
        { extend:'excelHtml5', text:'Exportar Excel', title:'Empleados_VWEF' }
      ],
      lengthMenu:[10,20,50,100],
      pageLength:10,
      language:{ url:'@Url.Content("~/Scripts/datatable.es-ES.json")' },
      responsive:true,
      processing:true
    });

    // Acciones filtro
    $('#btnFiltrar').on('click', function(){ dt.ajax.reload(); });
    $('#btnLimpiar').on('click', function(){
      $('#fDesde').val(min2024);
      $('#fHasta').val(hoy);
      dt.ajax.reload();
    });
  });
    </script>
}
