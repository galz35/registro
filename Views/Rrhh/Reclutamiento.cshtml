
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}


<div class="card shadow-sm mt-2">
    <div class="card-body p-3">
        <h6 class="card-title font-weight-bold text-primary">Exportar Reclutamiento</h6>
        <hr class="mt-1 mb-1" />
        @using (Html.BeginForm("ExportarReclutamiento", "Rrhh", FormMethod.Post))
        {
            <div class="form-row align-items-end">


                <div class="col-md-3">
                    <button type="submit" class="btn btn-block btn-success"><i class="fas fa-cloud-download-alt"></i> Descargar</button>
                </div>
            </div>
        }

    </div>
</div>


@section scripts{
    <script>

        $(document).ready(function () {


            $("input[name=fechainicio]").datepicker().datepicker('setDate', new Date());
            $("input[name=fechafin]").datepicker().datepicker('setDate', new Date());
        })

    </script>
}
