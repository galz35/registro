@model slnRhonline.Controllers.RrhhController.MenusUsuarioViewModel
<div>
    <h4>Menús Disponibles</h4>
    <form id="formMenus">
        @foreach (var menu in Model.Menus)
        {
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="menuIds" value="@menu.ID" id="menu_@menu.ID"
                       @(Model.MenusAsignados.Contains(menu.ID) ? "checked" : "") />
                <label class="form-check-label" for="menu_@menu.ID">
                    @menu.MenuText
                </label>
            </div>
        }
    </form>
</div>
<script>
    // Se guarda el userId en un atributo data del contenedor
    $('#contenidoModal').data('userid', '@Model.UserId');
</script>
