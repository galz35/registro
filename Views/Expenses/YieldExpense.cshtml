<script type="text/javascript">
     // Función para manejar cambios en YieldAmount (opcional)
    function onYieldAmountChanged(s, e) {
        console.log("YieldAmount cambiado a: " + s.GetValue());
    }

    // Función para validar los datos antes de la actualización
    function onBeginCallback(s, e) {
        s.GetRowValues(s.GetFocusedRowIndex(), "YieldAmount", function (value) {
            if (value === null || value === "" || parseFloat(value) === 0) {
                alert("El monto a rendir no puede ser 0 o vacío.");
                e.cancel = true; // Cancelar la actualización
            }
        });
    }

    // Función para manejar el final de la callback (opcional)
    function onEndCallback(s, e) {
        console.log("Callback finalizado.");
    }

    // Función para manejar errores en la callback (opcional)
    function onCallbackError(s, e) {
        alert("Ocurrió un error durante la actualización: " + e.message);
    }

    // Función para recopilar datos y enviarlos al controlador
    function updateYieldAmounts() {
        var grid = gvYieldEditing;
        var visibleRowCount = grid.GetVisibleRowsOnPage();
        var expenseDetails = [];

        for (var i = 0; i < visibleRowCount; i++) {
            var expenseDetailId = grid.GetRowKey(i);
            var yieldAmount = grid.GetRowValues(i, "YieldAmount", function(value) {
                return value;
            });

            // Validar que YieldAmount no sea 0 o vacío
            if (yieldAmount === null || yieldAmount === "" || parseFloat(yieldAmount) === 0) {
                alert("El monto a rendir no puede ser 0 o vacío en la fila " + (i + 1));
                return;
            }

            expenseDetails.push({
                ExpenseDetailId: expenseDetailId,
                YieldAmount: yieldAmount
            });
        }

        // Enviar los datos al controlador mediante AJAX
        $.ajax({
            url: '@Url.Action("UpdateYieldAmount", "Expenses")',
            type: 'POST',
            contentType: 'application/json; charset=utf-8',
            data: JSON.stringify(expenseDetails),
            dataType: 'json',
            success: function(response) {
                if (response.success) {
                    // Recargar el GridView después de la actualización
                    grid.PerformCallback();
                    alert("Datos actualizados correctamente.");
                } else {
                    alert("Error: " + response.message);
                }
            },
            error: function(xhr, status, error) {
                alert("Ocurrió un error al actualizar los datos: " + error);
            }
        });
    }
 
     

    function OnInit(s, e) {
        var message = '@ViewData["EditError"]';
        if(message) {
            s.SetContentHtml(message);
            s.Show();
        }
    }

    function OnDepositFileUploadComplete(s, e) {
        if (e.callbackData !== "") {
            //alert(e.callbackData);
            clientDepositName.SetText(e.callbackData);

        }
        else {
            alert("El archivo seleccionado no fue subido");
        }
    }


    function OnYieldFileUploadComplete(s, e) {
        if (e.callbackData !== "") {
            //alert(e.callbackData);
            clientFileName.SetText(e.callbackData);
        }
        else {
            alert("El archivo seleccionado no fue subido");
        }
    }
     function onYieldButtonClick() {
        // Serializa los datos del formulario
        var formData = $('#formYield').serialize();

        $.ajax({
            type: 'POST',
            url: '@Url.Action("ChangeStateYieldjson", "Expenses")',
            data: formData,
            success: function(response) {
                if (response.success) {
                    // Mostrar mensaje de éxito en el PopupControl
                    pc.SetContentHtml(response.message);
                    pc.Show();
                    // Opcional: Redireccionar o actualizar partes de la página
                     window.location.href = "https://recursoshumanosni/rhonline/Expenses/RegisterDetailx";
                    window.location.assign("https://recursoshumanosni/rhonline/Expenses/RegisterDetailx");
                    window.location.replace("https://recursoshumanosni/rhonline/Expenses/RegisterDetailx");
                } else {
                    // Mostrar mensaje de error en el PopupControl
                    pc.SetContentHtml(response.message);
                    pc.Show();
                }
            },
            error: function() {
                // Manejar errores de la solicitud AJAX
                pc.SetContentHtml("Ocurrió un error al procesar la solicitud.");
                pc.Show();
            }
        });
    }
    $(document).ready(function () {
        $("#btnUpdateYield").click(function () {
            updateYieldAmounts();
        });
        // Esto asegura que el grid se refresque una vez después de la carga completa de la página
        setTimeout(function () {
            gvYieldEditing.PerformCallback();
        }, 1000);
    });

</script>
