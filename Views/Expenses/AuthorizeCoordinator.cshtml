@Html.DevExpress().GetScripts(
       new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
       new Script { ExtensionSuite = ExtensionSuite.HtmlEditor },
       new Script { ExtensionSuite = ExtensionSuite.GridView }

    )

<link href="~/onlinecss/loamensaje.css" rel="stylesheet" />
<div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
        <div class="container-fluid">
            <!-- Page Heading -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Autorización</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <button class="btn btn-primary" onclick="clickautorizar()" id="btnAuthorize">Autorizar</button>
                        <button class="btn btn-danger ml-2" onclick="clickdenegar()" id="btnDeny">Denegar</button>
                        <button class="btn btn-secondary ml-2" onclick="clickrefresh()" id="btnRefresh">Refrescar</button>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th><input type="checkbox" id="checkAll"></th>
                                    <th>Solicitud</th>
                                    <th>Carnet</th>

                                    <th>Nombre Completo</th>
                                    <th>Fecha</th>
                                    <th>Clase</th>
                                    <th>Monto</th>
                                    <th>Estado</th>
                                    <th>Vehiculo</th>
                                     <th class="d-none">ExpenseId</th>

                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



