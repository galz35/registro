    <script type="text/javascript">
    var selectedIDs;
    function getSelectedIDs() {
        var selectedIDs = '';
        $('.checkItem:checked').each(function () {
            var id = $(this).data('expenseid');
             if (selectedIDs !== '') {
                selectedIDs += ',';
            }
            selectedIDs += id;
        });
        return selectedIDs;
    }

     $(document).ready(function () {

              tablaExpenses = $('#dataTable').DataTable({
    processing: true,
    deferRender: true,
