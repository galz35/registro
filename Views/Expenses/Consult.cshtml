                                    <th>Clase</th>
                                    <th>Monto</th>
                                    <th>Estado</th>
                                  
                                    <th class="d-none">ExpenseId</th>

                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

