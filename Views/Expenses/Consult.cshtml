    // Función para cargar el gráfico de Área
    function cargarGraficoArea() {
        $.ajax({
            "url": '@Url.Action("Consultjson2", "Expenses")',
            "type": "GET",
            "datatype": "json",
            "success": function (response) {
                var data = response.data;

                // Agregar gráfico por AreaName
                var areaData = {};
                data.forEach(function(item) {
                    if(areaData[item.AreaName]){
                        areaData[item.AreaName] += item.TotalAmount;
                    } else {
                        areaData[item.AreaName] = item.TotalAmount;
                    }
                });

                var areaLabels = Object.keys(areaData);
                var areaAmounts = Object.values(areaData);
                datosCargados1 = true;
                var ctxArea = document.getElementById('areaChart').getContext('2d');
                // Destruir el gráfico si ya existe
                if (window.areaChart instanceof Chart) window.areaChart.destroy();
                window.areaChart = new Chart(ctxArea, {
                    type: 'bar',
                    data: {
                        labels: areaLabels,
                        datasets: [{
                            label: 'Monto Total por Área',
                            data: areaAmounts,
                            backgroundColor: 'rgba(54, 162, 235, 0.6)',
                            borderColor: 'rgba(54, 162, 235, 1)',
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: { beginAtZero: true }
                        },
                        plugins: {
                            legend: {
                                display: false
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        return 'C$ ' + context.parsed.y.toFixed(2);
                                    }
                                }
                            }
                        }
                    }
                });
            },
            "error": function (xhr, status, error) {
                console.error("Error al cargar los datos del gráfico de Área:", error);
            }
        });
    }

    // Función para cargar el gráfico de Estado
    function cargarGraficoEstado() {
        $.ajax({
            "url": '@Url.Action("Consultjson2", "Expenses")',
            "type": "GET",
            "datatype": "json",
            "success": function (response) {
                var data = response.data;
                // Filtrar los datos para excluir los estados ignorados
                var filteredData = data.filter(function (item) {
                    return !ignoredStatuses.includes(item.ExpenseStatus);
                });

                // Obtener todos los estados únicos de los datos filtrados

                // Agregar gráfico por Estado
                var statusData = {};
                filteredData.forEach(function(item) {
                    if(statusData[item.ExpenseStatus]){
                        statusData[item.ExpenseStatus] += 1;
                    } else {
                        statusData[item.ExpenseStatus] = 1;
                    }
                });

                var statusLabels = Object.keys(statusData);
                var statusCounts = Object.values(statusData);
                datosCargados2 = true;
                const labels = ['Red', 'Orange', 'Yellow', 'Green', 'Blue'];
                var ctxStatus = document.getElementById('statusChart').getContext('2d');
                // Destruir el gráfico si ya existe
                if (window.statusChart instanceof Chart) window.statusChart.destroy();
                window.statusChart = new Chart(ctxStatus, {
                    type: 'pie',
                    data: {
                        labels: statusLabels,
                        datasets: [{
                            label: 'Cantidad de Gastos por Estado',
                            data: statusCounts,
                            backgroundColor: [
                                '#FFB3BA', // Pastel Red
                                '#FFDFBA', // Pastel Orange
                                '#FFFFBA', // Pastel Yellow
                                '#BAFFC9', // Pastel Green
                                '#BAE1FF', // Pastel Blue
                                '#D4BAFF', // Pastel Purple
                                '#FFB3E6', // Pastel Pink
                                '#CCCCCC'  // Pastel Grey
                                // Añade más colores pastel si es necesario
                            ],
                            borderColor: [
                                '#FFB3BA',
                                '#FFDFBA',
                                '#FFFFBA',
                                '#BAFFC9',
                                '#BAE1FF',
                                '#D4BAFF',
                                '#FFB3E6',
                                '#CCCCCC'
                                // Añade más colores si es necesario
                            ],
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: true,  // Mostrar leyenda
                                position: 'top',  // Posición de la leyenda
                                labels: {
                                    font: {
                                        size: 16  // Tamaño de la fuente de las etiquetas de la leyenda
                                    },
                                    color: '#333' // Color de la fuente de la leyenda
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function (context) {
                                        let label = context.label || '';
                                        let value = context.raw || 0;
                                        return `${label}: ${value} gastos`;
                                    }
                                },
                                bodyFont: {
                                    size: 14  // Tamaño de la fuente de los tooltips
                                }
                            }
                        }
                    }
                });
            },
            "error": function (xhr, status, error) {
                console.error("Error al cargar los datos del gráfico de Estado:", error);
            }
        });
    }

           function cargarResumenArea() {
            $.ajax({
                "url": '@Url.Action("Consultjson2", "Expenses")',
                "type": "GET",
                "datatype": "json",
                "success": function (response) {
                    var data = response.data;

                    // Filtrar los datos para excluir los estados ignorados
                    var filteredData = data.filter(function(item) {
                        return !ignoredStatuses.includes(item.ExpenseStatus);
                    });

                    // Resumen por Área: cantidad de registros y monto total
                    var summaryData = {};
                    filteredData.forEach(function(item) {
                        if(summaryData[item.AreaName]){
                            summaryData[item.AreaName].count += 1;
                            summaryData[item.AreaName].amount += item.TotalAmount;
                        } else {
                            summaryData[item.AreaName] = { count: 1, amount: item.TotalAmount };
                        }
                    });

                    var summaryRows = '';
                    var totalCount = 0;
                    var totalAmount = 0;
                    for(var area in summaryData){
                        summaryRows += `
                            <tr>
                                <td>${area}</td>
                                <td>${summaryData[area].count}</td>
                                <td>C$ ${summaryData[area].amount.toFixed(2)}</td>
                            </tr>
                        `;
                        totalCount += summaryData[area].count;
                        totalAmount += summaryData[area].amount;
                    }

                    $('#areaSummaryTable tbody').html(summaryRows);

                    // Actualizar el footer con los totales
                    $('#areaSummaryTable tfoot th').eq(1).html(totalCount);
                    $('#areaSummaryTable tfoot th').eq(2).html('C$ ' + totalAmount.toFixed(2));
                    datosCargados3 = true;
                    // Inicializar o actualizar DataTable para el resumen por Área
                    if (!$.fn.DataTable.isDataTable('#areaSummaryTable')) {
                        $('#areaSummaryTable').DataTable({
                            "paging": true, // Habilitado
                            "pageLength": 10,
                            "lengthChange": false,
                            "searching": false,
                            "info": false,
                            "ordering": false,
                            "responsive": true,
                            "dom": 'Bfrtip',
                            "buttons": [
                                'excelHtml5'
                            ]
                        });
                    } else {
                        $('#areaSummaryTable').DataTable().clear().destroy();
                        $('#areaSummaryTable').DataTable({
                            "paging": true, // Habilitado
                            "pageLength": 10,
                            "lengthChange": false,
                            "searching": false,
                            "info": false,
                            "ordering": false,
                            "responsive": true,
                            "dom": 'Bfrtip',
                            "buttons": [
                                'excelHtml5'
                            ]
                        });
                    }
                },
                "error": function (xhr, status, error) {
                    console.error("Error al cargar el resumen por Área:", error);
                }
            });
        }

        // Función para cargar el resumen por Área y Estado
        function cargarResumenAreaEstado() {
            $.ajax({
                "url": '@Url.Action("Consultjson2", "Expenses")',
                "type": "GET",
                "datatype": "json",
                "success": function (response) {
                    var data = response.data;

                    // Filtrar los datos para excluir los estados ignorados
                    var filteredData = data.filter(function(item) {
                        return !ignoredStatuses.includes(item.ExpenseStatus);
                    });

                    // Obtener todos los estados únicos de los datos filtrados
                    var estadosSet = new Set();
                    filteredData.forEach(function(item) {
                        estadosSet.add(item.ExpenseStatus);
                    });
                    var estados = Array.from(estadosSet);

                    // Construir el header de la tabla
                    var headerRow = '<th>Área</th>';
                    estados.forEach(function(estado) {
                        headerRow += `<th>${estado}</th><th>(C$)</th>`;
                    });
                    $('#areaStatusSummaryHeader').html(headerRow);

                    // Resumen por Área y Estado: cantidad de registros y monto total
                    var summaryData = {};
                    filteredData.forEach(function(item) {
                        var area = item.AreaName;
                        var estado = item.ExpenseStatus;
                        if(!summaryData[area]){
                            summaryData[area] = {};
                        }
                        if(!summaryData[area][estado]){
                            summaryData[area][estado] = { count: 0, amount: 0 };
                        }
                        summaryData[area][estado].count += 1;
                        summaryData[area][estado].amount += item.TotalAmount;
                    });

                    // Construir las filas de la tabla y calcular totales
                    var summaryRows = '';
                    var totalCounts = Array(estados.length).fill(0);
                    var totalAmounts = Array(estados.length).fill(0);

                    for(var area in summaryData){
                        summaryRows += `<tr><td>${area}</td>`;
                        estados.forEach(function(estado, index) {
                            var count = summaryData[area][estado] ? summaryData[area][estado].count : 0;
                            var amount = summaryData[area][estado] ? summaryData[area][estado].amount.toFixed(2) : '0.00';
                            summaryRows += `<td>${count}</td><td>C$ ${amount}</td>`;
                            totalCounts[index] += count;
                            totalAmounts[index] += parseFloat(amount);
                        });
                        summaryRows += `</tr>`;
                    }

                    $('#areaStatusSummaryTable tbody').html(summaryRows);

                    // Construir el footer con los totales
                    var footerRow = '<th>Total</th>';
                    estados.forEach(function(estado, index) {
                        footerRow += `<th>${totalCounts[index]}</th><th>C$ ${totalAmounts[index].toFixed(2)}</th>`;
                    });
                    $('#areaStatusSummaryFooter').html(footerRow);
                    datosCargados4 = true;
                    // Inicializar o actualizar DataTable para el resumen por Área y Estado
                    if (!$.fn.DataTable.isDataTable('#areaStatusSummaryTable')) {
                        $('#areaStatusSummaryTable').DataTable({
                            "paging": true, // Habilitado
                            "pageLength": 10,
                            "lengthChange": false,
                            "searching": true, // Habilitado para búsqueda
                            "info": false,
                            "ordering": false,
                            "responsive": true,
                            "dom": 'Bfrtip',
                            "buttons": [
                                'excelHtml5',
                             ]
                        });
                    } else {
                        $('#areaStatusSummaryTable').DataTable().clear().destroy();
                        $('#areaStatusSummaryTable').DataTable({
                            "paging": true, // Habilitado
                            "pageLength": 10,
                            "lengthChange": false,
                            "searching": true, // Habilitado para búsqueda
                            "info": false,
                            "ordering": false,
                            "responsive": true,
                            "dom": 'Bfrtip',
                            "buttons": [
                                'excelHtml5',
                             ]
                        });
                    }
                },
                "error": function (xhr, status, error) {
                    console.error("Error al cargar el resumen por Área y Estado:", error);
                }
            });
        }
