                    </button>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-warning btn-block" data-toggle="modal" data-target="#statusChartModal">
                        Gráfico de Estado
                    </button>
                </div>
                <div class="col-md-3">
                    <button class="btn btn-success btn-block" data-toggle="modal" data-target="#areaSummaryModal">
                        Resumen por Área
                    </button>
                </div>
                <div class="col-md-3">
                    <button class="btn btn-secondary btn-block" data-toggle="modal" data-target="#areaStatusSummaryModal">
                        Resumen Área y Estado
                    </button>
