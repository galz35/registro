     function LoadPartial(s, e) {
        $.ajax({
            url: '@Url.Action("AuthorizeManagerPartial", "Expenses")',
            //contentType: 'application/json; charset=utf-8',
            type: 'GET',
            //dataType: 'json',
            cache: false,
            traditional: true,
            data: {},
        }).done(function(result) {
            $('#authorizePartial').html(result);
        });
    }

            function verDetalle(idExpense) {
                 var url = '@Url.Action("AuthorizeConsultPartial", "Expenses", new { _expenseId = "0" })'.replace("0", idExpense);
                popup.SetContentUrl(url);
         /*       popup.ShowAtElementByID(idExpense);*/

    $.ajax({
        url: '@Url.Action("AuthorizeConsultParptial", "Expenses")',
        type: 'GET',
        data: { _expenseId: idExpense },
        success: function (data) {
            // Cargar la vista parcial en el contenido del PopupControl
            $('#popup').html(data);

            // Mostrar el PopupControl
            popup.Show();
        },
        error: function () {
            // Manejar errores si es necesario
        }
    });
            }

            function verPDF(idExpense) {
                    var url = '@Url.Action("LoadYield", "Expenses", new { expenseId = "0" })'.replace("0", idExpense);
                popImage.SetContentUrl(url);
                popImage.ShowAtElementByID(idExpense);

}

    </script>
}
