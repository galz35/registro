                 }
        });

        }


        if (e.item.name == "Denied") {
             $.ajax({
             url: '@Url.Action("DeniedManager")',
             type: "POST",
             data: { ids: selectedIDs },
            dataType: "json",
            traditional: true,
            cache: false,

                 success: function (data) {
                     Swal.close();
                 if (data.status != "Error") {
                     swal.fire({
                             title: "Exito!",
                             text: data.message,
                             icon: "success",
                         confirmButtonText: "Aceptar",
                         })
                         .then((willSaved) => {
                             if (willSaved) {

                                 LoadPartial();
                             }

                         });
                 } else {
                     swal.fire({
                         title: "Error!",
                         text: data.message,
                         icon: "error",
                         confirmButtonText: "Aceptar",
                     })

                 }


             },
                 beforeSend: function () {
                     Swal.fire({
                         title: 'Procesando solicitud...',
                         html: '<div class="loader"></div><br><b style="color:#e74c3c;">Por favor espere</b>',
                         allowOutsideClick: false,
                         showConfirmButton: false
                     });                 },
                 error: function (error) {
                     Swal.close();
                     alert("An error has occured!!!");
                 }
        });
        }
