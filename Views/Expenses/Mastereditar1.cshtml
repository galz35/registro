           function openEditModal(data) {
                // Aquí puedes abrir un modal con los datos actuales para editar
                // por ejemplo:
                $('#popupModal').modal('show');
                $('#ClasificationId').val(data.ClasificationId);
                $('#CategoryId').val(data.CategoryId);
                $('#SubCategoryId').val(data.SubCategoryId);
                $('#DepartmentId').val(data.DepartmentId);
                $('#ExpenseDetailNotes').val(data.ExpenseDetailNotes);
                $('#Amount').val(data.Amount);
                $('#HourStart').val(data.HourStart);

                $('#editId').val(data.ExpenseDetailId);
            }

            $('#saveChanges').on('click', function () {
                var ExpenseDetailId = $('#editId').val();
                var ClasificationId = $('#ClasificationId').val();
                var CategoryId = $('#CategoryId').val();
                var SubCategoryId = $('#SubCategoryId').val();
                var DepartmentId = $('#DepartmentId').val();
                var ExpenseDetailNotes = $('#ExpenseDetailNotes').val();
                var Amount = $('#Amount').val();
                var HourStart = $('#HourStart').val();



                // Validación básica (puedes agregar más validaciones según sea necesario)
                if (!ClasificationId || !CategoryId || !SubCategoryId || !DepartmentId || !Amount || !HourStart) {
                    alert('Por favor complete todos los campos obligatorios.');
                    return;
                }

                var updatedData = {
                    ExpenseDetailId: ExpenseDetailId,
                    ClasificationId: ClasificationId,
                    CategoryId: CategoryId,
                    SubCategoryId: SubCategoryId,
                    DepartmentId: DepartmentId,
                    ExpenseDetailNotes: ExpenseDetailNotes,
                    Amount: Amount,
                    HourStart: HourStart

                };


                $.ajax({
                    url: '@Url.Action("AddDetailLinejson", "Expenses")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(updatedData),
                    success: function (response) {
                        if (response.success) {
                            $('#popupModal').modal('hide');
                            table.ajax.reload(); // Recargar la tabla
                        } else {
                            Swal.fire({
                                icon: 'warning',
                                title: 'informacion',
                                text: response.message
                            });
                        }
                    }
                });
            });
        });
        // Evento al cambiar la clasificación
        document.getElementById('ClasificationId').addEventListener('change', function () {
            console.log('ClasificationId changed');

            var selectedClasificationId = this.value;
            var categorySelect = document.getElementById('CategoryId');
            categorySelect.innerHTML = ''; // Limpiar las opciones actuales
            categorySelect.appendChild(new Option('SELECCIONE CATEGORÍA', ''));
             var categories = @Html.Raw(Json.Encode(slnRhonline.Models.Concepts.GetAllCategories()));

            categories.forEach(function (category) {
                if (category.ClasificationId == selectedClasificationId) {
                    categorySelect.appendChild(new Option(category.CategoryName, category.CategoryId));
                }
            });

            // Limpiar el select de subcategorías también
            var subCategorySelect = document.getElementById('SubCategoryId');
            subCategorySelect.innerHTML = '';
            subCategorySelect.appendChild(new Option('SELECCIONE SUB CATEGORÍA', ''));
        });

        // Evento al cambiar la categoría
        document.getElementById('CategoryId').addEventListener('change', function () {
            var categoryId = this.value;
            $.ajax({
                url: '@Url.Action("GetAllSubCategories", "Expenses")',
                type: 'GET',
                data: { categoryId: categoryId },
                success: function (data) {
                    var subCategorySelect = $('#SubCategoryId');
                    subCategorySelect.empty();
                    subCategorySelect.append($('<option>').val('').text('SELECCIONE SUB CATEGORÍA'));
                    $.each(data, function (i, item) {
                        var subCategoryName = item.SubCategoryName || '';
                        var sanitizedSubCategoryName = subCategoryName.replace(' - ', '–'); // Reemplaza " - " con "–"

                        subCategorySelect.append($('<option>').val(item.SubCategoryId).text(sanitizedSubCategoryName + ' - ' + item.Amount));
                    });
                }
            });
        });

        // Evento al cambiar la subcategoría
        document.getElementById('SubCategoryId').addEventListener('change', function () {
            var selectedSubCategoryId = this.value;
            var prueba = $('#SubCategoryId').val();
            var selectedOptionText = $(this).find('option:selected').text();
            var amount = selectedOptionText.split(' - ')[1];
            if (amount) {
                document.getElementById('Amount').value = amount;

                // Realizar llamada AJAX para almacenar el valor en la sesión
                $.ajax({
                    url: '@Url.Action("StoreSubCategoryId", "Expenses")',
                    type: 'POST',
                    data: { subCategoryId: selectedSubCategoryId },
                    success: function (response) {
                        if (response.success) {
                            console.log('SubCategoryId stored in session successfully');
                        } else {
                            console.log('Failed to store SubCategoryId in session');
                        }
                    },
                    error: function () {
                        console.log('Error occurred while storing SubCategoryId in session');
                    }
                });
            }
        });
    </script>
}


