                 var categories = @Html.Raw(categories);
            var departments = @Html.Raw(departments);
                        var clasifi = @Html.Raw(clasificsl);
                        var sub = @Html.Raw(categoriessub);

              function getCategoryName(categoryId) {
                  var category = categories.find(function (cat) {
                      return cat.CategoryId === categoryId;
                  });
                  return category ? category.CategoryName : '';
              }

            function getClasificName(ClasificationId) {
                var category = clasifi.find(function (cat) {
                    return cat.ClasificationId === ClasificationId;
                });
                return category ? category.ClasificationName : '';
            }

              function getSubCategoryName(subCategoryId) {
                  var subCategory = sub.find(function (cat) {
                      return cat.SubCategoryId === subCategoryId;
                  });
                  return subCategory ? subCategory.SubCategoryName : '';
              }

              function getDepartmentName(departmentId) {
                  var department = departments.find(function (dep) {
                      return dep.DepartmentId === departmentId;
                  });
                  return department ? department.DepartmentName : '';
              }
