                        $('#expenseDetailsTable').on('click', '.edit-btn', function () {
        var cell = table.cell($(this).parents('td, th'));
        $(cell.node()).editable(function(value, settings) {
            var columnIndex = cell.index().column;
            var rowData = cell.row(cell.index().row).data();

            // Actualizar el valor en la celda
            rowData[cell.column(columnIndex).dataSrc()] = value;

            // Realizar la actualización en la sesión
            $.ajax({
                url: '@Url.Action("UpdateDetailLinejson", "Expenses")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(rowData),
                success: function(response) {
                    if (response.success) {
                        table.ajax.reload(); // Recargar la tabla
                        Swal.fire({
                            icon: 'success',
                            title: 'Éxito',
                            text: 'El registro ha sido actualizado exitosamente.'

                        });


                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: 'Hubo un problema al actualizar el registro.'
                        });
                    }
                },
                error: function() {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Hubo un problema al actualizar el registro.'
                    });
                }
            });

            return value;
        }, {
            "width": "100%",
            "height": "100%"
        });
    });
