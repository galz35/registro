                    "datatype": "json"
                }, "columnDefs": [
                    {
                        "targets": 0,
                        "data": null,
                        "defaultContent": '',
                        "orderable": false
                    }
                ],
                "columns": [
                    {
                        "data": null,

                    },
                    {
                        "data": null,
                        "render": function (data) {
                            return "<input type='checkbox' class='checkItem' data-expenseid='" + data.Id + "'>";
                        },
                        "orderable": true,
                        "searchable": true,
                        "width": "10px"
                    },



                    { "data": "EmployeeNumber" },
                    { "data": "Employee" },
                    { "data": "ExecutionDate", "render": function (data) { return moment(data).format("DD/MM/YYYY"); } },

                    { "data": "HourStart", "render": function (data) { return moment(data).format("HH:mm:ss"); } },
                    { "data": "HourEnd", "render": function (data) { return moment(data).format("HH:mm:ss"); } },
                    { "data": "Reasons" },
                    { "data": "Service" },



                    { "data": "Status" },
                    { "data": "Notes" },


                    {
                        "data": "Id", "visible": false // Oculta visualmente la columna
 },


                ],
                 "dom": 'Blfrtip',
           "lengthMenu": [10, 20, 50, 100], // Opciones de selección de registros por página
           "pageLength": 10, // Número de registros por página por defecto
             "language": {
                "url": "@Url.Content("~/Scripts/datatable.es-ES.json")"
                },
            "responsive": true,

                "drawCallback": function (settings) {
                    var api = this.api();
                    var rows = api.rows({ page: 'current' }).nodes();
                    var counter = 1;

                    $.each(rows, function (index, row) {
                        row.cells[0].innerHTML = counter;
                        counter++;
                    });
                },



            });
        $.LoadingOverlay("hide");

        $('#checkAll').click(function () {
                $('.checkItem').prop('checked', this.checked);
            });

            $('.checkItem').change(function () {
                var allChecked = true;
                $('.checkItem').each(function () {
                    if (!this.checked) {
                        allChecked = false;
                    }
                });
                $('#checkAll').prop('checked', allChecked);
            });
        $('#exportExcel').click(function () {
            var exportButton = new $.fn.dataTable.Buttons(tablaExpenses, {
                buttons: ['excel']
            });
            exportButton.container().appendTo($('.dataTables_length')); // Agregar el botón en el mismo contenedor que la barra de herramientas
            exportButton.trigger();
        });
    $('#selectAll').on('change', function () {
        var isChecked = $(this).prop('checked');
        $('.checkItem').prop('checked', isChecked);
    });
    $('.checkItem').on('change', function () {
        var id = $(this).closest('tr').find('td:last').text();
        if (this.checked) {
            selectedIDs.push(id);
        } else {
            selectedIDs = selectedIDs.filter(function (value) {
                return value !== id;
            });
        }
        console.log(selectedIDs); // Verificar IDs seleccionados en la consola
    });
    // Control para enviar los IDs seleccionados al hacer clic en el botón


    $('.checkItem:checked').each(function () {
        selectedIDs.push($(this).closest('tr').find('td:first').text()); // Ajusta esta línea según la estructura de tu tabla
    });
            // Check Todo
          // Check Todo
            $('#btnDeny').on('click', function () {
                // Lógica para el botón "Denegar"
            });

            $('#btnRefresh').on('click', function () {
                tablaExpenses.ajax.reload();
            });


         });

    function getSelectedIDs() {
        var selectedIDs = '';
        $('.checkItem:checked').each(function () {
            var id = $(this).data('expenseid');
             if (selectedIDs !== '') {
                selectedIDs += ',';
            }
            selectedIDs += id;
        });
        return selectedIDs;


    }



        function clickrefresh() {
            $.LoadingOverlay("show");
        tablaExpenses.ajax.reload();
            $.LoadingOverlay("hide");
    }
    function clickdenegar() {
        debugger;
        var selectedIDsx = getSelectedIDs();
        if (selectedIDsx != null) {
                 $.ajax({
             url: '@Url.Action("DeniedBoss")',
             type: "POST",
                     data: { ids: selectedIDsx },
            dataType: "json",
            traditional: true,
            cache: false,

                 success: function (data) {
                     $.LoadingOverlay("hide");
                     //$.LoadingOverlay("hide");
                     if (data.status != "Error") {
                     swal.fire({
                             title: "Exito!",
                             text: data.message,
                             icon: "success",
                             confirmButtonText: "Aceptar",
                         })
                         .then((willSaved) => {
                             if (willSaved) {

                                 tablaExpenses.ajax.reload();
                             }

                         });
                 } else {
                     swal.fire({
                         title: "Error!",
                         text: data.message,
                         icon: "error",
                         confirmButtonText: "Aceptar",
                     })

                 }


                 },
                 beforeSend: function () {
                     $.LoadingOverlay("show");
                 },
                 error: function (error) {
                     $.LoadingOverlay("hide");
                     alert("An error has occured!!!");
                 }

                 });
            clickrefresh();
        }
    }
    function clickautorizar() {
        debugger;
        var selectedIDsx = getSelectedIDs();
        if (selectedIDsx != null)
        {
             $.ajax({
             url: '@Url.Action("AuthorizeBoss")',
             type: "POST",
                 data: { ids: selectedIDsx },
            dataType: "json",
            traditional: true,
            cache: false,
                 success: function (data) {
                     $.LoadingOverlay("hide");
                 if (data.status != "Error") {
                     swal.fire({
                             title: "Exito!",
                             text: data.message,
                             icon: "success",
                             confirmButtonText: "Aceptar",
                         })
                         .then((willSaved) => {
                             if (willSaved) {
                                 tablaExpenses.ajax.reload();

                              //   LoadPartial();
                                 //setTimeout(
                                 //    function () {
                                 //        location.reload(true);
                                 //    }, 0001);

                             }
                             //    history.go(0);
                             clickrefresh();
                             //window.location.href = window.location.href;

                         });
                 } else {
                     swal.fire({
                         title: "Error!",
                         text: data.message,
                         icon: "error",
                         confirmButtonText: "Aceptar",
                     })
                     clickrefresh();
                 }


             },

                 beforeSend: function () {
                  $.LoadingOverlay("show");
                 },
                 error: function (error) {
                     $.LoadingOverlay("hide");
                     alert("An error has occured!!!");
                 }
        });
            clickrefresh();
        }
    }






    function onBeginCallback(s, e) {
        // Pasamos los ids seleccionados al boton de autorizar
        e.customArgs["selectedIDs"] = selectedIDs;
        if (selectedIDs != "")
            gvAuthorizeBoss.PerformCallback;
    }

    function onSelectionChanged(s, e) {
        s.GetSelectedFieldValues("ExpenseId", GetSelectedFieldValuesCallback);
    }

    function GetSelectedFieldValuesCallback(values) {
        // Captura todas las llaves seleccionadas
        selectedIDs = values.join(',');
    }

    function onAuthorizeButtonClick(s, e) {
        $("#selectedIdsAP").val(selectedIDs);
        selectedIDs = "";
    }

    function onDeniedButtonClick(s, e) {
        $("#selectedIdsDN").val(selectedIDs);
        selectedIDs = "";
    }


    function OnInit(s, e) {
        AdjustSize();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            AdjustSize();
        });
    }
    function OnEndCallback(s, e) {
        AdjustSize();
    }
    function AdjustSize() {
        var height = document.documentElement.clientHeight;
        gvAuthorizeBoss.SetHeight(height - 150);
    }

    function ShowDetailPopup(elementID, url) {
        popImage.SetContentUrl(url);
        popImage.ShowAtElementByID(elementID);
    }

