@{
    ViewBag.Title = "Horas Extraordinarias – Pivot";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}

<style>
    /* Compacto y legible */
    #pivotHorasExtra th, #pivotHorasExtra td {
        vertical-align: middle;
    }

    #pivotHorasExtra thead th {
        white-space: nowrap;
    }

    .pivot-cell {
        cursor: pointer;
    }
</style>

<div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
        <div class="container-fluid">

            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold" style="color:#800 !important;">Lista de Horas Extraordinarias</h6>

                    <div class="d-flex align-items-center">
                        <label for="selectMes" class="mb-0 mr-2">Mes:</label>
                        <select id="selectMes" class="form-control d-inline-block" style="width:auto;"></select>

                        <button id="btnBuscar" class="btn btn-danger ml-2" style="background:#b00;border:none;">Buscar</button>

                        <!-- ⬇️ Nuevo botón Excel -->
                        <button id="btnExcel" class="btn btn-success ml-2" style="background:#198754;border:none;">
                            <i class="fa fa-file-excel-o"></i> Descargar Excel
                        </button>

                        <button id="btnReporte" class="btn btn-dark ml-2" style="background:#222;border:none;">
                            <i class="fa fa-file-pdf-o"></i> Generar consolidado
                        </button>

                        <button id="btnReporte2" class="btn btn-dark ml-2" style="background:#222;border:none;">
                            <i class="fa fa-file-pdf-o"></i> Generar detalle
                        </button>
                    </div>
                </div>

                <div class="card-body">
                    <!-- KPIs -->
                    <div id="dashboard" class="row mb-3"></div>

                    <!-- Pivot estilo Excel -->
                    <div class="table-responsive">
                        <table id="pivotHorasExtra" class="table table-striped table-bordered" style="width:100%"></table>
                    </div>

                    <!-- (Opcional) Tabla cruda, oculta -->
                    <div class="table-responsive d-none">
                        <table id="tablaHorasExtra" class="table table-bordered table-hover display nowrap" style="width:100%">
                            <thead>
                                <tr>
                                    <th>Horas</th>
                                    <th>Estado</th>
                                    <th>Empleado</th>
                                    <th>Area</th>
                                    <th>Gerencia</th>
                                </tr>
                            </thead>
                        </table>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

<!-- Modal detalle -->
<div class="modal fade" id="modalDetalle" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header" style="background:#111;color:#fff;">
                <h5 class="modal-title">Detalle</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close"><span>×</span></button>
            </div>
            <div class="modal-body">
                <table id="detalleTabla" class="table table-bordered table-hover display nowrap" style="width:100%;">
                    <thead>
                        <tr>
                            <th>Horas</th>
                            <th>Estado</th>
                            <th>Nombre</th>
                            <th>Carnet</th>
                            <th>Área</th>
                            <th>Gerencia</th>
                        </tr>
                    </thead>
                </table>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary btn-sm" data-dismiss="modal">Cerrar</button></div>
        </div>
    </div>
</div>

@section scripts{
    <!-- librerías que usas en el proyecto -->
    <script src="~/onlinejs/jquery-3.6.0.min.js"></script>
    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.buttons.min.js"></script>
    <script src="~/onlinejs/buttons.html5.min.js"></script>
    <script src="~/onlinejs/buttons.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.select.min.js"></script>
    <script src="~/onlinejs/bootstrap.bundle.min.js"></script>
    <script src="~/onlinejs/bootstrap.min.js"></script>
    <script src="~/onlinejs/loadingoverlay.min.js"></script>
    <script src="~/onlinejs/dataTables.responsive.min.js"></script>
    <script src="~/Content/plugin/sweetalert2/sweetalert2.all.js"></script>
    <script src="~/onlinejs/moment.min.js"></script>
    <script src="~/onlinejs/jszip.min.js"></script>
    <script src="~/onlinejs/jquery-ui.js"></script>
    <script src="~/onlinejs/spin.min.js"></script>
    <script src="~/js/popper.min.js"></script>

    <script>
  // Meses dinámicos
  function cargarMeses() {
    var $select = $('#selectMes');
    var today = new Date();
    for (var i = 0; i < 12; i++) {
      var d = new Date(today.getFullYear(), today.getMonth() - i, 1);
      var val = d.getFullYear() + '-' + ('0' + (d.getMonth() + 1)).slice(-2);
      $select.append($('<option>', { value: val, text: moment(d).format('MMMM YYYY') }));
    }
    $select.val(today.getFullYear() + '-' + (today.getMonth() + 1).toString().padStart(2, '0'));
  }

  // Normaliza "NI "
  function normGerencia(g){ return (g||'').replace(/^NI\s+/,'').trim(); }

  // KPIs
  function renderDashboard(datos){
    var resumen = {};
    var horasTotales = 0;
    datos.forEach(function(d){
      var est = d.STATUS || 'SIN ESTADO';
      if(!resumen[est]) resumen[est] = { conteo:0, horas:0 };
      resumen[est].conteo += 1;
      resumen[est].horas  += Number(d.HOURS||0);
      horasTotales        += Number(d.HOURS||0);
    });

    var $dash = $('#dashboard').empty();
    $.each(resumen, function (est, v) {
      $dash.append(
        '<div class="col-md-3 mb-2">'+
          '<div class="card text-white bg-secondary h-100">'+
            '<div class="card-body p-2 text-center">'+
              '<h6 class="card-title mb-1">'+est+'</h6>'+
              '<p class="mb-0"><strong>'+v.conteo+'</strong> registros</p>'+
              '<p class="mb-0"><strong>'+v.horas+'</strong> h</p>'+
            '</div>'+
          '</div>'+
        '</div>'
      );
    });
    $dash.append(
      '<div class="col-md-3 mb-2">'+
        '<div class="card text-white bg-dark h-100">'+
          '<div class="card-body p-2 text-center">'+
            '<h6 class="card-title mb-1">TOTAL HORAS</h6>'+
            '<p class="mb-0"><strong>'+horasTotales+'</strong> h</p>'+
          '</div>'+
        '</div>'+
      '</div>'
    );
  }

  // Pivot (filas=Gerencia, cols=Estado, valores=SUM(HOURS))
  function renderPivot(datos){
    var estados   = Array.from(new Set(datos.map(function(x){ return (x.STATUS||'SIN ESTADO'); }))).sort();
    var gerencias = Array.from(new Set(datos.map(function(x){ return normGerencia(x.GERENCIA); }))).sort();

    var mapa = {}, totCol = {}, totRow = {}, totalGeneral = 0;
    estados.forEach(function(s){ totCol[s]=0; });
    gerencias.forEach(function(g){ totRow[g]=0; });

    datos.forEach(function(d){
      var g = normGerencia(d.GERENCIA);
      var s = d.STATUS || 'SIN ESTADO';
      var h = Number(d.HOURS||0);
      var k = g+'|'+s;
      mapa[k] = (mapa[k]||0) + h;
      totRow[g] += h;
      totCol[s] += h;
      totalGeneral += h;
    });

    var html = '<thead><tr><th>Gerencia</th>';
    estados.forEach(function(s){ html += '<th class="text-right">'+s+'</th>'; });
    html += '<th class="text-right">TOTAL</th></tr></thead><tbody>';

    gerencias.forEach(function(g){
      html += '<tr><th>'+g+'</th>';
      estados.forEach(function(s){
        var val = (mapa[g+'|'+s]||0);
        html += '<td class="text-right pivot-cell" data-gerencia="'+g.replace(/"/g,'&quot;')+'" data-status="'+s.replace(/"/g,'&quot;')+'">'+ val.toLocaleString(undefined,{maximumFractionDigits:2}) +'</td>';
      });
      html += '<td class="text-right pivot-cell" data-gerencia="'+g.replace(/"/g,'&quot;')+'" data-status="__TOTAL__">'+ (totRow[g]||0).toLocaleString(undefined,{maximumFractionDigits:2}) +'</td></tr>';
    });

    html += '<tr><th>TOTAL</th>';
    estados.forEach(function(s){
      html += '<th class="text-right pivot-cell" data-gerencia="__TOTAL__" data-status="'+s.replace(/"/g,'&quot;')+'">'+ (totCol[s]||0).toLocaleString(undefined,{maximumFractionDigits:2}) +'</th>';
    });
    html += '<th class="text-right">'+ totalGeneral.toLocaleString(undefined,{maximumFractionDigits:2}) +'</th></tr>';

    html += '</tbody>';
    $('#pivotHorasExtra').html(html);

    // click → detalle
    $('#pivotHorasExtra').off('click','.pivot-cell').on('click','.pivot-cell', function(){
      var g = $(this).data('gerencia');
      var s = $(this).data('status');
      mostrarDetalle(datos, g, s);
    });
  }

  // Modal detalle (DataTable + export)
  function mostrarDetalle(datos, gerencia, estado){
    var filtro = datos.filter(function(d){
      var g = normGerencia(d.GERENCIA);
      var okG = (gerencia==='__TOTAL__') ? true : (g === gerencia);
      var okS = (estado==='__TOTAL__') ? true : ((d.STATUS||'SIN ESTADO') === estado);
      return okG && okS;
    });

    var tit = 'Detalle';
    if(gerencia && gerencia!=='__TOTAL__') tit += ' · '+gerencia;
    if(estado && estado!=='__TOTAL__')     tit += ' · '+estado;
    $('#modalDetalle .modal-title').text(tit);

    if ($.fn.DataTable.isDataTable('#detalleTabla')){
      var dt = $('#detalleTabla').DataTable();
      dt.clear().rows.add(filtro).draw();
    }else{
      $('#detalleTabla').DataTable({
        data: filtro,
        columns: [
          { data:'HOURS', className:'text-right' },
          { data:'STATUS' },
          { data:'FULL_NAME' },
          { data:'EMPLOYEE_NUMBER' },
          { data:'AREA' },
          { data:'GERENCIA', render:function(g){ return normGerencia(g); } }
        ],
        dom: 'Bfrtip',
        buttons: [{ extend:'excelHtml5', title: tit.replace(/\s+/g,'_') }],
        responsive: true,
        deferRender: true,
        pageLength: 10,
        language: { url: '@Url.Content("~/Scripts/datatable.es-ES.json")' }
      });
    }

    $('#modalDetalle').modal('show');
  }

  // Inicialización
  $(document).ready(function () {
    cargarMeses();

    // Tabla cruda (oculta)
    $('#tablaHorasExtra').DataTable({
      data: [],
      columns: [
        { data: 'HOURS',        defaultContent: "", title: "Horas", className:'text-right' },
        { data: 'STATUS',       defaultContent: "", title: "Estado" },
        { data: 'FULL_NAME',    defaultContent: "", title: "Empleado" },
        { data: 'AREA',         defaultContent: "", title: "Area" },
        { data: 'GERENCIA',     defaultContent: "", title: "Gerencia",
          render: function(g){ return (g||'').replace(/^NI\s+/,'').trim(); }
        }
      ],
      dom: 'Bfrtip',
      buttons: [{
        extend: 'excelHtml5',
        text: 'Exportar a Excel',
        title: 'HorasExtra',
        exportOptions: { columns: ':visible', modifier: { page: 'all' } }
      }],
      lengthMenu: [10,20,50,100],
      pageLength: 10,
      language: { url: '@Url.Content("~/Scripts/datatable.es-ES.json")' },
      responsive: true
    });

    // Reportes PDF
    $('#btnReporte').click(function () {
      var mes = $('#selectMes').val();
      var url = '@Url.Action("horaextratodo3", "ExtraTime")' + '?id=' + mes;
      window.open(url, '_blank');
    });
    $('#btnReporte2').click(function () {
      var mes = $('#selectMes').val();
      var url = '@Url.Action("horaextratodo4", "ExtraTime")' + '?id=' + mes;
      window.open(url, '_blank');
    });

    // ⬇️ Botón Excel → descarga directa
    $('#btnExcel').on('click', function () {
      var mes = $('#selectMes').val();                                    // mes seleccionado
      var url = '@Url.Action("HoraExtraTodo5Excel","ExtraTime")'          // acción MVC
                + '?id=' + encodeURIComponent(mes);
      console.log('Excel URL:', url);                                     // depuración
      location.href = url;                                                // dispara descarga
    });

    // Buscar → JSON → KPIs + Pivot
    $('#btnBuscar').click(function () {
      $.LoadingOverlay("show");
      var url = '@Url.Action("horaextratodo2", "ExtraTime")' + '?id=' + $('#selectMes').val();

      $.ajax({ url: url, type: 'GET', dataType: 'json' })
      .done(function (json) {
        var datos = (json && json.data) ? json.data : [];
        var dt = $('#tablaHorasExtra').DataTable();
        dt.clear().rows.add(datos).draw();
        renderDashboard(datos);
        renderPivot(datos);
      })
      .fail(function () {
        $('#dashboard').empty();
        $('#pivotHorasExtra').empty();
      })
      .always(function () { $.LoadingOverlay("hide"); });
    });

    // Autocarga opcional:
    // $('#btnBuscar').trigger('click');
  });
    </script>
}
