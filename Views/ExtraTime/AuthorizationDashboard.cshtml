@{
    ViewBag.Title = "Autorización de Horas Extras | Claro";
    Layout = "~/Views/Shared/_mainLayout.cshtml";

    bool isBoss = ViewBag.CanAuthBoss != null && (bool)ViewBag.CanAuthBoss;
    bool isManager = ViewBag.CanAuthManager != null && (bool)ViewBag.CanAuthManager;
}

<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">

<style>
    /* =============================================
       1. TEMA CLARO EMPRESA (Tus estilos originales)
       ============================================= */
    #claro-wrapper {
        font-family: 'Roboto', 'Segoe UI', sans-serif;
        background-color: #F4F6F9 !important;
        color: #333333 !important;
        min-height: 85vh;
        padding: 20px;
        border-radius: 8px;
        position: relative;
    }

        /* Reset de Textos */
        #claro-wrapper h1, #claro-wrapper h2, #claro-wrapper h3,
        #claro-wrapper h4, #claro-wrapper h5, #claro-wrapper span,
        #claro-wrapper div, #claro-wrapper p, #claro-wrapper td {
            color: #333 !important;
        }

        #claro-wrapper .text-white {
            color: #fff !important;
        }

        

        #claro-wrapper .text-danger {
            color: #DA291C !important;
        }

    /* Loader */
    #page-loader {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255, 255, 255, 0.8);
        z-index: 9999;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        border-radius: 8px;
        backdrop-filter: blur(3px);
    }

    .claro-spinner {
        width: 50px;
        height: 50px;
        border: 5px solid #f3f3f3;
        border-top: 5px solid #DA291C;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-bottom: 15px;
    }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    /* Header & Botones (Originales) */
    .claro-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        background: #fff;
        padding: 20px 25px;
        border-radius: 12px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        border-left: 5px solid #DA291C;
    }

    .btn-claro {
        background-color: #333;
        color: #fff !important;
        border: none;
        padding: 10px 20px;
        border-radius: 50px;
        font-weight: 500;
        transition: all 0.3s;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-claro:hover {
            background-color: #000;
            transform: translateY(-2px);
        }

    .btn-excel {
        background-color: #1D6F42;
        color: white !important;
        margin-right: 10px;
    }

        .btn-excel:hover {
            background-color: #155724;
        }

    .btn-action-approve {
        background: linear-gradient(45deg, #28a745, #218838);
        color: white !important;
        border: none;
    }

    .btn-action-deny {
        background: linear-gradient(45deg, #DA291C, #b01f14);
        color: white !important;
        border: none;
    }

    /* KPIs (Originales) */
    .kpi-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .kpi-box {
        background: #fff;
        border-radius: 15px;
        padding: 20px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        transition: transform 0.3s;
        border: 1px solid rgba(0,0,0,0.03);
    }

        .kpi-box:hover {
            transform: translateY(-5px);
        }

        .kpi-box::before {
            content: '';
            position: absolute;
            top: -20px;
            right: -20px;
            width: 100px;
            height: 100px;
            border-radius: 50%;
            opacity: 0.1;
        }

    .kpi-jefe::before {
        background: #f6c23e;
    }

    .kpi-gerente::before {
        background: #DA291C;
    }

    .kpi-icon {
        font-size: 2.5rem;
        margin-bottom: 10px;
        opacity: 0.8;
    }

    .kpi-number {
        font-size: 2.8rem;
        font-weight: 800;
        line-height: 1;
        color: #222 !important;
    }

    .kpi-title {
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #888 !important;
        font-weight: 600;
    }

    /* Tabs (Originales) */
    .claro-tabs {
        border-bottom: none;
        background: transparent;
        gap: 10px;
    }

        .claro-tabs .nav-link {
            border: none;
            background: #e9ecef;
            color: #555 !important;
            border-radius: 10px 10px 0 0;
            padding: 12px 25px;
            font-weight: 600;
            transition: all 0.3s;
            opacity: 0.7;
        }

            .claro-tabs .nav-link:hover {
                opacity: 1;
                background: #dfe2e6;
            }

            .claro-tabs .nav-link.active {
                background: #fff;
                color: #DA291C !important;
                box-shadow: 0 -4px 10px rgba(0,0,0,0.05);
                opacity: 1;
                border-top: 3px solid #DA291C;
            }

    /* =============================================
       2. NUEVO DISEÑO DE TABLA (Dentro del Wrapper)
       ============================================= */
    .table-wrapper {
        background: #fff;
        border-radius: 0 15px 15px 15px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    table.dataTable {
        width: 100% !important;
        border-collapse: collapse !important;
    }

        table.dataTable thead th {
            background-color: #333;
            color: #fff !important;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            border: none;
            padding: 12px 8px !important;
            vertical-align: middle;
        }

            table.dataTable thead th.select-checkbox-header {
                background-color: #DA291C;
                text-align: center;
                width: 40px;
            }

        table.dataTable tbody tr td {
            padding: 12px 8px !important;
            vertical-align: top; /* Alineación arriba para notas largas */
            border-bottom: 1px solid #f0f0f0;
            font-size: 0.9rem;
        }

        table.dataTable tbody tr:hover {
            background-color: #fff9f9 !important;
        }

    /* ESTILOS DE CELDAS PERSONALIZADAS */

    /* Pila de Usuario (Nombre + Area) */
    .stack-user {
        display: flex;
        flex-direction: column;
    }

        .stack-user strong {
            font-size: 0.95rem;
            color: #222 !important;
        }

        .stack-user small {
            color: #888 !important;
            text-transform: uppercase;
            font-size: 0.7rem;
            margin-top: 2px;
        }

    /* Pila de Horario (Inicio + Fin) */
    .stack-time {
        display: flex;
        flex-direction: column;
        font-family: 'Roboto Mono', monospace;
        font-size: 0.85rem;
    }

    .time-row {
        display: flex;
        align-items: center;
        gap: 5px;
        margin-bottom: 2px;
    }

        .time-row i {
            font-size: 0.7rem;
        }

    .text-in {
        color: #28a745 !important;
    }

    .text-out {
        color: #DA291C !important;
    }

    /* Celda de Nota (WRAP) */
    .cell-note {
        white-space: normal !important; /* Permite saltos de línea */
        min-width: 250px; /* Ancho mínimo generoso */
        color: #444 !important;
        line-height: 1.4;
        background-color: #fcfcfc;
        border-radius: 4px;
        padding: 8px !important;
        border-left: 3px solid #ddd;
    }

    /* Badges */
    .badge-status {
        padding: 5px 10px;
        border-radius: 4px;
        font-size: 0.7rem;
        font-weight: 700;
        display: inline-block;
        width: 100%;
    }

    .st-gray {
        background: #e2e3e5;
        color: #383d41 !important;
    }

    .st-yellow {
        background: #fff3cd;
        color: #856404 !important;
    }

    .st-blue {
        background: #d1ecf1;
        color: #0c5460 !important;
    }

    .st-green {
        background: #d4edda;
        color: #155724 !important;
    }

    .big-checkbox {
        width: 18px;
        height: 18px;
        cursor: pointer;
        accent-color: #DA291C;
    }

    .dataTables_filter input {
        border: 2px solid #eee;
        border-radius: 20px;
        padding: 5px 15px;
        transition: border 0.3s;
    }

        .dataTables_filter input:focus {
            border-color: #DA291C;
            outline: none;
        }
    /* Pila de Horario (Inicio + Fin) - VERSIÓN GRANDE */
    .stack-time {
        display: flex;
        flex-direction: column;
        gap: 6px; /* Más separación entre las dos horas */
    }

    .time-row {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'Roboto Mono', monospace; /* Fuente monoespaciada para alinear números */
        font-size: 0.95rem; /* AUMENTADO (Antes era 0.85rem) */
        font-weight: 700; /* NEGRITA */
        color: #333;
        background-color: #f8f9fc; /* Fondo sutil para resaltar */
        padding: 4px 8px; /* Espacio interno */
        border-radius: 6px; /* Bordes redondeados */
        width: fit-content; /* Ajustar ancho al contenido */
        border: 1px solid #e3e6f0;
    }

        .time-row i {
            font-size: 0.9rem; /* Iconos más grandes */
        }

    .text-in {
        color: #28a745 !important;
    }
    /* Verde */
    .text-out {
        color: #DA291C !important;
    }
    /* Rojo Claro */
</style>

<div id="claro-wrapper">

    <div id="page-loader">
        <div class="claro-spinner"></div>
        <span class="font-weight-bold text-muted">Cargando datos...</span>
    </div>

    <div class="claro-header">
        <div>
            <h2 style="margin:0; font-weight:800;">Tablero de Control de Horas Extras</h2>
            <span class="text-muted">Gestión Centralizada 2025</span>
        </div>
        <div>
            <button class="btn btn-claro btn-excel" onclick="exportActiveTable()">
                <i class="fas fa-file-excel"></i> Exportar Excel
            </button>
            <button class="btn btn-claro" onclick="reloadAll()">
                <i class="fas fa-sync-alt spin-on-hover"></i> Actualizar
            </button>
        </div>
    </div>

    <div class="kpi-container">
        <div class="kpi-box kpi-jefe">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="kpi-title">Pendiente Jefe</div>
                    <div class="kpi-number" id="lblJefe">...</div>
                </div>
                <div class="kpi-icon text-warning"><i class="fas fa-user-clock"></i></div>
            </div>
        </div>
        <div class="kpi-box kpi-gerente">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="kpi-title">Pendiente Gerencia</div>
                    <div class="kpi-number" id="lblGerente">...</div>
                </div>
                <div class="kpi-icon text-danger"><i class="fas fa-briefcase"></i></div>
            </div>
        </div>
    </div>

    <ul class="nav nav-tabs claro-tabs" id="mainTabs" role="tablist">
        <li class="nav-item"><a class="nav-link active" data-toggle="tab" href="#pane-1" onclick="loadGrid(1)"><i class="fas fa-pen-square mr-1"></i>Pendiente autorizar por jefe inmediato</a></li>
        <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#pane-2" onclick="loadGrid(2)"><i class="fas fa-check-square mr-1"></i>Pendiente Autorizar por Gerente</a></li>
        <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#pane-3" onclick="loadGrid(3)"><i class="fas fa-history mr-1"></i> Registro Empleado</a></li>
    </ul>

    <div class="table-wrapper">
        <div class="tab-content">

            <div class="tab-pane fade show active" id="pane-1">
                <div class="d-flex justify-content-between align-items-center mb-3">
                   
                    @if (isBoss)
                    {
                        <div>
                            <button class="btn btn-action-approve btn-sm rounded-pill px-3 py-2 mr-2 shadow-sm" onclick="executeBatch(1, 'APROBAR')"><i class="fas fa-check"></i>  Autorizar</button>
                            <button class="btn btn-action-deny btn-sm rounded-pill px-3 py-2 shadow-sm" onclick="executeBatch(1, 'DENEGAR')"><i class="fas fa-times"></i> Denegar</button>
                        </div>
                    }
                    else
                    { <span class="badge badge-secondary p-2"><i class="fas fa-lock"></i> Solo Lectura</span>}
                </div>
                <table id="dtTable1" class="table w-100"></table>
            </div>

            <div class="tab-pane fade" id="pane-2">
                <div class="d-flex justify-content-between align-items-center mb-3">
                     @if (isManager)
                    {
                        <div>
                            <button class="btn btn-action-approve btn-sm rounded-pill px-3 py-2 mr-2 shadow-sm" onclick="executeBatch(2, 'APROBAR')"><i class="fas fa-check-double"></i> Autorizar Final</button>
                            <button class="btn btn-action-deny btn-sm rounded-pill px-3 py-2 shadow-sm" onclick="executeBatch(2, 'DENEGAR')"><i class="fas fa-times"></i> Denegar</button>
                        </div>
                    }
                    else
                    { <span class="badge badge-info p-2"><i class="fas fa-lock"></i> Solo Lectura</span>}
                </div>
                <table id="dtTable2" class="table w-100"></table>
            </div>

            <div class="tab-pane fade" id="pane-3">
                <div class="d-flex align-items-center mb-3">
                    <h4 class="font-weight-bold mr-3"> </h4>
                </div>
                <table id="dtTable3" class="table w-100"></table>
            </div>

        </div>
    </div>

</div>

@section scripts {
    <script src="~/onlinejs/jquery-3.6.0.min.js"></script>
    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>

    <script src="~/onlinejs/dataTables.buttons.min.js"></script>
    <script src="~/onlinejs/jszip.min.js"></script>
    <script src="~/onlinejs/buttons.html5.min.js"></script>

    <script src="~/onlinejs/bootstrap.bundle.min.js"></script>
    <script src="~/onlinejs/loadingoverlay.min.js"></script>
    <script src="~/Content/plugin/sweetalert2/sweetalert2.all.js"></script>
    <script src="~/onlinejs/moment.min.js"></script>

    <script>
        $(document).ready(function () {
            reloadAll();
        });

        function reloadAll() {
            $('#page-loader').fadeIn(200);
            updateKPIs();
            var activeTab = $('.nav-link.active').attr('href');
            if(activeTab === '#pane-1') loadGrid(1);
            else if(activeTab === '#pane-2') loadGrid(2);
            else if(activeTab === '#pane-3') loadGrid(3);
        }

        function updateKPIs() {
            $.get('@Url.Action("GetBoardStats2025", "ExtraTime")', function (res) {
                if (res.status === "OK") {
                    $('#lblJefe').text((res.jefe || 0).toLocaleString('en-US'));
                    $('#lblGerente').text((res.gerente || 0).toLocaleString('en-US'));
                }
            });
        }

        function exportActiveTable() {
            var activeTab = $('.nav-link.active').attr('href');
            var tableId = (activeTab === '#pane-1') ? '#dtTable1' : (activeTab === '#pane-2') ? '#dtTable2' : '#dtTable3';

            if ($.fn.DataTable.isDataTable(tableId)) {
                $(tableId).DataTable().button('.buttons-excel').trigger();
            } else {
                Swal.fire("Info", "No hay datos para exportar.", "info");
            }
        }

        function loadGrid(stage) {
            var tableId = '#dtTable' + stage;

            if ($.fn.DataTable.isDataTable(tableId)) {
                var dt = $(tableId).DataTable();
                dt.ajax.reload(function() {
                    $('#page-loader').fadeOut(300);
                    $(tableId + '_wrapper .checkAll').prop('checked', false);
                });
                return;
            }

            var cols = [];
            // 1. Checkbox
            if (stage < 3) {
                cols.push({
                    "data": null, "width": "30px", "orderable": false, "className": "select-checkbox-header text-center desktop",
                    "title": '<input type="checkbox" class="big-checkbox checkAll">',
                    "render": function (d, t, r) { return '<input type="checkbox" class="big-checkbox checkItem" value="' + r.EXTRATIME_ID + '">'; }
                });
            }

            // --- DEFINICIÓN DE COLUMNAS REDISEÑADA ---
            cols.push(
                // 2. Carnet
                { "data": "EMPLOYEE_NUMBER", "title": "Carnet", "width": "70px", "className": "font-weight-bold text-center" },

                // 3. NOMBRE + ÁREA (Stack)
                {
                    "data": "FULL_NAME",
                    "title": "Colaborador / Área",
                    "width": "220px",
                    "render": function(data, type, row) {
                        var area = row.AREA || "Sin Área";
                        // Nombre en negrita, Área abajo pequeña y gris
                        return `<div class="stack-user">
                                    <strong>${data}</strong>
                                    <small>${area}</small>
                                </div>`;
                    }
                },

                // 4. ESTADO
                { "data": "STATUS", "title": "Estado", "width": "90px", "className": "text-center", "render": function(d){
                    if(d=='1') return '<span class="badge-status st-gray">Registrado</span>';
                    if(d=='2') return '<span class="badge-status st-yellow">Aut. Jefe</span>';
                    if(d=='3') return '<span class="badge-status st-blue">Aut. Gerente</span>';
                    if(d=='4') return '<span class="badge-status st-green">Finalizado</span>';
                    return '<span class="badge-status st-gray">'+d+'</span>';
                }},

                // 5. FECHA (Limpia)
                { "data": "DATE_EXTRATIME", "title": "Fecha", "width": "80px", "className": "text-center", "render": function(d){
                    if (!d) return "";
                    return d.replace(/ 12:00:00.*$/gi, "").replace(/ 00:00:00.*$/gi, "");
                }},

                // 6. HORARIO APILADO (Entrada Arriba / Salida Abajo)
                // 6. HORARIO APILADO (Entrada Arriba / Salida Abajo) - DISEÑO GRANDE
                {
                    "data": null,
                    "title": "Entrada / Salida", // Título más corto para ahorrar espacio
                    "width": "130px", // Un poco más ancho para acomodar la fuente grande
                    "className": "text-center",
                    "render": function (data, type, row) {
                        var ini = formatTimeOnly(row.Hour_Start);
                        var fin = formatTimeOnly(row.Hour_End);
                        // Nota: Agregué clases de utilidad para asegurar alineación
                        return `<div class="stack-time">
                                    <div class="time-row" title="Hora Entrada">
                                        <i class="fas fa-arrow-right text-in"></i> 
                                        <span>${ini}</span>
                                    </div>
                                    <div class="time-row" title="Hora Salida">
                                        <i class="fas fa-arrow-left text-out"></i> 
                                        <span>${fin}</span>
                                    </div>
                                </div>`;
                    }
                },

                // 7. HORAS TOTALES
                { "data": "HOURS", "title": "TOTAL HORA", "width": "100px", "className": "text-right font-weight-bold" },

                // 8. NOTA EXPANDIDA (Lo importante)
                {
                    "data": "Notes",
                    "title": "Nota / Justificación",
                    "className": "cell-note", // Clase CSS aplicada para wrapping
                    "defaultContent": "-"
                },

                // 9. SERVICIO
                { "data": "Service_Number", "title": "Servicio", "className": "small text-muted", "defaultContent": "-" }
            );

            var table = $(tableId).DataTable({
                "ajax": {
                    "url": '@Url.Action("GetBoardData2025", "ExtraTime")',
                    "type": "GET",
                    "data": { stage: stage }
                },
                "columns": cols,
                "language": { "url": '@Url.Content("~/Scripts/datatable.es-ES.json")' },
                "responsive": false, // Desactivado responsive automático para forzar nuestro diseño
                "autoWidth": false,
                "dom": 'Bfrtip',
                "buttons": [
                    {
                        extend: 'excel',
                        className: 'd-none',
                        title: 'Reporte_' + (stage==1?'Jefe':(stage==2?'Gerente':'Historial')),
                        exportOptions: {
                            columns: ':not(:first-child)',
                            format: { body: function (data, row, column, node) {
                                if(typeof data === 'string') {
                                    // Limpiar HTML para Excel (Hack para separar nombre y area)
                                    var clean = data.replace('<small>', ' - ').replace(/<[^>]*>?/gm, ' ').replace(/\s+/g,' ').trim();
                                    return clean;
                                }
                                return data;
                            }}
                        }
                    }
                ],
                "order": [[ stage < 3 ? 4 : 3, "desc" ]],
                "initComplete": function() { $('#page-loader').fadeOut(300); },
                "drawCallback": function() { $(tableId + ' .checkAll').prop('checked', false); }
            });

            // Select All Logic
            $('body').on('change', tableId + ' .checkAll', function() {
                var isChecked = $(this).prop('checked');
                $(tableId + ' tbody .checkItem').prop('checked', isChecked);
            });
            $('body').on('change', tableId + ' tbody .checkItem', function() {
                var total = $(tableId + ' tbody .checkItem').length;
                var checked = $(tableId + ' tbody .checkItem:checked').length;
                $(tableId + ' .checkAll').prop('checked', (total === checked && total > 0));
            });
        }

        function formatTimeOnly(timeString) {
            if (!timeString) return "--:--";
            var m = moment(timeString);
            return m.isValid() ? m.format('HH:mm') : timeString;
        }

        function executeBatch(stage, action) {
            var tableId = '#dtTable' + stage;
            var ids = [];
            $(tableId + ' .checkItem:checked').each(function() { ids.push($(this).val()); });

            if (ids.length === 0) {
                Swal.fire({ title: "Atención", text: "Seleccione registros", icon: "warning", confirmButtonColor: "#333" });
                return;
            }

            var colorBtn = (action === 'APROBAR') ? '#28a745' : '#DA291C';
            Swal.fire({
                title: '¿Confirmar?',
                text: `Procesar ${ids.length} registros: ${action}`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: colorBtn,
                confirmButtonText: 'Sí, Procesar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.LoadingOverlay("show", { text: "Procesando..." });
                    $.ajax({
                        url: '@Url.Action("ProcessBatch2025", "ExtraTime")',
                        type: 'POST',
                        data: { ids: ids.join(','), stage: stage, action: action },
                        success: function (res) {
                            $.LoadingOverlay("hide");
                            if (res.status === "OK") {
                                Swal.fire("¡Hecho!", res.message, "success");
                                reloadAll();
                            } else {
                                Swal.fire("Error", res.message, "error");
                            }
                        },
                        error: function() {
                            $.LoadingOverlay("hide");
                            Swal.fire("Error", "Fallo de comunicación", "error");
                        }
                    });
                }
            });
        }
    </script>
}