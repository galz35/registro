    }

    #appointmentsModal .modal-body {
        background: #fff;
        color: #111827;
    }

    /* modal CRUD (corporativo) */
    #modalCrud .modal-header {
        background: #111827;
        color: #fff;
    }

    #modalCrud .modal-footer {
        background: #f3f4f6;
    }



    #btnGuardarCrud:hover {
        background: #dc2626;
        border-color: #dc2626;
    }

    #btnAddDetail {
        background: #374151;
        color: #fff;
    }

        #btnAddDetail:hover {
            background: #1f2937;
            color: #fff;
        }

    .req-hint {
        color: #ef4444;
        font-weight: 600;
    }

    .form-text-muted {
        color: #6b7280;
        font-size: .85rem;
    }
    /* === Estilos OTP (paleta rojo/blanco/gris/negro) === */
    /* Barra de aviso debajo del header del modal CRUD */
    :root {
        --brand-red-600: #dc2626;
        --brand-red-500: #ef4444;
        --brand-red-700: #b91c1c;
        --ink-900: #111827;
        --ink-700: #374151;
        --ink-600: #4b5563;
        --ink-200: #e5e7eb;
        --ink-100: #f3f4f6;
        --warn-100: #fff7cc; /* amarillo suave */
        --warn-200: #ffe680;
        --ok-100: #d1fae5; /* verde pastel claro */
    }

    /* Contenedor del modal */
    #modalCrud .modal-dialog {
        max-width: 1120px; /* xl pero un poco más elegante en pantallas grandes */
    }

    #modalCrud .modal-content {
        border: 1px solid var(--ink-200);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 18px 60px rgba(0,0,0,.18);
        background: #fff;
    }

    /* Header con gradiente sobrio */
    #modalCrud .modal-header {
        padding: 14px 18px;
        background: linear-gradient(90deg, var(--ink-900), #1f2937);
        color: #fff;
        border-bottom: none;
        align-items: center;
    }

    #modalCrud .modal-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 800;
        letter-spacing: .2px;
        font-size: 1.15rem;
    }

        #modalCrud .modal-title .ttl-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--brand-red-500);
            box-shadow: 0 0 0 3px rgba(239,68,68,.25);
        }

    #modalCrud .close {
        opacity: .9;
        text-shadow: none;
        color: #fff !important;
        font-size: 1.6rem;
    }

        #modalCrud .close:hover {
            opacity: 1;
        }

    /* Barra informativa obligatoria (entre header y body) */
    #modalCrud .header-info-bar {
        display: flex;
        gap: 14px;
        align-items: flex-start;
        background: linear-gradient(180deg, #fafafa, #ffffff);
        padding: 16px 18px;
        border-bottom: 1px dashed var(--ink-200);
    }

        #modalCrud .header-info-bar .icon-wrap {
            min-width: 38px;
            height: 38px;
            display: grid;
            place-items: center;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--brand-red-600), var(--brand-red-500));
            color: #fff;
            box-shadow: 0 6px 16px rgba(239,68,68,.35);
        }

        #modalCrud .header-info-bar .t1 {
            font-weight: 800;
            color: var(--ink-900);
            margin-bottom: 4px;
            font-size: 1.02rem;
        }

        #modalCrud .header-info-bar .hl {
            background: var(--warn-100);
            border: 1px solid var(--warn-200);
            padding: .08rem .38rem;
            border-radius: .38rem;
            font-weight: 700;
            color: #111;
        }

        #modalCrud .header-info-bar ol {
            margin: .35rem 0 0 1.1rem;
            padding: 0;
            color: var(--ink-700);
        }

        #modalCrud .header-info-bar p {
            margin: .45rem 0 0 0;
            color: var(--ink-700);
        }

    /* Formulario */
    #modalCrud .modal-body {
        padding: 18px;
        background: #fff;
    }

    #modalCrud .form-label {
        font-weight: 700;
        color: var(--ink-900);
        margin-bottom: .35rem;
    }

    #modalCrud .badge-obligatorio {
        background: var(--brand-red-500);
        color: #fff;
        font-weight: 700;
        padding: .2rem .45rem;
        border-radius: 999px;
        font-size: .72rem;
        margin-left: .25rem;
        vertical-align: top;
    }

    #modalCrud .helper {
        display: block;
        margin-top: .25rem;
        font-size: .82rem;
        color: var(--ink-600);
    }

    /* Inputs: foco en rojo corporativo */
    #modalCrud .form-control, #modalCrud select, #modalCrud textarea {
        border: 1px solid var(--ink-200);
        transition: box-shadow .2s ease, border-color .2s ease;
    }

        #modalCrud .form-control:focus, #modalCrud select:focus, #modalCrud textarea:focus {
            border-color: var(--brand-red-500);
            box-shadow: 0 0 0 .2rem rgba(239,68,68,.2);
        }

    /* Tabla detalle */
    #modalCrud #detailGrid thead {
        background: var(--ink-900);
        color: #fff;
    }

    #modalCrud #detailGrid th {
        text-transform: uppercase;
        font-size: .8rem;
        letter-spacing: .4px;
    }

    #modalCrud #detailGrid tbody tr:hover {
        background: #fdf2f2; /* leve rose/rojo muy claro */
    }

    /* Botones */
    #modalCrud #btnAddDetail {
        background: var(--ink-700);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: .4rem .75rem;
        font-weight: 700;
        box-shadow: 0 6px 20px rgba(55,65,81,.25);
    }

        #modalCrud #btnAddDetail:hover {
            background: #2b3440;
        }

    #modalCrud #btnGuardarCrud {
        background: var(--brand-red-500);
        border-color: var(--brand-red-500);
        font-weight: 800;
        border-radius: 10px;
        padding: .45rem 1.1rem;
        box-shadow: 0 10px 26px rgba(239,68,68,.35);
    }

        #modalCrud #btnGuardarCrud:hover {
            background: var(--brand-red-600);
            border-color: var(--brand-red-600);
        }

    /* Footer pegado visualmente */
    #modalCrud .modal-footer {
        border-top: 1px solid var(--ink-200);
        background: #fff;
        padding: 12px 18px;
    }
</style>




<!-- Template opciones Tipo Servicio -->
<select id="tplTipoServicio" class="d-none">
    <option value="">Seleccione un tipo</option>
    @foreach (var ts in tiposServicios)
    {
        <option value="@ts.IdTipoServicio">@ts.NombreTipoServicio</option>
    }
</select>

<!-- BREADCRUMB -->
<div class="breadcrumb-container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="@url2"><span class="breadcrumb-box"><i class="fas fa-home"></i>&nbsp;Home</span></a>
            </li>
            <li class="breadcrumb-item">
                <a href="@url"><span class="breadcrumb-box"><i class="fas fa-users"></i>&nbsp;Lista Unidad</span></a>
            </li>
            <li class="breadcrumb-item active">
                <a href="javascript:void(0);" onclick="location.reload();"><span class="breadcrumb-box"><i class="fas fa-calendar-alt"></i>&nbsp;Lista Cita</span></a>
            </li>
        </ol>
    </nav>
</div>

<!-- LISTA -->
<div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
        <div class="container-fluid">
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-primary" style="color:#111827!important;">Lista de Cita - @ViewBag.Unidad</h6>
                    <a href="javascript:void(0);" id="mostrarPopupBtn" onclick="ShowEditAppointment2()" class="btn btn-primary btn-icon-split">
                        <span class="icon text-white-50"><i class="fas fa-plus"></i></span>
                        <span class="text">Registrar Nuevo</span>
                    </a>
                </div>
                <div class="card-body p-3">
                    <table id="listTable" class="table table-striped table-bordered table-hover display responsive nowrap" style="width:100%">
                        <thead>
                            <tr>
                                <th>Acción</th>
                                <th>Código cita</th>
                                <th>Unidad</th>
                                <th>Fecha</th>
                                <th>Km</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>

                    <div class="mt-3">
                        <span class="req-hint">* El número de WhatsApp/SMS es obligatorio para la solicitud.</span>
                        <div class="form-text-muted">Se responderá por ese mismo canal. Si no contesta, la solicitud pasará a una lista de “No contesta WhatsApp”.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- === MODAL OTP (Bootstrap, sin SweetAlert2) === -->
<div class="modal fade" id="otpModal" tabindex="-1" role="dialog" aria-labelledby="otpTitle" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered" role="document">
        <div class="modal-content otp-card">
            <div class="modal-header py-2">
                <h5 class="modal-title" id="otpTitle">Verificación por SMS</h5>
                <button type="button" class="close text-dark" data-dismiss="modal" aria-label="Cerrar"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <p class="mb-2 text-muted">Ingresa el código enviado a tu Telefono o Correo.</p>
                <input id="otpInput" type="text" class="form-control text-center otp-input" maxlength="6"
                       inputmode="numeric" autocomplete="one-time-code" placeholder="000000" />
                <small id="otpError" class="text-danger d-none mt-2">Ingresa un código numérico válido (6 dígitos).</small>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                <button id="btnOtpConfirm" type="button" class="btn btn-danger">Validar</button>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="modalCrud" tabindex="-1" role="dialog" aria-labelledby="modalCrudTitle" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <form id="frmAppointment" class="modal-content">
            <!-- Header -->
            <div class="modal-header">
                <h5 class="modal-title" id="modalCrudTitle">
                    <span class="ttl-dot"></span> Registrar Cita
                </h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <!-- Info obligatoria -->
            <div class="header-info-bar" role="alert" aria-live="polite">
                <div class="icon-wrap"><i class="fas fa-info"></i></div>
                <div>
                    <div class="t1">Requisito obligatorio para la solicitud</div>
                    Ahora es <span class="hl">obligatorio</span> indicar un <span class="hl">número de teléfono con WhatsApp activo</span>:
                    <ol>
                        <li><span class="hl">Te enviaremos un código por SMS</span> para completar el registro de la cita.</li>
                        <li><span class="hl">Usaremos WhatsApp</span> para notificar el avance de tu solicitud; por favor <span class="hl">responde</span> a esos mensajes.</li>
                    </ol>
                    <p><span class="hl">Si no respondes</span>, se entenderá que no asistirás y tu solicitud pasará a <b>“No contesta WhatsApp”</b>.</p>
                </div>
            </div>

            <!-- Body -->
            <div class="modal-body">
                <div class="row g-3 mb-3">
                    <input type="hidden" id="IdCita" name="IdCita" />
                    <div class="col-md-4">
                        <label class="form-label">Fecha de Cita</label>
                        <input type="date" class="form-control" id="FechaCita" name="FechaCita" required />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label mb-1">
                            WhatsApp / SMS
                            <span class="badge-obligatorio">Obligatorio</span>
                        </label>
                        <input type="text"
                               class="form-control"
                               id="WhatsApp"
                               name="WhatsApp"
                               placeholder="0000-0000"
                               maxlength="9"
                               required />
                        <small class="helper">A este número enviaremos el SMS de verificación y las notificaciones por WhatsApp.</small>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Km Actual</label>
                        <input type="number" class="form-control" id="KilometrajeActual" name="KilometrajeActual" min="0" required />
                    </div>

                    <div class="col-12">
                        <label class="form-label">Observaciones</label>
                        <textarea class="form-control" id="Observacion" name="Observacion" rows="3" style="text-transform:uppercase;"></textarea>
                    </div>
                </div>

                <table id="detailGrid" class="table table-bordered table-hover w-100">
                    <thead>
                        <tr>
                            <th style="width:45%">Tipo de Servicio</th>
                            <th>Observación</th>
                            <th style="width:90px">Acción</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>

                <button type="button" id="btnAddDetail" class="btn btn-sm">
                    <i class="fas fa-plus"></i> Fila
                </button>
            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button type="submit" id="btnGuardarCrud" class="btn btn-primary">Guardar</button>
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
            </div>
        </form>
    </div>
</div>
<!-- MODAL ANEXAR SOLICITUD -->
<div class="modal fade" id="appointmentsModal" tabindex="-1" role="dialog" aria-labelledby="appointmentsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header" style="background:#111827;color:#fff;">
                <h5 class="modal-title" id="appointmentsModalLabel">Gestión de Citas</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar"><span aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body" style="background:#fff;color:#111827;">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="appointmentsGrid">
                        <thead style="background:#1f2937;color:#fff;">
                            <tr>
                                <th>Tipo de Servicio</th>
                                <th>Observación</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody><!-- dinámico --></tbody>
                    </table>

                    <div class="d-flex justify-content-between mt-3">
                        <button class="btn btn-success" id="addRowBtn" style="background:#ef4444;border-color:#ef4444;">Agregar Nueva Solicitud</button>
                        <div>
                            <button class="btn btn-primary" id="saveAllBtn" style="background:#111827;border-color:#111827;">Guardar Todo</button>
                            <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
