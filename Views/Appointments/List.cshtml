@model List<Entities.ViewModels.AppointmentsView>
@{
    ViewBag.Title = "Lista de Citas";
    Layout = "~/Views/Shared/_mainLayout.cshtml";

    // Opciones del <select> de Tipo de Servicio generadas en servidor (sin DevExpress)
    var tiposServicios = slnRhonline.Data.TipoServicio.ObtenerTipoServicios() ?? new List<Entities.TipoServicios>();
}

@section scripts {
    <!-- libs -->
    <script src="~/onlinejs/jquery-3.6.0.min.js"></script>
    <script src="~/onlinejs/bootstrap.bundle.min.js"></script>
    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.responsive.min.js"></script>
    <script src="~/onlinejs/loadingoverlay.min.js"></script>
    <script src="~/Content/plugin/sweetalert2/sweetalert2.all.js"></script>
    <script src="~/onlinejs/moment.min.js"></script>
    <script>
 // -------------------------------
// Variables
// -------------------------------
var tabla_persona;
let valoresSeleccionados = new Set(); // evita duplicados en selects

// stack de modales
$(document).on('show.bs.modal', '.modal', function () {
    var z = 1040 + (10 * $('.modal:visible').length);
    $(this).css('z-index', z);
    setTimeout(function () {
        $('.modal-backdrop').not('.modal-stack')
            .css('z-index', z - 1)
            .addClass('modal-stack');
    }, 0);
});

// -------------------------------
// Helpers
// -------------------------------
function tplOptionsHtml() { return $('#tplTipoServicio').html(); }

// -------------------------------
// CRUD Modal (Nuevo/Editar/Consultar)
// -------------------------------
function openCrud(id, modo) {
    $('#modalCrudTitle').text(
        modo === 'nuevo' ? 'Registrar Cita' :
            (modo === 'consultar' ? 'Consultar Cita #' + id : 'Editar Cita #' + id)
    );

    $('#frmAppointment')[0].reset();
    $('#detailGrid tbody').empty();
    valoresSeleccionados.clear();

    $('#IdCita').val(id == -1 ? 0 : id);

    const readOnly = (modo === 'consultar');
    $('#frmAppointment :input').prop('disabled', readOnly);
    $('#btnAddDetail, #btnGuardarCrud').toggle(!readOnly);

    if (id != -1) {
        $.ajax({
            url: '@Url.Action("GetAppointment", "Appointments")',
            type: 'GET',
            data: { id: id },
            dataType: 'json'
        }).done(function (r) {
            if (!r) return;

            if (r.FechaCita) $('#FechaCita').val(r.FechaCita.split('T')[0]);
            $('#WhatsApp').val(r.Telefono || '');
            $('#KilometrajeActual').val(r.KilometrajeActual || '');
            $('#Observacion').val(r.Observacion || '');

            (r.Detalle || []).forEach(function (d) { addDetailRow(d); });
        }).fail(function () {
            Swal.fire('Error', 'No se pudo cargar la cita', 'error');
        });
    }

    $('#modalCrud').modal('show');
}

function ShowEditAppointment2() { openCrud(-1, 'nuevo'); }
function EditarCita(id) { openCrud(id, 'editar'); }
function ConsultarCita(id) { openCrud(id, 'consultar'); }

// -------------------------------
// Detalle (CRUD)
// -------------------------------
function addDetailRow(obj) {
    obj = obj || {};
    const options = tplOptionsHtml();

    const $tr = $(
        '<tr>' +
        '<td><select class="form-control tipo-servicio"><option value="">Seleccione un tipo</option>' + options + '</select></td>' +
        '<td><input type="text" class="form-control observacion-detalle" placeholder="Ingrese una observación" /></td>' +
        '<td class="text-center"><button type="button" class="btn btn-danger btn-sm btn-del-detail"><i class="fas fa-trash"></i></button></td>' +
        '</tr>'
    );

    if (obj.IdTipoServicio) {
        $tr.find('select').val(obj.IdTipoServicio);
        valoresSeleccionados.add(String(obj.IdTipoServicio));
    }
    if (obj.Observacion) $tr.find('.observacion-detalle').val(obj.Observacion);

    // ✅ evita "valores pegados" al cambiar
    $tr.find('select').data('prev', String($tr.find('select').val() || ''));

    $tr.find('select').on('change', function () {
        const $sel = $(this);
        const prev = String($sel.data('prev') || '');
        const v = String($sel.val() || '');

        if (prev) valoresSeleccionados.delete(prev);

        if (!v) { $sel.data('prev', ''); return; }

        if (valoresSeleccionados.has(v)) {
            Swal.fire('Error', 'Este tipo de servicio ya está registrado.', 'error');
            $sel.val('');
            $sel.data('prev', '');
            return;
        }

        valoresSeleccionados.add(v);
        $sel.data('prev', v);
    });

    $tr.find('.btn-del-detail').on('click', function () {
        const v = String($tr.find('select').val() || '');
        const prev = String($tr.find('select').data('prev') || '');
        if (v) valoresSeleccionados.delete(v);
        if (prev) valoresSeleccionados.delete(prev);
        $tr.remove();
    });

    $('#detailGrid tbody').append($tr);
}

// -------------------------------
// Sync detalle a Session (server)
// -------------------------------
function syncDetailSessionDesdeCrud() {
    const detalles = $('#detailGrid tbody tr').map(function () {
        const tipo = $(this).find('select.tipo-servicio').val();
        if (!tipo) return null;

        let obs = $(this).find('input.observacion-detalle').val();
        obs = (obs == null || obs === '') ? ' ' : obs;

        return { IdTipoServicio: tipo, Observacion: obs };
    }).get();

    return $.ajax({
        url: '@Url.Action("SyncDetailSession", "Appointments")',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({ items: detalles })
    }).then(function (resp) {
        return (resp && resp.success === true);
    }).catch(function () {
        return false;
    });
}

// -------------------------------
// OTP SMS + Guardar (con fallback)
// -------------------------------
function solicitarCodigoSMS(numero) {
    return $.ajax({
        url: '@Url.Action("RequestSmsCode", "Appointments")',
        type: 'POST',
        data: { numero: numero }
    });
}

// ✅ MISMO endpoint; en fallback mandamos SkipOtp=1 y OTP vacío
function verificarCodigoYGuardar(formDataPlano, codigo, skipOtp) {
    const extra = '&OtpCode=' + encodeURIComponent(codigo || '') +
        '&SkipOtp=' + encodeURIComponent(skipOtp ? '1' : '0');

    return $.ajax({
        url: '@Url.Action("VerifySmsAndSave", "Appointments")',
        type: 'POST',
        data: formDataPlano + extra
    });
}

// ✅ Guardar directo (sin mostrar error) cuando falla el SMS
function guardarSinOtp(formDataPlano, $btnGuardar) {
    // 1) sync detalle
    syncDetailSessionDesdeCrud().then(function (ok) {
        if (!ok) {
            $.LoadingOverlay("hide");
            $btnGuardar.prop('disabled', false);
            Swal.fire('Error', 'No se pudo preparar el detalle.', 'error');
            return;
        }

        // 2) guarda sin OTP
        verificarCodigoYGuardar(formDataPlano, '', true)
            .done(function (res) {
                if (res && res.status !== "Error") {
                    Swal.fire({ title: 'Éxito', text: res.message || 'Guardado correctamente', icon: 'success' })
                        .then(() => {
                            $('#modalCrud').modal('hide');
                            if (window.tabla_persona) tabla_persona.ajax.reload(null, false);
                        });
                } else {
                    Swal.fire('Error', (res && res.message) || 'No se pudo guardar.', 'error');
                }
            })
            .fail(function () {
                Swal.fire('Error', 'No se pudo guardar.', 'error');
            })
            .always(function () {
                $.LoadingOverlay("hide");
                $btnGuardar.prop('disabled', false);
            });
    });
}

// -------------------------------
// SUBMIT: intenta SMS->OTP; si SMS falla => guarda igual (sin OTP) y sin mostrar error de SMS
// -------------------------------
$(document).on('submit', '#frmAppointment', function (e) {
    e.preventDefault();

    const $btnGuardar = $('#btnGuardarCrud');
    const numero = ($('#WhatsApp').val() || '').replace(/\D+/g, '').trim();

    if (!numero) { Swal.fire('Obligatorio', 'El número de WhatsApp/SMS es obligatorio.', 'warning'); return; }
    if ($('#detailGrid tbody tr').length === 0) { Swal.fire('Obligatorio', 'Agregue al menos una fila de detalle.', 'warning'); return; }

    const formDataPlano = $(this).serialize();

    // anti doble click
    $btnGuardar.prop('disabled', true);
    $.LoadingOverlay("show");

    solicitarCodigoSMS(numero)
        .done(function (r) {
            // ✅ si no se pudo enviar SMS -> guardar igual sin OTP (sin mostrar error de SMS)
            if (!r || r.success !== true) {
                guardarSinOtp(formDataPlano, $btnGuardar);
                return;
            }

            // ✅ SMS enviado -> pedir OTP
            $.LoadingOverlay("hide");
            $('#otpError').addClass('d-none').text('Ingresa un código numérico válido (6 dígitos).');
            $('#otpInput').val('');
            $('#otpModal').modal('show');

            // Confirmar OTP (click)
            $('#btnOtpConfirm').off('click').on('click', function () {
                confirmarOtpYGuardar(formDataPlano, $btnGuardar);
            });

            // Confirmar OTP (Enter)
            $('#otpModal')
                .off('shown.bs.modal').on('shown.bs.modal', function () { $('#otpInput').trigger('focus'); })
                .off('keypress').on('keypress', function (ev) {
                    if (ev.key === 'Enter') {
                        ev.preventDefault();
                        confirmarOtpYGuardar(formDataPlano, $btnGuardar);
                    }
                });

            // si cierran el OTP, habilita guardar otra vez
            $('#otpModal').off('hidden.bs.modal').on('hidden.bs.modal', function () {
                $btnGuardar.prop('disabled', false);
                $('#otpInput').val('');
                $('#otpError').addClass('d-none');
            });
        })
        .fail(function () {
            // ✅ request SMS falló -> guardar igual sin OTP (sin error de SMS)
            guardarSinOtp(formDataPlano, $btnGuardar);
        });
});

// -------------------------------
// Confirmar OTP y guardar
// -------------------------------
function confirmarOtpYGuardar(formDataPlano, $btnGuardar) {
    const codigo = String(($('#otpInput').val() || '').trim());
    const isValid = /^\d{6}$/.test(codigo);

    if (!isValid) {
        $('#otpError').removeClass('d-none').text('Ingresa un código numérico válido (6 dígitos).');
        $('#otpInput').focus();
        return;
    }

    $('#otpError').addClass('d-none');
    $('#btnOtpConfirm').prop('disabled', true);
    $.LoadingOverlay("show");

    syncDetailSessionDesdeCrud().then(function (ok) {
        if (!ok) {
            $.LoadingOverlay("hide");
            $('#btnOtpConfirm').prop('disabled', false);
            $btnGuardar.prop('disabled', false);
            Swal.fire('Error', 'No se pudo preparar el detalle.', 'error');
            return;
        }

        verificarCodigoYGuardar(formDataPlano, codigo, false)
            .done(function (res) {
                if (res && res.status !== "Error") {
                    $('#otpModal').modal('hide');
                    Swal.fire({ title: 'Éxito', text: res.message || 'Guardado correctamente', icon: 'success' })
                        .then(() => {
                            $('#modalCrud').modal('hide');
                            if (window.tabla_persona) tabla_persona.ajax.reload(null, false);
                            $btnGuardar.prop('disabled', false);
                        });
                } else {
                    $('#otpError').removeClass('d-none').text((res && res.message) || 'Código inválido o expirado.');
                    $('#otpInput').focus();
                }
            })
            .fail(function () {
                $('#otpError').removeClass('d-none').text('Fallo en la verificación.');
                $('#otpInput').focus();
            })
            .always(function () {
                $.LoadingOverlay("hide");
                $('#btnOtpConfirm').prop('disabled', false);
            });
    });
}

// -------------------------------
// Modal "Anexar solicitud" (appointmentsModal)
// -------------------------------
function precargarCitas(idCita) {
    $.ajax({
        url: '@Url.Action("obtenerdetallecita", "Appointments")',
        type: 'GET',
        data: { idCita: idCita },
        dataType: 'json'
    }).done(function (detallesCita) {
        const $tb = $('#appointmentsGrid tbody');
        $tb.empty();
        const options = tplOptionsHtml();
        (detallesCita || []).forEach(function (cita) {
            const $row = $(
                '<tr data-existing="true">' +
                '<td><select class="form-control" disabled><option value="">Seleccione un tipo</option>' + options + '</select></td>' +
                '<td><textarea class="form-control" disabled></textarea></td>' +
                '<td><span class="text-muted">Registro existente</span></td>' +
                '</tr>'
            );
            $row.find('select').val(cita.IdTipoServicio || '');
            $row.find('textarea').val(cita.Observacion || '');
            $tb.append($row);
        });
    }).fail(function () {
        Swal.fire('Error', 'No se pudieron cargar los detalles de la cita.', 'error');
    });
}

function addRow() {
    const options = tplOptionsHtml();
    const $row = $(
        '<tr>' +
        '<td><select class="form-control"><option value="">Seleccione un tipo</option>' + options + '</select></td>' +
        '<td><textarea class="form-control" placeholder="Ingrese una observación"></textarea></td>' +
        '<td><button class="btn btn-danger btn-sm delete-btn">Eliminar</button></td>' +
        '</tr>'
    );

    $row.find('select').data('prev', '');

    $row.find('select').on('change', function () {
        const $sel = $(this);
        const prev = String($sel.data('prev') || '');
        const v = String($sel.val() || '');

        if (prev) valoresSeleccionados.delete(prev);
        if (!v) { $sel.data('prev', ''); return; }

        if (valoresSeleccionados.has(v)) {
            Swal.fire('Error', 'Este tipo ya está registrado.', 'error');
            $sel.val('');
            $sel.data('prev', '');
            return;
        }

        valoresSeleccionados.add(v);
        $sel.data('prev', v);
    });

    $row.find('.delete-btn').on('click', function () {
        const v = String($row.find('select').val() || '');
        const prev = String($row.find('select').data('prev') || '');
        if (v) valoresSeleccionados.delete(v);
        if (prev) valoresSeleccionados.delete(prev);
        $row.remove();
    });

    $('#appointmentsGrid tbody').append($row);
}

function saveAllRows() {
    const nuevasFilas = $('#appointmentsGrid tbody tr').not('[data-existing]');
    const nuevosDetalles = [];
    let invalid = false;

    nuevasFilas.each(function () {
        const tipo = $(this).find('select').val();
        const obs = $(this).find('textarea').val();
        if (!tipo || !obs) { invalid = true; return false; }
        nuevosDetalles.push({ IdTipoServicio: tipo, Observacion: obs });
    });

    if (invalid) { Swal.fire('Error', 'Completa todos los campos antes de guardar.', 'error'); return; }
    if (!nuevosDetalles.length) { Swal.fire('Error', 'No hay nuevas filas para guardar.', 'error'); return; }

    $.ajax({
        url: '@Url.Action("GuardarDetalleCitaanexo", "Appointments")',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({ idCita: $('#appointmentsModal').data('idCita'), nuevosDetalles: nuevosDetalles }),
        beforeSend: function () { $.LoadingOverlay("show"); }
    }).done(function (response) {
        if (response && response.success) {
            Swal.fire({ title: 'Éxito', text: 'Los detalles se guardaron correctamente.', icon: 'success', timer: 1000, showConfirmButton: false })
                .then(() => location.reload());
        } else {
            Swal.fire('Error', (response && response.message) || 'Error', 'error');
        }
    }).fail(function () {
        Swal.fire('Error', 'Hubo un problema al guardar los detalles.', 'error');
    }).always(function () { $.LoadingOverlay("hide"); });
}

async function EditarCita2(idCita) {
    try {
        valoresSeleccionados.clear();
        $('#appointmentsModal').data('idCita', idCita);
        $('#appointmentsModalLabel').text("Cita numero: " + idCita);
        precargarCitas(idCita);
        $('#appointmentsModal').modal('show');
    } catch (e) {
        Swal.fire('Error', 'No se pudieron cargar los tipos de servicio.', 'error');
    }
}

function parseFecha(d) {
    if (!d) return null;
    var m = /^\/Date\((\d+)\)\/$/.test(d)
        ? moment(parseInt(RegExp.$1, 10))
        : (moment(d, moment.ISO_8601, true).isValid() ? moment(d) : moment(d, 'DD/MM/YYYY HH:mm:ss', true));
    return m.isValid() ? m : null;
}

function AnularCita(idCita, estado) {
    $.ajax({
        url: '@Url.Action("AnularCita")',
        type: 'POST',
        data: { idCita: idCita, estado2: estado },
        dataType: 'json'
    }).done(function (data) {
        if (data && data.status !== "Error") {
            Swal.fire({ title: "Éxito!", text: data.message, icon: "success" })
                .then(() => { if (window.tabla_persona) tabla_persona.ajax.reload(null, false); });
        } else {
            Swal.fire("Advertencia!", (data && data.message) || 'Error', "warning");
        }
    }).fail(function () {
        Swal.fire("Error!", "Ha ocurrido un error en la transacción", "error");
    });
}

// -------------------------------
// DataTable principal
// -------------------------------
$(document).ready(function () {
    $.LoadingOverlay("show");

    tabla_persona = $('#listTable').DataTable({
        ajax: {
            url: "@Url.Action("Listjson", "Appointments")",
            type: "GET",
            datatype: "json",
            dataSrc: function (json) {
                let citaExistente = null;
                (json.data || []).forEach(function (item) {
                    if (["REGISTRADA", "CONFIRMADA", "ORDEN DE TRABAJO"].indexOf(item.EstadoCita) !== -1) citaExistente = item.IdCita;
                });
                if (citaExistente) {
                    $("#mostrarPopupBtn")
                        .attr("onclick", "EditarCita2(" + citaExistente + ")")
                        .removeClass("btn-primary").addClass("btn-warning");
                    $("#mostrarPopupBtn span.text").text("Anexar Solicitud");
                }
                return json.data;
            }
        },
        columns: [
            {
                data: "IdCita",
                render: function (data, type, full) {
                    var estadoCita = full.EstadoCita;
                    var anexarSolicitud = (estadoCita !== "ANULADA" && estadoCita !== "FINALIZADA")
                        ? `<a class="dropdown-item" href="javascript:void(0);" onclick="EditarCita2(${data})"><i class="fas fa-edit"></i> Anexar Solicitud</a>` : "";
                    return `
                        <div class="btn-group">
                            <button type="button" class="btn btn-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <i class="fas fa-cogs"></i> Acciones
                            </button>
                            <div class="dropdown-menu">
                                <a class="dropdown-item" href="javascript:void(0);" onclick="ConsultarCita(${data})"><i class="fas fa-eye"></i> Consultar Cita</a>
                                <a class="dropdown-item" href="javascript:void(0);" onclick="AnularCita(${data}, '${estadoCita}')"><i class="fas fa-ban"></i> Anular</a>
                                <a class="dropdown-item" href="javascript:void(0);" onclick="EditarCita(${data})"><i class="fas fa-edit"></i> Editar</a>
                                ${anexarSolicitud}
                            </div>
                        </div>`;
                }, orderable: true, searchable: true, width: "150px"
            },
            { data: "IdCita" },
            { data: "IdUnidad" },
            {
                data: "FechaCita",
                render: function (d, type) {
                    var m = parseFecha(d);
                    if (!m) return (type === 'display') ? '' : -Infinity;
                    if (type === 'display') return m.format('DD/MM/YYYY');
                    if (type === 'filter') return m.format('YYYY-MM-DD');
                    return m.valueOf();
                }
            },
            { data: "KilometrajeActual" },
            { data: "EstadoCita" }
        ],
        dom: 'Blfrtip',
        lengthMenu: [10, 20, 50, 100],
        pageLength: 10,
        order: [[3, 'desc']],
        orderMulti: false,
        language: { url: "@Url.Content("~/Scripts/datatable.es-ES.json")" },
        responsive: true,
        initComplete: function () {
            $.LoadingOverlay("hide");

            $('#listTable tbody')
                .off('click._toggleDropdown', '.dropdown-toggle')
                .on('click._toggleDropdown', '.dropdown-toggle', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    const $menu = $(this).siblings('.dropdown-menu');
                    $('.dropdown-menu.show').not($menu).removeClass('show');
                    $menu.toggleClass('show');
                });

            $(document)
                .off('click._closeDropdowns')
                .on('click._closeDropdowns', function (e) {
                    if ($(e.target).closest('.swal2-container').length) return;
                    if (!$(e.target).closest('.btn-group').length) {
                        $('.dropdown-menu.show').removeClass('show');
                    }
                });
        }
    });

    // binds anexos
    $('#addRowBtn').on('click', addRow);
    $('#saveAllBtn').on('click', saveAllRows);

    // binds CRUD
    $('#btnAddDetail').on('click', function () { addDetailRow(); });

    // limpiar anexos al cerrar
    $('#appointmentsModal').on('hidden.bs.modal', function () {
        $('#appointmentsGrid tbody').empty();
        valoresSeleccionados.clear();
    });
});
    </script>
 }

