function enviarCodigo() {

    var celular = TelefonoClient.GetValue(); // Obtener el valor del control

    if (!celular) {

        swal.fire({
            title: "Advertencia!",
            text: "Por favor ingrese un número de teléfono válido.",
            icon: "warning",
            button: "Aceptar",
        })
        return;
    }

    $.ajax({
        url: '@Url.Action("EnviarCodigoConfirmacion", "Appointments")',
        type: "POST",
        data: { celular: celular },
        success: function (data) {
            if (data.success) {
                swal.fire("Éxito!", `El código de confirmación ha sido enviado al número ${celular}.`, "success");
            } else {
                swal.fire("Error!", data.message, "error");
            }
        },
        error: function () {
            swal.fire("Error!", "Ocurrió un error al enviar el código de confirmación.", "error");
        }
    });
}


     function generarCodigoAleatorio() {
        return Math.floor(100000 + Math.random() * 900000).toString();
    }

    function enviarCodigoConfirmacion(celular, codigoAleatorio) {
        var celular = TelefonoClient.GetValue();
        const mensaje = `Tu código de confirmación es: ${codigoAleatorio}`;
        const url = `https://recursoshumanosni/apihcm/api/general/ssm?mensaje=${mensaje}&numero=${celular}`;

        const requestOptions = {
            method: "GET",
            redirect: "follow"
        };

        return fetch(url, requestOptions)
            .then(response => response.text())
            .then(result => {
                console.log(result);
                return codigoAleatorio;
            })
            .catch(error => {
                console.error('Error al enviar el código de confirmación', error);
                return null;
            });
    }

    function guardarCitaConConfirmacion() {
        $.LoadingOverlay("show");

        const celular = TelefonoClient.GetValue();
        const codigoAleatorio = generarCodigoAleatorio();
        $.LoadingOverlay("hide");

    enviarCodigoConfirmacion(celular, codigoAleatorio).then(codigoEnviado => {
    if (codigoEnviado) {
        Swal.fire({
            title: 'Introduce el código',
            input: 'text',
            inputLabel: 'Código',
            inputPlaceholder: 'Escribe el código aquí',
            showCancelButton: true
        }).then(result => {
            if (result !== "") {
                const enteredCode = result.value;

                // Asumo que 'codigoEnviado' es el código esperado
                if (enteredCode === codigoEnviado) {
                    // Enviar el formulario después de la validación del código
                    return new Promise((resolve) => {
                        const form = document.getElementById('frmAppointment');
                        const formData = new FormData(form);

                        fetch('@Url.Action("GuardarCita")', {
                            method: 'POST',
                            body: formData,
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        })
                        .then(response => response.json())
                        .then(data => {
                            if (data.status !== "Error") {
                                Swal.fire({
                                    title: "Éxito!",
                                    text: data.message,
                                    icon: "success",
                                    confirmButtonText: "Aceptar"
                                }).then(() => {
                                    top.popEditAppointment.Hide();
                                });
                            } else {
                                Swal.fire({
                                    title: "Advertencia!",
                                    text: data.message,
                                    icon: "warning",
                                    confirmButtonText: "Aceptar"
                                });
                            }
                            resolve();
                        })
                        .catch(error => {
                            Swal.fire("Error!", "Ocurrió un error en la transacción, por favor corrija.", "error");
                            resolve();
                        });
                    });
                } else {
                    Swal.fire('Error', 'El código es incorrecto', 'error');
                }
            }
        });
    } else {
        Swal.fire("Error!", "No se pudo enviar el código de confirmación. Inténtelo de nuevo más tarde.", "error");
    }
});
    }

