@using (Html.BeginForm("SaveAppointment", "Appointments", FormMethod.Post, new { id = "frmAppointment" }))
{
    @Html.DevExpress().FormLayout(settings =>
{
   settings.Name = "frmIndicator";
   settings.SettingsAdaptivity.AdaptivityMode = FormLayoutAdaptivityMode.SingleColumnWindowLimit;
   settings.SettingsAdaptivity.SwitchToSingleColumnAtWindowInnerWidth = 650;
   settings.ControlStyle.CssClass = "formLayout";

   settings.Items.AddGroupItem(g =>
   {
       g.Caption = "";
       g.ColCount = 3;

       g.UseDefaultPaddings = false;
       g.Paddings.PaddingTop = Unit.Pixel(10);
       g.GroupBoxDecoration = GroupBoxDecoration.None;

       g.Items.Add(m => m.IdCita, i =>
       {
           i.Caption = "Id";
           i.ClientVisible = false;
           i.NestedExtension().TextBox(s =>
           {
               s.Properties.ValidationSettings.ErrorDisplayMode = ErrorDisplayMode.ImageWithTooltip;
               s.Properties.ValidationSettings.Display = Display.Dynamic;
               s.ShowModelErrors = true;
               s.Width = Unit.Percentage(100);
           });
       });

       g.Items.Add(i =>
       {
           i.FieldName = "FechaCita";
           i.Caption = "Fecha de Cita";
           i.NestedExtension().DateEdit(s =>
           {
               s.Properties.NullText = "DD/MM/YYYY";
               s.Properties.EditFormat = EditFormat.Date;
               s.Properties.ValidationSettings.ErrorDisplayMode = ErrorDisplayMode.None;
               s.Properties.ValidationSettings.Display = Display.Dynamic;
               s.ShowModelErrors = true;
           });
       });

       g.Items.Add(i =>
       {
           i.FieldName = "Telefono";

           i.Caption = "Celular";
           i.NestedExtension().TextBox(s =>
           {
               s.Properties.NullText = "";
               s.Properties.ClientInstanceName = "TelefonoClient";

               s.Properties.MaskSettings.Mask = "0000-0000";
               s.Properties.MaskSettings.IncludeLiterals = MaskIncludeLiteralsMode.None;

               s.Properties.ValidationSettings.RequiredField.IsRequired = true;
               s.Properties.ValidationSettings.RequiredField.ErrorText = "Por favor ingrese un número de teléfono.";
               //s.Properties.ValidationSettings.RegularExpression.ValidationExpression = @"^\d{4}-\d{4}$";
               s.Properties.ValidationSettings.RegularExpression.ErrorText = "Por favor ingrese un número de teléfono válido en el formato 0000-0000.";
               s.ShowModelErrors = true;
           });
       });
 
       g.Items.Add(i =>
       {
           i.FieldName = "KilometrajeActual";
           i.Caption = "Km Actual";
           i.NestedExtension().TextBox(s =>
           {
               s.Properties.ValidationSettings.ErrorDisplayMode = ErrorDisplayMode.ImageWithTooltip;
               s.Properties.ValidationSettings.Display = Display.Dynamic;
               s.ShowModelErrors = true;
           });
       });

       g.Items.Add(i =>
       {
           i.FieldName = "Observacion";
           i.Caption = "Observaciones";
           i.NestedExtension().Memo(s =>
           {
               s.Properties.ValidationSettings.ErrorDisplayMode = ErrorDisplayMode.None;
               s.Properties.ValidationSettings.Display = Display.Dynamic;
               s.ShowModelErrors = true;
               s.Width = Unit.Percentage(460);
               s.Properties.Rows = 3;
               s.ControlStyle.CssClass = "memo";
           });
       });
   });
}).GetHtml()
}

