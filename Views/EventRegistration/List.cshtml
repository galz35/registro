
@model List<Entities.ViewModels.EventRegistrationView>
@{
    ViewBag.Title = "Lista de Registro de Eventos";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}

@section scripts {
    <!-- Scripts JS cargados al final de la página -->
    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.buttons.min.js"></script>
    <script src="~/onlinejs/buttons.html5.min.js"></script>
    <script src="~/onlinejs/buttons.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.select.min.js"></script>
    <script src="~/onlinejs/bootstrap.bundle.min.js"></script>
    <script src="~/onlinejs/dataTables.responsive.min.js"></script>
    <script src="~/Content/plugin/sweetalert2/sweetalert2.all.js"></script>

    <!-- Inicializar DataTables -->
    <script>
        $(document).ready(function () {
            $('#eventRegistrationTable').DataTable({
                responsive: true,
                scrollX: true, // Para permitir desplazamiento horizontal si es necesario
                autoWidth: false, // Desactivar el ajuste automático de ancho
                order: [], // Deshabilitar el orden automático
                columnDefs: [
                    { targets: 0, width: "2%", orderable: false }, // Ancho de la columna del ID y deshabilitar orden
                    { targets: 1, width: "2%", orderable: false }, // Ancho de la columna de acciones y deshabilitar orden
                    { targets: [2, 3, 4, 5, 6], width: "auto" }, // El resto de las columnas se ajusta automáticamente
                ],
                dom: 'Bfrtip',
                buttons: ['copy', 'csv', 'excel', 'pdf', 'print']
            });
        });

        function GoEvent(eventId) {
            $.ajax({
                url: '@Url.Action("GoEvent", "EventRegistration")',
                type: "POST",
                data: { eventId: eventId },
                success: function (data) {
                    if (data.status !== "Error") {
                        swal("Exito!", data.message, "success").then(() => {
                            LoadEventRegistration();
                        });
                    } else {
                        swal("ERROR!", data.message, "error");
                    }
                },
                error: function () {
                    swal("ERROR!", "Ocurrió un error al procesar la solicitud.", "error");
                }
            });
        }

        function DontGoEvent(eventId) {
            $.ajax({
                url: '@Url.Action("DontGoEvent", "EventRegistration")',
                type: "POST",
                data: { eventId: eventId },
                success: function (data) {
                    if (data.status !== "Error") {
                        swal("Exito!", data.message, "success").then(() => {
                            LoadEventRegistration();
                        });
                    } else {
                        swal("ERROR!", data.message, "error");
                    }
                },
                error: function () {
                    swal("ERROR!", "Ocurrió un error al procesar la solicitud.", "error");
                }
            });
        }

        function ShowCompanionDetail(eventId, url) {
            popImage.SetContentUrl(url);
            popImage.Show();
        }
        function Ligaregistro(eventId, url) {
            // Redirige al usuario a la URL especificada
            window.location.href = url;
        }


        function LoadEventRegistration() {
            $.ajax({
                url: '@Url.Action("ListPartial", "EventRegistration")',
                type: "GET",
                success: function (result) {
                    $('#ListPartial').html(result);
                },
                error: function () {
                    swal("ERROR!", "No se pudo cargar la lista de registros.", "error");
                }
            });
        }
    </script>
}

@Html.DevExpress().GetStyleSheets(
        new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
              new StyleSheet { ExtensionSuite = ExtensionSuite.Editors, Theme = "Aqua" },

        new StyleSheet { ExtensionSuite = ExtensionSuite.HtmlEditor },
         new StyleSheet { ExtensionSuite = ExtensionSuite.Chart },
        new StyleSheet { ExtensionSuite = ExtensionSuite.Report },
        new StyleSheet { ExtensionSuite = ExtensionSuite.GridView },
         new StyleSheet { ExtensionSuite = ExtensionSuite.Dashboard },
         new StyleSheet { ExtensionSuite = ExtensionSuite.TreeList },
           new StyleSheet { ExtensionSuite = ExtensionSuite.PivotGrid }

    )
@Html.DevExpress().GetScripts(
    new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
    new Script { ExtensionSuite = ExtensionSuite.HtmlEditor },
    new Script { ExtensionSuite = ExtensionSuite.Editors },
    new Script { ExtensionSuite = ExtensionSuite.Chart },
    new Script { ExtensionSuite = ExtensionSuite.Report },
    new Script { ExtensionSuite = ExtensionSuite.GridView },
    new Script { ExtensionSuite = ExtensionSuite.Dashboard },
    new Script { ExtensionSuite = ExtensionSuite.TreeList },
     new Script { ExtensionSuite = ExtensionSuite.PivotGrid }

)
@{


    Entities.Employees employee = (Entities.Employees)Session["User"];
    //string imgPic = employee.Picture == null ? "~/Content/Icons/Add.png" : String.Format("data:image/jpg;base64", Convert.ToBase64String(employee.Picture));


}
<div class="container-fluid">
    <h2>Registro de Eventos</h2>

    <!-- Contenedor para asegurar que la tabla sea responsiva -->
    <div class="table-responsive">
        <!-- Tabla de registros de eventos -->
        <table id="eventRegistrationTable" class="table table-striped table-bordered dt-responsive nowrap" style="width: 100%;">
            <thead>
                <tr>
                    <th style="width: 5%;">#</th> <!-- Ajustamos el ancho de la columna del ID -->
                    <th style="width: 15%;">Acciones</th> <!-- También ajustamos el ancho de la columna de acciones -->
                    <th>Nombre del Evento</th>
                    <th style="width: 15%;">Fecha del Evento</th>
                    <th>Estado</th>
                    <th>Mi Estado</th>
                    <th>Descripción</th>
                </tr>
            </thead>
            <tbody>

                @foreach (var item in Model.OrderByDescending(x => x.EventId))
                {
                    <tr>
                        <td>@item.EventId</td>
                        <td>
                            <div class="dropdown">
                                <button class="btn btn-primary dropdown-toggle" type="button" id="dropdownMenuButton" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                    Acciones
                                </button>
                                <div class="dropdown-menu dropdown-menu-right" aria-labelledby="dropdownMenuButton">
                                    <a class="dropdown-item btn btn-light btn-block" href="javascript:void(0)" onclick="GoEvent(@item.EventId)">Asistir</a>
                                    <a class="dropdown-item btn btn-light btn-block" href="javascript:void(0)" onclick="DontGoEvent(@item.EventId)">No Asistir</a>
                                    <a class="dropdown-item btn btn-light btn-block" href="javascript:void(0)" onclick="ShowCompanionDetail(@item.EventId, '@Url.Action("EventRegistrationDetail", "EventRegistrationDetail", new { eventId = item.EventId })')">Agregar Acompañantes</a>
                               @if (employee.GERENCIA.Contains("RECURSOS HUMANOS") == true)
                               {
                                    <a class="dropdown-item btn btn-light btn-block" href="javascript:void(0)" onclick="Ligaregistro(@item.EventId, '@Url.Action("EventoLiga", "EventRegistration", new { eventId = item.EventId })')">Registro de Evento especial</a>
                                    if (item.EventId == 193 || item.EventId == 194)
                                    {
                                        <a class="dropdown-item btn btn-light btn-block text-danger font-weight-bold" href="@Url.Action("DespachoDiaNino", "EventRegistration")"><i class="fas fa-gift mr-1"></i> Despacho de Juguetes</a>
                                    }
                               }
                                </div>
                            </div>
                        </td>
                        <td>@item.EventName</td>
                        <td>@item.EventDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.EventStatus</td>
                        <td>@item.RegistrationStatus</td>
                        <td>@item.EventDescription</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@Html.DevExpress().PopupControl(settingsPopup =>
{
settingsPopup.Name = "popImage";
settingsPopup.ShowOnPageLoad = false;
settingsPopup.HeaderText = "Agregar detalle de acompañantes";
settingsPopup.PopupHorizontalAlign = PopupHorizontalAlign.WindowCenter;
settingsPopup.PopupVerticalAlign = PopupVerticalAlign.WindowCenter;
settingsPopup.CloseOnEscape = true;
settingsPopup.Width = 700;
settingsPopup.Height = 400;
//settingsPopup.ClientSideEvents.CloseUp = "LoadEventList";



}).GetHtml()






