@model List<Entities.ViewModels.VistaTraslados>
@{
    ViewBag.Title = "Lista de Traslados";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}
@Html.DevExpress().GetStyleSheets(
         new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout },

         new StyleSheet { ExtensionSuite = ExtensionSuite.HtmlEditor },
         new StyleSheet { ExtensionSuite = ExtensionSuite.Editors },
         new StyleSheet { ExtensionSuite = ExtensionSuite.Chart },
         new StyleSheet { ExtensionSuite = ExtensionSuite.Report },
         new StyleSheet { ExtensionSuite = ExtensionSuite.GridView },
          new StyleSheet { ExtensionSuite = ExtensionSuite.Dashboard },
          new StyleSheet { ExtensionSuite = ExtensionSuite.TreeList },
            new StyleSheet { ExtensionSuite = ExtensionSuite.PivotGrid }

     )
@section scripts {
    <script src="~/onlinejs/jquery-3.6.0.min.js"></script>
    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.buttons.min.js"></script>
    <script src="~/onlinejs/buttons.html5.min.js"></script>
    <script src="~/onlinejs/buttons.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.select.min.js"></script>
    <script src="~/onlinejs/bootstrap.bundle.min.js"></script>
    <script src="~/onlinejs/bootstrap.min.js"></script>
    <script src="~/onlinejs/loadingoverlay.min.js"></script>
    <script src="~/onlinejs/dataTables.responsive.min.js"></script>
    <script src="~/Content/plugin/sweetalert2/sweetalert2.all.js"></script>
    <script src="~/onlinejs/moment.min.js"></script>
    <script src="~/onlinejs/jszip.min.js"></script>
    <script src="~/onlinejs/jquery-ui.js"></script>
    <script src="~/onlinejs/spin.min.js"></script>
 
    <script>
        var popupTable;
        var tabla_persona;

        $(document).ready(function() {
            $.LoadingOverlay("show");



            tabla_persona = $('#listTable').DataTable({
                "ajax": {
                    "url": "@Url.Action("ListPartialjson", "Traslados")",
                    "type": "GET",
                    "datatype": "json"
                },
                "columns": [
                    {
                        "data": "IdCombustibleTraslado",
                        "render": function(data, type, full, meta) {
                            var codigo = data.replace('TRS-', '');
                            return `
                                <div class="btn-group">
                                    <button type="button" class="btn btn-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                        <i class="fas fa-cogs"></i> Acciones
                                    </button>
                                    <div class="dropdown-menu">
                                        <a class="dropdown-item" href="javascript:void(0);" onclick="VerDetalleEstados('${codigo}')"><i class="fas fa-eye"></i> Ver Estado</a>
                                        <a class="dropdown-item" href="javascript:void(0);" onclick="AnularTraslado('${codigo}')"><i class="fas fa-ban"></i> Anular</a>
                                        <a class="dropdown-item" href="javascript:void(0);" onclick="EditarTraslado('${codigo}')"><i class="fas fa-edit"></i> Editar</a>
                                    </div>
                                </div>
                            `;
                        },
                        "orderable": true,
                        "searchable": true,
                        "width": "150px"
                    },
                    { "data": "IdCombustibleTraslado" },
                    { "data": "NumeroEmpleado" },
                    { "data": "Empleado" },
                    {
                        "data": "FechaTraslado",
                        "render": function(data) {
                            return moment(data).format('DD/MM/YYYY');
                        }
                    },
                    { "data": "TotalCantidadSolicitada" },
                    { "data": "TotalCantidadAutorizada" },
                    {
                        "data": "Estado",
                        "createdCell": function(td, cellData, rowData, row, col) {
                            var color = "";
                            if (cellData.toLowerCase().includes("registra")) {
                                color = "#fdfd96";
                            } else if (cellData.toLowerCase().includes("autorizado")) {
                                color = "#77dd77";
                            } else if (cellData.toLowerCase().includes("anulad")) {
                                color = "#ff6961";
                            } else {
                                color = "#ADD8E6";
                            }
                            $(td).css('color', color);
                        }
                    }
                ],
                "dom": 'Blfrtip',
                "lengthMenu": [10, 20, 50, 100],
                "pageLength": 10,
                "language": {
                    "url": "@Url.Content("~/Scripts/datatable.es-ES.json")"
                },
                "responsive": true,
                "initComplete": function() {
                    $('#listTable tbody').on('click', '.dropdown-toggle', function(e) {
                        e.stopPropagation();
                        $(this).siblings('.dropdown-menu').toggleClass('show');
                    });
                    $(document).on('click', function(e) {
                        if (!$('.dropdown-toggle').is(e.target) && $('.dropdown-toggle').has(e.target).length === 0 && $('.show').has(e.target).length === 0) {
                            $('.dropdown-menu').removeClass('show');
                        }
                    });
                }
            });

            $.LoadingOverlay("hide");

          popupTable = $('#popupTable').DataTable({
                columns: [
                    { data: 'NombreEmpleado' },
                    { data: 'Hora' },
                    {
                        data: 'FechaInsercion',
                        render: function(data) {
                            return moment(data).format('DD/MM/YYYY');
                        }
                    },
                    { data: 'Estado' }
                ],
                "language": {
                "url": "@Url.Content("~/Scripts/datatable.es-ES.json")"
                },
                "responsive": true
            });

            $("#btnAceptar").on("click", function(e) {
                e.preventDefault();
                GuardarConsumo2();
            });
        });

    function OnInit(s, e) {
        AdjustSize();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            AdjustSize();
        });
    }
    function OnEndCallback(s, e) {
        AdjustSize();
    }
    function AdjustSize() {
        var height = document.documentElement.clientHeight;
        gvTraslado.SetHeight(height - 150);
    }

    function EditarTraslado(elementID, url) {
        popImage.SetContentUrl(url);
        popImage.ShowAtElementByID(elementID);
    }
        function EditarTraslado(id) {

            var url = '@Url.Action("EditarTraslado", "Traslados", new { idTraslado = 0 })'.replace("0", id);
            $.ajax({
                url: '@Url.Action("ValidarTraslado")',
                type: "POST",
                data: { idTraslado: id, tipoEdicion: "Editar" },
                dataType: "json",
                cache: false, beforeSend: function () {
                    // Muestra el overlay antes de enviar la solicitud AJAX
                    $.LoadingOverlay("show");
                },
                complete: function () {
                    // Oculta el overlay una vez que la solicitud AJAX ha finalizado
                    $.LoadingOverlay("hide");
                },
                success: function(data) {
                    if (data.status != "Error") {
                        popImage.SetContentUrl(url);
                        popImage.ShowAtElementByID(id);

                    } else {
                        swal.fire("Advertencia!", data.message, "warning");
                    }
                },
                error: function() {
                    alert("An error has occured!!!");
                }
            });
        }
    function CargarTraslados(s, e) {
        $.ajax({
            url: '@Url.Action("ListPartial")',
            //contentType: 'application/json; charset=utf-8',
            type: 'GET',
            //dataType: 'json',
            cache: false,
            traditional: true,
            data: {},
        }).done(function(result) {
            $('#ListPartial').html(result);
        });
    }
        function AnularTraslado(id) {


            $.ajax({
                url: '@Url.Action("AnularTraslado")',
                type: "POST",
                data: { idTraslado: id },
                dataType: "json",
                cache: false, beforeSend: function () {
                    // Muestra el overlay antes de enviar la solicitud AJAX
                    $.LoadingOverlay("show");
                },
                complete: function () {
                    // Oculta el overlay una vez que la solicitud AJAX ha finalizado
                    $.LoadingOverlay("hide");
                },
                success: function(data) {
                    if (data.status != "Error") {
                        swal.fire({
                            title: "Exito!",
                            text: data.message,
                            icon: "success",
                            confirmButtonText: "Aceptar",
                        }).then((willSaved) => {
                            if (willSaved) {
                                $('#listTable').DataTable().ajax.reload();
                            }
                        });
                    } else {
                        swal.fire("Advertencia!", data.message, "warning");
                    }
                },
                error: function() {
                    alert("An error has occured!!!");
                }
            });
        }

    function AnularTraslado(id, e) {


        $.ajax({
            url: '@Url.Action("AnularTraslado")',
            type: "POST",
            data: { idTraslado:   id},
            dataType: "json",
            traditional: true,
            cache: false,
            beforeSend: function () {
                // Muestra el overlay antes de enviar la solicitud AJAX
                $.LoadingOverlay("show");
            },
            complete: function () {
                // Oculta el overlay una vez que la solicitud AJAX ha finalizado
                $.LoadingOverlay("hide");
            },
            //contentType: "application/json; charset=utf-8",
            success: function (data) {
                if (data.status != "Error") {
                    swal.fire({
                            title: "Exito!",
                            text: data.message,
                            icon: "success",
                            confirmButtonText: "Aceptar",
                        })
                        .then((willSaved) => {
                            if (willSaved) {
                               Reload();

                            }

                        });
                } else {
                    swal.fire("Advertencia!", data.message, "warning");
                }


            },
            error: function () {
                alert("An error has occured!!!");
            }
        });
    }


    function ValidarTraslado(id, e) {
        var visibleIndex = gvTraslado.GetFocusedRowIndex();
        var key = gvTraslado.GetRowKey(visibleIndex);

        $.ajax({
            url: '@Url.Action("ValidarTraslado")',
            type: "GET",
            data: { idTraslado: key },
            dataType: "json",
            traditional: true,
            cache: false,
            //contentType: "application/json; charset=utf-8",
            success: function (data) {
                if (data.status == "Error") {
                    swal.fire({
                            title: "Error!",
                            text: data.message,
                            icon: "error",
                            confirmButtonText: "Aceptar",
                        })
                        .then((willSaved) => {
                            if (willSaved) {
                                EditarTraslado();

                            }

                        });
                } else {
                    swal.fire("Advertencia!", data.message, "warning");
                }


            },
            error: function () {
                alert("An error has occured!!!");
            }
        });
    }
    //function VerDetalleEstados(elementID, url) {
    //    popDetalleEstado.SetContentUrl(url);
    //    popDetalleEstado.ShowAtElementByID(elementID);
    //}


        function VerDetalleEstados(codigo) {
            console.log("Código recibido:", codigo); // Para depuración

            $('#popupContainer').modal('show');
            $.ajax({
                url: '@Url.Action("TrasladosStateConsultjson", "Consumo")',
                data: { idTraslado: codigo },
                type: 'GET',
                dataType: 'json', beforeSend: function () {
                    // Muestra el overlay antes de enviar la solicitud AJAX
                    $.LoadingOverlay("show");
                },
                complete: function () {
                    // Oculta el overlay una vez que la solicitud AJAX ha finalizado
                    $.LoadingOverlay("hide");
                },
                success: function(data) {
                    $('#popupTable').DataTable().clear().rows.add(data.data).draw();
                },
                error: function(error) {
                    console.error(error);
                }
            });
        }

        function cerrar() {
            $('#popupContainer').modal('hide');
        }
        function EditarTraslado2() {
            var url = '@Url.Action("EditarTraslado", "Traslados", new { idTraslado = 0 })';
            $.ajax({
                url: '@Url.Action("ValidarTraslado")',
                type: "POST",
                data: { idTraslado: 0, tipoEdicion: "Nuevo" },
                dataType: "json",
                cache: false,
                success: function (data) {
                    if (data.status != "Error") {
                        popImage.SetContentUrl(url);
                        popImage.ShowAtElementByID(0);
                    } else {
                        swal.fire("Advertencia!", data.message, "warning");
                    }
                },
                error: function () {
                    alert("An error has occured!!!");
                }
            });
        }
    </script>
}
@Html.DevExpress().GetScripts(
    new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
    new Script { ExtensionSuite = ExtensionSuite.HtmlEditor },
    new Script { ExtensionSuite = ExtensionSuite.Editors },
    new Script { ExtensionSuite = ExtensionSuite.Chart },
    new Script { ExtensionSuite = ExtensionSuite.Report },
    new Script { ExtensionSuite = ExtensionSuite.GridView },
    new Script { ExtensionSuite = ExtensionSuite.Dashboard },
    new Script { ExtensionSuite = ExtensionSuite.TreeList },
     new Script { ExtensionSuite = ExtensionSuite.PivotGrid }

)@Html.DevExpress().PopupControl(settingsPopup =>
{
  settingsPopup.Theme = "Mulberry";
  settingsPopup.Name = "popImage";
  settingsPopup.ShowOnPageLoad = false;
  settingsPopup.HeaderText = "Edicion de Traslado";
  settingsPopup.PopupHorizontalAlign = PopupHorizontalAlign.WindowCenter;
  settingsPopup.PopupVerticalAlign = PopupVerticalAlign.WindowCenter;
  settingsPopup.CloseOnEscape = true;
  settingsPopup.Width = 700;
  settingsPopup.Height = 450;
  settingsPopup.ClientSideEvents.CloseUp = "";
}).GetHtml()
@Html.DevExpress().PopupControl(settings =>
{
    settings.Theme = "Mulberry";
    settings.Name = "popDetalleEstado";
    settings.ShowHeader = true;
    settings.HeaderText = "Detalle de Estados";
    settings.PopupHorizontalAlign = PopupHorizontalAlign.WindowCenter;
    settings.PopupVerticalAlign = PopupVerticalAlign.WindowCenter;
    settings.Width = 800;
    settings.Height = 400;
    settings.CloseAction = CloseAction.CloseButton;
    settings.CloseOnEscape = true;

}).GetHtml()
<div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
        <div class="container-fluid">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="m-0 font-weight-bold text-primary" style="color: #800 !important;">Traslado</h5>
                        <a href="#" id="mostrarPopupBtn" onclick="EditarTraslado2()" class="btn btn-primary btn-icon-split">
                            <span class="icon text-white-50">
                                <i class="fas fa-plus"></i>
                            </span>
                            <span class="text">Registrar Nuevo</span>
                        </a>
                    </div>
                </div>
                <div class="card-body p-3">
                    <table id="listTable" class="table table-striped table-bordered table-hover display responsive nowrap" style="width:100%">
                        <thead>
                            <tr>
                                <th>Acciones</th>
                                <th># Traslado</th>
                                <th>No.Empleado</th>
                                <th>Empleado</th>
                                <th>Fecha de Traslado</th>
                                <th>Cant.Sol</th>
                                <th>Cant.Aut</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="popupContainer">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Popup Modal con DataTable</h4>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <table id="popupTable" class="display" style="width:100%;">
                    <thead>
                        <tr>
                            <th>NombreEmpleado</th>
                            <th>Hora</th>
                            <th>Fecha</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="cerrar()" data-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>




