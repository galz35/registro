                        <div class="topbar-divider d-none d-sm-block"></div>

                        @{
                            Entities.Employees employee = (Employees)Session["User"];
                            // Si quieres forzar dominio para pruebas puedes dejar esta lÃ­nea:
                            // if (employee != null) { employee.Domain = "CLARONI"; }
                            var employeeName = (employee != null && !string.IsNullOrEmpty(employee.Names))
                                ? employee.Names
                                : "Usuario";
                            var employeeDomain = (employee != null && !string.IsNullOrEmpty(employee.Domain))
