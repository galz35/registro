    <!-- FIN MODALS -->

    <script src="~/onlinejs/jquery-3.6.0.min.js"></script>
    <script src="~/onlinejs/sb-admin-2.min.js"></script>
    <script src="~/onlinejs/inject.js"></script>
    <script src="~/onlinejs/bootstrap.bundle.min.js"></script>
    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>
    <script src="~/onlinejs/sweetalert2.10.js"></script>
    <script src="~/onlinejs/jquery-ui.js"></script>
    <script src="~/onlinejs/spin.min.js"></script>
    <script src="~/onlinejs/dataTables.buttons.min.js"></script>
    <!-- <script src="~/onlinejs/buttons.print.min.js"></script> -->
    <script src="~/onlinejs/moment.min.js"></script>
    <script src="~/Content/vendor/jquery-easing/jquery.easing.min.js"></script>
    <script src="~/Scripts/JsCustom.js" type="text/javascript"></script>
    <script src="~/onlinejs/jquery.fancybox.min.js"></script>

    <script>
        var citasData = [];

        // ===== INICIO CONTROLADO =====
        $(document).ready(function () {

            // Si no hay usuario no ejecutar nada de notificaciones/citas
            var canInit = '@(employee != null ? "1" : "")';
            if (!canInit) {
                console.warn('Init not executed: usuario sin sesiÃ³n.');
                return;
            }

            $.ajax({
                url: '@Url.Action("obtenercita", "Home")',
                type: 'GET',
                success: function (data) {
                    citasData = data || [];
                    $('#citasBadge').text(citasData.length);
                },
                error: function () {
                    console.error('Error al obtener las citas.');
                }
            });

            $.ajax({
                url: '@Url.Action("GetNotifications", "Notifications")',
                type: 'GET',
                dataType: 'json',
                success: function (data) {
                    if (data && data.Error) {
                        console.error(data.Error);
                        return;
                    }

                    $('#solicitudesBadge').text(data && data.SolicitudCount ? data.SolicitudCount : 0);

                    var solicitudesHtml = '';
                    if (data && data.SolicitudList && data.SolicitudList.length > 0) {

                        var groupedSolicitudes = {};
                        $.each(data.SolicitudList, function (i, solicitud) {
                            var key = solicitud.IdCita;
                            if (!groupedSolicitudes[key]) {
                                groupedSolicitudes[key] = solicitud;
                            }
                        });

                        $.each(groupedSolicitudes, function (key, solicitud) {
                            solicitudesHtml += '<div class="dropdown-item noti-solicitud-group border-bottom py-2">';
                            solicitudesHtml += '<div class="noti-group-header bg-light p-1 rounded">';
                            solicitudesHtml += '<span class="font-weight-bold">Unidad: ' + solicitud.IdUnidad + ' - Cita #: ' + solicitud.IdCita + ' </span>';
                            solicitudesHtml += '</div>';
                            solicitudesHtml += '<div class="text-right">';
                            solicitudesHtml += '<button class="btn btn-primary btn-sm" onclick="visualizarSolicitud(\'' + solicitud.IdCita + '\')">Visualizar</button>';
                            solicitudesHtml += '</div>';
                            solicitudesHtml += '</div>';
                        });
                    } else {
                        solicitudesHtml = '<a class="dropdown-item" href="#">No hay solicitudes</a>';
                    }

                    $('#solicitudesContainer').html(solicitudesHtml);
                },
                error: function (xhr, status, error) {
                    console.error("Error al cargar notificaciones: " + error);
                }
            });
        });
        // ===== FIN CONTROL =====

        $("#citasDropdown").on("click", function (e) {
            e.preventDefault();
            if (citasData && citasData.length > 0) {
                const hoy = new Date();
                $("#citas-grid-container").empty();

                // 1. Normalizar fechas para poder ordenar
                citasData.forEach(cita => {
                    if (!cita) return;
                    let f = new Date();
                    try {
                        if (cita.HoraCita && typeof cita.HoraCita === 'string' && cita.HoraCita.indexOf('/Date(') !== -1) {
                            f = new Date(parseInt(cita.HoraCita.match(/\d+/)[0], 10));
                        } else if (cita.HoraCita) {
                            f = new Date(cita.HoraCita);
                        } else if (cita.FechaCita) {
                            f = new Date(cita.FechaCita);
                        }
                    } catch(e) {}
                    cita._fechaObj = f;
                });

                // 2. Ordenar cronológicamente (las de hoy primero, luego en orden de fecha)
                citasData.sort((a, b) => {
                    if (!a._fechaObj) return 1;
                    if (!b._fechaObj) return -1;
                    return a._fechaObj.getTime() - b._fechaObj.getTime();
                });

                // 3. Renderizar las tarjetas
                citasData.forEach(cita => {
                    if (!cita) return;
                    let fechaCita = cita._fechaObj;
                    
                    const esHoy = moment(fechaCita).isSame(hoy, 'day');
                    const pasada = fechaCita < hoy && !esHoy;
                    
                    let badgeClass = esHoy ? 'badge-warning text-dark' : (pasada ? 'badge-danger' : 'badge-success');
                    let borderClass = esHoy ? 'border-left-warning' : (pasada ? 'border-left-danger' : 'border-left-success');
                    const label = esHoy ? 'Hoy' : (pasada ? 'Perdida' : 'Proxima');
                    
                    let cardHtml = `
                    <div class="col-xl-4 col-md-6 mb-3">
                        <div class="card shadow-sm h-100 ${borderClass} card-cita-premium bg-white">
                            <div class="card-body p-3">
                                <div class="row no-gutters align-items-center mb-2">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-dark text-uppercase mb-1"><i class="fas fa-car mr-1 text-primary"></i> ${cita.IdUnidad}</div>
                                    </div>
                                    <div class="col-auto">
                                        <span class="badge ${badgeClass} px-2 py-1 shadow-sm" style="font-size: 0.75rem;">${label}</span>
                                    </div>
                                </div>
                                <div class="h6 mb-2 font-weight-bold text-gray-800" style="font-size:0.9rem;">
                                    <i class="fas fa-clock mr-1 text-muted"></i> ${moment(fechaCita).format('DD/MM/YYYY hh:mm A')}
                                </div>
                                <div class="text-xs font-weight-bold text-muted text-uppercase mb-1 mt-2" style="font-size:0.7rem;">Conductor:</div>
                                <div class="h6 mb-0 text-gray-800" style="line-height: 1.2; font-size:0.85rem;">${cita.NombreEmpleado}</div>
                            </div>
                        </div>
                    </div>`;
                    
                    $("#citas-grid-container").append(cardHtml);
                });

                $("#tablaCitasModal").modal("show");
            } else {
                Swal.fire("Informacion", "No se encontraron citas.", "info");
            }
        });

        function visualizarSolicitud(id) {
            $('#solicitudModal').modal('show');

            $.ajax({
                url: '@Url.Action("GetSolicitudDetails", "Notifications")',
                type: 'GET',
                data: { id: id },
                dataType: 'json',
                success: function (data) {
                    var detailsHtml = '';
                    if (data && data.length > 0) {
                        detailsHtml += '<table class="table table-bordered noti-table-details">';
                        detailsHtml += '<thead><tr><th>Trabajo</th><th>Descripcion</th></tr></thead><tbody>';
                        $.each(data, function (i, detail) {
                            detailsHtml += '<tr>';
                            detailsHtml += '<td>' + detail.TipoOrden + '</td>';
                            detailsHtml += '<td>' + detail.Observacion + '</td>';
                            detailsHtml += '</tr>';
                        });
                        detailsHtml += '</tbody></table>';
                    } else {
                        detailsHtml = '<p>No se encontraron detalles para esta solicitud.</p>';
                    }
                    $('#solicitudDetails').html(detailsHtml);

                    var imagesHtml = '';
                    if (data && data.length > 0) {
                        if (data.length > 1) {
                            imagesHtml += '<div id="carouselImages" class="carousel slide noti-carousel" data-ride="carousel"><div class="carousel-inner">';
                            $.each(data, function (i, imgData) {
                                if (imgData.FotoBase64 && imgData.FotoBase64.trim() !== "") {
                                    var base64 = imgData.FotoBase64;
                                    imagesHtml += '<div class="carousel-item ' + (i === 0 ? 'active' : '') + '">';
                                    imagesHtml += '<a data-fancybox="gallery" href="data:image/webp;base64,' + base64 + '">';
                                    imagesHtml += '<img src="data:image/webp;base64,' + base64 + '" class="d-block w-100" style="max-height:300px;object-fit:contain;margin:5px;" />';
                                    imagesHtml += '</a></div>';
                                }
                            });
                            imagesHtml += '</div>';
                            imagesHtml += '<a class="carousel-control-prev" href="#carouselImages" role="button" data-slide="prev"><span class="carousel-control-prev-icon" aria-hidden="true"></span><span class="sr-only">Anterior</span></a>';
                            imagesHtml += '<a class="carousel-control-next" href="#carouselImages" role="button" data-slide="next"><span class="carousel-control-next-icon" aria-hidden="true"></span><span class="sr-only">Siguiente</span></a>';
                            imagesHtml += '</div>';
                        } else {
                            var base64 = data[0].FotoBase64;
                            imagesHtml = '<a data-fancybox="gallery" href="data:image/webp;base64,' + base64 + '">';
                            imagesHtml += '<img src="data:image/webp;base64,' + base64 + '" class="img-fluid" style="max-height:300px;object-fit:contain;margin:5px;" />';
                            imagesHtml += '</a>';
                        }
                    } else {
                        imagesHtml = '<p>No hay imÃ¡genes disponibles.</p>';
                    }
                    $('#solicitudImages').html(imagesHtml);
                },
                error: function () {
                    $('#solicitudDetails').html('<p>Error al cargar los detalles.</p>');
                    $('#solicitudImages').html('<p>Error al cargar las imÃ¡genes.</p>');
                }
            });

            $('#btnApprove').data('solicitudId', id);
            $('#btnDeny').data('solicitudId', id);
        }

        function aprobarSolicitud(id) {
            Swal.fire({
                title: 'Â¿EstÃ¡ seguro de aprobar la solicitud?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'SÃ­, aprobar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("Approve", "Notifications")',
                        type: 'POST',
                        data: { id: id },
                        dataType: 'json',
                        success: function (data) {
                            Swal.fire('Aprobada', data.message, 'success');
                            $('#solicitudModal').modal('hide');
                            window.location.reload();
                        },
                        error: function () {
                            Swal.fire('Error', 'Error al aprobar la solicitud.', 'error');
                        }
                    });
                }
            });
        }

        function denegarSolicitud(id) {
            Swal.fire({
                title: 'Ingrese el motivo de la denegaciÃ³n',
                input: 'text',
                inputPlaceholder: 'Motivo de la denegaciÃ³n...',
                showCancelButton: true,
                confirmButtonText: 'Enviar',
                cancelButtonText: 'Cancelar',
                inputValidator: (value) => {
                    if (!value || value.trim() === '') {
                        return 'Debe ingresar un motivo para denegar la solicitud.';
                    }
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    var motivo = result.value;
                    Swal.fire({
                        title: 'Â¿EstÃ¡ seguro?',
                        text: 'La solicitud serÃ¡ denegada.',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'SÃ­, denegar',
                        cancelButtonText: 'Cancelar'
                    }).then((confirmResult) => {
                        if (confirmResult.isConfirmed) {
                            $.ajax({
                                url: '@Url.Action("Deny", "Notifications")',
                                type: 'POST',
                                data: { id: id, motivo: motivo },
                                dataType: 'json',
                                success: function (data) {
                                    Swal.fire('Denegada', data.message, 'success');
                                    $('#solicitudModal').modal('hide');
                                    window.location.reload();
                                },
                                error: function () {
                                    Swal.fire('Error', 'Error al denegar la solicitud.', 'error');
                                }
                            });
                        }
                    });
                }
            });
        }

        $('#btnApprove').click(function () {
            var id = $(this).data('solicitudId');
            aprobarSolicitud(id);
        });

        $('#btnDeny').click(function () {
            var id = $(this).data('solicitudId');
            denegarSolicitud(id);
        });

        function toggleSubMenu(subMenuId) {
            var $target = $('#' + subMenuId);
            var $open = $('#accordionSidebar .collapse.show').not($target);

            if ($open.length) {
                if (!$target.hasClass('show')) {
                    $open.one('hidden.bs.collapse', function () {
                        $target.collapse('show');
                    });
                }
                $open.collapse('hide');
                return;
            }
            $target.collapse('toggle');
        }

        document.getElementById("userDropdownButton").addEventListener("click", function (e) {
            e.preventDefault();
            document.querySelector("#userDropdownLi .dropdown-menu").classList.toggle("show");
        });

        document.addEventListener("click", function (event) {
            if (event.target.closest("#userDropdownButton") === null &&
                document.querySelector("#userDropdownLi .dropdown-menu").classList.contains("show")) {
                document.querySelector("#userDropdownLi .dropdown-menu").classList.remove("show");
            }
        });
    </script>

    @RenderSection("scripts", required: false)
</body>
</html>

