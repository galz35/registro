    <style>
        .noti-table-details {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 15px;
            border-radius: 5px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

            .noti-table-details th,
            .noti-table-details td {
                border: 1px solid #ddd;
                padding: 8px;
            }

            .noti-table-details th {
                background-color: #f44336;
                color: white;
                text-align: center;
                font-size: 14px;
                font-weight: bold;
            }

                .noti-table-details th:first-child,
                .noti-table-details td:first-child {
                    width: 20%;
                    white-space: nowrap;
                }

                .noti-table-details th:last-child,
                .noti-table-details td:last-child {
                    width: 80%;
                }

            .noti-table-details tbody tr {
                background-color: #fff;
            }

        .noti-cita-group .card,
        .card.proxima,
        .card.hoy,
        .card.pasada {
            transition: transform 0.3s, box-shadow 0.3s;
            border-radius: 5px;
            border: 0;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            margin-bottom: 10px;
        }

        .card.proxima {
            border-left: 5px solid #4caf50;
        }

        .card.hoy {
            border-left: 5px solid orange;
            background-color: #fffbea;
        }

        .card.pasada {
            border-left: 5px solid #f44336;
        }

        .noti-dropdown .dropdown-menu {
            min-width: 320px;
        }

        .noti-dropdown .dropdown-header {
            font-size: 1rem;
            border-bottom: 1px solid #e9ecef;
            margin-bottom: 5px;
            padding-bottom: 5px;
        }

        .noti-dropdown .noti-items {
            max-height: 300px;
            overflow-y: auto;
        }

        .navbar-nav .dropdown-menu.notifications {
            min-width: 320px;
            padding: 0.5rem;
            border-radius: 0.5rem;
        }

        .notifications .dropdown-header {
            font-size: 1rem;
            border-bottom: 1px solid #e9ecef;
            margin-bottom: 0.5rem;
            padding-bottom: 0.3rem;
        }

        .notifications .items-container {
            max-height: 300px;
            overflow-y: auto;
        }

        .notifications .cita-group,
        .notifications .solicitud-group {
            border-bottom: 1px solid #dee2e6;
            padding: 0.5rem;
            margin-bottom: 0.5rem;
        }

            .notifications .cita-group .group-header,
            .notifications .solicitud-group .group-header {
                padding: 0.3rem 0.5rem;
                border-radius: 0.3rem;
                margin-bottom: 0.3rem;
            }

            .notifications .cita-group .group-item,
            .notifications .solicitud-group .group-item {
                padding-left: 1.5rem;
                font-size: 0.9rem;
            }

            .notifications .solicitud-group button {
                font-size: 0.75rem;
                padding: 0.2rem 0.4rem;
                margin-left: 0.3rem;
            }

        .noti-carousel .carousel-item img {
            max-height: 300px;
            object-fit: contain;
        }

        .navbar-nav .nav-item .badge {
            margin-left: 0.5rem;
            background-color: red;
            color: #fff;
            border-radius: 50%;
            padding: 0.2rem 0.5rem;
        }

        .sidebar-heading {
            color: white !important;
            font-weight: bold !important;
            font-size: 1.3rem !important;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        .nav-link {
            color: white !important;
            display: flex;
            align-items: center;
            padding: 8px 12px;
            transition: background-color 0.3s, color 0.3s;
        }

            .nav-link:hover {
                color: black !important;
                background-color: white !important;
            }

        .nav-item .collapse-inner .nav-link {
            color: #adb5bd !important;
        }

            .nav-item .collapse-inner .nav-link:hover {
                color: white !important;
            }

        .sidebar-brand {
            padding: 1.5rem 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            text-transform: uppercase;
            font-size: 1.25rem;
            letter-spacing: 0.1em;
            color: white;
        }

        .nav-link i {
            color: white !important;
        }

        .nav-link:hover i {
            color: black !important;
        }

        .sidebar-brand-icon {
            margin-right: 0.5rem;
        }

        .sidebar-divider {
            border-top: 1px solid rgba(255,255,255,0.15);
            margin: 0 1rem 1rem;
        }

        .nav-item.dropdown .icon-chat {
            color: #4e73df !important;
        }

        .nav-item.dropdown .icon-auth {
            color: #1cc88a !important;
        }

        .nav-item.dropdown .icon-solicitudes {
            color: #f6c23e !important;
        }

        .nav-item.dropdown .icon-solicitudes2 {
            color: #808080 !important;
        }

        .nav-item.dropdown .icon-solicitudes3 {
            color: #ff9e05 !important;
        }

        .nav-item.dropdown .icon-solicitudes4 {
            color: #f6c23e !important;
        }

        .rh-userbox {
            display: flex;
            align-items: center;
            gap: .75rem;
            color: black !important;
        }

        .rh-name-badge {
            font-weight: 700;
            font-size: .95rem;
            letter-spacing: .2px;
            color: black !important;
            border: 1px solid #e5e7eb;
            padding: .35rem .6rem;
            border-radius: 999px;
            line-height: 1;
            box-shadow: 0 2px 6px rgba(0,0,0,.06);
            white-space: nowrap;
            max-width: 28ch;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .rh-logout-btn {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            color: black !important;
            font-weight: 600;
            font-size: .85rem;
            padding: .45rem .9rem;
            border-radius: 20px;
            line-height: 1;
            transition: background-color .2s ease;
        }

            .rh-logout-btn:hover {
                color: black !important;
                text-decoration: none;
            }

            .rh-logout-btn:active {
                color: black !important;
                transform: translateY(1px);
            }

            .rh-logout-btn i {
                color: red !important;
            }

        #userDropdownLi.no-arrow .nav-link {
            border-left: none !important;
            background: transparent !important;
        }
    </style>
</head>

<body id="page-top" class="sidebar-toggled">
    <div id="wrapper">

        <ul class="navbar-nav bg-gradient-primary sidebar sidebar-dark accordion toggled" id="accordionSidebar">
            <a class="sidebar-brand d-flex align-items-center justify-content-center" href="index.html">
                <div class="sidebar-brand-icon">
                    <img src="~/Content/Images/rh5.jpg" alt="Logo" class="img-fluid" style="width: 200px; height: 50px;">
                </div>
            </a>

            <hr class="sidebar-divider my-0">

            @{
                List<Entities.MenuRhOnline> menuItems = (List<Entities.MenuRhOnline>)Session["Menulista"];
            }
            <div class="sidebar-heading">
                MENU
            </div>
            <ul class="nav">
                @foreach (var menuItem in menuItems)
                {
                    <li class="nav-item">
                        @if (menuItem.MenuList.Count > 0)
                        {
                            <a class="nav-link" href="javascript:void(0);" onclick="toggleSubMenu('@menuItem.Controller')">
                                <i class="fas @menuItem.icon"></i>
                                <span>@menuItem.MenuText</span>
                            </a>
                            <div id="@menuItem.Controller" class="collapse" data-parent="#accordionSidebar">
                                <div class="bg-white py-2 collapse-inner rounded">
                                    @RenderSubMenu(menuItem.MenuList)
                                </div>
                            </div>
                        }
                        else
                        {
                            <a class="nav-link" href="@Url.Action(menuItem.Action, menuItem.Controller)">
                                <i class="fas @menuItem.icon"></i>
                                <span>@menuItem.MenuText</span>
                            </a>
                        }
                    </li>
                }
            </ul>

            @helper RenderSubMenu(List<Entities.MenuRhOnline> subMenuItems)
            {
                foreach (var subMenuItem in subMenuItems)
                {
                    if (subMenuItem.MenuList.Count > 0)
                    {
                        <div id="@subMenuItem.Controller">
                            <div class="bg-white py-2 rounded">
                                <h6 class="collapse-header">@subMenuItem.MenuText:</h6>
                                @RenderSubMenu(subMenuItem.MenuList)
                            </div>
                        </div>
                    }
                    else
                    {
                        <a class="collapse-item" href="@Url.Action(subMenuItem.Action, subMenuItem.Controller)">@subMenuItem.MenuText</a>
                    }
                }
            }
        </ul>

        <div id="content-wrapper" class="d-flex flex-column">
            <div id="content">
                <nav class="navbar navbar-expand navbar-light bg-white2 topbar mb-4 static-top shadow">
                    <button id="sidebarToggleTop" class="btn btn-link d-md-none rounded-circle mr-3">
                        <i class="fa fa-bars"></i>
                    </button>

                    <ul class="navbar-nav ml-auto">
                        <div class="topbar-divider d-none d-sm-block"></div>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" id="citasDropdown" href="#" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <i class="fas fa-clock icon-solicitudes3"></i>
                                <span class="badge badge-info" id="citasBadge">0</span>
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" id="solicitudesDropdown" href="#" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <i class="fas fa-clipboard-list icon-solicitudes4"></i>
                                <span class="badge badge-info" id="solicitudesBadge">0</span>
                            </a>
                            <div class="dropdown-menu dropdown-menu-right shadow animated--grow-in notifications" aria-labelledby="solicitudesDropdown">
                                <h6 class="dropdown-header">Solicitudes:</h6>
                                <div id="solicitudesContainer" class="items-container"></div>
                            </div>
                        </li>

                        <li class="nav-item no-arrow" id="userDropdownLi">
                            <a class="nav-link rh-logout-btn" href="@Url.Action("Logout","Login")" title="Cerrar sesion">
                                <i class="fas fa-sign-out-alt"></i>
                                <span>Cerrar sesion</span>
                            </a>
