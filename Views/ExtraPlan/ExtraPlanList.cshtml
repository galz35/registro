 @{
    ViewBag.Title = "Lista de ExtraPlanes";
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}
@Html.DevExpress().GetStyleSheets(
         new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout },

         new StyleSheet { ExtensionSuite = ExtensionSuite.HtmlEditor },

         new StyleSheet { ExtensionSuite = ExtensionSuite.GridView }


     )
     @section scripts {



    <script src="~/onlinejs/jquery-3.6.0.min.js"></script>
    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.buttons.min.js"></script>
    <script src="~/onlinejs/buttons.html5.min.js"></script>
    <script src="~/onlinejs/buttons.bootstrap4.min.js"></script>
    <script src="~/onlinejs/dataTables.select.min.js"></script>
    <script src="~/onlinejs/bootstrap.bundle.min.js"></script>
    <script src="~/onlinejs/bootstrap.min.js"></script>
    <script src="~/onlinejs/loadingoverlay.min.js"></script>
    <script src="~/onlinejs/dataTables.responsive.min.js"></script>
    <script src="~/Content/plugin/sweetalert2/sweetalert2.all.js"></script>
    <script src="~/onlinejs/moment.min.js"></script>
    <script src="~/onlinejs/jszip.min.js"></script>
    <script src="~/onlinejs/jquery-ui.js"></script>
    <script src="~/onlinejs/spin.min.js"></script>

    <script>
  var tabla_persona;
        var popupTable;
           $(document).ready(function () {
            $.LoadingOverlay("show");

         tabla_persona = $('#listTable').DataTable({
    "ajax": {
        "url": "@Url.Action("Listjson", "ExtraPlan")",
        "type": "GET",
        "dataType": "json" // Se corrige la propiedad a 'dataType'
    },
    "columns": [
         
        { "data": "IdCombustibleExtraPlan" },
        {
            "data": "FechaSolicitud",
            "render": function (data) {
                return data ? moment(data).format('DD/MM/YYYY') : '';
            }
        },
        {
            "data": "FechaInicioActividad",
            "render": function (data) {
                return data ? moment(data).format('DD/MM/YYYY') : '';
            }
        },
        {
            "data": "FechaFinActividad",
            "render": function (data) {
                return data ? moment(data).format('DD/MM/YYYY') : '';
            }
        },
        { "data": "KmRecorrer" },
        {
            "data": "Estado",
            "createdCell": function (td, cellData, rowData, row, col) {
                var color = "";
                if (cellData.toLowerCase().includes("registra")) {
                    color = "#fdfd96"; // Amarillo para "registrado"
                } else if (cellData.toLowerCase().includes("autorizado") || cellData.toLowerCase().includes("aplicado")) {
                    color = "#77dd77"; // Verde
                } else if (cellData.toLowerCase().includes("anulad") || cellData.toLowerCase().includes("denegado por rrhh")) {
                    color = "#ff6961"; // Rojo
                } else {
                    color = "#ADD8E6"; // Azul para otros estados
                }
                $(td).css('color', color);
            }
        }
    ],
    "dom": 'Blfrtip',
    "lengthMenu": [10, 20, 50, 100],
    "pageLength": 10,
    "language": {
        "url": "@Url.Content("~/Scripts/datatable.es-ES.json")"
    },
    "responsive": true,
    "initComplete": function () {
        // Control de menúes desplegables en la tabla
        $('#listTable tbody').on('click', '.dropdown-toggle', function (e) {
            e.stopPropagation();
            $(this).siblings('.dropdown-menu').toggleClass('show');
        });
        $(document).on('click', function (e) {
            if (!$('.dropdown-toggle').is(e.target) &&
                $('.dropdown-toggle').has(e.target).length === 0 &&
                $('.show').has(e.target).length === 0) {
                $('.dropdown-menu').removeClass('show');
            }
        });
    }
});

            $.LoadingOverlay("hide");
             popupTable = $('#popupTable').DataTable({
                columns: [
                    { data: 'NombreEmpleado' },
                    { data: 'Hora' },
                    {
                        data: 'FechaInsercion',
                        render: function (data) {
                            return moment(data).format('DD/MM/YYYY');
                        }
                    },
                    { data: 'Estado' }
                ],
                "language": {
                    "url": "@Url.Content("~/Scripts/datatable.es-ES.json")"
                },
                "responsive": true
            });
        });
              function AnularExtraPlan(idExtraPlan) {
                 $.LoadingOverlay("show");
            $.ajax({
                url: '@Url.Action("AnularExtraPlan")',
                type: "POST",
                data: { idExtraPlan: idExtraPlan },
                dataType: "json",
                traditional: true,
                cache: false,

                success: function (data) {
                       $.LoadingOverlay("hide");
                    if (data.status != "Error") {
                        swal.fire({
                            title: "Exito!",
                            text: data.message,
                            icon: "success",
                            confirmButtonText: "Aceptar"
                        }).then((willSaved) => {
                            if (willSaved) {
                                Reload();
                            }
                        });
                    } else {
                        swal.fire("Advertencia!", data.message, "warning");
                    }
                },
                error: function () {
                                           $.LoadingOverlay("hide");

                    alert("An error has occurred!!!");
                }
            });
        }
    function OnInit(s, e) {
        AdjustSize();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            AdjustSize();
        });
    }
    function OnEndCallback(s, e) {
        AdjustSize();
    }
    function AdjustSize() {
        var height = document.documentElement.clientHeight;
        gvExtraPlan.SetHeight(height - 150);
    }

    function ShowEditExtraPlan(elementID, url) {
        var visibleIndex = gvExtraPlan.GetFocusedRowIndex();
        var key = gvExtraPlan.GetRowKey(visibleIndex);
        var idAccion = elementID;
        $.ajax({
            url: '@Url.Action("ValidarExtraPlan")',
            type: "POST",
            data: { idExtraPlan: key, tipoEdicion: idAccion },
            dataType: "json",
            traditional: true,
            cache: false,
            //contentType: "application/json; charset=utf-8",
            success: function (data) {
                if (data.status != "Error") {
                    popEditExtraPlan.SetContentUrl(url);
                    popEditExtraPlan.ShowAtElementByID(elementID);
                } else {
                    swal.fire("Advertencia!", data.message, "warning");
                }


            },
            error: function () {
                alert("An error has occured!!!");
            }
        });
    }
function EditarExtraPlan(idExtraPlan) {

               var url = '@Url.Action("EditExtraPlan", "ExtraPlan", new { idExtraPlan = "0" })'.replace("0", idExtraPlan);
          $.LoadingOverlay("show");
         $.ajax({
                url: '@Url.Action("ValidarExtraPlan")',
                type: "POST",
                data: { idExtraPlan: idExtraPlan, tipoEdicion: "Editar" },
                dataType: "json",
                traditional: true,
                cache: false,
                success: function (data) { $.LoadingOverlay("hide");
                    if (data.status != "Error") {

                        popEditExtraPlan.SetContentUrl(url);
                       popEditExtraPlan.ShowAtElementByID(idExtraPlan);

                    } else {
                        swal.fire("Advertencia!", data.message, "warning");
                    }
                },
                error: function () {
                     $.LoadingOverlay("hide");
                    alert("An error has occurred!!!");
                }
            });
        }
    //function ShowEditExtraPlan(elementID, url) {
    //    popImage.SetContentUrl(url);
    //    popImage.ShowAtElementByID(elementID);
    //}
      function EditarExtraPlannuevo() {
              var key = "-1";
              var url = '@Url.Action("EditExtraPlan", "Consumo", new { idExtraPlan = "0" })';
           $.LoadingOverlay("show");
          $.ajax({
                url: '@Url.Action("ValidarExtraPlan")',
                type: "POST",
                data: { idExtraPlan: "-1", tipoEdicion: "Nuevo" },
                dataType: "json",
                traditional: true,
                cache: false,
                success: function (data) {
                         $.LoadingOverlay("hide");
                    if (data.status != "Error") {
                        //var popup = ASPxClientControl.GetControlCollection().GetByName('popEditExtraPlan');
                        //popup.SetContentUrl(url);
                        //popup.Show();
                        popEditExtraPlan.SetContentUrl(url);
                        popEditExtraPlan.ShowAtElementByID(key);
                        //$('#popEditExtraPlan').dxPopup({
                        //    contentTemplate: function (contentElement) {
                        //        contentElement.load(url);
                        //    }
                        //}).dxPopup("instance").show();
                    } else {
                        swal.fire("Advertencia!", data.message, "warning");
                    }
                },
                error: function () {
                     $.LoadingOverlay("hide");
                    alert("An error has occurred!!!");
                }
            });
        }
    function Reload(s, e) {
        $.ajax({
            url: '@Url.Action("ListPartial")',
            //contentType: 'application/json; charset=utf-8',
            type: 'GET',
            //dataType: 'json',
            cache: false,
            traditional: true,
            data: {},
        }).done(function(result) {
            $('#ListPartial').html(result);
        });
    }
  function Reload() {
                tabla_persona.ajax.reload();
         }

     function AnularExtraPlan(idExtraPlan) {
            $.ajax({
                url: '@Url.Action("AnularExtraPlan")',
                type: "POST",
                data: { idExtraPlan: idExtraPlan },
                dataType: "json",
                traditional: true,
                cache: false,
                success: function (data) {
                    if (data.status != "Error") {
                        swal.fire({
                            title: "Exito!",
                            text: data.message,
                            icon: "success",
                            buttconfirmButtonTexton: "Aceptar"
                        }).then((willSaved) => {
                            if (willSaved) {
                                Reload();
                            }
                        });
                    } else {
                        swal.fire("Advertencia!", data.message, "warning");
                    }
                },
                error: function () {
                    alert("An error has occurred!!!");
                }
            });
        }
       // popDetalleEstado.SetContentUrl(url);
      //  popDetalleEstado.ShowAtElementByID(elementID);

      function VerDetalleEstados(idExtraPlan) {
                $('#popupContainer').modal('show');
                $.ajax({
                    url: '@Url.Action("ExtraPlanStateConsultPartialjson", "Consumo")',
                    data: { idExtraPlan: idExtraPlan }, // Reemplaza 'tuIdConsumo' con el valor correcto
                    type: 'GET',
                    dataType: 'json',
                    success: function (data) {
                        // Llena la tabla con los datos JSON
                        popupTable.clear().rows.add(data.data).draw();
                    },
                    error: function (error) {
                        console.error(error);
                    }
                });

            }



    </script>
     }
@Html.DevExpress().GetScripts(
    new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
    new Script { ExtensionSuite = ExtensionSuite.HtmlEditor },
    new Script { ExtensionSuite = ExtensionSuite.GridView }

 )
<div id="content-wrapper" class="d-flex flex-column">
    <div id="content">
        <div class="container-fluid">

            <!-- Page Heading -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="m-0 font-weight-bold text-primary" style="color: #800 !important;">Extra plan</h5>
                        <a href="#" id="mostrarPopupBtn" onclick="EditarExtraPlan('0')" class="btn btn-primary btn-icon-split">
                            <span class="icon text-white-50">
                                <i class="fas fa-plus"></i>
                            </span>
                            <span class="text">Registrar Nuevo</span>
                        </a>
                    </div>
                </div>


                <div class="card-body p-3">

                    <table id="listTable" style="width:100%"
                           class="table table-striped  table-bordered table-hover display responsive nowrap">
                        <thead>
                            <tr>
                                <th>Acciones</th>
                                <th># Extra Plan</th>
                                <th>Fecha de Solicitud</th>
                                <th>Fecha Inicio</th>
                                <th>Fecha Fin</th>
                                <th>Kms Recorrer</th>
                                <th>Estado</th>

                            </tr>
                        </thead>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>
@Html.DevExpress().PopupControl(settingsPopup =>
{settingsPopup.Theme = "Mulberry";
    settingsPopup.Name = "popEditExtraPlan";
    settingsPopup.ShowOnPageLoad = false;
    settingsPopup.HeaderText = "Edicion de Extra Plan";
    settingsPopup.PopupHorizontalAlign = PopupHorizontalAlign.WindowCenter;
    settingsPopup.PopupVerticalAlign = PopupVerticalAlign.WindowCenter;
    settingsPopup.CloseOnEscape = true;
    settingsPopup.Width = 850;
    settingsPopup.Height = 500;
    settingsPopup.ClientSideEvents.CloseUp = "";



}).GetHtml()
@Html.DevExpress().PopupControl(settings =>
{
    settings.Theme = "Mulberry";
    settings.Name = "popDetalleEstado";
    settings.ShowHeader = true;
    settings.HeaderText = "Detalle de Estados";
    settings.PopupHorizontalAlign = PopupHorizontalAlign.WindowCenter;
    settings.PopupVerticalAlign = PopupVerticalAlign.WindowCenter;
    settings.Width = 800;
    settings.Height = 400;
    settings.CloseAction = CloseAction.CloseButton;
    settings.CloseOnEscape = true;

}).GetHtml()
<div class="modal fade" id="popupContainer">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Lista estado</h4>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <table id="popupTable" class="display" style="width:100%;">
                    <thead>
                        <tr>
                            <th>NombreEmpleado</th>
                            <th>Hora</th>
                            <th>Fecha</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="cerrar()" data-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>