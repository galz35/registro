                        <div class="form-group col-md-6"><label class="small font-weight-bold text-muted">TIPO</label><select id="naTipo" class="form-control" required><option>EPP</option><option>ROPA</option><option>MEDICAMENTO</option><option class="text-danger">EVENTO</option></select></div>
