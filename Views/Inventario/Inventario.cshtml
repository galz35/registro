@{
    ViewBag.Title = "Inventario · Hub Central";
}

<style>
    :root {
        --rojo: #e1251b;
        --rojo2: #b30000;
        --primario: #1a252f;
        --gris: #f4f7f6;
        --gris2: #e9ecf2;
        --blanco: #fff;
        --card-shadow: 0 8px 30px rgba(0,0,0,0.04);
    }

    body {
        background-color: var(--gris);
        font-family: 'Segoe UI', system-ui, sans-serif;
    }

    /* ---- Header hero + KPIs Estilo Dashboard ---- */
    .hero {
        background: linear-gradient(135deg, var(--primario), #2c3e50);
        color: #fff;
        border-radius: 20px;
        padding: 25px 30px;
        box-shadow: 0 10px 25px rgba(26, 37, 47, 0.2);
        margin-bottom: 25px;
        position: relative;
        overflow: hidden;
    }

        .hero::before {
            content: '\f4d3';
            font-family: 'Font Awesome 5 Free';
            font-weight: 900;
            position: absolute;
            right: -20px;
            top: -30px;
            font-size: 150px;
            opacity: 0.05;
        }

    .kpi {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(5px);
        border-radius: 12px;
        padding: 12px 20px;
        border: 1px solid rgba(255,255,255,0.15);
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .kpi .n {
            font-size: 1.8rem;
            font-weight: 800;
            color: #fff;
            line-height: 1;
        }

        .kpi small {
            text-transform: uppercase;
            font-size: 0.7rem;
            letter-spacing: 1px;
            opacity: 0.8;
        }

    /* ---- Contenedores y Tablas ---- */
    .shell {
        border-radius: 20px;
        background: #fff;
        box-shadow: var(--card-shadow);
        border: none;
        padding: 20px;
    }

    table.dataTable thead th {
        border-bottom: 2px solid var(--gris2) !important;
        border-top: none;
        font-size: 0.8rem;
        text-transform: uppercase;
        color: #666;
        background: #fff;
    }

    table.dataTable tbody td {
        vertical-align: middle;
        border-bottom: 1px solid #f9f9f9;
    }

    .dt-filter-row th {
        background: #f8f9fa;
        border-top: none;
        padding: 8px !important;
    }

    .dt-filter-row input, .dt-filter-row select {
        border-radius: 6px;
        border: 1px solid #ddd;
        background: #fff;
    }

    /* ---- Pestañas (Tabs) Estilo Moderno ---- */
    .sticky-tabs {
        position: sticky;
        top: 15px;
        z-index: 100;
        border-radius: 15px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        padding: 5px;
        border: none;
        gap: 5px;
    }

    #menuTabs .nav-link {
        color: #666 !important;
        font-weight: 600;
        border-radius: 10px;
        padding: 10px 20px;
        border: none;
        transition: 0.3s;
    }

        #menuTabs .nav-link:hover {
            background-color: var(--gris);
        }

        #menuTabs .nav-link.active {
            background-color: var(--rojo) !important;
            color: #fff !important;
            box-shadow: 0 4px 10px rgba(225, 37, 27, 0.2);
        }

    /* ---- Chips (Filtros) ---- */
    .chip {
        display: inline-flex;
        align-items: center;
        padding: 6px 16px;
        border-radius: 20px;
        border: 1px solid var(--gris2);
        margin: 4px;
        cursor: pointer;
        background: #fff;
        font-size: 0.85rem;
        font-weight: 600;
        color: #555;
        transition: 0.2s;
        user-select: none;
    }

        .chip:hover {
            background: #f8f9fa;
        }

        .chip.active {
            background: var(--primario);
            color: white;
            border-color: var(--primario);
            box-shadow: 0 4px 10px rgba(26, 37, 47, 0.2);
        }

    /* ---- Botón flotante (FAB) ---- */
    .fab {
        position: fixed;
        right: 30px;
        bottom: 30px;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: var(--rojo);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        box-shadow: 0 10px 25px rgba(225, 37, 27, 0.4);
        cursor: pointer;
        z-index: 1050;
        transition: 0.3s;
    }

        .fab:hover {
            transform: scale(1.1);
            background: var(--rojo2);
        }

    /* ---- Resaltado bajo stock y Badges ---- */
    .row-low td {
        background-color: #fff5f5 !important;
        color: var(--rojo2);
        font-weight: bold;
    }

    .badge {
        padding: 6px 10px;
        border-radius: 6px;
        font-weight: 600;
    }

    /* ---- Modales Clean UI ---- */
    .modal-content {
        border-radius: 16px;
        border: none;
        overflow: hidden;
    }

    .modal-header {
        background: #f8f9fa;
        border-bottom: 1px solid var(--gris2);
        padding: 20px;
    }

    .modal-footer {
        border-top: 1px solid var(--gris2);
        background: #fff;
        padding: 20px;
    }

    .form-control {
        border-radius: 8px;
        border: 1px solid #ddd;
    }

        .form-control:focus {
            border-color: var(--primario);
            box-shadow: none;
        }

    .btn {
        border-radius: 8px;
        font-weight: 600;
    }

    /* ---- Autocomplete liviano ---- */
    .ac-wrap {
        position: relative;
    }

    .ac-input {
        width: 100%;
    }

    .ac-list {
        position: absolute;
        z-index: 2051;
        left: 0;
        right: 0;
        top: 100%;
        background: #fff;
        border: 1px solid var(--gris2);
        border-radius: 10px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        max-height: 250px;
        overflow: auto;
        display: none;
        margin-top: 5px;
    }

    .ac-item {
        padding: 10px 15px;
        cursor: pointer;
        border-bottom: 1px solid #f9f9f9;
    }

        .ac-item:hover {
            background: #fff5f5;
            color: var(--rojo);
            font-weight: bold;
        }
</style>

<div class="container-fluid mt-4 mb-5">

    <div class="hero d-flex flex-wrap justify-content-between align-items-center">
        <div class="mb-3 mb-lg-0">
            <h3 class="font-weight-bold mb-1">Hub Central de Logística</h3>
            <p class="mb-0 opacity-75">Gestión integral de EPP, Ropa y Medicamentos.</p>
            <small class="mt-2 d-block opacity-50"><i class="fas fa-keyboard mr-1"></i> Atajos: <kbd class="bg-dark text-light border-0">N</kbd> Solicitud · <kbd class="bg-dark text-light border-0">I</kbd> Inventario</small>
        </div>

        <div class="d-flex flex-wrap align-items-center" style="gap:15px">
            <div class="kpi">
                <div><div class="n" id="kpiPendAprob">0</div><small>Por Aprobar Jefe</small></div>
            </div>
            <div class="kpi">
                <div><div class="n text-warning" id="kpiPendAtender">0</div><small>Bodega Pendiente</small></div>
            </div>
            <div class="kpi">
                <div><div class="n text-danger" id="kpiBajo">0</div><small>Stock Crítico</small></div>
            </div>
            <div class="ml-2 pl-3 border-left" style="border-color: rgba(255,255,255,0.2) !important;">
                <label class="mb-1 text-white-50 small font-weight-bold d-block">BODEGA ACTIVA</label>
                <select id="selAlm" class="form-control form-control-sm font-weight-bold border-0 shadow-sm" style="width:200px; border-radius:6px; color: var(--primario);"></select>
            </div>
        </div>
    </div>

    <ul id="menuTabs" class="nav nav-tabs sticky-tabs bg-white mb-4">
        <li class="nav-item"><a class="nav-link active" data-target="#secSolic" href="#"><i class="fas fa-inbox mr-2"></i>Solicitudes Globales</a></li>
        <li class="nav-item"><a class="nav-link" data-target="#secBodega" href="#"><i class="fas fa-truck-loading mr-2"></i>Monitor Despachos</a></li>
        <li class="nav-item"><a class="nav-link" data-target="#secInv" href="#"><i class="fas fa-boxes mr-2"></i>Inventario Físico</a></li>
        <li class="nav-item"><a class="nav-link" data-target="#secReg" href="#"><i class="fas fa-history mr-2"></i>Auditoría y Kardex</a></li>
    </ul>

    <div class="tab-content shell">

        <div id="secSolic" class="tab-pane fade show active">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div id="chipsEstado">
                    <span class="chip active" data-estado="*">Todas</span>
                    <span class="chip" data-estado="Pendiente">Pendientes</span>
                    <span class="chip" data-estado="Aprobada">Aprobadas</span>
                    <span class="chip" data-estado="Parcial">Parciales</span>
                    <span class="chip" data-estado="Atendida">Atendidas</span>
                    <span class="chip" data-estado="Rechazada">Rechazadas</span>
                </div>
                <button id="btnNuevaSol" class="btn btn-danger font-weight-bold shadow-sm"><i class="fas fa-plus mr-1"></i> Crear Solicitud</button>
            </div>
            <div class="table-responsive">
                <table id="tblSolic" class="table table-hover w-100"></table>
            </div>
        </div>

        <div id="secBodega" class="tab-pane fade">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="d-flex align-items-center gap-2">
                    <button id="btnSalidaDir" class="btn btn-dark font-weight-bold"><i class="fas fa-dolly mr-1"></i> Salida Directa</button>
                    <button id="btnTransfer" class="btn btn-outline-secondary font-weight-bold ml-2"><i class="fas fa-exchange-alt mr-1"></i> Transferir Stock</button>
                </div>
                <small class="text-muted"><i class="fas fa-info-circle text-primary"></i> Aprobadas/Parciales → <b>Atender</b> (Medicamentos aplica FEFO automático).</small>
            </div>
            <div class="table-responsive">
                <table id="tblBod" class="table table-hover w-100"></table>
            </div>
        </div>

        <div id="secInv" class="tab-pane fade">
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
                <div class="d-flex gap-2">
                    <div class="chip active" data-filtro="tipo:*">Todos</div>
                    <div class="chip" data-filtro="tipo:ROPA">Ropa</div>
                    <div class="chip" data-filtro="tipo:EPP">EPP</div>
                    <div class="chip" data-filtro="tipo:MEDICAMENTO">Medicamentos</div>
                    <div class="chip text-danger border-danger" data-filtro="min:1"><i class="fas fa-exclamation-triangle mr-1"></i> Ver Críticos</div>
                </div>
                <button id="btnNewArt" class="btn btn-danger font-weight-bold shadow-sm"><i class="fas fa-box-open mr-1"></i> Nuevo Artículo</button>
            </div>
            <div class="table-responsive">
                <table id="tblInvVar" class="table table-hover w-100"></table>
            </div>
            <small class="text-muted mt-2 d-block"><i class="fas fa-info-circle text-primary"></i> <b>Entrada:</b> Compras/Ingresos | <b>Merma:</b> Daños/Vencimientos | <b>Historial:</b> Ver Kardex.</small>
        </div>

        <div id="secReg" class="tab-pane fade">
            <div class="bg-light p-3 rounded mb-3 border">
                <div class="row align-items-end">
                    <div class="col-md-2"><label class="small font-weight-bold text-muted mb-1">Desde</label><input type="date" id="fDesde" class="form-control form-control-sm"></div>
                    <div class="col-md-2"><label class="small font-weight-bold text-muted mb-1">Hasta</label><input type="date" id="fHasta" class="form-control form-control-sm"></div>
                    <div class="col-md-2">
                        <label class="small font-weight-bold text-muted mb-1">Tipo de Movimiento</label>
                        <select id="fTipo" class="form-control form-control-sm">
                            <option value="">(Todos)</option>
                            <option>ENTRADA</option>
                            <option>SALIDA</option>
                            <option>MERMA</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="small font-weight-bold text-muted mb-1">Origen / Causa</label>
                        <select id="fOrigen" class="form-control form-control-sm">
                            <option value="">(Todos)</option>
                            <option>Entrada</option>
                            <option>Merma</option>
                            <option>Solicitud</option>
                            <option>Directa</option>
                        </select>
                    </div>
                    <div class="col-md-2"><label class="small font-weight-bold text-muted mb-1">Carnet Empleado</label><input id="fEmp" class="form-control form-control-sm" placeholder="Opcional..."></div>
                    <div class="col-md-2 d-flex gap-2">
                        <button id="btnRegBuscar" class="btn btn-primary btn-sm btn-block font-weight-bold shadow-sm">Buscar</button>
                    </div>
                </div>
            </div>

            <ul class="nav nav-pills mb-3 small font-weight-bold">
                <li class="nav-item"><a class="nav-link active rounded-pill px-4" data-toggle="tab" href="#regMov">Kardex General</a></li>
                <li class="nav-item"><a class="nav-link rounded-pill px-4 text-muted" data-toggle="tab" href="#regDia">Resumen Salidas del Día</a></li>
            </ul>

            <div class="tab-content">
                <div id="regMov" class="tab-pane fade show active"><div class="table-responsive"><table id="tblReg" class="table table-hover w-100"></table></div></div>
                <div id="regDia" class="tab-pane fade"><div class="table-responsive"><table id="tblDia" class="table table-hover w-100"></table></div></div>
            </div>
        </div>
    </div>
</div>

<div class="fab" id="fabNueva" title="Crear nueva solicitud (Tecla N)"><i class="fas fa-plus"></i></div>

<div class="modal fade" id="mdlNuevaSol" tabindex="-1" data-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content shadow-lg">
            <div class="modal-header d-flex justify-content-between align-items-center">
                <h5 class="modal-title font-weight-bold text-dark"><i class="fas fa-file-alt text-danger mr-2"></i>Crear Solicitud Manual</h5>
                <button class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body bg-light" style="max-height:75vh; overflow-y:auto">
                <form id="frmNuevaSol" autocomplete="off">
                    <div class="row">
                        <div class="form-group col-md-4"><label class="small font-weight-bold text-muted">CARNET EMPLEADO</label><input id="nsEmpCarnet" class="form-control" placeholder="Ej: 123456" /></div>
                        <div class="form-group col-md-8"><label class="small font-weight-bold text-muted">MOTIVO DE SOLICITUD</label><input id="nsMotivo" class="form-control" placeholder="Ej: Ingreso nuevo, reposición por desgaste..." /></div>
                    </div>

                    <div class="bg-white p-3 rounded border mb-3 shadow-sm">
                        <div class="row align-items-end">
                            <div class="form-group col-md-5 mb-0"><label class="small font-weight-bold text-muted">BUSCAR ARTÍCULO</label><input id="nsArt" class="form-control border-primary" placeholder="Escribe código o nombre…" /><input type="hidden" id="nsIdArt" /></div>
                            <div class="form-group col-md-2 mb-0"><label class="small font-weight-bold text-muted">TALLA</label><select id="nsTalla" class="form-control"><option>UNI</option></select></div>
                            <div class="form-group col-md-2 mb-0"><label class="small font-weight-bold text-muted">SEXO</label><select id="nsSexo" class="form-control"><option>N</option><option>M</option><option>F</option></select></div>
                            <div class="form-group col-md-2 mb-0"><label class="small font-weight-bold text-muted">CANT</label><input id="nsCant" type="number" class="form-control text-center font-weight-bold" min="1" value="1" /></div>
                            <div class="form-group col-md-1 mb-0"><button type="button" id="btnAddNS" class="btn btn-dark btn-block shadow-sm"><i class="fas fa-level-down-alt"></i></button></div>
                        </div>
                        <div class="form-group mt-2 mb-0"><input id="nsObs" class="form-control form-control-sm bg-light" placeholder="Observación específica para este ítem (Opcional)" /></div>
                    </div>

                    <div class="table-responsive bg-white rounded border">
                        <table class="table table-sm mb-0" id="tblNS">
                            <thead class="bg-light text-muted"><tr><th>Código</th><th>Descripción</th><th>Talla</th><th>Sexo</th><th class="text-center">Cant</th><th>Notas</th><th></th></tr></thead>
                            <tbody></tbody>
                        </table>
                    </div>

                    <div class="mt-4 text-right">
                        <button type="button" class="btn btn-light border px-4 mr-2" data-dismiss="modal">Cancelar</button>
                        <button class="btn btn-danger px-5 shadow"><i class="fas fa-save mr-2"></i> Guardar Solicitud</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mdlDetalle" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content shadow">
            <div class="modal-header"><h5 class="modal-title font-weight-bold">Detalle de Solicitud</h5><button class="close" data-dismiss="modal">&times;</button></div>
            <div class="modal-body p-0">
                <table class="table table-hover mb-0" id="tblDetalle">
                    <thead class="bg-light small text-muted text-uppercase"><tr><th class="pl-3">Artículo</th><th>Variante</th><th class="text-center">Pidió</th><th class="text-center">Entregado</th><th class="text-center text-danger">Pendiente</th><th class="text-center">En Stock</th></tr></thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mdlMov" tabindex="-1" data-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header bg-dark text-white border-0 pb-3">
                <h5 class="modal-title font-weight-bold" id="movTitle"><i class="fas fa-exchange-alt mr-2"></i> Registro de Inventario</h5>
                <button class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <form id="frmMov">
                <div class="modal-body bg-light p-4">
                    <input type="hidden" id="movTipo" value="ENTRADA" />
                    <input type="hidden" id="movIdArt" />

                    <div class="form-group"><label class="small font-weight-bold text-muted">ARTÍCULO</label><input id="movArtTxt" class="form-control font-weight-bold" disabled /></div>

                    <div class="row">
                        <div class="form-group col-md-4"><label class="small font-weight-bold text-muted">TALLA</label><select id="movTalla" class="form-control"></select></div>
                        <div class="form-group col-md-4"><label class="small font-weight-bold text-muted">SEXO</label><select id="movSexo" class="form-control"><option>N</option><option>M</option><option>F</option></select></div>
                        <div class="form-group col-md-4"><label class="small font-weight-bold text-muted">CANTIDAD</label><input id="movCant" type="number" class="form-control text-center font-weight-bold text-primary" style="font-size:1.2rem" min="1" value="1" /></div>
                    </div>

                    <div class="row" id="grpLoteWrapper">
                        <div class="form-group col-md-6" id="grpLote"><label class="small font-weight-bold text-muted">LOTE (Medicina)</label><input id="movLote" class="form-control" placeholder="Cód. Lote" /></div>
                        <div class="form-group col-md-6" id="grpVenc"><label class="small font-weight-bold text-muted">VENCIMIENTO</label><input id="movVenc" type="date" class="form-control" /></div>
                    </div>

                    <div class="form-group mb-0"><label class="small font-weight-bold text-muted">RESPALDO / COMENTARIO</label><textarea id="movCom" class="form-control" rows="2" placeholder="Motivo o No. Factura"></textarea></div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0 bg-light">
                    <button class="btn btn-danger btn-block btn-lg font-weight-bold shadow-sm" id="btnSavMov">Procesar Transacción</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="mdlAtender" tabindex="-1" data-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content shadow-lg">
            <div class="modal-header">
                <h5 class="modal-title font-weight-bold text-dark"><i class="fas fa-box-open text-primary mr-2"></i> Despachar Solicitud</h5>
                <button class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body p-0 bg-light">
                <div class="table-responsive bg-white">
                    <table class="table table-hover mb-0" id="tblAtender">
                        <thead class="small text-muted text-uppercase bg-light"><tr><th class="pl-3">Artículo</th><th>Variante</th><th class="text-center">Aprobado</th><th class="text-center text-success">Ya Entregado</th><th class="text-center text-danger">Falta</th><th class="text-center bg-dark text-white">Stock Bodega</th><th class="text-center" style="width:120px">Cant. a Entregar</th></tr></thead>
                        <tbody></tbody>
                    </table>
                </div>
                <div class="p-4 border-top">
                    <div class="row align-items-end">
                        <div class="form-group col-md-6 mb-0"><label class="small font-weight-bold text-muted">Nota para el empleado (Opcional)</label><input id="bodComentario" class="form-control bg-white" placeholder="Ej: Pasa por bodega a retirar..." /></div>
                        <div class="form-group col-md-3 mb-0"><label class="small font-weight-bold text-muted">Fecha Envío Físico</label><input id="bodFechaEnvio" type="date" class="form-control bg-white" /></div>
                        <div class="form-group col-md-3 mb-0 d-flex align-items-center h-100 pb-2">
                            <div class="custom-control custom-checkbox"><input type="checkbox" class="custom-control-input" id="bodNotif"><label class="custom-control-label font-weight-bold text-primary" for="bodNotif">Enviar Email</label></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-between">
                <button id="btnRechazarTodo" class="btn btn-outline-danger font-weight-bold px-4"><i class="fas fa-ban mr-1"></i> Rechazar Todo</button>
                <div>
                    <button id="btnAuto" class="btn btn-dark font-weight-bold px-4 mr-2" title="Llena las cantidades basado en el stock disponible"><i class="fas fa-magic mr-1"></i> Auto-Completar</button>
                    <button id="btnDesp" class="btn btn-success font-weight-bold px-5 shadow"><i class="fas fa-check-circle mr-1"></i> Despachar</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mdlSalida" tabindex="-1" data-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content shadow-lg">
            <div class="modal-header bg-dark text-white border-0"><h5 class="modal-title font-weight-bold"><i class="fas fa-dolly mr-2"></i> Registro de Salida Directa</h5><button class="close text-white" data-dismiss="modal">&times;</button></div>
            <form id="frmSalida" autocomplete="off">
                <div class="modal-body bg-light" style="max-height:70vh;overflow:auto">
                    <div class="row bg-white p-3 rounded shadow-sm border mb-3 mx-0">
                        <div class="form-group col-md-4 mb-0"><label class="small font-weight-bold text-muted">CARNET EMPLEADO</label><input id="sdEmp" class="form-control font-weight-bold text-primary" placeholder="Requerido" /></div>
                        <div class="form-group col-md-5 mb-0"><label class="small font-weight-bold text-muted">OBSERVACIÓN GENERAL</label><input id="sdObsGlobal" class="form-control bg-light border-0" placeholder="Motivo del despacho exprés..." /></div>
                        <div class="form-group col-md-3 mb-0"><label class="small font-weight-bold text-muted">FECHA</label><input id="sdFechaEnvio" type="date" class="form-control" /></div>
                    </div>

                    <div class="bg-white p-3 rounded shadow-sm border mb-3">
                        <div class="row align-items-end">
                            <div class="form-group col-md-5 mb-0"><label class="small font-weight-bold text-muted">BUSCAR ARTÍCULO</label><input id="sdArt" class="form-control border-danger" placeholder="Código o nombre…" /><input type="hidden" id="sdIdArt" /></div>
                            <div class="form-group col-md-2 mb-0"><label class="small font-weight-bold text-muted">TALLA</label><select id="sdTalla" class="form-control"><option>UNI</option></select></div>
                            <div class="form-group col-md-2 mb-0"><label class="small font-weight-bold text-muted">SEXO</label><select id="sdSexo" class="form-control"><option>N</option><option>M</option><option>F</option></select></div>
                            <div class="form-group col-md-2 mb-0"><label class="small font-weight-bold text-muted">CANT</label><input id="sdCant" type="number" class="form-control text-center font-weight-bold" min="1" value="1" /></div>
                            <div class="form-group col-md-1 mb-0"><button id="btnAddSD" type="button" class="btn btn-dark btn-block shadow-sm"><i class="fas fa-plus"></i></button></div>
                        </div>
                        <div class="row mt-2">
                            <div class="form-group col-md-6 mb-0"><input id="sdLote" class="form-control form-control-sm bg-light" placeholder="Lote (Solo Medicinas)" /></div>
                            <div class="form-group col-md-6 mb-0"><input id="sdObs" class="form-control form-control-sm bg-light" placeholder="Nota por ítem (Opcional)" /></div>
                        </div>
                    </div>

                    <div class="table-responsive bg-white rounded border">
                        <table class="table table-sm mb-0" id="tblSalDet">
                            <thead class="bg-light text-muted"><tr><th class="pl-3">Código</th><th>Nombre</th><th>Variante</th><th class="text-center">Cant</th><th>Lote</th><th>Obs</th><th></th></tr></thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light px-4 mr-2" data-dismiss="modal">Cancelar</button>
                    <button class="btn btn-danger px-5 font-weight-bold shadow">Procesar Salida Inmediata</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="mdlTransfer" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg">
            <div class="modal-header bg-light border-0"><h5 class="modal-title font-weight-bold text-dark"><i class="fas fa-exchange-alt text-primary mr-2"></i> Traslado de Inventario</h5><button class="close" data-dismiss="modal">&times;</button></div>
            <form id="frmTransfer">
                <div class="modal-body p-4">
                    <div class="row mb-3">
