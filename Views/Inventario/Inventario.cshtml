                        <div class="form-group col-6"><label class="small font-weight-bold text-muted">BODEGA DESTINO</label><select id="trAlmDes" class="form-control font-weight-bold border-primary"></select></div>
                    </div>
                    <div class="form-group"><label class="small font-weight-bold text-muted">ARTÍCULO</label><input id="trArtTxt" class="form-control border-dark" placeholder="Buscar..." /><input type="hidden" id="trIdArt" /></div>
                    <div class="row">
