@* Views/Edificios/Permisos.cshtml *@
@{
    Layout = "~/Views/Shared/_mainLayout.cshtml";
}
<style>
    :root {
        --rojo: #dc3545;
        --rojo-osc: #c82333;
        --gris: #f7f7f9;
        --borde: #e5e7eb;
        --negro: #111827;
        --verde: #8bd3a3;
    }

    .card {
        border: 0;
        border-radius: 18px;
        box-shadow: 0 6px 18px rgba(0,0,0,.08);
    }

    .card-header-lite {
        background: linear-gradient(90deg,var(--rojo),#e35d6a);
        color: #fff;
        border-radius: 14px 14px 0 0;
        padding: .8rem 1rem;
    }

    .h-title {
        font-weight: 700;
        margin: 0;
    }

    .nav-pills .nav-link {
        border-radius: 999px;
    }

        .nav-pills .nav-link.active {
            background: var(--rojo);
        }

    #tblUsuarios thead th {
        background: var(--rojo);
        color: #fff;
        border: none;
        position: sticky;
        top: 0;
        z-index: 1;
    }

    #tblUsuarios tbody tr:hover {
        background: #fff8f8;
    }

    #tblEdificios thead th {
        background: #222;
        color: #fff;
        border: none;
        position: sticky;
        top: 0;
        z-index: 2;
    }

    #tblEdificios tbody tr:hover {
        background: #fff8f8;
    }

    .btn-rojo {
        background: var(--rojo);
        border-color: var(--rojo-osc);
        color: #fff;
    }

        .btn-rojo:hover {
            background: var(--rojo-osc);
            color: #fff;
        }

    #modalPermisos .modal-header {
        background: var(--rojo);
        color: #fff;
    }

    #modalEdificio .modal-header {
        background: #222;
        color: #fff;
    }

    .perm-row {
        border: 1px solid var(--borde);
        border-radius: 12px;
        padding: .5rem .75rem;
        margin-bottom: .5rem;
        background: #fff;
    }

        .perm-row.active {
            outline: 2px solid var(--verde);
        }

    .small-label {
        font-size: .78rem;
        color: #6b7280;
    }
</style>

<div class="card shadow mb-4">
    <div class="card-header-lite d-flex align-items-center justify-content-between">
        <h1 class="h5 h-title"><i class="fas fa-building mr-2"></i>Permisos de Geocerca</h1>
        <ul class="nav nav-pills">
            <li class="nav-item"><a class="nav-link active" data-toggle="tab" href="#tab-permisos"><i class="fas fa-user-shield mr-1"></i>Permisos</a></li>
            <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#tab-catalogo"><i class="fas fa-list mr-1"></i>Catálogo de Geocerca</a></li>
        </ul>
    </div>

    <div class="card-body tab-content">
        <!-- ====== TAB 1: Permisos por usuario ====== -->
        <div class="tab-pane fade show active" id="tab-permisos">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="form-inline">
                    <label class="mr-2 small-label">Gerencia:</label>
                    <select id="filtroGerencia" class="form-control form-control-sm" style="min-width:240px">
                        <option value="">Todas</option>
                    </select>
                </div>
                <button id="btnRefrescarEmp" class="btn btn-sm btn-outline-secondary"><i class="fas fa-sync-alt"></i> Refrescar</button>
            </div>

            <div class="table-responsive" style="max-height:58vh">
                <table id="tblUsuarios" class="table table-bordered table-hover table-sm" width="100%">
                    <thead>
                        <tr>
                            <th style="width:80px" class="text-center">ID</th>
                            <th>Nombre</th>
                            <th>Correo</th>
                            <th>Gerencia</th>
                            <th style="width:120px" class="text-center">Acción</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>

        <!-- ====== TAB 2: Catálogo ====== -->
        <div class="tab-pane fade" id="tab-catalogo">
            <div class="d-flex align-items-center justify-content-between mb-2">
              
                <button id="btnNuevoEdif" class="btn btn-sm btn-rojo"><i class="fas fa-plus"></i> Nuevo Geocerca</button>
            </div>

            <div class="table-responsive">
                <table id="tblEdificios" class="table table-bordered table-hover table-sm" width="100%">
                    <thead>
                        <tr>
                            <th style="width:70px" class="text-center">ID</th>
                            <th>Nombre</th>
                            <th>Dirección</th>
                            <th style="width:140px">Lat, Lon</th>
                            <th style="width:90px" class="text-center">Editar</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Permisos -->
<div class="modal fade" id="modalPermisos" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title"><i class="fas fa-user mr-1"></i>Permisos de <span id="lblUsuarioPerm"></span></h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="d-flex align-items-center mb-2">
                    <input id="txtBuscarPerm" class="form-control form-control-sm" type="search" placeholder="Buscar Geocerca...">
                    <small class="ml-2 small-label">Seleccionados: <b id="lblPermCount">0</b></small>
                    <button id="btnSelTodos" class="btn btn-sm btn-outline-secondary ml-auto">Seleccionar todos</button>
                    <button id="btnLimpiarSel" class="btn btn-sm btn-outline-secondary ml-2">Limpiar</button>
                </div>
                <div id="listaPermisos"></div>
            </div>
            <div class="modal-footer py-2">
                <button class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                <button id="btnGuardarPerm" class="btn btn-rojo" disabled><i class="fas fa-save mr-1"></i>Guardar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Edificio (Upsert) -->
<div class="modal fade" id="modalEdificio" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title"><i class="fas fa-pen mr-1"></i><span id="lblEdifTitulo">Nuevo Geocerca</span></h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="frmEdificio">
                    <input type="hidden" id="edif_id" />
                    <div class="form-group mb-2">
                        <label class="small-label">Nombre</label>
                        <input id="edif_nombre" class="form-control form-control-sm" required />
                    </div>
                    <div class="form-group mb-2">
                        <label class="small-label">Dirección</label>
                        <input id="edif_direccion" class="form-control form-control-sm" />
                    </div>
                    <div class="form-row">
                        <div class="form-group col-6">
                            <label class="small-label">Latitud</label>
                            <input id="edif_lat" class="form-control form-control-sm" type="number" step="0.000001" required />
                        </div>
                        <div class="form-group col-6">
                            <label class="small-label">Longitud</label>
                            <input id="edif_lon" class="form-control form-control-sm" type="number" step="0.000001" required />
                        </div>
                    </div>
                    <div class="form-row d-none">
                        <div class="form-group col-6">
                            <label class="small-label">Exactitud</label>
                            <input id="edif_exactitud" class="form-control form-control-sm" />
                        </div>
                        <div class="form-group col-6">
                            <label class="small-label">Fuente</label>
                            <input id="edif_fuente" class="form-control form-control-sm" />
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer py-2">
                <button class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <button id="btnGuardarEdif" class="btn btn-dark"><i class="fas fa-save mr-1"></i>Guardar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <script src="~/onlinejs/jquery-3.6.0.min.js"></script>
    <script src="~/onlinejs/bootstrap.bundle.min.js"></script>
    <script src="~/onlinejs/jquery.dataTables.min.js"></script>
    <script src="~/onlinejs/dataTables.bootstrap4.min.js"></script>
    <script src="~/onlinejs/loadingoverlay.min.js"></script>
    <script src="~/Content/plugin/sweetalert2/sweetalert2.all.js"></script>
    <script>
$(function(){
  let tablaEmp;
  let currentUserId = 0, currentCarnet = '';
  let snapshot = new Map(); // edificio_id -> {checked, es_default, radio_mts, vigencia_ini, vigencia_fin, activo}

  /* ====== Empleados (con Gerencia) ====== */
  function cargarGerencias(){
    $.getJSON('@Url.Action("GetGerencias","Edificios")', list=>{
      const $g = $('#filtroGerencia').empty().append('<option value="">Todas</option>');
      (list||[]).forEach(g => $g.append(`<option>${g}</option>`));
    });
  }
  cargarGerencias();

  tablaEmp = $('#tblUsuarios').DataTable({
    ajax:{ url:'@Url.Action("GetUsuariosActivos","Edificios")', dataSrc:'' },
    columns:[
      { data:'idhcm', className:'text-center' },
      { data:'nombre_completo' },
      { data:'correo' },
      { data:'OGERENCIA' },
      { data:null, orderable:false, className:'text-center',
        render:r=>`<button class="btn btn-sm btn-rojo btnPerm" data-id="${r.idhcm}" data-nombre="${r.nombre_completo}">
                      <i class="fas fa-edit"></i> Permisos
                    </button>` }
    ],
    dom:'<"row mb-2"<"col-sm-6"l><"col-sm-6 text-right"f>>t<"row mt-2"<"col-sm-5"i><"col-sm-7"p>>',
    pageLength: 10, lengthMenu: [[5,10,25,50],[5,10,25,50]],
    order:[[1,'asc']], language:{ url:'@Url.Content("~/Scripts/datatable.es-ES.json")' }, stripeClasses:[]
  });

  $('#filtroGerencia').on('change', function(){ tablaEmp.column(3).search(this.value).draw(); });
  $('#btnRefrescarEmp').on('click', ()=>tablaEmp.ajax.reload(null,false));

  /* ====== Catálogo de Geocerca (DataTable búsqueda global + 5/10) ====== */
  let tablaEdif = $('#tblEdificios').DataTable({
    ajax: { url: '@Url.Action("Edificios","Edificios")', dataSrc: '' },
    columns: [
      { data:'id', className:'text-center', width: 70 },
      { data:'nombre' },
      { data:'direccion', defaultContent:'' },
      { data:null, width:140, render:r=> `${r.latitud}, ${r.longitud}` },
      { data:null, orderable:false, className:'text-center', width:90,
        render:r=>`
         <button class="btn btn-sm btn-dark btnEditEdif"
                 data-id="${r.id}"
                 data-nombre="${r.nombre||''}"
                 data-dir="${r.direccion||''}"
                 data-lat="${r.latitud}"
                 data-lon="${r.longitud}"
                 data-ex="${r.exactitud||''}"
                 data-fu="${r.fuente||''}">
           <i class="fas fa-pen"></i>
         </button>`}
    ],
    pageLength: 5, lengthMenu: [[5,10,25,50],[5,10,25,50]],
    dom:'<"row mb-2"<"col-sm-6"l><"col-sm-6 text-right"f>>t<"row mt-2"<"col-sm-5"i><"col-sm-7"p>>',
    language:{ url:'@Url.Content("~/Scripts/datatable.es-ES.json")',
               searchPlaceholder:'Buscar en todas las columnas...' },
    order:[[1,'asc']], stripeClasses:[]
  });

  // Buscar con input propio (manteniendo buscador nativo)
 

  // Nuevo / Editar edificio
  $('#btnNuevoEdif').on('click', ()=>{
      $('#lblEdifTitulo').text('Nuevo Geocerca'); $('#frmEdificio')[0].reset(); $('#edif_id').val('');
    $('#modalEdificio').modal('show');
  });
  $('#tblEdificios').on('click','.btnEditEdif', function(){
      $('#lblEdifTitulo').text('Editar Geocerca');
    $('#edif_id').val($(this).data('id'));
    $('#edif_nombre').val($(this).data('nombre'));
    $('#edif_direccion').val($(this).data('dir'));
    $('#edif_lat').val($(this).data('lat'));
    $('#edif_lon').val($(this).data('lon'));
    $('#edif_exactitud').val($(this).data('ex'));
    $('#edif_fuente').val($(this).data('fu'));
    $('#modalEdificio').modal('show');
  });
  $('#btnGuardarEdif').on('click', function(){
    const dto = {
      id: $('#edif_id').val()||null,
      nombre: $('#edif_nombre').val(),
      direccion: $('#edif_direccion').val(),
      latitud: $('#edif_lat').val(),
      longitud: $('#edif_lon').val(),
      exactitud: $('#edif_exactitud').val(),
      fuente: $('#edif_fuente').val()
    };
    if(!dto.nombre || !dto.latitud || !dto.longitud) return Swal.fire('Validación','Nombre/Lat/Lon requeridos','warning');
    $.LoadingOverlay('show');
    $.post('@Url.Action("UpsertEdificio","Edificios")', dto, r=>{
      $.LoadingOverlay('hide');
      if(r.ok){ $('#modalEdificio').modal('hide'); tablaEdif.ajax.reload(null,false); Swal.fire('Éxito','Guardado','success'); }
      else Swal.fire('Error', r.msg || 'No guardó','error');
    }).fail(()=>{ $.LoadingOverlay('hide'); Swal.fire('Error','No guardó','error'); });
  });

  /* ====== Permisos por usuario ====== */
  function plantillaPermiso(edif){
    const snp = snapshot.get(edif.id) || { checked:false, es_default:false, radio_mts:150, vigencia_ini:'', vigencia_fin:'', activo:true };
    const ch = snp.checked ? 'checked' : '';
    const df = snp.es_default ? 'checked' : '';
    const dis = snp.checked ? '' : 'disabled';
    return `
      <div class="perm-row ${snp.checked?'active':''}" data-text="${(edif.nombre||'').toLowerCase()}" data-id="${edif.id}">
        <div class="custom-control custom-checkbox">
          <input type="checkbox" class="custom-control-input chk-sel" id="p_${edif.id}" ${ch}>
          <label class="custom-control-label" for="p_${edif.id}">
            <b>${edif.nombre}</b> <small class="text-muted">#${edif.id}</small>
            <div class="small text-muted">${edif.direccion||''}</div>
          </label>
        </div>
        <div class="mt-1 d-flex align-items-center flex-wrap">
          <div class="form-inline mr-3">
            <span class="small-label mr-1">Radio (m):</span>
            <input type="number" class="form-control form-control-sm inp-radio" value="${snp.radio_mts||''}" style="width:90px" ${dis} />
          </div>
          <div class="form-inline mr-3">
            <span class="small-label mr-1">Vigencia:</span>
            <input type="date" class="form-control form-control-sm inp-ini" value="${snp.vigencia_ini||''}" ${dis}/>
            <span class="mx-1">→</span>
            <input type="date" class="form-control form-control-sm inp-fin" value="${snp.vigencia_fin||''}" ${dis}/>
          </div>
          <div class="form-inline mr-3">
            <div class="custom-control custom-radio">
              <input type="radio" name="defaultEdif" class="custom-control-input rad-def" id="d_${edif.id}" ${df} ${dis}>
              <label class="custom-control-label" for="d_${edif.id}">Default</label>
            </div>
          </div>
          <div class="form-inline">
            <div class="custom-control custom-switch">
              <input type="checkbox" class="custom-control-input sw-act" id="a_${edif.id}" ${snp.activo?'checked':''} ${dis}>
              <label class="custom-control-label" for="a_${edif.id}">Activo</label>
            </div>
          </div>
        </div>
      </div>`;
  }

  function contarSeleccionados(){
    let c=0; snapshot.forEach(v=>{ if(v.checked) c++; });
    $('#lblPermCount').text(c);
    $('#btnGuardarPerm').prop('disabled', c===0);
  }

  function pintarPermisos(catalogo){
    const $list = $('#listaPermisos').empty();
    (catalogo||[]).forEach(ed=> $list.append(plantillaPermiso(ed)));
    contarSeleccionados();
  }

  function cargarPermisosUsuario(userId, nombre){
    currentUserId = userId;
    $('#lblUsuarioPerm').text(`${nombre} (ID: ${String(userId).padStart(6,'0')})`);
    $('#txtBuscarPerm').val('');
    snapshot.clear();

    $.LoadingOverlay('show');
    $.when(
      $.getJSON('@Url.Action("Edificios","Edificios")'),
      $.getJSON('@Url.Action("PermisosUsuario","Edificios")', { userId })
    ).done((resEdif, resPerm)=>{
      const catalogo = resEdif[0]||[];
      const data = resPerm[0]||{};
      currentCarnet = data.carnet||'';

      (catalogo||[]).forEach(ed=>{
        snapshot.set(ed.id, { checked:false, es_default:false, radio_mts:150, vigencia_ini:'', vigencia_fin:'', activo:true });
      });
      (data.permisos||[]).forEach(p=>{
        if(snapshot.has(p.edificio_id)){
          snapshot.set(p.edificio_id, {
            checked: true,
            es_default: !!p.es_default,
            radio_mts: p.radio_mts || 150,
            vigencia_ini: p.vigencia_ini ? String(p.vigencia_ini).substr(0,10) : '',
            vigencia_fin: p.vigencia_fin ? String(p.vigencia_fin).substr(0,10) : '',
            activo: p.Activo !== false
          });
        }
      });

      pintarPermisos(catalogo);
      $.LoadingOverlay('hide');
      $('#modalPermisos').modal('show');
    }).fail(()=>{
      $.LoadingOverlay('hide');
      Swal.fire('Error','No se pudo cargar','error');
    });
  }

  // Abrir modal permisos
  $('#tblUsuarios tbody').on('click','.btnPerm', function(){
    const id = $(this).data('id'), nombre = $(this).data('nombre');
    cargarPermisosUsuario(id, nombre);
  });

  // Selección fila
  $('#listaPermisos').on('change','.chk-sel', function(){
    const $row = $(this).closest('.perm-row'); const id = parseInt($row.data('id'));
    const sel = $(this).is(':checked');
    const st = snapshot.get(id) || {};
    st.checked = sel;
    if(sel){ $row.addClass('active'); $row.find('input:not(.chk-sel)').prop('disabled', false); }
    else{
      $row.removeClass('active');
      $row.find('.rad-def').prop('checked', false);
      $row.find('input:not(.chk-sel)').prop('disabled', true);
      st.es_default = false;
    }
    snapshot.set(id, st); contarSeleccionados();
  });

  // Default único
  $('#listaPermisos').on('change','.rad-def', function(){
    if(!$(this).is(':checked')) return;
    const idSel = parseInt($(this).closest('.perm-row').data('id'));
    $('#listaPermisos .rad-def').not(this).prop('checked', false);
    snapshot.forEach((v,k)=>{ v.es_default = (k===idSel) && v.checked; snapshot.set(k,v); });
  });

  // Inputs detalle
  $('#listaPermisos').on('input change','.inp-radio,.inp-ini,.inp-fin,.sw-act', function(){
    const $row = $(this).closest('.perm-row'); const id = parseInt($row.data('id'));
    const st = snapshot.get(id) || {};
    st.radio_mts = parseInt($row.find('.inp-radio').val()||'150');
    st.vigencia_ini = $row.find('.inp-ini').val()||'';
    st.vigencia_fin = $row.find('.inp-fin').val()||'';
    st.activo = $row.find('.sw-act').is(':checked');
    snapshot.set(id, st);
  });

  // Buscar en permisos (cliente)
  $('#txtBuscarPerm').on('input', function(){
    const q = (this.value||'').toLowerCase().trim();
    $('#listaPermisos .perm-row').each(function(){
      const m = String($(this).data('text')||'').includes(q);
      $(this).toggleClass('d-none', !m);
    });
  });

  // Seleccionar/Limpiar todos
  $('#btnSelTodos').on('click', ()=>$('#listaPermisos .chk-sel:not(:checked)').prop('checked', true).trigger('change'));
  $('#btnLimpiarSel').on('click', ()=>$('#listaPermisos .chk-sel:checked').prop('checked', false).trigger('change'));

  // Guardar permisos
  $('#btnGuardarPerm').on('click', function(){
    const data = [];
    snapshot.forEach((v,k)=>{
      if(v.checked){
        data.push({
          edificio_id: k,
          es_default: !!v.es_default,
          radio_mts: v.radio_mts || 150,
          vigencia_ini: v.vigencia_ini || null,
          vigencia_fin: v.vigencia_fin || null,
          activo: v.activo !== false
        });
      }
    });
    if(!data.length) return Swal.fire('Validación','Seleccione al menos un edificio','warning');

    $.LoadingOverlay('show');
    $.ajax({
      url:'@Url.Action("GuardarPermisos","Edificios")',
      method:'POST',
      data: JSON.stringify({ userId: currentUserId, data: data }),
      contentType:'application/json; charset=utf-8',
      success: r=>{
        $.LoadingOverlay('hide');
        if(r.ok){ $('#modalPermisos').modal('hide'); Swal.fire('Éxito','Permisos actualizados','success'); }
        else Swal.fire('Error', r.msg||'No guardó','error');
      },
      error: ()=>{ $.LoadingOverlay('hide'); Swal.fire('Error','No guardó','error'); }
    });
  });

});
    </script>
}
