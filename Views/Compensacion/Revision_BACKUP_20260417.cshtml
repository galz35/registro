@{
    ViewBag.Title = "Certificacion de Plantillas RRHH";
}
<meta charset="utf-8" />

<style>
    body { background-color: #f8f9fa; }
    .bg-claro { background: linear-gradient(135deg, #B71C1C 0%, #D32F2F 100%) !important; color: #fff !important; }
    .btn-claro { background: linear-gradient(135deg, #B71C1C 0%, #D32F2F 100%); color: #fff; border: none; transition: transform 0.2s; }
    .btn-claro:hover { transform: translateY(-2px); box-shadow: 0 4px 10px rgba(183, 28, 28, 0.3); color: #fff; }
    .card { border-radius: 12px; border: none; box-shadow: 0 8px 16px rgba(0,0,0,0.05); }
    .card-header { border-radius: 8px 8px 0 0 !important; }
    .table-hover tbody tr:hover { background-color: #ffe6e6 !important; }
    .btn-rounded { border-radius: 20px; }
    
    .estado-Enviado { color: #0056b3; font-weight: bold; }
    .estado-Aprobado { color: #28a745; font-weight: bold; }
    .estado-Devuelto { color: #dc3545; font-weight: bold; }
    .estado-Borrador { color: #6c757d; font-style: italic; }

    /* Estilo para los badge de cambios y las celdas comparativas */
    .dif-badge { font-size: 10px; margin-right: 5px; vertical-align: top; }
    
    .card-config { border-left: 5px solid #fcb913; background: #fff; }
    .nav-pills .nav-link.active { background-color: #B71C1C; }
    .nav-pills .nav-link { color: #B71C1C; font-weight: bold; border: 1px solid #B71C1C; margin-right: 5px; }
    
    /* [NUEVO] Resalta los campos modificados */
    .changed {
      background-color: #ffe6e6 !important;
      font-weight: bold;
      color: #B71C1C;
    }
</style>

<!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="continer mt-4">
    <div class="d-flex justify-content-between align-items-center mt-3 mb-2">
        <h2 class="m-0 text-dark font-weight-bold" style="color:#B71C1C !important;">
            <i class="fas fa-tasks"></i> Certificacion y Gestion (RRHH)
        </h2>
        <div class="form-inline">
            <label class="mr-2 font-weight-bold text-muted">Periodo:</label>
            <select id="ddlPeriodo" class="form-control form-control-sm border-0 shadow-sm" onchange="actualizarVista()">
                <option value="">Cargando...</option>
            </select>
            <button class="btn btn-sm btn-claro btn-rounded shadow-sm ml-2" onclick="actualizarVista()">
                <i class="fas fa-sync-alt"></i>
            </button>
            <button class="btn btn-sm btn-outline-dark btn-rounded shadow-sm ml-2" onclick="abrirModalExclusiones()">
                <i class="fas fa-ban"></i> Lista de Exclusiones
            </button>
            <a href="@Url.Action("GestionMaestra", "Compensacion")" class="btn btn-sm btn-danger btn-rounded shadow-sm ml-2">
                <i class="fas fa-users-cog"></i> Gestion Maestra
            </a>
        </div>
    </div>

    <!-- Indicadores de Avance (KPIs) -->
    <div class="row mb-3 animate__animated animate__fadeIn">
        <div class="col-md-4">
            <div class="card shadow-sm border-left-claro bg-white p-3">
                <h6 class="text-muted small font-weight-bold text-uppercase mb-1">Avance Global Jefes</h6>
                <div class="row no-gutters align-items-center">
                    <div class="col-auto h5 mb-0 mr-3 font-weight-bold" id="txtKPIPerc">0%</div>
                    <div class="col">
                        <div class="progress progress-sm"><div id="barKPI" class="progress-bar bg-claro" style="width:0%"></div></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-left-claro bg-white p-3 text-center">
                <h6 class="text-muted small font-weight-bold text-uppercase mb-1">Colaboradores Procesados</h6>
                <div class="h5 mb-0 font-weight-bold" id="txtKPIPlazas">0</div>
            </div>
        </div>
        <div class="col-md-4 text-center">
            <div class="card shadow-sm border-left-claro bg-light p-3">
                <h6 class="text-muted small font-weight-bold text-uppercase mb-1">Periodo Activo</h6>
                <div class="h5 mb-0 font-weight-bold text-claro" id="txtKPIPeriodo">...</div>
            </div>
        </div>
    </div>

    <style>
        .border-left-claro { border-left: 5px solid #B71C1C !important; }
        .text-claro { color: #B71C1C; }
    </style>

    <!-- Seccon de Configuracon de Notificaciones -->
    <div class="card mb-4 shadow-sm card-config">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-md-3">
                    <label class="small font-weight-bold text-muted mb-1"><i class="fas fa-calendar-alt"></i> Fecha Limite de Entrega:</label>
                    <input type="date" id="txtFechaLimite" class="form-control form-control-sm">
                </div>
                <div class="col-md-5">
                    <label class="small font-weight-bold text-muted mb-1"><i class="fas fa-envelope"></i> Tipo de Notificacion a Enviar:</label>
                    <ul class="nav nav-pills nav-fill" id="pills-tab" role="tablist">
                      <li class="nav-item">
                        <a class="nav-link active py-1" id="tab-1" data-toggle="pill" href="#p-comis" role="tab" onclick="setTipo(1)">Comisiones</a>
                      </li>
                      <li class="nav-item">
                        <a class="nav-link py-1" id="tab-2" data-toggle="pill" href="#p-perso" role="tab" onclick="setTipo(2)">Personal</a>
                      </li>
                      <li class="nav-item">
                        <a class="nav-link py-1" id="tab-3" data-toggle="pill" href="#p-seguimiento" role="tab" onclick="setTipo(3)"><i class="fas fa-chart-line"></i> Bajas e Ingresos</a>
                      </li>
                    </ul>
                </div>
                <div class="col-md-4 text-right">
                    <button class="btn btn-sm btn-outline-secondary btn-rounded mt-3" onclick="guardarConfig()">
                        <i class="fas fa-save"></i> Guardar Plazo
                    </button>
                    <button class="btn btn-sm btn-primary btn-rounded shadow-sm mt-3 ml-2" id="btnMassMil" onclick="notificarMasivo()" disabled>
                        <i class="fas fa-paper-plane"></i> Notificar a Validadores Pendientes
                    </button>
                </div>
            </div>
        </div>
    </div>

                <table class="table table-bordered table-hover mb-0" id="tbResumen">
                    <thead class="bg-claro text-white text-center">
                        <tr>
                            <th>Gerencia / Area</th>
                            <th>Validador Designado</th>
                            <th>Estado Actual</th>
                            <th>Fecha Cierre</th>
                            <th>Acciones Especialista</th>
                        </tr>
                    </thead>
                    <tbody id="tbCuerpo"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Detalle -->
<div class="modal fade" id="modalDetalle" style="z-index: 1050;">
    <div class="modal-dialog" style="max-width: 95%;">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-claro text-white">
                <h5 class="modal-title"><i class="fas fa-users"></i> Detalle de Empleados - <span id="lblGerente"></span></h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body p-0 table-responsive" style="max-height: 70vh; overflow-y: auto;">
                <table class="table table-sm table-bordered table-hover mb-0" style="font-size: 0.9rem;">
                    <thead class="bg-light text-center" style="position: sticky; top: 0; z-index: 10; font-size: 11px;">
                        <tr>
                            <th rowspan="2" class="align-middle">Empleado</th>
                            <th colspan="2">Cargo / Puesto</th>
                            <th colspan="2">Edificio / Ubicacion</th>
                            <th colspan="2">Comisiona</th>
                            <th colspan="2">Observaciones</th>
                        </tr>
                        <tr>
                            <th class="bg-secondary text-white">SighoO</th>
                            <th class="bg-claro text-white">Reportado</th>
                            <th class="bg-secondary text-white">SighoO</th>
                            <th class="bg-claro text-white">Reportado</th>
                            <th class="bg-secondary text-white">Ant.</th>
                            <th class="bg-claro text-white">Act.</th>
                            <th class="bg-secondary text-white">Ant.</th>
                            <th class="bg-claro text-white">Act.</th>
                        </tr>
                    </thead>
                    <tbody id="tbDetalles"></tbody>
                </table>
            </div>
            <div class="modal-footer bg-light" id="footerAcciones"></div>
        </div>
    </div>
</div>

<!-- Modal Historial -->
<div class="modal fade" id="modalHistorial" style="z-index: 1060;">
    <div class="modal-dialog modal-lg">
        <div class="modal-content shadow-lg">
            <div class="modal-header text-white" style="background-color: #343a40;">
                <h5 class="modal-title"><i class="fas fa-history"></i> Historial Auditable: <span id="lblHistorialEmp"></span></h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body p-0 table-responsive">
                <table class="table table-sm table-striped mb-0">
                    <thead class="bg-light"><tr><th>Fecha</th><th>Usuario</th><th>Campo Modificado</th><th>Valor Anterior</th><th>Valor Nuevo</th></tr></thead>
                    <tbody id="tbHistorial"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Exclusiones (Blacklist) -->
<div class="modal fade" id="modalExclusiones">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title"><i class="fas fa-ban"></i> Gestion de Exclusiones (Depuracion)</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info py-2" style="font-size:12px;">
                    <i class="fas fa-info-circle"></i> Las gerencias o carnet agregados aqui? <b>no recibiran notificaciones</b> y no apareceran en la lista de revison.
                </div>
                <div class="form-row align-items-end mb-3">
                    <div class="col-md-3">
                        <label class="small font-weight-bold">Tipo:</label>
                        <select id="ddlTipoEx" class="form-control form-control-sm">
                            <option value="OGERENCIA">Gerencia</option>
                            <option value="CARNET">Carnet Empleado</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="small font-weight-bold">Valor (Exacto):</label>
                        <input type="text" id="txtValorEx" class="form-control form-control-sm" placeholder="Ej: NI GERENCIA DE RRHH">
                    </div>
                    <div class="col-md-3">
                        <label class="small font-weight-bold">Motivo:</label>
                        <input type="text" id="txtMotivoEx" class="form-control form-control-sm" placeholder="Opcional">
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-sm btn-dark btn-block" onclick="guardarExclusion()"><i class="fas fa-plus"></i></button>
                    </div>
                </div>
                <div class="table-responsive" style="max-height: 300px;">
                    <table class="table table-sm table-striped">
                        <thead class="bg-light"><tr><th>Tipo</th><th>Valor</th><th>Motivo</th><th></th></tr></thead>
                        <tbody id="tbExclusiones"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
<script>
    let TIPO_ACTUAL = 1; // 1: Comisiones, 2: Personal

    $(document).ready(function() {
        $.get('/Compensacion/CargarMiPlantilla', function(res) {
            if(res.success && res.periodo) {
                $('#ddlPeriodo').html(`<option value="${res.periodo.PeriodoID}">${res.periodo.NombrePeriodo}</option>`);
                actualizarVista();
            }
        });
    });

    function setTipo(t) {
        TIPO_ACTUAL = t;
        $('#lblTipoActual').text(t === 1 ? 'Comisiones' : t === 2 ? 'Personal' : 'Seguimiento de Bajas e Ingresos');
        actualizarVista();
    }

    function actualizarVista() {
        const idPer = $('#ddlPeriodo').val();
        if(!idPer) return;

        // Cargar KPIs del Periodo
        $.get('@Url.Action("ObtenerKPI", "Compensacion")?periodoId=' + idPer, function(res) {
            if(res.success) {
                const k = res.kpi;
                const perc = k.TotalJefes > 0 ? Math.round((k.Terminados / k.TotalJefes) * 100) : 0;
                $('#txtKPIPerc').text(perc + '%');
                $('#barKPI').css('width', perc + '%');
                $('#txtKPIPlazas').text(k.UniversoTotal);
                $('#txtKPIPeriodo').text($('#ddlPeriodo option:selected').text());
            }
        });

        if (TIPO_ACTUAL === 3) {
            $('#lblTipoActual').text('Seguimiento de Bajas e Ingresos');
            $('#tbResumen thead').html('<tr class="bg-claro text-white text-center"><th>Tipo</th><th>Colaborador</th><th>Fecha Efec.</th><th>Resultado / Motivo</th><th>Evaluador</th><th>Fecha Eval</th></tr>');
            cargarHistorial();
            return;
        }

        $('#tbResumen thead').html('<tr class="bg-claro text-white text-center"><th>Gerencia / Area</th><th>Jefe Responsable</th><th>Estado Actual</th><th>Fecha Cierre</th><th>Acciones Especialista</th></tr>');
        
        // Cargar lista de plantillas filtrada por tipo
        $.get('@Url.Action("ObtenerTodasPlantillas", "Compensacion")?periodoId=' + idPer + '&tipoPlantilla=' + TIPO_ACTUAL, function(res) {
            let html = '';
            res.data.forEach(p => {
                const fEnvio = p.FechaEnvio ? new Date(parseInt(p.FechaEnvio.substr(6))).toLocaleDateString('es-ES') : '-';
                const btnMilClass = p.Estado === 'Borrador' ? 'btn-info' : 'btn-outline-info';
                
                html += `<tr>
                    <td class="align-middle small">${p.OGERENCIA || 'No Asignada'}</td>
                    <td class="align-middle"><strong>${p.NombreGerente}</strong><br><small class="text-muted">${p.CarnetGerente}</small></td>
                    <td class="align-middle text-center"><span class="estado-${p.Estado}"><i class="fas fa-circle px-1" style="font-size:10px;"></i> ${p.Estado}</span></td>
                    <td class="align-middle text-center">${fEnvio}</td>
                    <td class="text-center align-middle">
                        <button class="btn btn-sm btn-outline-secondary btn-rounded shadow-sm mr-1" onclick="verDetalle(${p.PlantilliD}, '${p.NombreGerente}', '${p.Estado}')">
                            <i class="fas fa-eye"></i> Revisar
                        </button>
                        <button class="btn btn-sm btn-outline-success btn-rounded shadow-sm mr-1" onclick="exportarExcel(${p.PlantilliD})" title="Descargar Excel">
                            <i class="fas fa-file-excel"></i>
                        </button>
                        <button class="btn btn-sm ${btnMilClass} btn-rounded shadow-sm" onclick="notificarJefe('${p.CarnetGerente}')" title="Notificar por Correo">
                            <i class="fas fa-envelope"></i>
                        </button>
                    </td>
                </tr>`;
            });
            $('#tbCuerpo').html(html || '<tr><td colspan="5" class="text-center p-4">No se han generado plantillas para este tipo i?n.</td></tr>');
            
            // Habilitar boti?n masivo si hay borradores
            const hayPendientes = res.data.some(x => x.Estado === 'Borrador');
            $('#btnMassMil').prop('disabled', !hayPendientes);
        });

        // Cargar configuracon de fecha li?mite (se puede optimizar consultando metadata del periodo)
        $.get('@Url.Action("Index", "Compensacion")', function(r) {
             // Aqui? se podri?a cargar la fecha desde el ViewBag si existiera en la respuesta JSON
        });
    }

    function notificarJefe(carnet) {
        const idPer = $('#ddlPeriodo').val();
        Swal.fire({
            title: 'Enviar notificacion?',
            text: "Se enviara un correo con la tabla de su personal al validador designado.",
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#B71C1C',
            confirmButtonText: 'Si, enviar ahora'
        }).then((result) => {
            if (result.isConfirmed) {
                Swal.showLoading();
                $.post('@Url.Action("NotificarJefe", "Compensacion")', { periodoId: idPer, carnetJefe: carnet, tipoPlantilla: TIPO_ACTUAL }, function(res) {
                    if(res.success) {
                        Swal.fire('Enviado', res.message, 'success');
                        actualizarVista();
                    } else {
                        Swal.fire('Error', res.message, 'error');
                    }
                });
            }
        });
    }

    function guardarConfig() {
        const idPer = $('#ddlPeriodo').val();
        const f = $('#txtFechaLimite').val();
        if(!f) { alert('Seleccione una fecha'); return; }

        $.post('@Url.Action("GuardarConfiguracionPeriodo", "Compensacion")', { periodoId: idPer, fechaLimite: f, cuerpo: '' }, function(res) {
            if(res.success) {
                Swal.fire('Guardado', 'Se ha configurado la fecha limite para este periodo.', 'success');
            }
        });
    }

    function notificarMasivo() {
        const idPer = $('#ddlPeriodo').val();
        Swal.fire({
            title: 'Notificar a todos los pendientes?',
            text: `Se enviara un correo a todos los validadores que aun tienen su Certificacion en 'Borrador' para el tipo ${TIPO_ACTUAL === 1 ? 'Comisiones' : 'Personal'}.`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#B71C1C',
            confirmButtonText: 'Si, enviar masivamente'
        }).then((result) => {
            if (result.isConfirmed) {
                Swal.showLoading();
                $.post('@Url.Action("NotificarMasivo", "Compensacion")', { periodoId: idPer, tipoPlantilla: TIPO_ACTUAL }, function(res) {
                    if(res.success) {
                        Swal.fire('Masivo Completado', res.message, 'success');
                        actualizarVista();
                    } else {
                        Swal.fire('Error', res.message, 'error');
                    }
                });
            }
        });
    }

    function abrirModalExclusiones() {
        cargarExclusiones();
        $('#modalExclusiones').modal('show');
    }

    function cargarExclusiones() {
        $.get('@Url.Action("ObtenerExclusiones", "Compensacion")', function(res) {
            let html = '';
            res.data.forEach(x => {
                html += `<tr>
                    <td class="small">${x.TipoExclusion}</td>
                    <td><strong>${x.ValorExclusion}</strong></td>
                    <td class="small text-muted">${x.Motivo || '-'}</td>
                    <td class="text-right"><button class="btn btn-sm btn-outline-danger border-0" onclick="quitarExclusion(${x.ExclusionID})"><i class="fas fa-trash-alt"></i></button></td>
                </tr>`;
            });
            $('#tbExclusiones').html(html || '<tr><td colspan="4" class="text-center text-muted">No hay exclusiones activas.</td></tr>');
        });
    }

    function guardarExclusion() {
        const t = $('#ddlTipoEx').val();
        const v = $('#txtValorEx').val();
        const m = $('#txtMotivoEx').val();
        if(!v) return;

        $.post('@Url.Action("AgregarExclusion", "Compensacion")', { tipo: t, valor: v, motivo: m }, function(res) {
            if(res.success) {
                $('#txtValorEx').val('');
                $('#txtMotivoEx').val('');
                cargarExclusiones();
                actualizarVista();
            }
        });
    }

    function quitarExclusion(id) {
        $.post('@Url.Action("QuitarExclusion", "Compensacion")', { exclusionId: id }, function(res) {
            if(res.success) { 
                cargarExclusiones();
                actualizarVista();
            }
        });
    }

    function exportarExcel(id) {
        window.location.href = '@Url.Action("ExportarExcelFinal", "Compensacion")?plantillid=' + id;
    }

    function cargarHistorial() {
        $.get('@Url.Action("ObtenerHistorialEvaluaciones", "Compensacion")', function(res) {
            let html = '';
            res.data.forEach(h => {
                const fEval = new Date(parseInt(h.FechaEvaluacion.substr(6))).toLocaleDateString();
                const fEfec = new Date(parseInt(h.FechaBaja || h.Fechingreso)).toLocaleDateString();
                const badge = h.Tipo === 'BAJA' ? 'badge-danger' : 'badge-primary';
                html += `<tr>
                    <td><span class="badge ${badge}">${h.Tipo}</span></td>
                    <td>${h.NombreEmpleado}<br><small class="text-muted">${h.CarnetEmpleado}</small></td>
                    <td>${fEfec}</td>
                    <td>${h.MotivoBaja || h.ResultadoFinal}</td>
                    <td>${h.CarnetEvaluador}</td>
                    <td>${fEval}</td>
                </tr>`;
            });
            $('#tbodyHistorial').html(html);
        });
    }

    function notificarMasivoBajas() {
        Swal.fire({ title: 'Enviar recordatorios?', text: 'Se notificara a los jefes con evaluaciones de baja pendientes.', icon: 'question', showCancelButton: true }).then(r => {
            if(r.isConfirmed) {
                $.post('@Url.Action("NotificarPendientesBaja", "Compensacion")', r => Swal.fire('Enviado', r.message, 'success'));
            }
        });
    }

    function notificarMasivoIngresos() {
        Swal.fire({ title: 'Enviar recordatorios?', text: 'Se notificara a los jefes con ingresos de periodo de prueba pendientes.', icon: 'question', showCancelButton: true }).then(r => {
            if(r.isConfirmed) {
                $.post('@Url.Action("NotificarPendientesIngreso", "Compensacion")', r => Swal.fire('Enviado', r.message, 'success'));
            }
        });
    }

    function sincronizarSighoo(id) {
        Swal.fire({
            title: 'Sincronizar con SighoO1?',
            text: "Esta accion actualizara directamente los cargos y ubicaciones en la base de datos oficial de empleados. Es irreversible!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            confirmButtonText: 'Si, sincronizar ahora'
        }).then((result) => {
            if (result.isConfirmed) {
                Swal.showLoading();
                $.post('@Url.Action("AplicarCambiosSighoo", "Compensacion")', { plantillid: id }, function(res) {
                    if(res.success) {
                        Swal.fire('Sincronizado', res.message, 'success');
                    } else {
                        Swal.fire('Error', res.message, 'error');
                    }
                });
            }
        });
    }

    function verDetalle(id, nom, est) {
        $('#lblGerente').text(nom);
        $.get('@Url.Action("ObtenerDetallePlantilla", "Compensacion")?plantillid=' + id, res => {
            let html = '';
            res.data.forEach(d => {
                const cCargo = (d.Cargo_Reportado && d.Cargo_Reportado !== d.Cargo_SIGHO) ? 'changed' : '';
                const cUbi = (d.Ubicacion_Reportada && d.Ubicacion_Reportada !== d.Ubicacion_SIGHO) ? 'changed' : '';
                const cCom = (d.Comisiona && d.Comisiona !== (d.Comisiona_Original || d.Comisiona)) ? 'changed' : ''; // Fallback si no hay original
                
                html += `<tr>
                    <td class="align-middle"><strong>${d.NombreCompleto}</strong><br><small class="text-muted">${d.CarnetEmpleado}</small></td>
                    
                    <td class="align-middle small text-muted">${d.Cargo_SIGHO || '-'}</td>
                    <td class="align-middle ${cCargo}">${d.Cargo_Reportado || d.Cargo_SIGHO || '-'}</td>
                    
                    <td class="align-middle small text-muted">${d.Ubicacion_SIGHO || '-'}</td>
                    <td class="align-middle ${cUbi}">${d.Ubicacion_Reportada || d.Ubicacion_SIGHO || '-'}</td>
                    
                    <td class="text-center align-middle small text-muted">${d.Comisiona_Original || 'N'}</td>
                    <td class="text-center align-middle ${cCom}"><b>${d.Comisiona}</b></td>
                    
                    <td class="align-middle small text-muted">-</td>
                    <td class="align-middle">${d.Observacion || '-'}</td>
                </tr>`;
            });
            });
            $('#tbDetalles').html(html);

            let footer = '';
            if(est === 'Enviado') {
                footer = `
                    <div class="input-group">
                        <input type="text" id="txtDev" class="form-control form-control-sm" placeholder="Motivo en caso de devolver...">
                        <div class="input-group-append">
                            <button class="btn btn-danger btn-sm" onclick="devolver(${id})"><i class="fas fa-undo"></i> Devolver al Gerente</button>
                        </div>
                    </div>
                    <button class="btn btn-success btn-sm ml-2 shadow-sm font-weight-bold" onclick="aprobar(${id})"><i class="fas fa-check"></i> Aprobar Plantilla Definitiva</button>`;
            } else if (est === 'Aprobado') {
                footer = `
                    <div class="alert alert-success d-inline-block py-1 px-2 m-0 mr-auto small">
                        <i class="fas fa-check-double"></i> Plantilla Aprobada
                    </div>
                    <button class="btn btn-primary btn-sm shadow-sm font-weight-bold" onclick="sincronizarSighoo(${id})">
                        <i class="fas fa-sync"></i> Sincronizar con SighoO1
                    </button>
                    <button class="btn btn-secondary btn-sm ml-2" data-dismiss="modal">Cerrar</button>`;
            } else {
                footer = `<button class="btn btn-secondary btn-sm" data-dismiss="modal">Cerrar</button>`;
            }
            $('#footerAcciones').html(footer);
            $('#modalDetalle').modal('show');
        });
    }

    function verHistorial(detalleId, nombreEmp) {
        $('#lblHistorialEmp').text(nombreEmp);
        $.get('@Url.Action("ObtenerAuditoria", "Compensacion")?detalleId=' + detalleId, res => {
            let html = '';
            if(res.data.length === 0){
                html = '<tr><td colspan="5" class="text-center text-muted p-3">No hay registro de modificaciones o auditoria para este empleado.</td></tr>';
            } else {
                res.data.forEach(d => {
                    const fecha = new Date(parseInt(d.FechaCambio.substr(6))).toLocaleString('es-ES');
                    html += `<tr>
                        <td class="align-middle">${fecha}</td>
                        <td class="align-middle"><small>${d.NombreGeneraCambio || d.CarnetUsuario}</small></td>
                        <td class="align-middle text-primary"><b>${d.Campo}</b></td>
                        <td class="text-danger align-middle">${d.ValorAnterior || '-'}</td>
                        <td class="text-success align-middle font-weight-bold">${d.ValorNuevo || '-'}</td>
                    </tr>`;
                });
            }
            $('#tbHistorial').html(html);
            $('#modalHistorial').modal('show');
        });
    }

    function aprobar(id){
        if(confirm('Aprobar esta plantilla? Quedara cerrada y Lista para Pago.')){
            $.post('@Url.Action("AprobarPlantilla", "Compensacion")', { plantillid: id }, r => {
                if(r.success) { $('#modalDetalle').modal('hide'); cargarPlantillas($('#ddlPeriodo').val()); }
            });
        }
    }

    function devolver(id){
        const m = $('#txtDev').val();
        if(!m) { alert('Debe ingresar un motivo de devolucion'); return; }
        $.post('@Url.Action("DevolverPlantilla", "Compensacion")', { plantillid: id, comentario: m }, r => {
            if(r.success) { $('#modalDetalle').modal('hide'); cargarPlantillas($('#ddlPeriodo').val()); }
        });
    }

    function cargarBitacora() {
        const list = $('#listBitacora');
        list.html('<li class="list-group-item text-center"><div class="spinner-border spinner-border-sm text-claro"></div> Cargando historial...</li>');

        $.get('@Url.Action("ObtenerBitacora", "Compensacion")', function(res) {
            if (res.success && res.logs.length > 0) {
                let html = '';
                res.logs.forEach(log => {
                    const fecha = new Date(parseInt(log.FechaCambio.substr(6))).toLocaleString();
                    html += `<li class="list-group-item">
                        <div class="d-flex w-100 justify-content-between">
                            <h6 class="mb-1 text-dark font-weight-bold"><i class="fas fa-edit text-muted"></i> ${log.Empleado}</h6>
                            <small class="text-muted"><i class="far fa-clock"></i> ${fecha}</small>
                        </div>
                        <p class="mb-1 small">
                            Cambo <strong>${log.Campo}</strong>: de <span class="badge badge-light strike">${log.ValorAnterior || '-'}</span> 
                            a <span class="badge badge-success shadow-sm">${log.ValorNuevo}</span>
                        </p>
                        <small class="text-muted"><i class="fas fa-user-tag"></i> Responsable: ${log.CarnetUsuario}</small>
                    </li>`;
                });
                list.html(html);
            } else {
                list.html('<li class="list-group-item text-center text-muted">No hay actividad reciente registrada.</li>');
            }
        });
    }
</script>
}



