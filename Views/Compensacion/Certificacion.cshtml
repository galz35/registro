    function abrirModalCatalogoRapido() {
        $('#txtNombreCatalogo').val('');
        $('#selTipoCatalogo').val('puesto');
        $('#modalCatalogoRapido').modal('show');
    }

    function guardarCatalogoRapido() {
        var tipo = $('#selTipoCatalogo').val();
        var nombre = $('#txtNombreCatalogo').val().trim();

        if (nombre === '') {
            Swal.fire('Atencion', 'El nombre es obligatorio.', 'warning');
            return;
        }

        var url = tipo === 'puesto' 
            ? '@Url.Action("AgregarCargoRapido", "Compensacion")' 
            : '@Url.Action("AgregarDepartamentoRapido", "Compensacion")';

        Swal.fire({
            title: 'Guardando...',
            allowOutsideClick: false,
            didOpen: () => { Swal.showLoading(); }
        });

        $.ajax({
            url: url,
            type: 'POST',
            data: { nombre: nombre },
            success: function(res) {
                Swal.close();
                if (res.success) {
                    Swal.fire('Exito', res.message, 'success');
                    $('#modalCatalogoRapido').modal('hide');

                    // Agregar al datalist respectivo
                    if (tipo === 'puesto') {
                        if ($('#dlCargos').length > 0) {
                            $('#dlCargos').append('<option value="' + res.nombre + '">');
                        }
                    } else {
                        if ($('#dlDeptos').length > 0) {
                            $('#dlDeptos').append('<option value="' + res.nombre + '">');
                        }
                    }
                } else {
                    Swal.fire('Error', res.message, 'error');
                }
            },
            error: function() {
                Swal.close();
                Swal.fire('Error', 'No se pudo completar la solicitud.', 'error');
            }
        });
    }

    function exportarExcel() {
        if (!g_Detalles || g_Detalles.length === 0) return Swal.fire('Error', 'No hay datos para exportar', 'error');

        // Capturar filtros actuales
        let valGer = $('#fGerencia').val();
        let valSub = $('#fSubgerencia').val();
        let valArea = $('#fArea').val();
        let valJefeTop = $('#fJefe').val();
        let filters = [];
        $('.filter-input').each(function() { filters.push($(this).val() ? $(this).val().toLowerCase() : ''); });

        // Filtrar datos igual que en la tabla
        let paraExportar = g_Detalles.filter(d => {
            let matchGer = (valGer === '' || d.OGERENCIA_SIGHO === valGer);
            let matchSub = (valSub === '' || d.OSUBGERENCIA_SIGHO === valSub);
            let matchArea = (valArea === '' || d.Area_SIGHO === valArea);
            let matchJefeTop = (!valJefeTop || d.Jefe_SIGHO === valJefeTop);
            let matchCol = true;
            if (filters[0] && !(d.NombreCompleto + ' ' + d.CarnetEmpleado).toLowerCase().includes(filters[0])) matchCol = false;
            if (filters[1] && !(d.Departamento_SIGHO || '').toLowerCase().includes(filters[1])) matchCol = false;
            if (filters[2] && !(d.Cargo_Reportado || d.Cargo_SIGHO || '').toLowerCase().includes(filters[2])) matchCol = false;
            if (filters[3] && !(d.Jefe_Reportado || d.Jefe_SIGHO || '').toLowerCase().includes(filters[3])) matchCol = false;
            if (filters[4] && !(d.Ubicacion_Reportada || d.Ubicacion_SIGHO || '').toLowerCase().includes(filters[4])) matchCol = false;
            return matchGer && matchSub && matchArea && matchJefeTop && matchCol;
        });

        if (paraExportar.length === 0) return Swal.fire('Atencion', 'No hay registros con los filtros actuales', 'warning');

        // Generar CSV
        let csv = "\ufeff"; // BOM para Excel
        csv += "Carnet;Colaborador;Gerencia;Subgerencia;Area;Puesto SIGHO;Puesto Reportado;Departamento SIGHO;Departamento Reportado;Jefe SIGHO;Jefe Reportado;Ubicacion SIGHO;Ubicacion Reportada;Justificacion;Observaciones\n";

        paraExportar.forEach(d => {
            let row = [
                d.CarnetEmpleado,
                d.NombreCompleto,
                d.OGERENCIA_SIGHO,
                d.OSUBGERENCIA_SIGHO,
                d.Area_SIGHO,
                d.Cargo_SIGHO,
                d.Cargo_Reportado || "",
                d.Departamento_SIGHO,
                d.Departamento_Reportado || "",
                d.Jefe_SIGHO,
                d.Jefe_Reportado || "",
                d.Ubicacion_SIGHO,
                d.Ubicacion_Reportada || "",
                (d.JustMotivo || "") + " " + (d.JustReposicion || ""),
                d.Observacion || ""
            ];
            csv += row.map(v => '"' + (v || '').toString().replace(/"/g, '""') + '"').join(';') + "\n";
        });

        let blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
        let link = document.createElement("a");
        let url = URL.createObjectURL(blob);
        link.setAttribute("href", url);
        link.setAttribute("download", "Certificacion_Personal_" + new Date().getTime() + ".csv");
        link.style.visibility = 'hidden';
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }
    </script>
}
