    }

    function borrarEvidenciaActual() {
        let id = $('#hdnDetalleIdEv').val();
        Swal.fire({ title: 'Quitar?', icon: 'warning', showCancelButton: true }).then(r => {
            if(r.isConfirmed) {
                $.post('@Url.Action("EliminarEvidencia", "Certificacion")', { detalleId: id }, function(res) {
