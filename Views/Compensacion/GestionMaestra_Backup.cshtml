<!-- Modal Configuracion de Periodo Premium -->
<div class="modal fade" id="modalPeriodo" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow" style="border-radius:25px;">
            <div class="modal-header bg-dark text-white p-4" style="border-radius: 25px 25px 0 0;">
                <h5 class="modal-title font-weight-bold"><i class="fas fa-calendar-alt mr-2"></i> Configurar Periodo</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
