                        </div>

                        <div class="custom-control custom-checkbox mb-2">
                            <input type="checkbox" class="custom-control-input" id="chkNotifComisiones">
                            <label class="custom-control-label small font-weight-bold" for="chkNotifComisiones">Notificar Apertura de COMISIONES</label>
                        </div>

                        <div class="custom-control custom-checkbox">
                            <input type="checkbox" class="custom-control-input" id="chkNotifCertificacion">
                            <label class="custom-control-label small font-weight-bold" for="chkNotifCertificacion">Notificar Apertura de CERTIFICACION</label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 p-4">
                <button class="btn btn-dark btn-block font-weight-bold py-3 shadow" style="border-radius:15px; background:#424242;" onclick="guardarPeriodo()">
                    <i class="fas fa-save mr-2"></i> Guardar Configuracion
                </button>
