</div>

@section scripts {
    <script src="~/onlinejs/moment.min.js"></script>
    <script src="~/onlinejs/dataTables.responsive.min.js"></script>
    <script src="~/onlinejs/dataTables.rowGroup.min.js"></script>
    <link href="~/onlinecss/select2.min.css" rel="stylesheet" />
    <script src="~/onlinejs/select2.min.js"></script>
     <style>
        .select2-continer {
            width: 100% !important;
        }

        .select2-continer--default .select2-selection--single {
            height: 45px;
            border-radius: 10px;
            border: none;
            background: #f8f9fa;
            display: flex;
            align-items: center;
        }

            .select2-continer--default .select2-selection--single .select2-selection__arrow {
                height: 45px;
            }
    </style>
    <script>
    var table = null;
    var universoOriginal = [];
    var g_PeriodoActivo = null;

    $(document).ready(function() {
        cargarUniverso();

        $('#checkAll').on('change', function() {
            var isChecked = $(this).is(':checked');
            $('.check-fila').prop('checked', isChecked);
        });

        // Inicializar Select2 para modales
        $('.modal select').select2({
            width: '100%',
            dropdownParent: $('.modal:visible').length ? $('.modal:visible') : null
        });
    });

    // Re-inicializar Select2 cuando se abre cualquier modal
    $('.modal').on('shown.bs.modal', function () {
        $(this).find('select').select2({
            dropdownParent: $(this)
        });
    });

    function cargarUniverso() {
        $('#pageLoader').show();
        $('#tbodyMaestra').html('<tr><td colspan="10" class="text-center p-5"><div class="spinner-border text-danger"></div> Cargando universo...</td></tr>');

        $.get('@Url.Action("ObtenerUniversoMaestro", "Compensacion")', function(res) {
            if (res.success) {
                universoOriginal = res.data || [];
                renderizarTabla(universoOriginal);
                $('#txtUniverso').text(universoOriginal.length);

                // Usar el periodo que ya viene en la respuesta
                if(res.periodo) {
                    g_PeriodoActivo = res.periodo;
                    $('#lblNombrePeriodo').text(g_PeriodoActivo.NombrePeriodo);
                    $('#badgeEstadoPeriodo').text(g_PeriodoActivo.Estado.toUpperCase())
                        .removeClass('text-success text-danger')
                        .addClass(g_PeriodoActivo.Estado === 'Activo' ? 'text-success' : 'text-danger');

                    var inicio = g_PeriodoActivo.Fechinicio ? moment(g_PeriodoActivo.Fechinicio).format('DD/MM/YYYY HH:mm') : 'No def.';
                    var fin = g_PeriodoActivo.FechaFin ? moment(g_PeriodoActivo.FechaFin).format('DD/MM/YYYY HH:mm') : 'No def.';
                    $('#txtVigenciaPeriodo').text(inicio + ' al ' + fin);
                } else {
                    g_PeriodoActivo = null;
                    $('#lblNombrePeriodo').text("SIN PERIODO ACTIVO");
                    $('#badgeEstadoPeriodo').text("CERRADO").addClass('text-danger');
                    $('#txtVigenciaPeriodo').text("N/A");
                }
            } else {
                Swal.fire('Error', res.message || "Error al cargar datos", 'error');
            }
            $('#pageLoader').fadeOut();
        }).fail(function() {
            $('#pageLoader').fadeOut();
            Swal.fire('Error de Red', 'No se pudo conectar con el servidor.', 'error');
        });
    }

    // Usar la version robusta de abrirConfigPeriodo que busca en la lista completa
    window.abrirConfigPeriodo = function() {
        $.get('@Url.Action("ObtenerListaPeriodos", "Compensacion")', function(res) {
            if(res.success) {
                window._listaPeriodos = res.data;
                var datinvertida = res.data.slice().reverse();
                var opt = '';
                datinvertida.forEach(function(p) {
                    var sel = (g_PeriodoActivo && p.PeriodoID == g_PeriodoActivo.PeriodoID) ? 'selected' : '';
                    opt += '<option value="'+p.PeriodoID+'" '+sel+'>'+p.NombrePeriodo+' ('+p.Estado+')</option>';
                });
                $('#selPeriodoConfig').html(opt);

                if(g_PeriodoActivo) cargarDetallePeriodoConfig(g_PeriodoActivo.PeriodoID);
                else if(datinvertida.length > 0) cargarDetallePeriodoConfig(datinvertida[0].PeriodoID);

                $('#modalPeriodo').modal('show');
            }
        });
    };

    window.reabrirPeriodo = function() {
        Swal.fire({
            title: 'Reabrir Periodo?',
            text: 'Permitira que los validadores vuelvan a enviar informacion.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Si, reabrir',
            cancelButtonText: 'Cancelar'
        }).then(function(r) {
            if(r.isConfirmed) {
                $.post('@Url.Action("ReabrirPeriodo", "Compensacion")', { periodoId: g_PeriodoActivo.PeriodoID }, function(res) {
                    if(res.success) {
                        $('#modalPeriodo').modal('hide');
                        Swal.fire('Reabierto', 'Periodo listo para ajustes.', 'success').then(function() { location.reload(); });
                    }
                });
            }
        });
    };

    function safeGet(row, key) {
        if (!row) return "";
        if (row[key] !== undefined && row[key] !== null) return row[key];
        var lowerKey = key.toLowerCase();
        for (var k in row) {
            if (k.toLowerCase() === lowerKey) return row[k];
        }
        return "";
    }

    function renderizarTabla(data) {
        if (table) table.destroy();

        table = $('#tablaMaestra').DataTable({
            data: data,
            deferRender: true,
            pageLength: 50,
            autoWidth: false,
            order: [[2, 'asc'], [3, 'asc'], [4, 'asc'], [1, 'asc']],
            drawCallback: function() {
                // Eliminar la logica de ocultar filas
                $('#tablaMaestra tbody tr').removeClass('hidden-row');
            },
            columns: [
                {
                    data: null,
                    className: 'text-center',
                    orderable: false,
                    render: function(d, t, r) {
                        var id = safeGet(r, 'DetalleID');
                        return '<input type="checkbox" class="check-fila" data-id="' + id + '">';
                    }
                },
                {
                    data: null,
                    render: function(d, t, r) {
                        var nombre = safeGet(r, 'NombreCompleto');
                        var carnet = safeGet(r, 'CarnetEmpleado');
                        return '<strong>' + nombre + '</strong><br><small class="text-muted">' + carnet + '</small>';
                    }
                },
                {
                    data: null,
                    visible: true,
                    render: function(d, t, r) { return '<small>' + safeGet(r, 'OGERENCIA_SIGHO') + '</small>'; }
                },
                {
                    data: null,
                    visible: true,
                    render: function(d, t, r) { return '<small>' + safeGet(r, 'OSUBGERENCIA_SIGHO') + '</small>'; }
                },
                {
                    data: null,
                    visible: true,
                    render: function(d, t, r) { return '<small>' + safeGet(r, 'Area_SIGHO') + '</small>'; }
                },
                {
                    data: null,
                    render: function(d, t, r) {
                        var nom = safeGet(r, 'NombreGerente');
                        var car = safeGet(r, 'CarnetValidador');
                        if(!car) return '<small class="text-muted italic">Sin asignar</small>';
                        return '<strong>' + nom + '</strong><br><small class="text-muted">' + car + '</small>';
                    }
                },
                {
                    data: null,
                    render: function(d, t, r) {
                        var jefe = safeGet(r, 'Jefe_SIGHO');
                        var cargo = safeGet(r, 'Cargo_SIGHO');
                        return '<b>J:</b> <small>' + (jefe || '-') + '</small><br><b>C:</b> <small>' + (cargo || '-') + '</small>';
                    }
                },
                {
                    data: null,
                    render: function(d, t, r) { return '<small>' + (safeGet(r, 'Ubicacion_SIGHO') || '-') + '</small>'; }
                },
                {
                    data: null,
                    className: 'text-center',
                    render: function(d, t, r) {
                        var val = safeGet(r, 'AplicaEmpleado');
                        var id = safeGet(r, 'DetalleID');
                        var checked = val === 'S' ? 'checked' : '';
                        return '<input type="checkbox" class="check-aplica-dual check-empleado" data-id="' + id + '" ' + checked + '>';
                    }
                },
                {
                    data: null,
                    className: 'text-center',
                    orderable: false,
                    render: function(d, t, r) {
                        var carnet = safeGet(r, 'CarnetEmpleado');
                        return '<button class="btn btn-sm btn-light btn-circle" onclick="verHistorial(\'' + carnet + '\')" title="Ver Historial"><i class="fas fa-history text-muted"></i></button>';
                    }
                }
            ],
            language: {
                search: "Buscar:",
                lengthMenu: "Mostrar _MENU_ registros",
                info: "Mostrando _START_ a _END_ de _TOTAL_ registros",
                paginate: { first: "Primero", last: "Ultimo", next: "Siguiente", previous: "Anterior" }
            }
        });

        // Eventos para filtros por columna
        table.columns().every(function (i) {
            var that = this;
            $('input', $('.filter-row th').eq(i)).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that.search(this.value).draw();
                }
            });
        });

        // Funcion global para filtrar columnas por select (Emp y Com)
        window.filterColumn = function(idx, val) {
            if (val) {
                $('#tablaMaestra tbody tr').removeClass('collapsed').removeClass('hidden-row');
            }
            table.column(idx).search(val ? '^' + val + '$' : '', true, false).draw();
        };

        // Evento Seleccion Masiva por Grupo
        $('#tablaMaestra tbody').on('change', '.check-grupo', function(e) {
            e.stopPropagation();
            var chk = $(this);
            var isChecked = chk.is(':checked');
            var row = chk.closest('tr');
            var level = parseInt(row.attr('data-level'));

            var nextRows = row.nextAll();
            for (var i = 0; i < nextRows.length; i++) {
                var nextRow = $(nextRows[i]);
                var nextLevel = parseInt(nextRow.attr('data-level'));

                if (nextRow.hasClass('group-gerencia') || nextRow.hasClass('group-subgerencia') || nextRow.hasClass('group-area')) {
                    if (nextLevel <= level) break;
                    nextRow.find('.check-grupo').prop('checked', isChecked);
                } else {
                    nextRow.find('.check-fila').prop('checked', isChecked);
                }
            }
        });

        $('#tablaMaestra tbody').on('click', '.check-grupo', function(e) {
            e.stopPropagation();
        });

        // Evento Click para colapsar/expandir
        $('#tablaMaestra tbody').off('click', 'tr[class^="group-"]').on('click', 'tr[class^="group-"]', function (e) {
            if ($(e.target).hasClass('check-grupo')) return;

            var row = $(this);
            var level = parseInt(row.attr('data-level'));
            var isCollapsed = row.hasClass('collapsed');
            row.toggleClass('collapsed');
            var nextRows = row.nextAll();
            for (var i = 0; i < nextRows.length; i++) {
                var nextRow = $(nextRows[i]);
                var nextLevel = parseInt(nextRow.attr('data-level'));
                if (nextRow.hasClass('group-gerencia') || nextRow.hasClass('group-subgerencia') || nextRow.hasClass('group-area')) {
                    if (nextLevel <= level) break;
                }
                if (isCollapsed) {
                    if (isNaN(nextLevel) || nextLevel === level + 1) {
                         nextRow.removeClass('hidden-row');
                         if (!isNaN(nextLevel)) nextRow.addClass('collapsed');
                    }
                } else {
                    nextRow.addClass('hidden-row').addClass('collapsed');
                }
            }
        });
    }

