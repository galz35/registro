        var id = $('#txtIdPeriodoConfig').val();
        var inicio = $('#txtFechinicio').val();
        var fin = $('#txtFechaFin').val();
        var estado = $('#selEstadoPeriodoConfig').val();
        
        var notifCom = $('#chkNotifComisiones').is(':checked');
        var notifCert = $('#chkNotifCertificacion').is(':checked');
        var fechaLimit = $('#txtFechaLimiteNotif').val() || "Lo antes posible";

        Swal.fire({ title: 'Guardando...', allowOutsideClick: false, didOpen: function() { Swal.showLoading(); }});

        $.post('@Url.Action("GuardarPeriodo", "Compensacion")', { periodoId: id, fechinicio: inicio, fechaFin: fin, estado: estado }, function(res) {
            if(res.success) {
                // Si no hay que notificar nada, terminamos aqui
                if(!notifCom && !notifCert) {
                    Swal.fire('Exito', 'Configuracion guardada correctamente.', 'success').then(function() { location.reload(); });
                    return;
                }

                // Si hay que notificar, empezamos el proceso masivo
                procesarNotificacionesMasivas(id, notifCom, notifCert, fechaLimit);
            } else {
                Swal.fire('Error', res.message, 'error');
            }
        });
    };

    function procesarNotificacionesMasivas(periodoId, com, cert, fecha) {
        Swal.fire({
            title: 'Enviando Notificaciones...',
            html: 'Por favor espere, estamos despachando los correos a los validadores.<br><br><div id="notifProgress" class="small text-muted text-left"></div>',
            allowOutsideClick: false,
            didOpen: function() { Swal.showLoading(); }
        });

        var tareas = [];
        if(com) tareas.push({ tipo: 1, nombre: 'Comisiones' });
        if(cert) tareas.push({ tipo: 2, nombre: 'Certificacion' });

        var index = 0;
        function ejecutarSiguiente() {
            if(index >= tareas.length) {
                Swal.fire('Proceso Completado', 'Periodo configurado y notificaciones enviadas exitosamente.', 'success').then(function() { location.reload(); });
                return;
            }

            var t = tareas[index];
            $('#notifProgress').append('<div><i class="fas fa-spinner fa-spin mr-2"></i> Enviando ' + t.nombre + '...</div>');

            $.post('@Url.Action("NotificarValidadores", "Compensacion")', { periodoId: periodoId, tipo: t.tipo, fechaLimite: fecha }, function(res) {
                if(res.success) {
                    $('#notifProgress').append('<div class="text-success"><i class="fas fa-check mr-2"></i> ' + t.nombre + ': Enviados ' + res.notificados + ' correos.</div>');
                } else {
                    $('#notifProgress').append('<div class="text-danger"><i class="fas fa-times mr-2"></i> ' + t.nombre + ': ' + (res.message || 'Error') + '</div>');
                }
                index++;
                setTimeout(ejecutarSiguiente, 500); // Pequena pausa entre rafagas
            });
        }

        ejecutarSiguiente();
    }

    function abrirHistorial() {
        $('#modalHistorial').modal('show');
        setHistModo($('.hist-tab').first()[0], 'emp_com');
    }

    function setHistModo(btn, modo) {
        histModoActual = modo;
        $('.hist-tab').removeClass('active');
        $(btn).addClass('active');
        if(modo === 'gerencia') {
            $('#histFiltroTextoCont').hide();
            $('#histFiltroGerenciaCont').show();
            var gs = [];
            for(var i=0; i<universoOriginal.length; i++) {
                var g = safeGet(universoOriginal[i], 'OGERENCIA_SIGHO');
                if(g && gs.indexOf(g) === -1) gs.push(g);
            }
            var opt = '<option value="">-- SELECCIONE --</option>';
            gs.sort().forEach(function(x) { opt += '<option value="'+x+'">'+x+'</option>'; });
            $('#histSelGerencia').html(opt);
        } else {
            $('#histFiltroGerenciaCont').hide();
            $('#histFiltroTextoCont').show();
        }
    }

    window.histCargarSubgerencias = function(g) {
        if(!g) return $('#histSelSubgerencia').html('<option value="">-- TODO --</option>');
        $.get('@Url.Action("ObtenerSubgerencias", "Compensacion")?gerencia=' + encodeURIComponent(g), function(res) {
            var opt = '<option value="">-- TODO --</option>';
            if(res.success) {
                res.data.forEach(function(s) { opt += '<option value="'+s+'">'+s+'</option>'; });
            }
            $('#histSelSubgerencia').html(opt);
            $('#histSelArea').html('<option value="">-- TODO --</option>');
        });
    };

    window.histCargarAreas = function(s) {
        var g = $('#histSelGerencia').val();
        if(!s) return $('#histSelArea').html('<option value="">-- TODO --</option>');
        $.get('@Url.Action("ObtenerAreas", "Compensacion")?gerencia=' + encodeURIComponent(g) + '&subgerencia=' + encodeURIComponent(s), function(res) {
            var opt = '<option value="">-- TODO --</option>';
            if(res.success) {
                res.data.forEach(function(a) { opt += '<option value="'+a+'">'+a+'</option>'; });
            }
            $('#histSelArea').html(opt);
        });
    };

    function buscarHistorial() {
        var filtro = histModoActual === 'gerencia' ? ($('#histSelArea').val() || $('#histSelSubgerencia').val() || $('#histSelGerencia').val()) : $('#histFiltro').val().trim();
        if (!filtro) return Swal.fire('Atencion', 'Ingrese criterio.', 'warning');
        $('#histResultados').html('<i class="fas fa-spinner fa-spin"></i>');
        $.getJSON('@Url.Action("ObtenerHistorial", "Compensacion")', { filtro: filtro, modo: histModoActual }, function(res) {
            var html = '<div class="table-responsive"><table class="table table-sm table-hover" style="font-size:12px;"><thead><tr style="background:#f5f5f5;"><th>Periodo</th><th>Modulo</th>';

            if (histModoActual.includes('validador') || histModoActual.includes('jefe') || histModoActual === 'gerencia') {
                html += '<th>Empleado</th>';
            }

            html += '<th>Cargo SighoO</th><th>Cargo Rep.</th><th>Jefe SighoO</th><th>Jefe Rep.</th><th>Ubic. SighoO</th><th>Ubic. Rep.</th><th>Com.</th><th>Justificacion</th>';

            if (histModoActual.includes('emp') || histModoActual === 'gerencia') {
                html += '<th>Validador</th>';
            }

            html += '<th>Estado</th></tr></thead><tbody>';

            res.data.forEach(function(r) {
                var tieneCambio = r.Cargo_Reportado || r.Jefe_Reportado || r.Ubicacion_Reportada || r.Departamento_Reportado || r.Comisiona === 'N';
                var rowStyle = tieneCambio ? 'background:#fffde7;' : '';

                html += '<tr style="' + rowStyle + '">';
                html += '<td><b>' + (r.NombrePeriodo || '-') + '</b></td>';
                html += '<td>' + (r.Modulo === 'Comisiones' ? '<span class="badge" style="background:#ff6f00;color:#fff;">COM</span>' : '<span class="badge" style="background:#b71c1c;color:#fff;">CERT</span>') + '</td>';

                if (histModoActual.includes('validador') || histModoActual.includes('jefe') || histModoActual === 'gerencia') {
                    html += '<td>' + (r.NombreCompleto || '') + '<br/><small class="text-muted">' + (r.CarnetEmpleado || '') + '</small></td>';
                }

                html += '<td>' + (r.Cargo_SIGHO || '-') + '</td>';
                html += '<td>' + (r.Cargo_Reportado ? '<b class="text-danger">' + r.Cargo_Reportado + '</b>' : '-') + '</td>';
                html += '<td>' + (r.Jefe_SIGHO || '-') + '</td>';
                html += '<td>' + (r.Jefe_Reportado ? '<b class="text-danger">' + r.Jefe_Reportado + '</b>' : '-') + '</td>';
                html += '<td>' + (r.Ubicacion_SIGHO || '-') + '</td>';
                html += '<td>' + (r.Ubicacion_Reportada ? '<b class="text-danger">' + r.Ubicacion_Reportada + '</b>' : '-') + '</td>';
                html += '<td>' + (r.Comisiona === 'S' ? '<span class="hist-badge-ok">SI</span>' : '<span class="hist-badge-cambio">NO</span>') + '</td>';

                html += '<td style="max-width:180px;">';
                if (r.JustMotivo) html += '<small><b>Motivo:</b> ' + r.JustMotivo + '</small><br/>';
                if (r.JustReposicion) html += '<small><b>Repone:</b> ' + r.JustReposicion + '</small><br/>';
                if (r.JustTiempo) html += '<small><b>Tiempo:</b> ' + r.JustTiempo + '</small>';
                if (!r.JustMotivo && !r.JustReposicion && !r.JustTiempo) html += '-';
                html += '</td>';

                if (histModoActual.includes('emp') || histModoActual === 'gerencia') {
                    html += '<td><small>' + (r.Validador || '-') + '</small></td>';
                }

                var estadoColor = r.EstadoPlantilla === 'Aprobado' ? '#2e7d32' : r.EstadoPlantilla === 'Enviado' ? '#e53935' : r.EstadoPlantilla === 'Devuelto' ? '#d84315' : '#757575';
                html += '<td><span class="badge" style="background:' + estadoColor + ';color:#fff;">' + (r.EstadoPlantilla || '-') + '</span></td>';
                html += '</tr>';
            });

            html += '</tbody></table></div>';
            html += '<div class="d-flex justify-content-between align-items-center mt-2">';
            html += '<span class="text-muted small"><i class="fas fa-info-circle mr-1"></i>' + res.totalRegistros + ' registros encontrados</span>';
            html += '<button class="btn btn-sm btn-success" onclick="exportarHistorialExcel()"><i class="fas fa-file-excel mr-1"></i> Descargar Excel</button>';
            html += '</div>';

            $('#histResultados').html(html);
            window._historialData = res.data;
        });
    }

    function exportarHistorialExcel() {
        if (!window._historialData || window._historialData.length === 0) return;
        var d = window._historialData;
        var csv = '\uFEFF'; // BOM para UTF-8
        // Headers
        var headers = ['Periodo','Modulo','Carnet','Nombre','Cargo SighoO','Cargo Reportado','Jefe SighoO','Jefe Reportado','Ubicacion SighoO','Ubicacion Reportada','Depto SighoO','Depto Reportado','Comisiona','Motivo Cambio','A Quien Repone','Por Cuanto Tiempo','Observacion','Validador','Estado'];
        csv += headers.join(',') + '\n';
        d.forEach(function(r) {
            var row = [
                '"' + (r.NombrePeriodo || '') + '"',
                '"' + (r.Modulo || '') + '"',
                '"' + (r.CarnetEmpleado || '') + '"',
                '"' + (r.NombreCompleto || '') + '"',
                '"' + (r.Cargo_SIGHO || '') + '"',
                '"' + (r.Cargo_Reportado || '') + '"',
                '"' + (r.Jefe_SIGHO || '') + '"',
                '"' + (r.Jefe_Reportado || '') + '"',
                '"' + (r.Ubicacion_SIGHO || '') + '"',
                '"' + (r.Ubicacion_Reportada || '') + '"',
                '"' + (r.Departamento_SIGHO || '') + '"',
                '"' + (r.Departamento_Reportado || '') + '"',
                '"' + (r.Comisiona || '') + '"',
                '"' + (r.JustMotivo || '') + '"',
                '"' + (r.JustReposicion || '') + '"',
                '"' + (r.JustTiempo || '') + '"',
                '"' + (r.Observacion || '') + '"',
                '"' + (r.Validador || r.CarnetValidador || '') + '"',
                '"' + (r.EstadoPlantilla || '') + '"'
            ];
            csv += row.join(',') + '\n';
        });
        var blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
        var link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = 'Historial_' + $('#histFiltro').val().trim() + '_' + new Date().toISOString().slice(0,10) + '.csv';
        link.click();
    }

    </script>
}




