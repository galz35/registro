            if(res.success) {
                window._listaPeriodos = res.data; // Guardar localmente para acceso rapido
                var datinvertida = res.data.slice().reverse(); // Mas recientes primero
                var opt = '';
                datinvertida.forEach(function(p) {
                    var sel = (g_PeriodoActivo && p.PeriodoID == g_PeriodoActivo.PeriodoID) ? 'selected' : '';
                    opt += '<option value="'+p.PeriodoID+'" '+sel+'>'+p.NombrePeriodo+' ('+p.Estado+')</option>';
                });
                $('#selPeriodoConfig').html(opt);

                // Si hay un activo, cargar ese. Si no, cargar el primero de la lista (el mas reciente)
                if(g_PeriodoActivo) cargarDetallePeriodoConfig(g_PeriodoActivo.PeriodoID);
                else if(datinvertida.length > 0) cargarDetallePeriodoConfig(datinvertida[0].PeriodoID);

                $('#modalPeriodo').modal('show');
            }
        });
    };

    window.cargarDetallePeriodoConfig = function(id) {
        if(!id || !window._listaPeriodos) return;

        var p = window._listaPeriodos.find(function(x) { return x.PeriodoID == id; });
        if(!p) return;

        $('#txtIdPeriodoConfig').val(p.PeriodoID);
        $('#selEstadoPeriodoConfig').val(p.Estado);

        var fechini = p.Fechinicio ? moment(p.Fechinicio).format('YYYY-MM-DDTHH:mm') : "";
        var fechaFin = p.FechaFin ? moment(p.FechaFin).format('YYYY-MM-DDTHH:mm') : "";

        $('#txtFechinicio').val(fechini);
        $('#txtFechaFin').val(fechaFin);
    };

