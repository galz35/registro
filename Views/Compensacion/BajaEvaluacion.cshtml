@{
    ViewBag.Title = "Evaluacon por Baja | Compensaciones";
}
<meta charset="utf-8" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    :root {
        --primary: #B71C1C;
        --primary-dark: #7f0000;
        --secondary: #6c757d;
        --bg-glass: rgba(255, 255, 255, 0.9);
        --accent: #fcb913;
    }

    body { 
        background-color: #f8f9fc; 
        font-family: 'Inter', -apple-system, sans-serif;
    }

    /* Header Estilo Premium */
    .header-premium {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        color: white;
        padding: 40px 0;
        border-radius: 0 0 30px 30px;
        margin-bottom: 40px;
        box-shadow: 0 10px 30px rgba(183, 28, 28, 0.2);
    }

    .glass-card {
        background: var(--bg-glass);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 20px;
        transition: all 0.3s ease;
    }

    .card-emp {
        border-left: 5px solid var(--primary);
        cursor: pointer;
    }

    .card-emp:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
    }

    .status-badge {
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 5px 12px;
        border-radius: 50px;
        font-weight: 800;
    }

    .badge-pending { background: #fff3cd; color: #856404; }

    /* Estrellas de Calificacon */
    .rating-wrapper {
        display: flex;
        flex-direction: row-reverse;
        justify-content: center;
    }

    .rating-wrapper input { display: none; }

    .rating-wrapper label {
        font-size: 40px;
        color: #ddd;
        cursor: pointer;
        transition: all 0.2s ease;
        margin: 0 5px;
    }

    .rating-wrapper label:before { content: 'a??'; }

    .rating-wrapper input:checked ~ label { color: var(--accent); transform: scale(1.2); }
    .rating-wrapper label:hover, .rating-wrapper label:hover ~ label { color: var(--accent); }

    .btn-premium {
        background: var(--primary);
        color: white;
        border-radius: 50px;
        padding: 12px 30px;
        font-weight: 700;
        border: none;
        transition: all 0.3s;
    }

    .btn-premium:hover {
        background: var(--primary-dark);
        color: white;
        transform: scale(1.05);
        box-shadow: 0 5px 15px rgba(183, 28, 28, 0.3);
    }

    .empty-state {
        text-align: center;
        padding: 60px;
        background: white;
        border-radius: 20px;
        margin-top: 20px;
    }
</style>

<div class="header-premium">
    <div class="continer d-flex justify-content-between align-items-center">
        <div>
            <h1 class="h2 font-weight-bold mb-1"><i class="fas fa-user-slash mr-2"></i> Evaluacon de Salida</h1>
            <p class="mb-0 opacity-75">Certifique el cierre de Gestion de sus bajas recientes</p>
        </div>
        <div class="text-right d-none d-md-block">
            <span class="badge badge-light p-2 px-3 shadow-sm rounded-pill text-dark font-weight-bold" style="font-size: 14px;">
                <i class="fas fa-calendar-alt mr-1"></i> Periodo Vigente
            </span>
        </div>
    </div>
</div>

<div class="continer mb-5">
    <div class="row" id="listaPendientes">
        <!-- Cargando skeleton -->
        <div class="col-12 text-center p-5">
            <div class="spinner-grow text-danger" role="status"></div>
            <p class="mt-3 text-muted font-weight-bold">Analizando bajas del sistema...</p>
        </div>
    </div>
</div>

<!-- Modal de Evaluacon Redisei?ado -->
<div class="modal fade" id="modalEvalBaja" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content glass-card shadow-2xl border-0">
            <div class="modal-header border-0 p-4">
                <h5 class="modal-title font-weight-bold text-dark">
                    <i class="fas fa-clipboard-check text-danger mr-2"></i> Evaluando a: <span id="lblNombreBaja" class="text-danger"></span>
                </h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body p-4 pt-0">
                <input type="hidden" id="txtCarnetBaja">
                <input type="hidden" id="txtFechaBaja">
                
                <div class="row">
                    <div class="col-md-6 form-group">
                        <label class="font-weight-bold text-muted small uppercase">Motivo Principal de la Baja</label>
                        <select id="ddlMotivo" class="form-control form-control-lg border-0 shadow-sm rounded-pill" style="background: #f1f3f5;">
                            <option value="Renuncia Voluntaria">Renuncia Voluntaria</option>
                            <option value="Terminacion de Contrato">Terminacion de Contrato</option>
                            <option value="Despido con Causa">Despido con Causa</option>
                            <option value="Jubilacion">Jubilacion</option>
                            <option value="Otro">Otro</option>
                        </select>
                    </div>
                    <div class="col-md-6 form-group text-center">
                        <label class="font-weight-bold text-muted small uppercase d-block">Calificacon General de Desempei?o</label>
                        <div class="rating-wrapper mt-2">
                            <input type="radio" name="star" id="star5" value="5"><label for="star5"></label>
                            <input type="radio" name="star" id="star4" value="4"><label for="star4"></label>
                            <input type="radio" name="star" id="star3" value="3"><label for="star3"></label>
                            <input type="radio" name="star" id="star2" value="2"><label for="star2"></label>
                            <input type="radio" name="star" id="star1" value="1"><label for="star1"></label>
                        </div>
                    </div>
                </div>

                <div class="glass-card p-3 mt-4 mb-4" style="background: rgba(183, 28, 28, 0.05);">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h6 class="mb-0 font-weight-bold text-dark">a?Se recomienda el re-ingreso?</h6>
                            <small class="text-muted">Indica si el colaborador es elegible para futuras vacantes</small>
                        </div>
                        <div class="custom-control custom-switch custom-switch-lg">
                            <input type="checkbox" class="custom-control-input" id="chkReingreso" checked>
                            <label class="custom-control-label" for="chkReingreso"></label>
                        </div>
                    </div>
                </div>

                <div class="form-group mt-4">
                    <label class="font-weight-bold text-muted small uppercase">Justificacion y Comentarios del Li?der</label>
                    <textarea id="txtObs" class="form-control border-0 shadow-sm" rows="4" style="background: #f1f3f5; border-radius: 15px;" placeholder="Escriba aqui? los detalles que RRHH debe conocer sobre esta baja..."></textarea>
                </div>
            </div>
            <div class="modal-footer border-0 p-4">
                <button type="button" class="btn btn-light rounded-pill px-4" data-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-premium px-5" onclick="guardarEvaluacion()">
                    <i class="fas fa-check-double mr-2"></i> Finalizar Certificacion de Baja
                </button>
            </div>
        </div>
    </div>
</div>

@section scripts {
<script>
    $(document).ready(function() {
        cargarPendientes();
    });

    function cargarPendientes() {
        $.get('@Url.Action("ObtenerPendientesBaja", "Compensacion")', function(res) {
            var html = '';
            if (res.data && res.data.length > 0) {
                res.data.forEach(function(e) {
                    var fecha = e.FechaBaja ? new Date(parseInt(e.FechaBaja.substr(6))).toLocaleDateString('es-ES') : 'N/A';
                    html += '<div class="col-md-6 col-lg-4 mb-4">' +
                        '<div class="glass-card card-emp p-4 h-100" onclick="abrirEval(\'' + e.CarnetEmpleado + '\', \'' + e.NombreEmpleado + '\', \'' + e.FechaBaja + '\')">' +
                            '<div class="d-flex justify-content-between">' +
                                '<span class="status-badge badge-pending">Pendiente</span>' +
                                '<div class="text-right">' +
                                    '<small class="text-muted d-block uppercase" style="font-size: 9px;">Ultimo Di?a</small>' +
                                    '<strong class="text-danger">' + fecha + '</strong>' +
                                '</div>' +
                            '</div>' +
                            '<div class="mt-3">' +
                                '<h5 class="mb-0 font-weight-bold text-dark">' + e.NombreEmpleado + '</h5>' +
                                '<p class="text-muted small mb-0">' + e.Cargo + '</p>' +
                            '</div>' +
                            '<div class="mt-4 pt-3 border-top d-flex justify-content-between align-items-center">' +
                                '<small class="text-muted"><i class="fas fa-id-badge mr-1"></i> ' + e.CarnetEmpleado + '</small>' +
                                '<span class="text-danger font-weight-bold small">Evaluar Ahora <i class="fas fa-arrow-right ml-1"></i></span>' +
                            '</div>' +
                        '</div>' +
                    '</div>';
                });
            } else {
                html = `
                <div class="col-12 empty-state shadow-sm border">
                    <div class="display-4 text-success mb-3"><i class="fas fa-check-circle"></i></div>
                    <h4 class="font-weight-bold">a?Todo al di?a!</h4>
                    <p class="text-muted mb-0">No hay colaboradores pendientes de evaluacon de salida en su gerencia activa.</p>
                </div>`;
            }
            $('#listaPendientes').html(html);
        });
    }

    function abrirEval(carnet, nombre, fecha) {
        $('#txtCarnetBaja').val(carnet);
        $('#lblNombreBaja').text(nombre);
        $('#txtFechaBaja').val(fecha);
        $('#modalEvalBaja').modal('show');
    }

    function guardarEvaluacion() {
        const calif = $('input[name="star"]:checked').val();
        if(!calif) { 
            Swal.fire({ icon: 'warning', title: 'Calificacon Faltante', text: 'Por favor asigne una calificacon de desempei?o.', confirmButtonColor: '#B71C1C' }); 
            return; 
        }

        const model = {
            CarnetEmpleado: $('#txtCarnetBaja').val(),
            NombreEmpleado: $('#lblNombreBaja').text(),
            FechaBaja: new Date(parseInt($('#txtFechaBaja').val().substr(6))).toISOString(),
            MotivoBaja: $('#ddlMotivo').val(),
            CalificacionDesempeno: calif,
            RecomendableReingreso: $('#chkReingreso').is(':checked'),
            ObservacionesJefe: $('#txtObs').val()
        };

        Swal.fire({
            title: 'a?Finalizar Evaluacon?',
            text: "Se registrara el cierre oficial de Gestion del colaborador.",
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#B71C1C',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Si?, enviar a RRHH',
            cancelButtonText: 'Revisar'
        }).then((result) => {
            if (result.isConfirmed) {
                Swal.showLoading();
                $.post('@Url.Action("GuardarEvaluacionBaja", "Compensacion")', model, function(res) {
                    if(res.success) {
                        $('#modalEvalBaja').modal('hide');
                        Swal.fire('a?Certificado!', res.message, 'success');
                        cargarPendientes();
                    } else {
                        Swal.fire('Error', res.message, 'error');
                    }
                });
            }
        });
    }
</script>
}



