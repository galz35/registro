    function extraerBody(html) {
        var m = html.match(/<body[^>]*>([\s\S]*)<\/body>/i);
        return m ? m[1] : html;
    }

    function reemplazarEjemplos(texto) {
        var r = texto;
        for (var k in _ejemplos) r = r.split(k).join(_ejemplos[k]);
        return r;
    }

    // Crea un chip visual HTML para un placeholder
    function crearChipHTML(placeholder) {
        var cfg = _chipConfig[placeholder];
        if (!cfg) return placeholder;
        return '<span contenteditable="false" data-ph="' + placeholder + '" draggable="false" style="background:' + cfg.color + '; border:1px solid ' + cfg.border + '; padding:2px 10px; border-radius:5px; font-weight:bold; color:#333; display:inline-block; font-size:12px; cursor:default; user-select:none; margin:0 2px;"><i class="fas ' + cfg.icon + '" style="font-size:10px; margin-right:4px;"></i>' + cfg.label + '</span>';
    }

    // Convierte {placeholders} a chips visuales
    function aChips(html) {
        var r = html;
        for (var ph in _chipConfig) r = r.split(ph).join(crearChipHTML(ph));
        return r;
    }

    // Convierte chips visuales de vuelta a {placeholders}
    function deChips(html) {
        var $t = $('<div>').html(html);
        $t.find('[data-ph]').each(function() { $(this).replaceWith($(this).attr('data-ph')); });
        return $t.html();
    }

