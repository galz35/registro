                        </div>

                        <!-- Boton de Despacho Directo -->
                        <button id="btnDespachoPeriodoConfig" class="btn btn-danger btn-block font-weight-bold py-3 mt-4 shadow-sm" style="border-radius:12px; font-size:0.95rem; letter-spacing:0.3px; background:linear-gradient(135deg,#ef3829,#c62828); border:none;" onclick="enviarNotificacionesDirecto()">
                            <i class="fas fa-paper-plane mr-2"></i> Enviar notificaciones
                        </button>
                    </div>
                </div>

                <!-- SECCION 3: CORREO QUE SE ENVIA -->
                <div class="card border-0 mt-4" style="border-radius:16px; background:#fff; border: 1px solid #e2e8f0 !important;">
                    <div class="card-header border-0 px-4 pt-4 pb-2" style="background:transparent;">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <div class="d-flex align-items-center justify-content-center mr-3" style="width:40px; height:40px; background:linear-gradient(135deg,#2e7d32,#4caf50); border-radius:10px;">
                                    <i class="fas fa-envelope-open-text text-white" style="font-size:1rem;"></i>
                                </div>
                                <div>
                                    <h6 class="font-weight-bold text-dark mb-0">Correo que reciben los Validadores</h6>
                                    <small class="text-muted">Edite el contenido y arrastre los datos dinamicos al correo</small>
                                </div>
                            </div>
                            <select id="selModuloPlantilla" class="form-control form-control-sm" style="border-radius:8px; width:160px; border:1px solid #e2e8f0;" onchange="alCambiarModuloPlantilla(this.value)">
                                <option value="1">Comisiones</option>
                                <option value="2">Certificacion</option>
                            </select>
                        </div>
                    </div>
                    <div class="card-body px-4 pt-2 pb-4">
                        <div class="row">
                            <!-- COLUMNA IZQUIERDA: Datos que se insertan -->
                            <div class="col-md-3">
                                <div class="mb-2">
                                    <small class="font-weight-bold text-uppercase text-muted d-block mb-2"><i class="fas fa-puzzle-piece mr-1"></i> Datos automaticos</small>
                                    <small class="text-muted d-block mb-3">Arrastre y suelte estos datos dentro del correo:</small>
                                </div>
                                <div draggable="true" class="drag-variable" data-var="{estructuraNombre}" style="background:#e8f5e9; border:1px solid #a5d6a7; border-radius:8px; padding:8px 12px; margin-bottom:8px; cursor:grab; user-select:none; font-size:12px;">
                                    <i class="fas fa-building mr-1 text-success"></i> <b>Nombre del Area</b>
                                    <div class="text-muted" style="font-size:10px;">Ej: GERENCIA COMERCIAL</div>
                                </div>
                                <div draggable="true" class="drag-variable" data-var="{periodoNombre}" style="background:#e3f2fd; border:1px solid #90caf9; border-radius:8px; padding:8px 12px; margin-bottom:8px; cursor:grab; user-select:none; font-size:12px;">
                                    <i class="fas fa-calendar-alt mr-1 text-primary"></i> <b>Periodo</b>
                                    <div class="text-muted" style="font-size:10px;">Ej: Junio 2026</div>
                                </div>
                                <div draggable="true" class="drag-variable" data-var="{fechaFormateada}" style="background:#fff3e0; border:1px solid #ffcc80; border-radius:8px; padding:8px 12px; margin-bottom:8px; cursor:grab; user-select:none; font-size:12px;">
                                    <i class="fas fa-clock mr-1 text-warning"></i> <b>Fecha Limite</b>
                                    <div class="text-muted" style="font-size:10px;">Ej: 15 de Junio de 2026</div>
                                </div>
                                <div draggable="true" class="drag-variable" data-var="{fechaActual}" style="background:#fce4ec; border:1px solid #ef9a9a; border-radius:8px; padding:8px 12px; margin-bottom:8px; cursor:grab; user-select:none; font-size:12px;">
                                    <i class="fas fa-calendar-day mr-1 text-danger"></i> <b>Fecha de Hoy</b>
                                    <div class="text-muted" style="font-size:10px;">Ej: 02/06/2026</div>
                                </div>
                                <hr style="border-color:#e2e8f0;">
                                <button class="btn btn-success btn-sm btn-block font-weight-bold" style="border-radius:8px;" onclick="guardarPlantillaConfig()">
                                    <i class="fas fa-save mr-1"></i> Guardar Cambios
                                </button>
                                <button class="btn btn-outline-secondary btn-sm btn-block mt-1" style="border-radius:8px;" onclick="alCambiarModuloPlantilla($('#selModuloPlantilla').val())">
                                    <i class="fas fa-undo mr-1"></i> Restaurar Original
                                </button>
                                <hr style="border-color:#e2e8f0; margin: 15px 0;">
                                <div class="bg-light p-3" style="border-radius:10px; border:1px solid #e2e8f0;">
                                    <small class="font-weight-bold text-uppercase text-muted d-block mb-2"><i class="fas fa-paper-plane mr-1"></i> Enviar correo de prueba</small>
                                    <div class="form-group mb-2">
                                        <input type="email" id="txtCorreoPrueba" class="form-control form-control-sm" placeholder="ejemplo@claro.com.ni" style="border-radius:8px; border:1px solid #cbd5e1; height:36px; font-size:12px;">
                                    </div>
                                    <button class="btn btn-dark btn-sm btn-block font-weight-bold" style="border-radius:8px;" onclick="enviarCorreoPrueba()">
                                        <i class="fas fa-paper-plane mr-1"></i> Enviar Prueba
                                    </button>
                                </div>
                            </div>
                            <!-- COLUMNA DERECHA: Editor del correo -->
                            <div class="col-md-9">
                                <!-- Tabs: Editar / Vista Previa -->
                                <ul class="nav nav-tabs mb-0" style="border-bottom:none;">
                                    <li class="nav-item">
                                        <a class="nav-link active" id="tabEditar" href="javascript:void(0)" onclick="mostrarTabCorreo('editar')" style="border-radius:8px 8px 0 0; font-size:13px; font-weight:bold;">
                                            <i class="fas fa-pencil-alt mr-1"></i> Editar Correo
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link" id="tabPreview" href="javascript:void(0)" onclick="mostrarTabCorreo('preview')" style="border-radius:8px 8px 0 0; font-size:13px; font-weight:bold;">
                                            <i class="fas fa-eye mr-1"></i> Vista Previa
                                        </a>
                                    </li>
                                </ul>
                                <!-- TAB EDITAR -->
                                <div id="panelEditar" style="border:1px solid #dee2e6; border-top:none; border-radius:0 0 10px 10px; overflow:hidden;">
                                    <div id="divEditorCorreo" contenteditable="true" style="padding:20px 25px; min-height:300px; background:#fff; font-family:Arial,sans-serif; font-size:13px; line-height:1.6; color:#333; outline:none; cursor:text;" ondragover="event.preventDefault(); this.style.background='#f0fff0';" ondragleave="this.style.background='#fff';" ondrop="soltarVariable(event)">
                                        <p class="text-muted text-center py-4"><i class="fas fa-spinner fa-spin mr-1"></i> Cargando...</p>
                                    </div>
                                </div>
                                <!-- TAB PREVIEW (oculto inicialmente) -->
                                <div id="panelPreview" style="display:none; border:1px solid #dee2e6; border-top:none; border-radius:0 0 10px 10px; overflow:hidden;">
                                    <div style="background:#f8f9fa; padding:10px 18px; border-bottom:1px solid #dee2e6;">
                                        <div class="small"><b class="text-muted">Para:</b> <span class="text-dark">validador@empresa.com</span></div>
                                        <div class="small"><b class="text-muted">Asunto:</b> <span id="lblAsuntoPreview" class="text-dark font-weight-bold">Cargando...</span></div>
                                    </div>
                                    <div id="divCorreoPreview" style="padding:20px 25px; min-height:250px; background:#fff; font-family:Arial,sans-serif; font-size:13px; line-height:1.6; color:#333;">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <input type="hidden" id="txtAsuntoPlantilla">
                        <textarea id="txtCuerpoPlantilla" style="display:none;"></textarea>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/onlinejs/moment.min.js"></script>
    <script src="~/onlinejs/dataTables.responsive.min.js"></script>
    <script src="~/onlinejs/dataTables.rowGroup.min.js"></script>
    <link href="~/onlinecss/select2.min.css" rel="stylesheet" />
    <script src="~/onlinejs/select2.min.js"></script>
     <style>
        .select2-continer {
            width: 100% !important;
        }

        .select2-continer--default .select2-selection--single {
            height: 45px;
            border-radius: 10px;
            border: none;
            background: #f8f9fa;
            display: flex;
            align-items: center;
        }

            .select2-continer--default .select2-selection--single .select2-selection__arrow {
                height: 45px;
            }

        .d-none-hierarchy, .d-none-search {
            display: none !important;
        }
     </style>
    <script>
    var table = null;
    var universoOriginal = [];
    var g_PeriodoActivo = null;
    var g_PeriodoCert = null;

    $(document).ready(function() {
        cargarUniverso();

        $('#checkAll').on('change', function() {
            var isChecked = $(this).is(':checked');
            $('.check-fila').prop('checked', isChecked);
        });

        // Evitar que los dropdown-checklist se cierren al hacer click dentro
        $(document).on('click', '#ddGerencia .dropdown-menu, #ddSubgerencia .dropdown-menu, #ddArea .dropdown-menu', function(e) {
            e.stopPropagation();
        });

        // Select2 de modales se inicializara dinamicamente en el evento shown.bs.modal para asegurar posicionamiento correcto.

        // Evento para habilitar/deshabilitar el filtro por cargo y actualizar obligatoriedad de destinatarios
        $('#chkNotifCertificacion').on('change', function() {
            actualizarEstadoFiltroCargo();
            actualizarObligatoriedadDestinatarios();
        });
        $('#chkNotifComisiones').on('change', function() {
            actualizarObligatoriedadDestinatarios();
        });

        // Eventos para el registro interactivo de estructuras manuales (Subgerencia y Area)
        $('#selSubgerenciaNueva').on('change', function() {
            var val = $(this).val();
            if (val === '__NUEVA_SUB__') {
                var gerencia = $('#selGerenciaNueva').val();
                if (!gerencia) {
                    Swal.fire('Error', 'Seleccione una gerencia primero.', 'error');
                    $('#selSubgerenciaNueva').val('').trigger('change');
                    return;
                }
                Swal.fire({
                    title: 'Registrar Nueva Subgerencia',
                    text: 'Ingrese el nombre de la nueva Subgerencia para: ' + gerencia,
                    input: 'text',
                    inputPlaceholder: 'Escriba la subgerencia aqui...',
                    showCancelButton: true,
                    confirmButtonText: 'Registrar',
                    cancelButtonText: 'Cancelar',
                    inputValidator: (value) => {
                        if (!value || !value.trim()) {
                            return 'Debe ingresar un nombre!';
                        }
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        var subName = result.value.trim().toUpperCase();
                        Swal.fire({ title: 'Registrando...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });
                        $.post('@Url.Action("RegistrarEstructuraManual", "Compensacion")', {
                            gerencia: gerencia,
                            subgerencia: subName,
                            area: ''
                        }, function(res) {
                            if (res.success) {
                                Swal.fire('Exito', res.message || 'Subgerencia registrada.', 'success');
                                // Recargar select y pre-seleccionar
                                $.get('@Url.Action("ObtenerSubgerencias", "Compensacion")?gerencia=' + encodeURIComponent(gerencia), function(resSub) {
                                    var opt = '<option value="">-- TODO (Nivel Gerencia) --</option>';
                                    if(resSub.success) {
                                        resSub.data.forEach(function(s) { opt += '<option value="'+s+'">'+s+'</option>'; });
                                    }
                                    opt += '<option value="__NUEVA_SUB__" style="font-weight:bold; color:#d9534f;">+ REGISTRAR NUEVA SUBGERENCIA...</option>';
                                    $('#selSubgerenciaNueva').html(opt).val(subName).trigger('change');
                                });
                            } else {
                                Swal.fire('Error', res.message, 'error');
                                $('#selSubgerenciaNueva').val('').trigger('change');
                            }
                        });
                    } else {
                        $('#selSubgerenciaNueva').val('').trigger('change');
                    }
                });
            }
        });

        $('#selAreaNueva').on('change', function() {
            var val = $(this).val();
            if (val === '__NUEVA_AREA__') {
                var gerencia = $('#selGerenciaNueva').val();
                var subgerencia = $('#selSubgerenciaNueva').val();
                if (!gerencia || !subgerencia || subgerencia === '__NUEVA_SUB__') {
                    Swal.fire('Error', 'Seleccione una Gerencia y Subgerencia primero.', 'error');
                    $('#selAreaNueva').val('').trigger('change');
                    return;
                }
                Swal.fire({
                    title: 'Registrar Nueva Area / Departamento',
                    text: 'Ingrese el nombre de la nueva Area para: ' + subgerencia,
                    input: 'text',
                    inputPlaceholder: 'Escriba el area aqui...',
                    showCancelButton: true,
                    confirmButtonText: 'Registrar',
                    cancelButtonText: 'Cancelar',
                    inputValidator: (value) => {
                        if (!value || !value.trim()) {
                            return 'Debe ingresar un nombre!';
                        }
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        var areaName = result.value.trim().toUpperCase();
                        Swal.fire({ title: 'Registrando...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });
                        $.post('@Url.Action("RegistrarEstructuraManual", "Compensacion")', {
                            gerencia: gerencia,
                            subgerencia: subgerencia,
                            area: areaName
                        }, function(res) {
                            if (res.success) {
                                Swal.fire('Exito', res.message || 'Area registrada.', 'success');
                                // Recargar select y pre-seleccionar
                                $.get('@Url.Action("ObtenerAreas", "Compensacion")?gerencia=' + encodeURIComponent(gerencia) + '&subgerencia=' + encodeURIComponent(subgerencia), function(resArea) {
                                    var opt = '<option value="">-- TODO (Nivel Subgerencia) --</option>';
                                    if(resArea.success) {
                                        resArea.data.forEach(function(a) { opt += '<option value="'+a+'">'+a+'</option>'; });
                                    }
                                    opt += '<option value="__NUEVA_AREA__" style="font-weight:bold; color:#d9534f;">+ REGISTRAR NUEVA AREA...</option>';
                                    $('#selAreaNueva').html(opt).val(areaName).trigger('change');
                                });
                            } else {
                                Swal.fire('Error', res.message, 'error');
                                $('#selAreaNueva').val('').trigger('change');
                            }
                        });
                    } else {
                        $('#selAreaNueva').val('').trigger('change');
                    }
                });
            }
        });
    });

    function actualizarEstadoFiltroCargo() {
        var certActivo = $('#chkNotifCertificacion').is(':checked');
        var $sel = $('#selNivelCert');
        if (certActivo) {
            $sel.prop('disabled', false);
            $('#secNivelCert').css({
                'opacity': '1',
                'pointer-events': 'auto'
            });
        } else {
            $sel.prop('disabled', true).val('Todos');
            $('#secNivelCert').css({
                'opacity': '0.5',
                'pointer-events': 'none'
            });
        }
        // Notificar a select2 para refrescar estado visual de deshabilitado
        if ($sel.data('select2')) {
            $sel.trigger('change');
        }
    }

    function actualizarObligatoriedadDestinatarios() {
        var certActivo = $('#chkNotifCertificacion').is(':checked');
        if (certActivo) {
            $('#lblDestinatariosPaso4').text('Seleccionar destinatarios (obligatorio)');
        } else {
            $('#lblDestinatariosPaso4').text('Seleccionar destinatarios (opcional)');
        }
    }

    // Re-inicializar Select2 cuando se abre cualquier modal, asegurando dropdownParent correcto y destruyendo instancias previas (excluyendo modalPeriodo)
    $('.modal').on('shown.bs.modal', function () {
        var $modal = $(this);
        $modal.find('select').not('#ddGerencia select, #ddSubgerencia select, #ddArea select, #modalPeriodo select').each(function() {
            var $select = $(this);
            if ($select.data('select2')) {
                $select.select2('destroy');
            }
            $select.select2({
                width: '100%',
                dropdownParent: $modal
            });
        });
    });

    function abrirMonitorValidadores() {
        $('#modalMonitor').modal('show');
        cargarMonitorValidadores();
    }

    function cargarMonitorValidadores() {
        if (!g_PeriodoActivo) return;
        
        $('#tbodyMonitor').html('<tr><td colspan="7" class="text-center py-5"><div class="spinner-border text-danger"></div> Calculando avance de validadores...</td></tr>');
        
        $.get('@Url.Action("ObtenerDashboardRevision", "Compensacion")', { periodoId: g_PeriodoActivo.PeriodoID, tipo: 1 }, function(res) {
            if (res.success) {
                var html = '';
                var listos = 0;
                var pendientes = 0;
                
                res.data.forEach(function(d) {
                    var badgeCls = d.Estado === 'Aprobado' ? 'badge-success' : (d.Estado === 'Enviado' ? 'badge-info' : 'badge-warning');
                    var estadoTxt = d.Estado || 'SIN INICIAR';
                    
                    if (d.Estado === 'Enviado' || d.Estado === 'Aprobado') listos++;
                    else pendientes++;
                    
                    html += '<tr>' +
                        '<td><div class="font-weight-bold">' + d.NombreGerente + '</div><small class="text-muted">' + d.CarnetGerente + '</small></td>' +
                        '<td><small>' + (d.OGERENCIA || '-') + '</small></td>' +
                        '<td class="text-center font-weight-bold">' + d.TotalColaboradores + '</td>' +
                        '<td class="text-center text-primary">' + d.TotalEnPlantilla + '</td>' +
                        '<td class="text-center ' + (d.TotalDiscrepancias > 0 ? 'text-danger font-weight-bold' : 'text-muted') + '">' + d.TotalDiscrepancias + '</td>' +
                        '<td class="text-center"><span class="badge badge-pill ' + badgeCls + ' px-3">' + estadoTxt + '</span></td>' +
                        '<td class="text-right">' +
                            '<button class="btn btn-sm btn-light" onclick="verPersonalValidador(\'' + d.CarnetGerente + '\', \'' + d.NombreGerente + '\')" title="Ver Detalle"><i class="fas fa-search"></i></button>' +
                        '</td>' +
                    '</tr>';
                });
                
                $('#tbodyMonitor').html(html || '<tr><td colspan="7" class="text-center py-5">No hay validadores configurados para este periodo.</td></tr>');
                
                // Actualizar KPIs en el encabezado
                $('#txtJefesListos').text(listos);
                $('#txtJefesPendientes').text(pendientes);
            }
        });
    }

