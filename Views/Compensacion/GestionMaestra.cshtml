    window._personalActualData = [];
    window._personalSortCol = 'Ubicacion';
    window._personalSortDir = 1;

    window.filtrarPersonalColumnas = function() {
        var filters = [];
        $('.filter-row-personal input').each(function() { filters.push($(this).val().toLowerCase()); });
        $('#tbodyPersonalValidador tr').each(function() {
            var show = true;
            $(this).find('td').each(function(idx) {
                if (filters[idx] && $(this).text().toLowerCase().indexOf(filters[idx]) === -1) show = false;
            });
            $(this).toggle(show);
        });
    }

    window.ordenarPersonal = function(col) {
        if (window._personalSortCol === col) {
            window._personalSortDir *= -1;
        } else {
            window._personalSortCol = col;
            window._personalSortDir = 1;
        }
        renderPersonalData(window._personalActualData);
    }

    function renderPersonalData(data) {
        if(!data || data.length === 0) return;
        var sorted = data.slice().sort(function(a, b) {
            var valA = (a[window._personalSortCol] || '').toString().toLowerCase();
            var valB = (b[window._personalSortCol] || '').toString().toLowerCase();
            return valA.localeCompare(valB) * window._personalSortDir;
        });
        var html = '';
        sorted.forEach(function(e) {
            html += '<tr>' +
                '<td><strong>' + (e.CarnetEmpleado || '-') + '</strong></td>' +
                '<td>' + (e.NombreCompleto || '-') + '</td>' +
                '<td><small>' + (e.Gerencia || '-') + '</small></td>' +
                '<td><small>' + (e.Departamento || '-') + '</small></td>' +
                '<td><small>' + (e.Cargo || '-') + '</small></td>' +
                '<td><small>' + (e.Ubicacion || '-') + '</small></td>' +
            '</tr>';
        });
        $('#tbodyPersonalValidador').html(html);
    }

