                    g_PeriodoActivo = res.periodoCom;
                    $('#lblNombrePeriodoCom').text(g_PeriodoActivo.NombrePeriodo);
                    $('#badgeEstadoPeriodoCom').text(g_PeriodoActivo.Estado.toUpperCase())
