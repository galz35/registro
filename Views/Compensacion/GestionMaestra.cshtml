                    var fin = g_PeriodoActivo.FechaFin ? moment(g_PeriodoActivo.FechaFin).format('DD/MM/YYYY HH:mm') : 'No def.';
                    $('#txtVigenciaPeriodoCom').text(inicio + ' al ' + fin);
                } else {
                    g_PeriodoActivo = null;
                    $('#lblNombrePeriodoCom').text("SIN PERIODO ACTIVO");
                    $('#badgeEstadoPeriodoCom').text("CERRADO").removeClass('text-success').addClass('text-danger');
                    $('#txtVigenciaPeriodoCom').text("N/A");
                }

                // Periodo de Certificacion (g_PeriodoCert)
                if(res.periodoCert) {
                    g_PeriodoCert = res.periodoCert;
                    $('#lblNombrePeriodoCert').text(g_PeriodoCert.NombrePeriodo);
                    $('#badgeEstadoPeriodoCert').text(g_PeriodoCert.Estado.toUpperCase())
                        .removeClass('text-success text-danger')
                        .addClass(g_PeriodoCert.Estado === 'Activo' ? 'text-success' : 'text-danger');

                    var inicio = g_PeriodoCert.Fechinicio || g_PeriodoCert.FechaInicio ? moment(g_PeriodoCert.Fechinicio || g_PeriodoCert.FechaInicio).format('DD/MM/YYYY HH:mm') : 'No def.';
                    var fin = g_PeriodoCert.FechaFin ? moment(g_PeriodoCert.FechaFin).format('DD/MM/YYYY HH:mm') : 'No def.';
                    $('#txtVigenciaPeriodoCert').text(inicio + ' al ' + fin);
                } else {
                    g_PeriodoCert = null;
                    $('#lblNombrePeriodoCert').text("SIN PERIODO ACTIVO");
                    $('#badgeEstadoPeriodoCert').text("CERRADO").removeClass('text-success').addClass('text-danger');
                    $('#txtVigenciaPeriodoCert').text("N/A");
