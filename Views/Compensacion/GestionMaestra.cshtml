    window.abrirConfigValidadores = function() {
        cargarListaValidadores();
        $('#modalValidadores').modal('show');
    };

    function cargarListaValidadores() {
        // Llenar select de gerencias inicial
        var gerencias = [];
        for(var i=0; i<universoOriginal.length; i++){
            var g = safeGet(universoOriginal[i], 'OGERENCIA_SIGHO');
            if(g && gerencias.indexOf(g) === -1) gerencias.push(g);
        }

        if(gerencias.length === 0) {
            $.get('@Url.Action("ObtenerGerenciasSigho", "Compensacion")', function(res) {
                if(res.success) {
                    var optHtml = '<option value="">-- SELECCIONE GERENCIA --</option>';
                    res.data.forEach(function(g) { optHtml += '<option value="'+g+'">'+g+'</option>'; });
                    $('#selGerenciaNueva').html(optHtml);
                }
            });
        } else {
            gerencias.sort();
            var optHtml = '<option value="">-- SELECCIONE GERENCIA --</option>';
            gerencias.forEach(function(g) { optHtml += '<option value="'+g+'">'+g+'</option>'; });
            $('#selGerenciaNueva').html(optHtml);
        }

        $('#selSubgerenciaNueva').html('<option value="">-- (OPCIONAL) --</option>');
        $('#selAreaNueva').html('<option value="">-- (OPCIONAL) --</option>');

        $('#tbodyValidadores').html('<tr><td colspan="5" class="text-center p-4"><i class="fas fa-spinner fa-spin"></i> Cargando configuracion...</td></tr>');

        $.get('@Url.Action("ObtenerConfigValidadores", "Compensacion")', function(res) {
            var configActual = res.data || [];
            var html = '';

            if(configActual.length === 0) {
                html = '<tr><td colspan="5" class="text-center p-4 text-muted">No hay validadores configurados.</td></tr>';
            } else {
                // Renderizar sin agrupar, apilando la estructura para ahorrar espacio
                configActual.forEach(function(c) {
                    var ger = safeGet(c, 'Gerencia') || '-';
                    var sub = safeGet(c, 'Subgerencia');
                    var area = safeGet(c, 'Area');
                    var carVal = safeGet(c, 'CarnetValidador');
                    var nomVal = safeGet(c, 'NombreValidador');
                    var carEmp = safeGet(c, 'CarnetEmpleado');

                    // Armar la ruta de estructura
                    var estructuraHtml = '<strong class="text-dark">' + ger + '</strong>';
                    if(sub) estructuraHtml += '<br><small class="text-muted"><i class="fas fa-level-up-alt fa-rotate-90 mr-1"></i>' + sub + '</small>';
                    if(area) estructuraHtml += '<br><small class="text-muted ml-2"><i class="fas fa-level-up-alt fa-rotate-90 mr-1"></i>' + area + '</small>';

                    html += '<tr class="validador-row-item" style="cursor:pointer;" onclick="verPersonalValidador(\'' + carVal + '\', \'' + (nomVal || '').replace(/'/g, "\\'") + '\')">' +
                        '<td class="text-center" onclick="event.stopPropagation();">' +
                            '<input type="checkbox" class="chk-validador" data-id="' + safeGet(c, 'ConfigID') + '" onchange="actualizarEstadoSeleccion()">' +
                        '</td>' +
                        '<td>' + estructuraHtml + '</td>' +
                        '<td><strong>' + (nomVal || '-') + '</strong><br><small class="text-muted">' + carVal + '</small></td>' +
                        '<td class="text-center">' + (carEmp ? '<span class="badge badge-info" title="Asignacion Directa">' + carEmp + '</span>' : '<span class="badge badge-secondary" title="Por Estructura">Masivo</span>') + '</td>' +
                        '<td class="text-center">' +
                            '<button class="btn btn-sm btn-info mb-1" onclick="event.stopPropagation(); verPersonalValidador(\'' + carVal + '\', \'' + (nomVal || '').replace(/'/g, "\\'") + '\')" title="Ver Personal"><i class="fas fa-eye"></i></button><br>' +
                            '<button class="btn btn-sm btn-outline-danger" onclick="event.stopPropagation(); quitarValidador(' + safeGet(c, 'ConfigID') + ', \'' + ger + '\', \'' + carVal + '\')" title="Eliminar"><i class="fas fa-trash-alt"></i></button>' +
                        '</td>' +
                    '</tr>';
                });
            }
            $('#tbodyValidadores').html(html);
            $('#chkSeleccionarTodosVal').prop('checked', false);
            actualizarEstadoSeleccion();
        });

        // Resetear panel derecho
        cerrarPanelDetalle();
    }

    window.filtrarValidadores = function() {
        var query = $('#txtBuscarValidador').val().toLowerCase();
        $('#tbodyValidadores tr').each(function() {
            var text = $(this).text().toLowerCase();
            var visible = text.indexOf(query) > -1;
            $(this).toggle(visible);
            if (!visible) {
                $(this).find('.chk-validador').prop('checked', false);
            }
        });
        actualizarEstadoSeleccion();
    }

    window.seleccionarTodosValidadores = function(headerCheckbox) {
        var checked = $(headerCheckbox).prop('checked');
        $('#tbodyValidadores tr:visible').each(function() {
            $(this).find('.chk-validador').prop('checked', checked);
        });
        actualizarEstadoSeleccion();
    }

    window.actualizarEstadoSeleccion = function() {
        var totalVisibles = $('#tbodyValidadores tr:visible').length;
        var totalChequeados = $('#tbodyValidadores tr:visible .chk-validador:checked').length;

        // Sincronizar checkbox superior
        if (totalVisibles > 0 && totalVisibles === totalChequeados) {
            $('#chkSeleccionarTodosVal').prop('checked', true);
        } else {
            $('#chkSeleccionarTodosVal').prop('checked', false);
        }

        // Mostrar/ocultar boton de eliminacion masiva
        if (totalChequeados > 0) {
            $('#btnEliminarSeleccionadosVal').html('<i class="fas fa-trash-alt mr-1"></i> Eliminar (' + totalChequeados + ')').show();
        } else {
            $('#btnEliminarSeleccionadosVal').hide();
        }
    }

    window.eliminarValidadoresSeleccionados = function() {
        var ids = [];
        $('#tbodyValidadores tr:visible .chk-validador:checked').each(function() {
            var id = $(this).attr('data-id');
            if (id) ids.push(parseInt(id));
        });

        if (ids.length === 0) {
            Swal.fire('Advertencia', 'No se ha seleccionado ningun validador.', 'warning');
            return;
        }

        Swal.fire({
            title: "Eliminar validadores seleccionados?",
            html: 'Se eliminaran <b>' + ids.length + '</b> configuraciones seleccionadas.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            confirmButtonText: 'Si, eliminar',
            cancelButtonText: 'Cancelar'
        }).then(function(result) {
            if (result.isConfirmed) {
                Swal.fire({
                    title: 'Eliminando...',
                    html: 'Por favor espere.',
                    allowOutsideClick: false,
                    didOpen: function() {
                        Swal.showLoading();
                    }
                });

                var promises = ids.map(function(id) {
                    return $.post('@Url.Action("EliminarConfigValidador", "Compensacion")', { configId: id });
                });

                Promise.all(promises).then(function() {
                    cargarListaValidadores();
                    Swal.fire({ icon: 'success', title: 'Eliminados correctamente', timer: 1500, showConfirmButton: false });
                }).catch(function(err) {
                    Swal.fire('Error', 'Ocurrio un error al eliminar algunos validadores.', 'error');
                });
            }
        });
    }

