            var gs = [];
            for(var i=0; i<universoOriginal.length; i++) {
                var g = safeGet(universoOriginal[i], 'OGERENCIA_SIGHO');
                if(g && gs.indexOf(g) === -1) gs.push(g);
            }
            var opt = '<option value="">-- SELECCIONE --</option>';
            gs.sort().forEach(function(x) { opt += '<option value="'+x+'">'+x+'</option>'; });
            $('#histSelGerencia').html(opt);
        } else {
            $('#histFiltroGerenciaCont').hide();
            $('#histFiltroTextoCont').show();
        }
    }

