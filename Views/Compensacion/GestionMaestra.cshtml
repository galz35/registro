                        var cargo = safeGet(r, 'Cargo_SIGHO');
                        return '<b>J:</b> <small>' + (jefe || '-') + '</small><br><b>C:</b> <small>' + (cargo || '-') + '</small>';
                    }
                },
                {
                    data: null,
                    render: function(d, t, r) { return '<small>' + (safeGet(r, 'Ubicacion_SIGHO') || '-') + '</small>'; }
                },
                {
                    data: null,
                    className: 'text-center',
                    render: function(d, t, r) {
                        var val = safeGet(r, 'AplicaEmpleado');
                        var id = safeGet(r, 'DetalleID');
                        var checked = val === 'S' ? 'checked' : '';
                        return '<input type="checkbox" class="check-aplica-dual check-empleado" data-id="' + id + '" ' + checked + '>';
                    }
                },
                {
                    data: null,
                    className: 'text-center',
                    orderable: false,
                    render: function(d, t, r) {
                        var carnet = safeGet(r, 'CarnetEmpleado');
                        return '<button class="btn btn-sm btn-light btn-circle" onclick="verHistorial(\'' + carnet + '\')" title="Ver Historial"><i class="fas fa-history text-muted"></i></button>';
                    }
                }
            ],
            language: {
                search: "Buscar:",
                lengthMenu: "Mostrar _MENU_ registros",
                info: "Mostrando _START_ a _END_ de _TOTAL_ registros",
                paginate: { first: "Primero", last: "Ultimo", next: "Siguiente", previous: "Anterior" }
            }
        });

        // Eventos para filtros por columna
        table.columns().every(function (i) {
            var that = this;
            $('input', $('.filter-row th').eq(i)).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that.search(this.value).draw();
                }
            });
        });

        // Funcion global para filtrar columnas por select (Emp y Com)
        window.filterColumn = function(idx, val) {
            if (val) {
                $('#tablaMaestra tbody tr').removeClass('collapsed').removeClass('hidden-row');
            }
            table.column(idx).search(val ? '^' + val + '$' : '', true, false).draw();
        };

        // Evento Seleccion Masiva por Grupo
        $('#tablaMaestra tbody').on('change', '.check-grupo', function(e) {
            e.stopPropagation();
            var chk = $(this);
            var isChecked = chk.is(':checked');
            var row = chk.closest('tr');
            var level = parseInt(row.attr('data-level'));

            var nextRows = row.nextAll();
            for (var i = 0; i < nextRows.length; i++) {
                var nextRow = $(nextRows[i]);
                var nextLevel = parseInt(nextRow.attr('data-level'));

                if (nextRow.hasClass('group-gerencia') || nextRow.hasClass('group-subgerencia') || nextRow.hasClass('group-area')) {
                    if (nextLevel <= level) break;
                    nextRow.find('.check-grupo').prop('checked', isChecked);
                } else {
                    nextRow.find('.check-fila').prop('checked', isChecked);
                }
            }
        });

        $('#tablaMaestra tbody').on('click', '.check-grupo', function(e) {
            e.stopPropagation();
        });

        // Evento Click para colapsar/expandir
        $('#tablaMaestra tbody').off('click', 'tr[class^="group-"]').on('click', 'tr[class^="group-"]', function (e) {
            if ($(e.target).hasClass('check-grupo')) return;

            var row = $(this);
            var level = parseInt(row.attr('data-level'));
            var isCollapsed = row.hasClass('collapsed');
            row.toggleClass('collapsed');
            var nextRows = row.nextAll();
            for (var i = 0; i < nextRows.length; i++) {
                var nextRow = $(nextRows[i]);
                var nextLevel = parseInt(nextRow.attr('data-level'));
                if (nextRow.hasClass('group-gerencia') || nextRow.hasClass('group-subgerencia') || nextRow.hasClass('group-area')) {
                    if (nextLevel <= level) break;
                }
                if (isCollapsed) {
                    if (isNaN(nextLevel) || nextLevel === level + 1) {
                         nextRow.removeClass('hidden-row');
                         if (!isNaN(nextLevel)) nextRow.addClass('collapsed');
                    }
                } else {
                    nextRow.addClass('hidden-row').addClass('collapsed');
                }
            }
        });
    }

    $(document).on('change', '.check-aplica-dual', function() {
