    function cargarEnEditor(asunto, cuerpo) {
        $('#txtAsuntoPlantilla').val(asunto);
        $('#txtCuerpoPlantilla').val(cuerpo);

        // Editor: mostrar con chips visuales
        var bodyHtml = extraerBody(cuerpo || '');
        $('#divEditorCorreo').html(aChips(bodyHtml));

        // Preview: mostrar con datos de ejemplo
        $('#lblAsuntoPreview').text(reemplazarEjemplos(asunto || ''));
        $('#divCorreoPreview').html(reemplazarEjemplos(bodyHtml));
    }

    // DRAG & DROP de variables
    // Inicializar drag en las tarjetas de variables
    $(document).on('dragstart', '.drag-variable', function(e) {
        var varCode = $(this).attr('data-var');
        e.originalEvent.dataTransfer.setData('text/plain', varCode);
        e.originalEvent.dataTransfer.effectAllowed = 'copy';
        $(this).css('opacity', '0.5');
    });
    $(document).on('dragend', '.drag-variable', function() {
        $(this).css('opacity', '1');
    });

    // Soltar variable en el editor
    window.soltarVariable = function(e) {
        e.preventDefault();
        e.target.style.background = '#fff';
        var varCode = e.dataTransfer.getData('text/plain');
        if (!varCode || !_chipConfig[varCode]) return;

        // Insertar el chip en la posicion del cursor dentro del editor
        var chipHtml = crearChipHTML(varCode);

        // Usar Range/Selection API para insertar en la posicion exacta del drop
        var sel = window.getSelection();
        if (sel.rangeCount) {
            var range = document.caretRangeFromPoint(e.clientX, e.clientY);
            if (range) {
                sel.removeAllRanges();
                sel.addRange(range);
                var frag = document.createRange().createContextualFragment(chipHtml + '&nbsp;');
                range.insertNode(frag);
                // Mover cursor despues del chip insertado
                range.collapse(false);
                sel.removeAllRanges();
                sel.addRange(range);
            }
        }
    };

