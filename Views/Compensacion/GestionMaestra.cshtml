                        <label class="small font-weight-bold text-uppercase text-muted">Estado del Periodo</label>
                        <select id="selEstadoPeriodoConfig" class="form-control border-0 bg-white" style="border-radius:10px;">
                            <option value="Activo">ACTIVO (Abierto para Jefes)</option>
                            <option value="Cerrado">CERRADO (Solo lectura para Jefes)</option>
                        </select>
                    </div>

                    <div class="mt-3">
                        <button id="btnGuardarPeriodoConfig" class="btn btn-success btn-block font-weight-bold py-2 shadow-sm" style="border-radius:10px;" onclick="guardarPeriodo()">
                            <i class="fas fa-save mr-1"></i> Guardar Solo Datos del Periodo
                        </button>
                    </div>
                </div>

                <!-- SECCION 2: DESPACHO DE NOTIFICACIONES -->
                <div class="card border-0 mt-4" style="border-radius:16px; background:#f8f9fb; border: 1px solid #e2e8f0 !important;">
                    <!-- Header -->
                    <div class="card-header border-0 px-4 pt-4 pb-2" style="background:transparent;">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <div id="iconDespachoNotifConfig" class="d-flex align-items-center justify-content-center mr-3" style="width:40px; height:40px; background:linear-gradient(135deg,#ef3829,#c62828); border-radius:10px;">
                                    <i class="fas fa-mail-bulk text-white" style="font-size:1rem;"></i>
                                </div>
                                <div>
                                    <h6 class="font-weight-bold text-dark mb-0">Centro de Despacho de Notificaciones</h6>
                                    <small class="text-muted">Envio controlado de correos a validadores y jefes</small>
                                </div>
                            </div>
                            <span id="badgeConfirmacionDespacho" class="badge badge-danger px-3 py-2" style="font-size:10px; letter-spacing:0.5px; border-radius:20px;">REQUIERE CONFIRMACION</span>
                        </div>
                    </div>

                    <div class="card-body px-4 pt-2 pb-4">
                        <div class="row">
                            <!-- COLUMNA IZQUIERDA: Configuracion -->
                            <div class="col-md-5">
                                <!-- Paso 1: Modulos -->
                                <div class="mb-3">
                                    <div class="d-flex align-items-center mb-2">
                                        <span class="d-flex align-items-center justify-content-center mr-2" style="width:22px; height:22px; background:#ef3829; color:#fff; border-radius:50%; font-size:10px; font-weight:bold;">1</span>
                                        <span class="font-weight-bold text-uppercase text-muted" style="font-size:11px; letter-spacing:0.5px;">Modulo a notificar</span>
                                    </div>
                                    <label class="d-flex align-items-center p-3 mb-2 bg-white" style="border-radius:10px; cursor:pointer; border:1px solid #e2e8f0; transition:all 0.2s;" onmouseover="this.style.borderColor='#ef3829'" onmouseout="this.style.borderColor='#e2e8f0'">
                                        <input type="checkbox" class="mr-3" id="chkNotifComisiones" style="width:17px; height:17px; accent-color:#ef3829;">
                                        <div>
                                            <strong class="text-dark d-block" style="font-size:13px;">Comisiones</strong>
                                            <small class="text-muted">Validadores + copia al Gerente</small>
                                        </div>
                                    </label>
                                    <label class="d-flex align-items-center p-3 mb-0 bg-white" style="border-radius:10px; cursor:pointer; border:1px solid #e2e8f0; transition:all 0.2s;" onmouseover="this.style.borderColor='#ef3829'" onmouseout="this.style.borderColor='#e2e8f0'">
                                        <input type="checkbox" class="mr-3" id="chkNotifCertificacion" style="width:17px; height:17px; accent-color:#ef3829;">
                                        <div>
                                            <strong class="text-dark d-block" style="font-size:13px;">Certificacion</strong>
                                            <small class="text-muted">Jefes inmediatos por nivel</small>
                                        </div>
                                    </label>
                                </div>

                                <!-- Paso 2: Filtro por Cargo -->
                                <div class="mb-3" id="secNivelCert" style="transition: all 0.3s; opacity: 0.5; pointer-events: none;">
                                    <div class="d-flex align-items-center mb-2">
                                        <span class="d-flex align-items-center justify-content-center mr-2" style="width:22px; height:22px; background:#ef3829; color:#fff; border-radius:50%; font-size:10px; font-weight:bold;">2</span>
                                        <span class="font-weight-bold text-uppercase text-muted" style="font-size:11px; letter-spacing:0.5px;">Filtrar por cargo (opcional)</span>
                                    </div>
                                    <select id="selNivelCert" class="form-control bg-white" disabled style="border-radius:10px; height:42px; border:1px solid #e2e8f0; font-size:13px;">
                                        <option value="Todos">Enviar a Todos los Jefes</option>
                                        <option value="Gerente">Solo Gerente de Area</option>
                                        <option value="Subgerente">Solo Subgerente</option>
                                        <option value="Coordinador">Solo Coordinador</option>
                                    </select>
                                    <small class="text-muted mt-1 d-block"><i class="fas fa-info-circle mr-1"></i>Aplica solo para Certificacion</small>
                                </div>

                                <!-- Paso 3: Fecha Limite -->
                                <div class="mb-3">
                                    <div class="d-flex align-items-center mb-2">
                                        <span class="d-flex align-items-center justify-content-center mr-2" style="width:22px; height:22px; background:#ef3829; color:#fff; border-radius:50%; font-size:10px; font-weight:bold;">3</span>
