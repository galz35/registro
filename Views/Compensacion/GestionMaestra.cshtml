    window.verPersonalValidador = function(carnet, nombre) {
        $('#panelDetalleVacio').hide();
        $('#panelDetalleLleno').show();
        $('#lblValidadorSeleccionado').html('<i class="fas fa-user-shield text-danger mr-2"></i>' + nombre + ' <small class="text-muted">(' + carnet + ')</small>');
        $('#tbodyPersonalValidador').html('<tr><td colspan="6" class="text-center p-4"><i class="fas fa-spinner fa-spin text-danger"></i> Consultando personal...</td></tr>');
        $('#txtFiltroPersonal').val('');

        // Marcar fila activa
        $('#tbodyValidadores tr').removeClass('table-active');
        $('#tbodyValidadores tr').each(function() {
            if($(this).text().indexOf(carnet) > -1) $(this).addClass('table-active');
        });

        $.get('@Url.Action("ObtenerPersonalValidador", "Compensacion")', { carnetValidador: carnet }, function(res) {
            if(!res.success) {
                $('#tbodyPersonalValidador').html('<tr><td colspan="6" class="text-center p-4 text-danger"><i class="fas fa-exclamation-triangle mr-1"></i> ' + res.message + '</td></tr>');
                return;
            }

            var data = res.data || [];
            window._personalActualData = data;
            $('#lblTotalPersonal').text(data.length + ' colaboradores');
            $('#lblFuenteDatos').html('<i class="fas fa-database mr-1"></i> Fuente: ' + (res.fuente || 'N/A'));

            if(data.length === 0) {
                $('#tbodyPersonalValidador').html('<tr><td colspan="6" class="text-center p-4 text-muted">Este validador no tiene personal asignado en el periodo activo.</td></tr>');
                return;
            }

            renderPersonalData(data);
        }).fail(function() {
            $('#tbodyPersonalValidador').html('<tr><td colspan="6" class="text-center p-4 text-danger"><i class="fas fa-exclamation-triangle mr-1"></i> Error de conexion</td></tr>');
        });
