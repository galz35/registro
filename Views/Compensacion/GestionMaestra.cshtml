                                    </div>
                                    <input type="date" id="txtFechaLimiteNotif" class="form-control bg-white" style="border-radius:10px; height:42px; border:1px solid #e2e8f0; font-size:13px;">
                                </div>
                            </div>

                            <!-- COLUMNA DERECHA: 3 Combobox con checkboxes -->
                            <div class="col-md-7">
                                <div class="d-flex align-items-center mb-2">
                                    <span class="d-flex align-items-center justify-content-center mr-2" style="width:22px; height:22px; background:#ef3829; color:#fff; border-radius:50%; font-size:10px; font-weight:bold;">4</span>
                                    <span id="lblDestinatariosPaso4" class="font-weight-bold text-uppercase text-muted" style="font-size:11px; letter-spacing:0.5px;">Seleccionar destinatarios (obligatorio)</span>
                                </div>

                                <!-- GERENCIA dropdown checklist -->
                                <div class="mb-3">
                                    <label class="small font-weight-bold text-dark mb-1"><i class="fas fa-building mr-1 text-danger"></i> Gerencia</label>
                                    <div class="dropdown w-100" id="ddGerencia">
                                        <button class="btn btn-block bg-white text-left d-flex justify-content-between align-items-center" type="button" data-toggle="dropdown" aria-expanded="false" style="border:1px solid #e2e8f0; border-radius:10px; height:40px; font-size:13px; color:#555;">
                                            <span id="lblDdGerencia">-- Seleccionar Gerencias --</span>
                                            <i class="fas fa-chevron-down text-muted" style="font-size:10px;"></i>
                                        </button>
                                        <div class="dropdown-menu w-100 p-2 shadow-sm" style="max-height:220px; overflow-y:auto; border-radius:10px; border:1px solid #e2e8f0;">
                                            <div class="px-2 pb-2 mb-2" style="border-bottom:1px solid #f0f0f0;">
                                                <input type="text" class="form-control form-control-sm border-0 bg-light" placeholder="Buscar gerencia..." onkeyup="filtrarDropdown(this, 'ddGerencia')" style="border-radius:6px; font-size:12px;">
                                            </div>
                                            <div class="px-2 pb-2 mb-2" style="border-bottom:1px solid #f0f0f0;">
                                                <label class="d-flex align-items-center mb-0" style="cursor:pointer; font-size:12px; font-weight:bold; color:#333;">
                                                    <input type="checkbox" id="chkAllGerencia" class="mr-2" onchange="toggleAllDropdown('ddGerencia', this.checked);" style="accent-color:#ef3829;"> Seleccionar todas
                                                </label>
                                            </div>
                                            <div id="ddGerenciaItems"></div>
                                        </div>
                                    </div>
                                </div>

                                <!-- SUBGERENCIA dropdown checklist -->
                                <div class="mb-3">
                                    <label class="small font-weight-bold text-dark mb-1"><i class="fas fa-sitemap mr-1 text-danger"></i> Subgerencia</label>
                                    <div class="dropdown w-100" id="ddSubgerencia">
                                        <button class="btn btn-block bg-white text-left d-flex justify-content-between align-items-center" type="button" data-toggle="dropdown" aria-expanded="false" style="border:1px solid #e2e8f0; border-radius:10px; height:40px; font-size:13px; color:#555;">
                                            <span id="lblDdSubgerencia">-- Seleccionar Subgerencias --</span>
                                            <i class="fas fa-chevron-down text-muted" style="font-size:10px;"></i>
                                        </button>
                                        <div class="dropdown-menu w-100 p-2 shadow-sm" style="max-height:220px; overflow-y:auto; border-radius:10px; border:1px solid #e2e8f0;">
                                            <div class="px-2 pb-2 mb-2" style="border-bottom:1px solid #f0f0f0;">
                                                <input type="text" class="form-control form-control-sm border-0 bg-light" placeholder="Buscar subgerencia..." onkeyup="filtrarDropdown(this, 'ddSubgerencia')" style="border-radius:6px; font-size:12px;">
                                            </div>
                                            <div class="px-2 pb-2 mb-2" style="border-bottom:1px solid #f0f0f0;">
                                                <label class="d-flex align-items-center mb-0" style="cursor:pointer; font-size:12px; font-weight:bold; color:#333;">
                                                    <input type="checkbox" id="chkAllSubgerencia" class="mr-2" onchange="toggleAllDropdown('ddSubgerencia', this.checked);" style="accent-color:#ef3829;"> Seleccionar todas
                                                </label>
                                            </div>
                                            <div id="ddSubgerenciaItems"></div>
                                        </div>
                                    </div>
                                </div>

                                <!-- AREA dropdown checklist -->
                                <div class="mb-3">
                                    <label class="small font-weight-bold text-dark mb-1"><i class="fas fa-layer-group mr-1 text-danger"></i> Area / Departamento</label>
                                    <div class="dropdown w-100" id="ddArea">
                                        <button class="btn btn-block bg-white text-left d-flex justify-content-between align-items-center" type="button" data-toggle="dropdown" aria-expanded="false" style="border:1px solid #e2e8f0; border-radius:10px; height:40px; font-size:13px; color:#555;">
                                            <span id="lblDdArea">-- Seleccionar Areas --</span>
                                            <i class="fas fa-chevron-down text-muted" style="font-size:10px;"></i>
                                        </button>
                                        <div class="dropdown-menu w-100 p-2 shadow-sm" style="max-height:220px; overflow-y:auto; border-radius:10px; border:1px solid #e2e8f0;">
                                            <div class="px-2 pb-2 mb-2" style="border-bottom:1px solid #f0f0f0;">
                                                <input type="text" class="form-control form-control-sm border-0 bg-light" placeholder="Buscar area..." onkeyup="filtrarDropdown(this, 'ddArea')" style="border-radius:6px; font-size:12px;">
                                            </div>
                                            <div class="px-2 pb-2 mb-2" style="border-bottom:1px solid #f0f0f0;">
                                                <label class="d-flex align-items-center mb-0" style="cursor:pointer; font-size:12px; font-weight:bold; color:#333;">
                                                    <input type="checkbox" id="chkAllArea" class="mr-2" onchange="toggleAllDropdown('ddArea', this.checked);" style="accent-color:#ef3829;"> Seleccionar todas
                                                </label>
                                            </div>
                                            <div id="ddAreaItems"></div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Resumen de seleccion -->
                                <div class="d-flex align-items-center justify-content-between p-2 bg-white" style="border-radius:8px; border:1px solid #e2e8f0;">
                                    <small class="text-muted"><i class="fas fa-filter mr-1"></i> Seleccion actual:</small>
                                    <span id="lblResumenSeleccion" class="badge badge-danger px-3 py-1" style="font-size:11px;">Sin filtros</span>
                                </div>
