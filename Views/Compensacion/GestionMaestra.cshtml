    // Variable global para almacenar todas las estructuras
    window._todasEstructuras = [];

    window.poblarDropdownEstructuras = function(universo) {
        var gerSet = {}, subSet = {}, areaSet = {};
        var estructuras = [];
        var tempKeys = {};
        
        for (var i = 0; i < universo.length; i++) {
            var row = universo[i];
            var g = (safeGet(row, 'OGERENCIA_SIGHO') || '').trim();
            var s = (safeGet(row, 'OSUBGERENCIA_SIGHO') || '').trim();
            var a = (safeGet(row, 'Area_SIGHO') || '').trim();
            if (g) {
                gerSet[g] = true;
                if (s) subSet[s] = true;
                if (a) areaSet[a] = true;
                var key = g + '|' + s + '|' + a;
                if (!tempKeys[key]) {
                    tempKeys[key] = true;
                    estructuras.push({ Gerencia: g, Subgerencia: s, Area: a });
                }
            }
        }
        window._todasEstructuras = estructuras;
        
        // Poblar dropdown Gerencia (con checked por defecto)
        var gerArr = Object.keys(gerSet).sort();
        var htmlGer = '';
        gerArr.forEach(function(g) {
            htmlGer += '<label class="dropdown-item-chk d-flex align-items-center px-2 py-1 mb-0" style="cursor:pointer; border-radius:6px; font-size:12px;" onmouseover="this.style.background=\'#f7f7f7\'" onmouseout="this.style.background=\'transparent\'">' +
                '<input type="checkbox" class="chk-dd-gerencia mr-2" checked value="' + g.replace(/"/g, '&quot;') + '" onchange="alCambiarFiltroEstructura(\'gerencia\')" style="accent-color:#ef3829;"> ' + g + '</label>';
        });
        $('#ddGerenciaItems').html(htmlGer);
        
        // Poblar dropdown Subgerencia (con checked por defecto)
        var subArr = Object.keys(subSet).sort();
        var htmlSub = '';
        subArr.forEach(function(s) {
            htmlSub += '<label class="dropdown-item-chk d-flex align-items-center px-2 py-1 mb-0" style="cursor:pointer; border-radius:6px; font-size:12px;" onmouseover="this.style.background=\'#f7f7f7\'" onmouseout="this.style.background=\'transparent\'">' +
                '<input type="checkbox" class="chk-dd-subgerencia mr-2" checked value="' + s.replace(/"/g, '&quot;') + '" onchange="alCambiarFiltroEstructura(\'subgerencia\')" style="accent-color:#ef3829;"> ' + s + '</label>';
        });
        $('#ddSubgerenciaItems').html(htmlSub || '<div class="text-center text-muted small py-2">No hay subgerencias</div>');
        
        // Poblar dropdown Area (con checked por defecto)
        var areaArr = Object.keys(areaSet).sort();
        var htmlArea = '';
        areaArr.forEach(function(a) {
            htmlArea += '<label class="dropdown-item-chk d-flex align-items-center px-2 py-1 mb-0" style="cursor:pointer; border-radius:6px; font-size:12px;" onmouseover="this.style.background=\'#f7f7f7\'" onmouseout="this.style.background=\'transparent\'">' +
                '<input type="checkbox" class="chk-dd-area mr-2" checked value="' + a.replace(/"/g, '&quot;') + '" onchange="alCambiarFiltroEstructura(\'area\')" style="accent-color:#ef3829;"> ' + a + '</label>';
        });
        $('#ddAreaItems').html(htmlArea || '<div class="text-center text-muted small py-2">No hay areas</div>');
        
        // Inicializar el resumen y los filtros jerarquicos
        alCambiarFiltroEstructura('gerencia');
    };

    window.filtrarDropdown = function(input, ddId) {
        var query = input.value.toLowerCase();
        $('#' + ddId + 'Items label').each(function() {
            var text = $(this).text().toLowerCase();
            if (text.indexOf(query) > -1) {
                $(this).removeClass('d-none-search');
            } else {
                $(this).addClass('d-none-search');
            }
        });
    };

    window.alCambiarFiltroEstructura = function(tipo) {
        var gerSel = []; $('#ddGerenciaItems .chk-dd-gerencia:checked').each(function() { gerSel.push($(this).val().toLowerCase()); });
        var subSel = []; $('#ddSubgerenciaItems .chk-dd-subgerencia:checked').each(function() { subSel.push($(this).val().toLowerCase()); });
        
        if (tipo === 'gerencia') {
            // Filtrar Subgerencias por Gerencia seleccionada
            if (gerSel.length === 0) {
                $('#ddSubgerenciaItems label').removeClass('d-none-hierarchy');
            } else {
                var subValidas = {};
                window._todasEstructuras.forEach(function(est) {
                    var gLower = (est.Gerencia || '').toLowerCase();
                    if (gerSel.indexOf(gLower) > -1 && est.Subgerencia) {
                        subValidas[est.Subgerencia.toLowerCase()] = true;
                    }
                });
                $('#ddSubgerenciaItems .chk-dd-subgerencia').each(function() {
                    var val = ($(this).val() || '').toLowerCase();
                    var label = $(this).closest('label');
                    if (subValidas[val]) {
                        if (label.hasClass('d-none-hierarchy')) {
                            $(this).prop('checked', true);
                        }
                        label.removeClass('d-none-hierarchy');
                    } else {
                        $(this).prop('checked', false);
                        label.addClass('d-none-hierarchy');
                    }
                });
            }
            // Recalcular subSel despues de desmarcar las no validas
            subSel = []; $('#ddSubgerenciaItems .chk-dd-subgerencia:checked').each(function() { subSel.push($(this).val().toLowerCase()); });
        }

        if (tipo === 'gerencia' || tipo === 'subgerencia') {
            // Filtrar Areas por Gerencia y Subgerencia seleccionadas
            if (gerSel.length === 0 && subSel.length === 0) {
                $('#ddAreaItems label').removeClass('d-none-hierarchy');
            } else {
                var areasValidas = {};
                window._todasEstructuras.forEach(function(est) {
                    var gLower = (est.Gerencia || '').toLowerCase();
                    var sLower = (est.Subgerencia || '').toLowerCase();
                    var matchGer = gerSel.length === 0 || gerSel.indexOf(gLower) > -1;
                    var matchSub = subSel.length === 0 || subSel.indexOf(sLower) > -1;
                    if (matchGer && matchSub && est.Area) {
                        areasValidas[est.Area.toLowerCase()] = true;
                    }
                });
                $('#ddAreaItems .chk-dd-area').each(function() {
                    var val = ($(this).val() || '').toLowerCase();
                    var label = $(this).closest('label');
                    if (areasValidas[val]) {
                        if (label.hasClass('d-none-hierarchy')) {
                            $(this).prop('checked', true);
                        }
                        label.removeClass('d-none-hierarchy');
                    } else {
                        $(this).prop('checked', false);
                        label.addClass('d-none-hierarchy');
                    }
                });
            }
        }

        actualizarResumenSeleccion();
    };

    window.toggleAllDropdown = function(ddId, val) {
        $('#' + ddId + 'Items input[type=checkbox]:visible').prop('checked', val);
        if (ddId === 'ddGerencia') {
            alCambiarFiltroEstructura('gerencia');
            if (val === true) {
                $('#chkAllSubgerencia').prop('checked', true);
                toggleAllDropdown('ddSubgerencia', true);
            } else {
                $('#chkAllSubgerencia').prop('checked', false);
                toggleAllDropdown('ddSubgerencia', false);
            }
        } else if (ddId === 'ddSubgerencia') {
            alCambiarFiltroEstructura('subgerencia');
            if (val === true) {
                $('#chkAllArea').prop('checked', true);
                toggleAllDropdown('ddArea', true);
            } else {
                $('#chkAllArea').prop('checked', false);
                toggleAllDropdown('ddArea', false);
            }
        } else {
            alCambiarFiltroEstructura('area');
        }
    };

    window.actualizarResumenSeleccion = function() {
        var gSel = $('#ddGerenciaItems .chk-dd-gerencia:checked').length;
        var sSel = $('#ddSubgerenciaItems .chk-dd-subgerencia:checked').length;
        var aSel = $('#ddAreaItems .chk-dd-area:checked').length;
        
        // Actualizar labels de botones con los nombres reales si son pocos
        var gerNames = [];
        $('#ddGerenciaItems .chk-dd-gerencia:checked').each(function() {
            gerNames.push($(this).val().trim());
        });
        var textGer = '-- Seleccionar Gerencias --';
        if (gerNames.length > 0) {
            textGer = gerNames.length <= 3 ? gerNames.join(', ') : gerNames.length + ' gerencia(s)';
        }
        $('#lblDdGerencia').text(textGer);

        var subNames = [];
        $('#ddSubgerenciaItems .chk-dd-subgerencia:checked').each(function() {
            subNames.push($(this).val().trim());
        });
        var textSub = '-- Seleccionar Subgerencias --';
        if (subNames.length > 0) {
            textSub = subNames.length <= 3 ? subNames.join(', ') : subNames.length + ' subgerencia(s)';
        }
        $('#lblDdSubgerencia').text(textSub);

        var areaNames = [];
        $('#ddAreaItems .chk-dd-area:checked').each(function() {
            areaNames.push($(this).val().trim());
        });
        var textArea = '-- Seleccionar Areas --';
        if (areaNames.length > 0) {
            textArea = areaNames.length <= 3 ? areaNames.join(', ') : areaNames.length + ' area(s)';
        }
        $('#lblDdArea').text(textArea);
        
        // Sincronizar el checkbox superior "Seleccionar todas" de cada dropdown
        var totalGer = $('#ddGerenciaItems .chk-dd-gerencia').length;
        $('#chkAllGerencia').prop('checked', totalGer > 0 && totalGer === gSel);

        var totalSub = $('#ddSubgerenciaItems .chk-dd-subgerencia:visible').length;
        var checkedSubVisible = $('#ddSubgerenciaItems .chk-dd-subgerencia:visible:checked').length;
        $('#chkAllSubgerencia').prop('checked', totalSub > 0 && totalSub === checkedSubVisible);

        var totalArea = $('#ddAreaItems .chk-dd-area:visible').length;
        var checkedAreaVisible = $('#ddAreaItems .chk-dd-area:visible:checked').length;
        $('#chkAllArea').prop('checked', totalArea > 0 && totalArea === checkedAreaVisible);

        var total = gSel + sSel + aSel;
        if (total > 0) {
            var parts = [];
            if (gSel > 0) parts.push(gSel + ' Ger');
            if (sSel > 0) parts.push(sSel + ' Sub');
            if (aSel > 0) parts.push(aSel + ' Area');
            $('#lblResumenSeleccion').text(parts.join(' | ')).removeClass('badge-danger').addClass('badge-success');
        } else {
            $('#lblResumenSeleccion').text('Sin filtros').removeClass('badge-success').addClass('badge-danger');
        }
    };

    window.obtenerEstructurasSeleccionadas = function() {
        var gerSel = []; $('#ddGerenciaItems .chk-dd-gerencia:checked').each(function() { gerSel.push($(this).val().toLowerCase()); });
        var subSel = []; $('#ddSubgerenciaItems .chk-dd-subgerencia:checked').each(function() { subSel.push($(this).val().toLowerCase()); });
        var areaSel = []; $('#ddAreaItems .chk-dd-area:checked').each(function() { areaSel.push($(this).val().toLowerCase()); });
        
        // Filtrar las estructuras que coincidan con CUALQUIERA de los filtros seleccionados
        var resultado = [];
        var keys = {};
        window._todasEstructuras.forEach(function(est) {
            var gLower = (est.Gerencia || '').toLowerCase();
            var sLower = (est.Subgerencia || '').toLowerCase();
            var aLower = (est.Area || '').toLowerCase();
            
            var matchGer = gerSel.length === 0 || gerSel.indexOf(gLower) > -1;
            var matchSub = subSel.length === 0 || subSel.indexOf(sLower) > -1;
            var matchArea = areaSel.length === 0 || areaSel.indexOf(aLower) > -1;
            
            if (matchGer && matchSub && matchArea) {
                var k = est.Gerencia + '|' + est.Subgerencia + '|' + est.Area;
                if (!keys[k]) {
                    keys[k] = true;
                    resultado.push(est);
                }
            }
        });
        return resultado;
    };

    window.reabrirPeriodo = function() {
        Swal.fire({
            title: 'Reabrir Periodo?',
            text: 'Permitira que los validadores vuelvan a enviar informacion.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Si, reabrir',
            cancelButtonText: 'Cancelar'
        }).then(function(r) {
            if(r.isConfirmed) {
                $.post('@Url.Action("ReabrirPeriodo", "Compensacion")', { periodoId: g_PeriodoActivo.PeriodoID }, function(res) {
                    if(res.success) {
                        $('#modalPeriodo').modal('hide');
                        Swal.fire('Reabierto', 'Periodo listo para ajustes.', 'success').then(function() { location.reload(); });
                    }
                });
            }
        });
    };

    function safeGet(row, key) {
        if (!row) return "";
        if (row[key] !== undefined && row[key] !== null) return row[key];
        var lowerKey = key.toLowerCase();
        for (var k in row) {
            if (k.toLowerCase() === lowerKey) return row[k];
        }
        return "";
    }

    function renderizarTabla(data) {
        if (table) table.destroy();

        table = $('#tablaMaestra').DataTable({
            data: data,
            deferRender: true,
            pageLength: 50,
            autoWidth: false,
            order: [[2, 'asc'], [3, 'asc'], [4, 'asc'], [1, 'asc']],
            drawCallback: function() {
                // Eliminar la logica de ocultar filas
                $('#tablaMaestra tbody tr').removeClass('hidden-row');
            },
            columns: [
                {
                    data: null,
                    className: 'text-center',
                    orderable: false,
                    render: function(d, t, r) {
                        var id = safeGet(r, 'DetalleID');
                        return '<input type="checkbox" class="check-fila" data-id="' + id + '">';
                    }
                },
                {
                    data: null,
                    render: function(d, t, r) {
                        var nombre = safeGet(r, 'NombreCompleto');
                        var carnet = safeGet(r, 'CarnetEmpleado');
                        return '<strong>' + nombre + '</strong><br><small class="text-muted">' + carnet + '</small>';
                    }
                },
                {
                    data: null,
                    visible: true,
                    render: function(d, t, r) { return '<small>' + safeGet(r, 'OGERENCIA_SIGHO') + '</small>'; }
                },
                {
                    data: null,
                    visible: true,
                    render: function(d, t, r) { return '<small>' + safeGet(r, 'OSUBGERENCIA_SIGHO') + '</small>'; }
                },
                {
                    data: null,
                    visible: true,
                    render: function(d, t, r) { return '<small>' + safeGet(r, 'Area_SIGHO') + '</small>'; }
                },
                {
                    data: null,
                    render: function(d, t, r) {
                        var nom = safeGet(r, 'NombreGerente');
                        var car = safeGet(r, 'CarnetValidador');
                        if(!car) return '<small class="text-muted italic">Sin asignar</small>';
                        return '<strong>' + nom + '</strong><br><small class="text-muted">' + car + '</small>';
