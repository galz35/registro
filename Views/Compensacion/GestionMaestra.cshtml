            </div>
            <div class="modal-body p-4">
                <!-- SECCION 1: CONFIGURACION GENERAL DEL PERIODO -->
                <div class="card border-0 bg-light p-3 mb-4" style="border-radius:15px; border-left: 5px solid #333 !important;">
                    <h6 class="font-weight-bold text-dark text-uppercase mb-3"><i class="fas fa-cog mr-1"></i> Datos del Periodo</h6>
                    <div class="alert alert-light border-0 bg-white mb-3" style="border-radius:10px;">
                        <div class="d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center flex-grow-1 mr-3">
                                <i class="fas fa-calendar-check text-danger mr-3" style="font-size:1.5rem"></i>
                                <div class="flex-grow-1">
