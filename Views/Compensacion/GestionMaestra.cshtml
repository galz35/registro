                                <label class="small font-weight-bold text-uppercase text-muted">Fecha de Cierre (Fin)</label>
                                <input type="datetime-local" id="txtFechaFin" class="form-control border-0 bg-white" style="border-radius:10px;">
                            </div>
                        </div>
                    </div>

