@{ ViewBag.Title = "Gestion Maestra de Compensacion"; }
<div id="pageLoader" class="page-loader">
    <div class="loader-content text-center">
        <div class="spinner-claro"></div>
        <div class="loader-text mt-3">Cargando informacion estrategica...</div>
    </div>
</div>
<style>
    :root {
        --claro-red: #ef3829;
    }

    /* Loader Style */
    .page-loader {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255,255,255,0.8);
        backdrop-filter: blur(8px);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        transition: opacity 0.5s ease;
    }

    .spinner-claro {
        width: 60px;
        height: 60px;
        border: 5px solid #f3f3f3;
        border-top: 5px solid var(--claro-red);
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin: 0 auto;
    }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .loader-text {
        color: #333;
        font-weight: 600;
        font-size: 1.1rem;
        letter-spacing: 1px;
    }

    .bg-claro {
        background: var(--claro-red-grad) !important;
    }

    .card {
        border-radius: 15px;
        border: none;
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
    }

    .table thead th {
        background-color: #f8f9fa;
        text-transform: uppercase;
        font-size: 11px;
        letter-spacing: 0.5px;
        border-bottom: 2px solid #eee;
    }

    .btn-rounded {
        border-radius: 50px;
        padding: 6px 20px;
        font-weight: 600;
    }

    .status-badge {
        font-size: 11px;
        padding: 4px 10px;
        border-radius: 20px;
    }

    .btn-rounded {
        border-radius: 50px;
        padding: 6px 20px;
        font-weight: 600;
    }

    .status-badge {
        font-size: 11px;
        padding: 4px 10px;
        border-radius: 20px;
    }

    .check-aplica-dual {
        width: 1.1rem;
        height: 1.1rem;
        cursor: pointer;
        accent-color: var(--claro-red);
    }

    /* Estilos para Agrupamiento Contrible */
    tr.group-gerencia, tr.group-subgerencia, tr.group-area {
        cursor: pointer;
        user-select: none;
    }

    tr.group-gerencia {
        background-color: #f5f5f5 !important;
    }

        tr.group-gerencia td {
            color: #424242;
            font-weight: 800;
            text-transform: uppercase;
            font-size: 13px;
            border-left: 5px solid #424242 !important;
            padding: 12px 15px !important;
        }

    tr.group-subgerencia {
        background-color: #f8f9fa !important;
    }

        tr.group-subgerencia td {
            color: #495057;
            font-weight: 700;
            font-size: 12px;
            padding-left: 30px !important;
            border-left: 5px solid #adb5bd !important;
        }

    tr.group-area {
        background-color: #ffffff !important;
    }

        tr.group-area td {
            color: #6c757d;
            font-weight: 600;
            font-size: 11px;
            padding-left: 50px !important;
            border-left: 3px solid #dee2e6 !important;
            border-bottom: 1px solid #f1f1f1 !important;
        }

    .check-grupo {
        width: 1rem;
        height: 1rem;
        margin-right: 10px;
        cursor: pointer;
        vertical-align: middle;
    }

    .group-icon {
        transition: transform 0.2s;
        display: inline-block;
        width: 20px;
        text-align: center;
    }

    .collapsed .group-icon {
        transform: rotate(-90deg);
    }

    /* Filtros por columna */
    .filter-row th {
        padding: 5px !important;
        background: #fff !important;
    }

    .btn-circle {
        width: 30px;
        height: 30px;
        padding: 6px 0px;
        border-radius: 15px;
        text-align: center;
        font-size: 12px;
        line-height: 1.42857;
    }

    /* Estilos Premium para Modal de Validadores */
    #modalValidadores .modal-content {
        border-radius: 20px;
        border: none;
        box-shadow: 0 15px 50px rgba(0,0,0,0.2);
    }

    #modalValidadores .modal-header {
        background: #fff;
        border-bottom: 1px solid #f0f0f0;
        border-radius: 20px 20px 0 0;
        color: #333;
    }

    #modalValidadores .modal-title {
        color: #d9534f;
    }
    /* Rojo suave para el titulo */
    #modalValidadores .table thead th {
        background: #f8f9fa;
        color: #444;
        text-transform: uppercase;
        font-size: 11px;
        border: none;
        padding: 15px;
    }

    #modalValidadores .table tbody td {
        vertical-align: middle;
        padding: 12px 15px;
        color: #555;
        border-top: 1px solid #f9f9f9;
    }

    #modalValidadores .form-control {
        background: #f5f6f7;
        border: 1px solid #eee;
    }

    #modalValidadores .form-control:focus {
            background: #fff;
            box-shadow: 0 5px 15px rgba(217, 83, 79, 0.15);
            border-color: #d9534f;
        }

    #modalValidadores .modal-body {
        padding: 40px !important;
    }

    /* Layout de 2 paneles del modal de Validadores */
    #colListaValidadores {
        border-right: 2px solid #f0f0f0;
        padding-right: 20px;
    }

    #colDetalleValidador {
        padding-left: 20px;
    }

    .validador-row-item:hover {
        background: #fff5f5 !important;
    }

    .validador-row-item.table-active {
        background: #ffebee !important;
        border-left: 4px solid #d9534f;
    }

    #panelDetalleLleno {
        animation: fadeSlideIn 0.3s ease;
    }

    @@keyframes fadeSlideIn {
        from { opacity: 0; transform: translateX(15px); }
        to { opacity: 1; transform: translateX(0); }
    }

    #tablaPersonalValidador tbody tr:hover {
        background: #f8f9fa;
    }

    .form-group-premium {
        margin-bottom: 25px;
    }

    .form-group-premium label {
        display: block;
        margin-bottom: 10px;
        color: #555;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    .italic {
        font-style: italic;
    }

    .column-filter {
        width: 100%;
        border-radius: 4px;
        border: 1px solid #ddd;
        padding: 4px 8px;
        font-size: 12px;
        font-weight: normal;
    }

        .column-filter:focus {
            border-color: var(--claro-red);
            outline: none;
            box-shadow: 0 0 5px rgba(227, 25, 25, 0.2);
        }

    .table-hover tbody tr:not([class*="group-"]):hover {
        background-color: rgba(227, 25, 25, 0.03);
    }

    .hidden-row {
        display: none !important;
    }

    /* Estilos para Modal Historial */
    #modalHistorial .modal-content {
        border-radius: 20px;
        border: none;
        box-shadow: 0 15px 50px rgba(0,0,0,0.2);
    }

    #modalHistorial .modal-header {
        background: linear-gradient(135deg, #B71C1C 0%, #DA291C 100%);
        border-radius: 20px 20px 0 0;
    }

    #modalHistorial .modal-title {
        color: #fff;
    }

    #modalHistorial .modal-header .close {
        color: #fff;
        text-shadow: none;
        opacity: 0.8;
    }

    .hist-badge-cambio {
        background: #fff3e0;
        color: #e65100;
        font-size: 10px;
        padding: 2px 8px;
        border-radius: 10px;
        font-weight: 600;
    }

    .hist-badge-ok {
        background: #e8f5e9;
        color: #2e7d32;
        font-size: 10px;
        padding: 2px 8px;
        border-radius: 10px;
        font-weight: 600;
    }

    .hist-periodo-header {
        background: #f5f5f5;
        font-weight: 700;
        font-size: 13px;
        border-left: 4px solid #B71C1C;
    }

    .hist-info-card {
        background: linear-gradient(135deg, #e8eaf6, #c5cae9);
        border-radius: 15px;
        padding: 15px 20px;
    }

    .hist-tab {
        border: none;
        background: #fff5f5;
        color: #B71C1C;
        border-radius: 20px;
        padding: 6px 18px;
        font-weight: 600;
        font-size: 12px;
        cursor: pointer;
        margin-right: 5px;
    }

        .hist-tab.active {
            background: #B71C1C;
            color: #fff;
        }
</style>

<div class="continer-fluid py-4 animate__animated animate__fadeIn">
    <div class="row mb-4 sticky-actions py-2">
        <div class="col-md-6">
            <h3 class="font-weight-bold text-dark mb-0">Gestion Maestra</h3>
            <p class="text-muted small mb-0">Configuracion global del universo de colaboradores.</p>
        </div>
        <div class="col-md-6 text-right">
            <div class="btn-group mr-2">
                <button type="button" class="btn btn-outline-dark btn-rounded dropdown-toggle" data-toggle="dropdown">
                    <i class="fas fa-file-invoice mr-1"></i> Ver Reportes Revision
                </button>
                <div class="dropdown-menu dropdown-menu-right border-0 shadow" style="min-width: 280px;">
                    <h6 class="dropdown-header">MODULO COMISIONES</h6>
                    <a class="dropdown-item" href="@Url.Action("RevisionComisiones", "Compensacion")"><i class="fas fa-table mr-2 text-warning"></i> Ver Tabla Revision</a>
                    <a class="dropdown-item" href="javascript:void(0)" onclick="descargarExcel(1)"><i class="fas fa-file-excel mr-2 text-success"></i> Descargar Excel Cambios</a>

                    <div class="dropdown-divider"></div>

                    <h6 class="dropdown-header">MODULO CERTIFICACION</h6>
                    <a class="dropdown-item" href="@Url.Action("RevisionCertificacion", "Compensacion")"><i class="fas fa-table mr-2 text-danger"></i> Ver Tabla Revision</a>
                    <a class="dropdown-item" href="javascript:void(0)" onclick="descargarExcel(2)"><i class="fas fa-file-excel mr-2 text-success"></i> Descargar Excel Cambios</a>
                </div>
            </div>
            <button class="btn btn-outline-danger btn-rounded mr-2" style="border-color:#B71C1C; color:#B71C1C;" onclick="abrirHistorial()">
                <i class="fas fa-history mr-1"></i> Historial
            </button>
            <button class="btn btn-outline-danger btn-rounded mr-2" onclick="abrirConfigValidadores()">
                <i class="fas fa-user-shield mr-1"></i> Validadores
            </button>
 
            @* Boton Sincronizar Eliminado a solicitud de usuario *@
            <button class="btn btn-primary btn-rounded shadow" style="background:#424242; border-color:#424242;" onclick="guardarCambios()">
                <i class="fas fa-save"></i> Guardar Todo
            </button>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-left-claro h-100">
                <div class="card-body py-3 text-center">
                    <h6 class="text-muted small font-weight-bold text-uppercase mb-1">Universo de Personal</h6>
                    <div class="h5 mb-0 font-weight-bold text-dark" id="txtUniverso">0</div>
                </div>
            </div>
        </div>
        <div class="col-md-9">
            <div class="card shadow-sm border-left-claro h-100 bg-light">
                <div class="card-body py-2">
                    <div class="row align-items-center mb-2 pb-2 border-bottom">
                        <div class="col-md-3 border-right">
                            <h6 class="text-muted small font-weight-bold text-uppercase mb-1">Periodo Comisiones</h6>
                            <div class="h6 mb-0 font-weight-bold text-dark" id="lblNombrePeriodoCom">...</div>
                        </div>
                        <div class="col-md-3 border-right text-center">
                            <h6 class="text-muted small font-weight-bold text-uppercase mb-1">Estado</h6>
                            <div id="badgeEstadoPeriodoCom" class="h6 mb-0 font-weight-bold text-success">...</div>
                        </div>
                        <div class="col-md-4 border-right">
                            <h6 class="text-muted small font-weight-bold text-uppercase mb-1">Vigencia Web</h6>
                            <div class="small font-weight-bold text-dark">
                                <i class="far fa-calendar-alt"></i> <span id="txtVigenciaPeriodoCom">No configurada</span>
                            </div>
                        </div>
                        <div class="col-md-2 text-center p-0">
                            <button class="btn btn-sm btn-outline-dark btn-block" onclick="abrirConfigPeriodo(1)" title="Configurar Periodo Comisiones">
                                <i class="fas fa-cog"></i> Comisiones
                            </button>
                        </div>
                    </div>
                    <div class="row align-items-center">
                        <div class="col-md-3 border-right">
                            <h6 class="text-muted small font-weight-bold text-uppercase mb-1">Periodo Certificacion</h6>
                            <div class="h6 mb-0 font-weight-bold text-dark" id="lblNombrePeriodoCert">...</div>
                        </div>
                        <div class="col-md-3 border-right text-center">
                            <h6 class="text-muted small font-weight-bold text-uppercase mb-1">Estado</h6>
                            <div id="badgeEstadoPeriodoCert" class="h6 mb-0 font-weight-bold text-success">...</div>
                        </div>
                        <div class="col-md-4 border-right">
                            <h6 class="text-muted small font-weight-bold text-uppercase mb-1">Vigencia Web</h6>
                            <div class="small font-weight-bold text-dark">
                                <i class="far fa-calendar-alt"></i> <span id="txtVigenciaPeriodoCert">No configurada</span>
                            </div>
                        </div>
                        <div class="col-md-2 text-center p-0">
                            <button class="btn btn-sm btn-outline-danger btn-block" onclick="abrirConfigPeriodo(2)" title="Configurar Periodo Certificacion">
                                <i class="fas fa-cog"></i> Certificacion
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .border-left-claro {
            border-left: 4px solid var(--claro-red) !important;
        }
    </style>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="m-0 font-weight-bold text-dark"><i class="fas fa-users mr-2 text-danger"></i>Gestion Maestro de Compensacion</h5>
     
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive p-3">
                <table id="tablaMaestra" class="table table-hover align-middle w-100">
                    <thead>
                        <tr>
                            <th class="text-center" style="width: 40px;"><input type="checkbox" id="checkAll"></th>
                            <th>Colaborador</th>
                            <th>Gerencia</th>
                            <th>Subgerencia</th>
                            <th>Departamento</th>
                            <th>Validador</th>
                            <th>Jefe / Cargo</th>
                            <th>Ubicacion</th>
                            <th class="text-center">Emp.</th>
                            <th class="text-center">Acc.</th>
                        </tr>
                        <tr class="filter-row">
                            <th></th>
                            <th><input type="text" class="column-filter" placeholder="Nombre/Carnet"></th>
                            <th><input type="text" class="column-filter" placeholder="Filtro Gerencia"></th>
                            <th><input type="text" class="column-filter" placeholder="Filtro Subger."></th>
                            <th><input type="text" class="column-filter" placeholder="Filtro Depto."></th>
                            <th><input type="text" class="column-filter" placeholder="Filtro Validador"></th>
                            <th><input type="text" class="column-filter" placeholder="Filtro Jefe/Cargo"></th>
                            <th><input type="text" class="column-filter" placeholder="Ubicacion"></th>
                            <th class="text-center">
                                <select class="column-filter" onchange="filterColumn(8, this.value)">
                                    <option value="">Todos</option>
                                    <option value="S">Si</option>
                                    <option value="N">No</option>
                                </select>
                            </th>
                            <th class="text-center"></th>
                        </tr>
                    </thead>
                    <tbody id="tbodyMaestra"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Configuracion de Validadores -->
<!-- Modal Historial Auditable -->
<div class="modal fade" id="modalHistorial" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header p-4">
                <div>
                    <h5 class="modal-title mb-1"><i class="fas fa-history mr-2"></i>Historial Auditable</h5>
                    <small style="color:rgba(255,255,255,0.7);">Consulta el historial de cambios separado por modulo y tipo de busqueda.</small>
                </div>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body p-4">
                <!-- Seccion COMISIONES -->
                <div class="mb-2" style="border-bottom:2px solid #ff6f00; padding-bottom:5px;">
                    <span style="font-weight:700; color:#ff6f00; font-size:13px;"><i class="fas fa-coins mr-1"></i> COMISIONES</span>
                </div>
                <div class="mb-3 d-flex flex-wrap">
                    <button class="hist-tab active" onclick="setHistModo(this, 'emp_com')"><i class="fas fa-user mr-1"></i> Empleado</button>
                    <button class="hist-tab" onclick="setHistModo(this, 'validador_com')"><i class="fas fa-user-shield mr-1"></i> Validador</button>
                </div>
                <!-- Seccion CERTIFICACION -->
                <div class="mb-2" style="border-bottom:2px solid #b71c1c; padding-bottom:5px;">
                    <span style="font-weight:700; color:#b71c1c; font-size:13px;"><i class="fas fa-certificate mr-1"></i> CERTIFICACION</span>
                </div>
                <div class="mb-3 d-flex flex-wrap">
                    <button class="hist-tab" onclick="setHistModo(this, 'emp_cert')"><i class="fas fa-user mr-1"></i> Empleado</button>
                    <button class="hist-tab" onclick="setHistModo(this, 'jefe_cert')"><i class="fas fa-user-tie mr-1"></i> Jefe Inmediato</button>
                </div>
                <!-- Seccion ORGANIZACION -->
                <div class="mb-2" style="border-bottom:2px solid #1a237e; padding-bottom:5px;">
                    <span style="font-weight:700; color:#1a237e; font-size:13px;"><i class="fas fa-sitemap mr-1"></i> ORGANIZACION</span>
                </div>
                <div class="mb-3 d-flex flex-wrap">
                    <button class="hist-tab" onclick="setHistModo(this, 'gerencia')"><i class="fas fa-building mr-1"></i> Gerencia / Subgerencia / Area</button>
                </div>

                <!-- Modo seleccionado -->
                <div id="histModoLabel" class="mb-2"><span class="badge badge-dark px-3 py-2"><i class="fas fa-filter mr-1"></i> Modo: Empleado en Comisiones</span></div>

                <!-- Barra de busqueda texto (Por defecto) -->
                <div id="histFiltroTextoCont" class="input-group mb-3">
                    <div class="input-group-prepend">
                        <span class="input-group-text border-0" style="background:#fff5f5; color:#B71C1C;"><i class="fas fa-search"></i></span>
                    </div>
                    <input type="text" id="histFiltro" class="form-control border-0 bg-light" placeholder="Ingrese carnet o correo..." onkeypress="if(event.key==='Enter') buscarHistorial();">
                    <div class="input-group-append">
                        <button class="btn btn-dark px-4" onclick="buscarHistorial()"><i class="fas fa-search mr-1"></i> Buscar</button>
                    </div>
                </div>

                <!-- Busqueda por Selectores de Gerencia (Oculto por defecto) -->
                <div id="histFiltroGerenciaCont" class="mb-3 p-4 bg-light" style="display:none; border-radius:15px;">
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label class="small font-weight-bold text-uppercase text-muted">1. Seleccionar Gerencia</label>
                            <select id="histSelGerencia" class="form-control border-0 shadow-sm" onchange="histCargarSubgerencias(this.value)" style="border-radius:10px; height:45px;"></select>
                        </div>
                        <div class="col-md-5">
                            <label class="small font-weight-bold text-uppercase text-muted">2. Seleccionar Subgerencia</label>
                            <select id="histSelSubgerencia" class="form-control border-0 shadow-sm" onchange="histCargarAreas(this.value)" style="border-radius:10px; height:45px;"></select>
                        </div>
                        <div class="col-md-5">
                            <label class="small font-weight-bold text-uppercase text-muted">3. Seleccionar Departamento</label>
                            <select id="histSelArea" class="form-control border-0 shadow-sm" style="border-radius:10px; height:45px;"></select>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button class="btn btn-dark btn-block shadow-sm" onclick="buscarHistorial()" style="border-radius:10px; height:45px;"><i class="fas fa-search mr-1"></i> Buscar</button>
                        </div>
                    </div>
                </div>
                <!-- Card informativa -->
                <div id="histInfoCard" class="hist-info-card mb-3" style="display:none;"></div>
                <!-- Resultados -->
                <div id="histResultados" style="max-height: 450px; overflow-y: auto;">
                    <div class="text-center text-muted py-5">
                        <i class="fas fa-search fa-3x mb-3" style="color:#c5cae9;"></i>
                        <p>Seleccione un modo y busque por carnet, correo o nombre de gerencia.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- Modal Monitor de Avance Validadores -->
<div class="modal fade" id="modalMonitor" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content border-0 shadow" style="border-radius:25px;">
            <div class="modal-header bg-danger text-white p-4" style="border-radius: 25px 25px 0 0;">
                <h5 class="modal-title font-weight-bold"><i class="fas fa-chart-line mr-2"></i> Monitor de Avance - Validadores</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="d-flex gap-3">
                        <div class="bg-light p-2 px-3 rounded-pill small font-weight-bold">LISTOS: <span class="text-success" id="txtJefesListos">0</span></div>
                        <div class="bg-light p-2 px-3 rounded-pill small font-weight-bold">PENDIENTES: <span class="text-warning" id="txtJefesPendientes">0</span></div>
                    </div>
                    <button class="btn btn-sm btn-outline-danger btn-rounded" onclick="notificarPendientesMasivo()">
                        <i class="fas fa-envelope mr-1"></i> Notificar a todos los pendientes
                    </button>
                </div>
                <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                    <table class="table table-hover w-100" id="tablaMonitor">
                        <thead class="bg-light sticky-top">
                            <tr>
                                <th>Validador / Jefe</th>
                                <th>Gerencias a Cargo</th>
                                <th class="text-center">Asignados</th>
                                <th class="text-center">En Plantilla</th>
                                <th class="text-center">Cambios</th>
