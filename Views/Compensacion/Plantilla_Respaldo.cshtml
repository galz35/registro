@{ ViewBag.Title = "Gestion de Comisiones"; }

<style>
    :root {
        --primary: #B71C1C;
        --accent: #9e9e9e;
        --dark: #1e1e2d;
        --glass: rgba(255, 255, 255, 0.05);
    }

    body {
        background-color: #f8fafc;
        font-family: 'Outfit', sans-serif;
    }

    #pageLoader {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(255, 255, 255, 0.9); z-index: 9999;
        display: flex; flex-direction: column; align-items: center; justify-content: center;
    }
    .spinner-border-premium { width: 4rem; height: 4rem; border-width: 0.3em; color: var(--primary); }

    .status-card {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 25px;
        padding: 20px 30px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .min-card {
        border-radius: 30px;
        border: none;
        box-shadow: 0 20px 40px rgba(0,0,0,0.04);
        overflow: hidden;
        background: white;
    }

        .min-card .card-header {
            background: white;
            border-bottom: 1px solid #f0f0f0;
            padding: 25px 35px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

    .table thead th {
        background: #f8fafc;
        color: #64748b;
        text-transform: uppercase;
        font-size: 0.7rem;
        letter-spacing: 1px;
        border: none;
        padding: 20px;
        font-weight: 700;
        position: sticky;
        top: 0;
        z-index: 10;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }

    .table tbody td {
        vertical-align: middle;
        padding: 12px 15px;
        border-color: #f1f5f9;
        font-size: 0.85rem;
    }

    .input-premium {
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        font-size: 0.85rem;
        padding: 6px 8px;
        transition: 0.2s;
        background: #fcfcfc;
        width: 100%;
        min-width: 170px;
        color: #333;
        font-weight: 500;
    }

        .input-premium:focus {
            border-color: var(--primary);
            outline: none;
            box-shadow: 0 0 0 3px rgba(66, 66, 66, 0.1);
            background: white;
        }

    .btn-floating {
        position: fixed;
        bottom: 30px;
        right: 30px;
        z-index: 1000;
        display: flex;
        gap: 15px;
        background: white;
        padding: 15px 25px;
        border-radius: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        border: 1px solid #eee;
    }

    .gerencia-header {
        background: #1e293b !important;
        color: white !important;
        font-weight: 600;
        padding: 12px 25px !important;
        font-size: 0.8rem;
        letter-spacing: 1px;
    }

    .dif-bg {
        background-color: #fffbeb !important;
        border-left: 4px solid #f59e0b !important;
    }

    .badge-pill {
        padding: 5px 12px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.7rem;
    }

    .btn-primary {
        background-color: var(--primary);
        border-color: var(--primary);
        color: white;
    }

        .btn-primary:hover {
            background-color: #212121;
            border-color: #212121;
        }
</style>

<div id="pageLoader">
    <div class="spinner-border spinner-border-premium" role="status"></div>
    <h4 class="mt-4 font-weight-bold text-dark">Cargando Colaboradores...</h4>
    <p class="text-muted">Por favor espere un momento</p>
</div>

<div class="continer-fluid px-4 mt-4" style="margin-bottom: 100px;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="font-weight-bold m-0 text-dark"><i class="fas fa-wallet mr-2"></i> <span id="lblTituloModulo">Gestion de Comisiones</span></h3>
            <div class="mt-2 text-muted" style="font-size: 0.85rem;"><span class="font-weight-bold">ESTADO DE NOMINA:</span> <span id="badgeEstado" class="badge badge-dark ml-1">---</span></div>
        </div>
        <div class="d-flex align-items-center bg-white p-2 shadow-sm border" style="border-radius: 10px;">
            <select id="ddlPeriodo" class="form-control-sm border-0 bg-light font-weight-bold mr-3" style="border-radius: 6px; height: 35px;" onchange="recargarConPeriodo()"></select>
            <button class="btn btn-dark btn-sm font-weight-bold px-4" style="border-radius: 6px; height: 35px;" onclick="abrirModalAgregar()">
                <i class="fas fa-user-plus mr-2"></i> Agregar Colaborador
            </button>
        </div>
    </div>

    <div class="card min-card border">
        <div class="card-header bg-white pb-0 border-0 pt-4">
            <div class="d-flex align-items-center">
                <i class="fas fa-filter text-muted mr-3"></i>
                <select id="fGerencia" class="form-control-sm border bg-light px-3 font-weight-bold" style="border-radius: 6px; min-width: 250px;" onchange="aplicarFiltros()"></select>
                <div class="custom-control custom-switch ml-4">
                    <input type="checkbox" class="custom-control-input" id="chkSoloComisionan" checked onchange="aplicarFiltros()">
                    <label class="custom-control-label font-weight-bold small text-muted pt-1" for="chkSoloComisionan">SOLO AREAS QUE COMISIONAN</label>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive" style="max-height: 65vh; overflow-y: auto;">
                <table class="table mb-0" id="tbMaestro">
                    <thead>
                        <tr>
                            <th>Colaborador</th>
                            <th>Departamento / Area</th>
                            <th>Puesto</th>
                            <th>Jefe</th>
                            <th>Sede / Ubicacion</th>
                            <th class="text-center">Comisiona</th>
                            <th class="text-center">Evid.</th>
                            <th style="width:200px;">Observaciones</th>
                        </tr>
                    </thead>
                    <tbody id="tbEmpleados"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Justificacion de Cambio -->
<div class="modal fade" id="modalJustificacion" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 25px;">
            <div class="modal-body p-4">
                <div class="text-center mb-3">
                    <div class="d-inline-block p-3 rounded-circle" style="background:#fff3e0; color:#e65100; font-size: 2rem;">
                        <i class="fas fa-exchange-alt"></i>
                    </div>
                    <h4 class="mt-3 font-weight-bold text-dark">Justificacion de Cambio</h4>
                    <p class="text-muted small">Se detecti? un cambio en <b id="lblCampoModificado"></b>. Complete la siguiente informacion obligatoria.</p>
                </div>
                <div class="p-3 mb-3" style="background:#fafafa; border-radius:15px; border:1px solid #eee;">
                    <div class="small font-weight-bold text-dark mb-1"><i class="fas fa-user mr-1"></i> <span id="lblEmpleadoCambio"></span></div>
                    <div class="small text-muted"><span id="lblValorAnterior"></span> a?? <b class="text-danger" id="lblValorNuevo"></b></div>
                </div>
                <input type="hidden" id="justDetalleID">
                <input type="hidden" id="justCampo">
                <input type="hidden" id="justValor">
                <label class="small font-weight-bold text-muted">a?POR QUi? SE REALIZA EL CAMBIO?</label>
                <textarea id="justMotivo" class="form-control border bg-light mb-3" rows="2" style="border-radius:10px;" placeholder="Ej: Traslado por necesidad operativa..."></textarea>
                <label class="small font-weight-bold text-muted">a?A QUi?N VA A REPONER?</label>
                <input type="text" id="justReposicion" class="form-control border bg-light mb-3" style="border-radius:10px;" placeholder="Nombre del colaborador que reemplaza o N/A">
                <label class="small font-weight-bold text-muted">a?POR CUANTO TIEMPO?</label>
                <select id="justTiempo" class="form-control border bg-light mb-4" style="border-radius:10px;">
                    <option value="">-- Seleccione --</option>
                    <option value="1 mes">1 mes</option>
                    <option value="2 meses">2 meses</option>
                    <option value="3 meses">3 meses</option>
                    <option value="6 meses">6 meses</option>
                    <option value="Indefinido">Indefinido / Permanente</option>
                </select>
                <div class="row">
                    <div class="col-5"><button class="btn btn-light btn-block font-weight-bold py-3" style="border-radius:15px;" onclick="cancelarJustificacion()">Cancelar Cambio</button></div>
                    <div class="col-7"><button class="btn btn-dark btn-block font-weight-bold py-3" style="border-radius:15px;" onclick="confirmarJustificacion()"><i class="fas fa-check mr-2"></i>Confirmar</button></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Floating Actions -->
<div class="btn-floating" id="panelBotonera">
    <button class="btn btn-warning font-weight-bold px-4" style="border-radius:15px; color:#533f03;" onclick="guardarBorrador()">
        <i class="fas fa-save mr-2"></i> Guardar Borrador
    </button>
    <button class="btn font-weight-bold px-4 text-white" style="border-radius:15px; background:#424242;" onclick="enviarPlantilla()">
        <i class="fas fa-paper-plane mr-2"></i> Finalizar y Enviar
    </button>
</div>

<!-- Modal Agregar -->
<div class="modal fade" id="modalAgregarExtra">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 25px;">
            <div class="modal-body p-4">
                <div class="text-center mb-4">
                    <div class="d-inline-block p-3 rounded-circle" style="background:#f5f5f5; color:var(--primary); font-size: 2rem;">
                        <i class="fas fa-search-plus"></i>
                    </div>
                    <h4 class="mt-3 font-weight-bold">Busqueda de Personal</h4>
                    <p class="text-muted">Si un colaborador no aparece en su lista, puede buscarlo por carnet.</p>
                </div>

                <label class="small font-weight-bold text-muted">CARNET O CORREO</label>
                <div class="input-group mb-3">
                    <input type="text" id="txtCarnetExtra" class="form-control border-0 bg-light" style="border-radius: 12px 0 0 12px;" placeholder="Ej: 500xxx o correo">
                    <div class="input-group-append">
                        <button class="btn btn-dark px-3" style="border-radius: 0 12px 12px 0;" onclick="buscarReferenciaSighoo()"><i class="fas fa-search"></i></button>
                    </div>
                </div>

                <div id="infoEmpleadoExtra" class="alert alert-light border-0 bg-light mb-3" style="display:none; border-radius: 15px;"></div>

                <label class="small font-weight-bold text-muted">GERENCIA DE DESTINO</label>
                <select id="selGerenciaDestino" class="form-control border-0 bg-light mb-4" style="border-radius: 12px;"></select>

                <div class="row">
                    <div class="col-6"><button class="btn btn-light btn-block font-weight-bold py-3" style="border-radius: 15px;" data-dismiss="modal">Cancelar</button></div>
                    <div class="col-6"><button class="btn btn-dark btn-block font-weight-bold py-3" style="border-radius: 15px;" onclick="ejecutarAgregarExtra()">Agregar</button></div>
                </div>
            </div>
        </div>
    </div>
</div>
    <!-- Modal Evidencia -->
<div class="modal fade" id="modalEvidencia">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 25px;">
            <div class="modal-body p-4">
                <div class="text-center mb-4">
                    <div id="evIconCont" class="d-inline-block p-3 rounded-circle bg-light text-danger" style="font-size: 2rem;">
                        <i class="fas fa-paperclip"></i>
                    </div>
                    <h4 class="mt-3 font-weight-bold">Adjuntar Evidencia</h4>
                    <p class="text-muted small">Cargue el sustento (PDF, Word, Excel o Foto) para el cambio solicitado.</p>
                </div>

                <div id="evInfoActual" class="alert alert-success border-0 mb-3" style="display:none; border-radius:15px;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="small">
                            <i class="fas fa-file-alt mr-2"></i> <span id="lblNombreArchivo">archivo.pdf</span>
                        </div>
                        <div>
                            <button class="btn btn-sm btn-link text-danger mr-1" onclick="descargarMiEvidencia()" title="Ver Adjunto"><i class="fas fa-download"></i></button>
                            <button class="btn btn-sm btn-link text-danger" onclick="borrarEvidenciaActual()" title="Eliminar"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>
                </div>

                <div id="evFormCarga">
                    <input type="file" id="fileEvidencia" class="d-none" onchange="procesarArchivoSel()">
                    <button class="btn btn-primary btn-block font-weight-bold py-3 mb-3" style="border-radius:15px;" onclick="$('#fileEvidencia').click()">
                        <i class="fas fa-upload mr-2"></i> Seleccionar Archivo
                    </button>
                </div>

                <input type="hidden" id="hdnDetalleIdEv">
                <button class="btn btn-light btn-block font-weight-bold py-2" style="border-radius:12px;" data-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/onlinejs/select2.min.js"></script>
    <script>
    var g_Plantillid = 0, cambiosPendientes = {}, g_Detalles = [], g_Tipo = @(ViewBag.Tipo ?? 1);
    var optsCargos = '', optsUbis = '', optsJefes = '', optsDeptos = '';

    $(document).ready(function() {
        if(g_Tipo == 2) {
            $('#lblTituloModulo').text('Certificacion de Personal');
            $('.fas.fa-wallet').removeClass('fa-wallet').addClass('fa-user-check');
        }
        inicializarPeriodos();
        cargarGerenciasAsignadas();
    });

    function cargarGerenciasAsignadas() {
        $.get('@Url.Action("ObtenerGerenciasValidador", "Compensacion")', function(res) {
            if(res.success) {
                let html = '<option value="">-- SELECCIONE GERENCIA --</option>';
                res.data.forEach(g => { html += '<option value="'+g+'">'+g+'</option>'; });
                $('#selGerenciaDestino').html(html);
            }
        });
    }

    function inicializarPeriodos() {
        $.get('@Url.Action("ObtenerPeriodos", "Compensacion")', function(res) {
            if(res.success && res.data.length > 0) {
                let html = '';
                res.data.forEach(p => {
                    html += '<option value="' + p.PeriodoID + '" ' + (p.PeriodoID === res.activoID ? 'selected' : '') + '>' + p.NombrePeriodo + '</option>';
                });
                $('#ddlPeriodo').html(html);
                recargarConPeriodo();
            }
        });
    }

    function recargarConPeriodo() {
        var idPer = $('#ddlPeriodo').val();
        $('#pageLoader').show();
        $('#tbEmpleados').html('<tr><td colspan="6" class="text-center p-5"><div class="spinner-border text-dark"></div></td></tr>');
        $.get('@Url.Action("CargarMiPlantilla", "Compensacion")', { periodoId: idPer, tipo: g_Tipo }, function(res) {
            if(res.message === "SESION_EXPIRADA") { window.location.reload(); return; }
            if(!res.success) { Swal.fire('Error', res.message, 'error'); return; }
            g_Plantillid = res.plantilla.PlantilliD;
            $('#badgeEstado').text(res.plantilla.Estado);

            optsCargos = (res.cargos || []).map(x => '<option value="' + x + '">' + x + '</option>').join('') + '<option value="__NEW__">+ OTRO...</option>';
            optsUbis = (res.ubicaciones || []).map(x => '<option value="' + x + '">' + x + '</option>').join('');
            optsJefes = (res.jefes || []).map(x => '<option value="' + x + '">' + x + '</option>').join('');
            optsDeptos = (res.departamentos || []).map(x => '<option value="' + x + '">' + x + '</option>').join('');

            g_Detalles = res.detalles;
            aplicarFiltros(res.plantilla.Estado !== 'Borrador' && res.plantilla.Estado !== 'Devuelto');
        }).fail(function() {
            Swal.fire('Error', 'Problema de conexion al cargar.', 'error');
        }).always(function() {
            $('#pageLoader').fadeOut(300);
        });
    }

    function aplicarFiltros(isLocked) {
        if(isLocked === undefined) {
            let estado = $('#badgeEstado').text();
            isLocked = (estado !== 'Borrador' && estado !== 'Devuelto' && estado !== '---');
        }

        let soloComisionan = $('#chkSoloComisionan').is(':checked');

        // Identificar areas que tienen al menos 1 comisiona
        let areasConComision = new Set();
        g_Detalles.forEach(d => {
            if(d.AplicaComision === 'S' || d.Comisiona === 'S') {
                areasConComision.add(d.OGERENCIA_SIGHO);
            }
        });

        // Configurar dropdown de gerencias
        let setGer = new Set(g_Detalles.map(d => d.OGERENCIA_SIGHO));
        let htmlGer = '<option value="">[ Todas las Gerencias ]</option>';
        Array.from(setGer).sort().forEach(g => {
            if(!soloComisionan || areasConComision.has(g)) {
                htmlGer += '<option value="'+g+'">'+g+'</option>';
            }
        });

        // Mantener valor actual si es posible
        let valAnterior = $('#fGerencia').val();
        $('#fGerencia').html(htmlGer);
        if($('#fGerencia option[value="'+valAnterior+'"]').length > 0) {
            $('#fGerencia').val(valAnterior);
        }

        let valGer = $('#fGerencia').val();
        let filtrados = g_Detalles.filter(d => {
            let pasaFiltroGerencia = (valGer === '' || d.OGERENCIA_SIGHO === valGer);
            let pasaFiltroSoloComisionan = (!soloComisionan || areasConComision.has(d.OGERENCIA_SIGHO));
            return pasaFiltroGerencia && pasaFiltroSoloComisionan;
        });

        filtrados.sort((a,b) => (a.OGERENCIA_SIGHO||'').localeCompare(b.OGERENCIA_SIGHO||'') || a.NombreCompleto.localeCompare(b.NombreCompleto));

        // Renderizar por lotes para no bloquear el navegador
        let tbody = document.getElementById('tbEmpleados');
        tbody.innerHTML = '';

        if(filtrados.length === 0) {
            tbody.innerHTML = '<tr><td colspan="8" class="text-center p-5 text-muted">No se encontraron colaboradores en las areas filtradas.</td></tr>';
            if(isLocked) $('#panelBotonera').hide(); else $('#panelBotonera').show();
            return;
        }

        let BATCH = 80;
        let idx = 0;
        let currentGer = '';

        function renderBatch() {
            let frag = document.createDocumentFragment();
            let end = Math.min(idx + BATCH, filtrados.length);

            for(let i = idx; i < end; i++) {
                let d = filtrados[i];
                if(d.OGERENCIA_SIGHO !== currentGer) {
                    let trH = document.createElement('tr');
                    trH.className = 'gerencia-header';
                    trH.innerHTML = '<td colspan="8"><i class="fas fa-sitemap mr-2"></i> ' + (d.OGERENCIA_SIGHO || 'Sin Gerencia') + '</td>';
                    frag.appendChild(trH);
                    currentGer = d.OGERENCIA_SIGHO;
                }

                let dis = isLocked ? 'disabled' : '';
                let btnCls = d.Comisiona === 'S' ? 'btn-dark' : 'btn-light text-muted';
                let badgePrueba = (d.EsPrueba_SIGHO === 'S' && g_Tipo == 1) ? '<span class="badge badge-warning ml-1" style="font-size:10px;">PRUEBA</span>' : '';

                let editDeptoHtml = '<div class="small text-muted mb-1 italic">' + (d.Departamento_SIGHO || '-') + '</div><select class="input-premium" data-v="'+(d.Departamento_Reportado||d.Departamento_SIGHO)+'" onchange="marcar('+d.DetalleID+',\'Departamento_Reportado\',this.value)" '+dis+'>'+optsDeptos+'</select>';

                let editCargoHtml = '';
                if(g_Tipo == 2) {
                    editCargoHtml = '<div class="text-danger font-weight-bold p-2 bg-light border" style="border-radius:6px; font-size:11px;">Certificado</div>';
                } else {
                    editCargoHtml = '<select class="form-control-sm input-premium" data-v="'+(d.Cargo_Reportado||d.Cargo_SIGHO)+'" onchange="marcar('+d.DetalleID+',\'Cargo_Reportado\',this.value)" '+dis+'>'+optsCargos+'</select>';
                }

                let tr = document.createElement('tr');
                tr.id = 'tr_' + d.DetalleID;
                tr.innerHTML =
                    '<td><div class="font-weight-bold text-dark">' + d.NombreCompleto + '</div><small class="text-muted">' + d.CarnetEmpleado + '</small>' + badgePrueba + '</td>' +
                    '<td>' + editDeptoHtml + '</td>' +
                    '<td><div class="small text-muted mb-1 italic">' + d.Cargo_SIGHO + '</div>' + editCargoHtml + '</td>' +
                    '<td><div class="small text-muted mb-1 italic">' + (d.Jefe_SIGHO || '-') + '</div><select class="input-premium" data-v="'+(d.Jefe_Reportado||d.Jefe_SIGHO)+'" onchange="marcar('+d.DetalleID+',\'Jefe_Reportado\',this.value)" '+dis+'>'+optsJefes+'</select></td>' +
                    '<td><div class="small text-muted mb-1 italic">' + (d.Ubicacion_SIGHO || '-') + '</div><select class="input-premium" data-v="'+(d.Ubicacion_Reportada||d.Ubicacion_SIGHO)+'" onchange="marcar('+d.DetalleID+',\'Ubicacion_Reportada\',this.value)" '+dis+'>'+optsUbis+'</select></td>' +
                    '<td class="text-center">' +
                        '<button class="btn btn-sm font-weight-bold px-4 '+btnCls+'" style="border-radius:10px;" onclick="marcarComision('+d.DetalleID+',this)" '+dis+'>'+(d.Comisiona==='S'?'SI':'NO')+'</button>' +
                    '</td>' +
                    '<td class="text-center">' +
                        '<i class="fas fa-paperclip cursor-pointer ' + ((d.EsDiscrepancia === 1 || Object.keys(cambiosPendientes[d.DetalleID] || {}).length > 0) ? (d.HasEvidencia ? 'text-success' : 'text-danger font-weight-bold') : 'text-muted opacity-25') + '" style="font-size:1.2rem; cursor:pointer" onclick="gestionarEvidencia(' + d.DetalleID + ')"></i>' +
                    '</td>' +
                    '<td><div class="d-flex"><input type="text" class="input-premium flex-grow-1 mr-2" id="obs_'+d.DetalleID+'" value="'+(d.Observacion||'')+'" onchange="marcar('+d.DetalleID+',\'Observacion\',this.value)" '+dis+'>' +
                    '<button class="btn btn-sm btn-outline-danger" title="No valido a este usuario" onclick="rechazarUsuario('+d.DetalleID+')" '+dis+'><i class="fas fa-user-times"></i></button></div></td>';
                frag.appendChild(tr);
            }

            tbody.appendChild(frag);

            // Asignar valores a los selects del lote recien insertado
            let rows = tbody.querySelectorAll('tr');
            for(let i = idx; i < end; i++) {
                let rowIdx = i + (filtrados.length > 0 ? 1 : 0); // offset por headers
                // Buscar selects en las filas recientes
            }

            idx = end;
            if(idx < filtrados.length) {
                requestAnimationFrame(renderBatch);
            } else {
                // Asignar todos los valores de select al finalizar
                $('#tbEmpleados select').each(function() { $(this).val($(this).data('v')); });
            }
        }

        requestAnimationFrame(renderBatch);
        if(isLocked) $('#panelBotonera').hide(); else $('#panelBotonera').show();
    }

    function marcarComision(id, btn) {
        let val = $(btn).text() === 'SI' ? 'N' : 'S';
        $(btn).text(val === 'S' ? 'SI' : 'NO').toggleClass('btn-dark btn-light text-muted');
        marcar(id, 'Comisiona', val);
    }

    function rechazarUsuario(id) {
        if(confirm('a?Seguro que deseas reportar que este usuario NO te corresponde?')) {
            // Marcar que NO comisiona con el validador actual
            let btn = $('#tr_'+id).find('button:contins("SI")');
            if (btn.length > 0) {
                btn.text('NO').toggleClass('btn-dark btn-light text-muted');
                marcar(id, 'Comisiona', 'N');
            }
            
            // Poner el texto en la observacion
            let msj = 'NO CORRESPONDE A MI GERENCIA/AREA';
            $('#obs_'+id).val(msj);
            marcar(id, 'Observacion', msj);
            
            toastr.warning('Usuario marcado como no correspondiente. RRHH sera notificado.');
        }
    }

    var _justBackupSelect = null; // Para revertir si cancela

    function marcar(id, prop, val) {
        if(!cambiosPendientes[id]) cambiosPendientes[id] = { DetalleID: id };
        cambiosPendientes[id][prop] = val; $('#tr_'+id).addClass('dif-bg');

        // Si cambiaron Ubicacion o Jefe, pedir Justificacion obligatoria
        if(prop === 'Ubicacion_Reportada' || prop === 'Jefe_Reportado' || prop === 'Cargo_Reportado' || prop === 'Departamento_Reportado') {
            // El usuario pido "ubicacion o organizacion o jefe". Incluyo Cargo y Departamento por si acaso, 
            // pero nos centramos en Ubicacion y Jefe como principales.
            var det = g_Detalles.find(x => x.DetalleID === id);
            if(!det) return;

            var campoLabel = prop === 'Ubicacion_Reportada' ? 'Ubicacion / Edificio' : 
                             prop === 'Jefe_Reportado' ? 'Jefe Inmediato' : 
                             prop === 'Cargo_Reportado' ? 'Cargo / Puesto' : 'Departamento / i?rea';
            var valorAnterior = prop === 'Ubicacion_Reportada' ? (det.Ubicacion_SIGHO || '-') : 
                                prop === 'Jefe_Reportado' ? (det.Jefe_SIGHO || '-') : 
                                prop === 'Cargo_Reportado' ? (det.Cargo_SIGHO || '-') : (det.Departamento_SIGHO || '-');

            // Solo abrir si realmente cambo respecto al original
            if(val === valorAnterior) return;

            $('#justDetalleID').val(id);
            $('#justCampo').val(prop);
            $('#justValor').val(val);
            $('#lblCampoModificado').text(campoLabel);
            $('#lblEmpleadoCambio').text(det.NombreCompleto + ' (' + det.CarnetEmpleado + ')');
            $('#lblValorAnterior').text(valorAnterior);
            $('#lblValorNuevo').text(val);
            $('#justMotivo').val('');
            $('#justReposicion').val('');
            $('#justTiempo').val('');

            // Guardar referencia del select para revertir si cancela
            _justBackupSelect = { id: id, prop: prop, original: valorAnterior };

            $('#modalJustificacion').modal('show');
        }
    }

    function confirmarJustificacion() {
        var motivo = $('#justMotivo').val().trim();
        var reposicion = $('#justReposicion').val().trim();
        var tiempo = $('#justTiempo').val();

        if(!motivo || !reposicion || !tiempo) {
            Swal.fire('Campos Obligatorios', 'Debe completar las 3 preguntas para justificar el cambio.', 'warning');
            return;
        }

        var id = parseInt($('#justDetalleID').val());
        var campo = $('#justCampo').val();
        var campoLabel = campo === 'Ubicacion_Reportada' ? 'UBICACi?N' : 
                         campo === 'Jefe_Reportado' ? 'JEFE' : 
                         campo === 'Cargo_Reportado' ? 'CARGO' : 'DEPARTAMENTO';

        // Guardar Justificacion en campos dedicados
        if(!cambiosPendientes[id]) cambiosPendientes[id] = { DetalleID: id };
        cambiosPendientes[id].JustMotivo = motivo;
        cambiosPendientes[id].JustReposicion = reposicion;
        cambiosPendientes[id].JustTiempo = tiempo;
        
        // Tambien agregar resumen en observacion para visibilidad rapida
        var obsTexto = '[CAMBIO ' + campoLabel + '] ' + motivo + ' (Repone: ' + reposicion + ', ' + tiempo + ')';
        var obsActual = cambiosPendientes[id].Observacion || '';
        cambiosPendientes[id].Observacion = obsActual ? obsActual + ' || ' + obsTexto : obsTexto;

        // Actualizar visualmente el input de observacion en la fila
        var inputObs = $('#obs_' + id);
        if(inputObs.length) inputObs.val(cambiosPendientes[id].Observacion);

        _justBackupSelect = null;
        $('#modalJustificacion').modal('hide');
        Swal.fire({title:'Justificacion Registrada', text:'La informacion se guardara con el borrador.', icon:'success', timer:2000, showConfirmButton:false});
    }

    function cancelarJustificacion() {
        // Revertir el cambio en el select
        if(_justBackupSelect) {
            var sel = $('#tr_' + _justBackupSelect.id + ' select').filter(function() {
                return $(this).data('v') !== undefined;
            });
            // Revertir el valor del campo al original
            var id = _justBackupSelect.id;
            var prop = _justBackupSelect.prop;
            if(cambiosPendientes[id]) delete cambiosPendientes[id][prop];
            // Revertir visualmente recargando los filtros
            aplicarFiltros();
        }
        _justBackupSelect = null;
        $('#modalJustificacion').modal('hide');
    }

    function guardarBorrador() {
        if(Object.keys(cambiosPendientes).length === 0) return;
        $.ajax({
            url: '@Url.Action("GuardarBorrador", "Compensacion")', type: 'POST',
            contentType: 'application/json', data: JSON.stringify(Object.values(cambiosPendientes)),
            success: function(res) { 
                if(res.message === "SESION_EXPIRADA") { window.location.reload(); return; }
                if(res.success) { 
                    Swal.fire('Exito', 'Borrador guardado.', 'success'); 
                    cambiosPendientes = {}; 
                    $('.dif-bg').removeClass('dif-bg'); 
                } else {
                    Swal.fire('Error', res.message, 'error');
                }
            }
        }).fail(function() {
            Swal.fire('Error', 'No se pudo conectar con el servidor para guardar.', 'error');
        });
    }

    function enviarPlantilla() {
        // Validacion estricta de evidencias
        let pendientes = g_Detalles.filter(d => (d.EsDiscrepancia === 1 || cambiosPendientes[d.DetalleID]) && !d.HasEvidencia);
        
        if(pendientes.length > 0) {
            Swal.fire({
                title: 'Evidencia Requerida',
                text: 'Hay ' + pendientes.length + ' cambios reportados que no tienen su evidencia adjunta (clip rojo). RRHH requiere un sustento para cada cambio.',
                icon: 'error',
                confirmButtonColor: '#d33'
            });
            return;
        }

        if(Object.keys(cambiosPendientes).length > 0) {
             Swal.fire('Atencion', 'Tiene cambios sin guardar en el borrador. Guardelos antes de enviar.', 'info');
             return;
        }

        Swal.fire({ title: 'Enviar Comisiones', text: 'Se cerrara la edicion y RRHH recibira el reporte.', icon: 'warning', showCancelButton: true, confirmButtonColor: '#424242' }).then(r => {
            if(r.isConfirmed) $.post('@Url.Action("EnviarPlantilla", "Compensacion")', { plantillid: g_Plantillid }, res => { if(res.success) location.reload(); });
        });
    }

    function gestionarEvidencia(id) {
        let d = g_Detalles.find(x => x.DetalleID === id);
        $('#hdnDetalleIdEv').val(id);
        $('#fileEvidencia').val('');
        
        if(d.HasEvidencia) {
            $('#lblNombreArchivo').text('Documento Adjunto');
            $('#evInfoActual').show(); $('#evFormCarga').hide();
        } else {
            $('#evInfoActual').hide(); $('#evFormCarga').show();
        }
        $('#modalEvidencia').modal('show');
    }

    function procesarArchivoSel() {
        let id = $('#hdnDetalleIdEv').val();
        let file = $('#fileEvidencia')[0].files[0];
        if(!file) return;

        let formData = new FormData();
        formData.append('detalleId', id);
        formData.append('file', file);

        Swal.fire({ title: 'Subiendo...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); }});

        $.ajax({
            url: '@Url.Action("SubirEvidencia", "Compensacion")',
            type: 'POST', data: formData, processData: false, contentType: false,
            success: function(res) {
                if(res.success) {
                    let d = g_Detalles.find(x => x.DetalleID == id);
                    d.HasEvidencia = true;
                    Swal.fire('Listo', 'Evidencia cargada correctamente.', 'success');
                    $('#modalEvidencia').modal('hide');
                    aplicarFiltros();
                } else {
                    Swal.fire('Error', res.message, 'error');
                }
            }
        });
    }

    function descargarMiEvidencia() {
        let id = $('#hdnDetalleIdEv').val();
        window.location.href = '@Url.Action("DescargarEvidencia", "Compensacion")?detalleId=' + id;
    }

    function borrarEvidenciaActual() {
        let id = $('#hdnDetalleIdEv').val();
        Swal.fire({ title: 'Quitar evidencia?', text: 'Se eliminara el archivo adjunto.', icon: 'warning', showCancelButton: true }).then(r => {
            if(r.isConfirmed) {
                $.post('@Url.Action("EliminarEvidencia", "Compensacion")', { detalleId: id }, function(res) {
                    if(res.success) {
                        let d = g_Detalles.find(x => x.DetalleID == id);
                        d.HasEvidencia = false;
                        $('#modalEvidencia').modal('hide');
                        aplicarFiltros();
                    }
                });
            }
        });
    }

    function abrirModalAgregar() { $('#modalAgregarExtra').modal('show'); }
    function buscarReferenciaSighoo() {
        let car = $('#txtCarnetExtra').val().trim(); if(!car) return;
        $.get('@Url.Action("BuscarEmpleadoSighoo", "Compensacion")', { carnet: car }, res => {
            if(res.success) {
                var nombre = res.data.NombreCompleto || res.data.nombreCompleto || res.data.CARNET;
                var cargo = res.data.Cargo_SIGHO || res.data.cargo_SIGHO || '';
                $('#infoEmpleadoExtra').html('<strong>'+nombre+'</strong><br><small>'+cargo+'</small>').show();
            }
            else $('#infoEmpleadoExtra').html('<span class="text-danger">No encontrado</span>').show();
        });
    }
    function ejecutarAgregarExtra() {
        let car = $('#txtCarnetExtra').val(), ger = $('#selGerenciaDestino').val();
        if(!car || !ger) return Swal.fire('Atencion', 'Complete los campos.', 'warning');
        $.post('@Url.Action("AgregarEmpleadoManual", "Compensacion")', { carnet: car, plantillid: g_Plantillid, gerencia: ger }, res => { if(res.success) location.reload(); });
    }
    </script>
}



