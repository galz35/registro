    function descargarExcel() {
        var idPer = $('#ddlPeriodo').val();
        window.location.href = '@Url.Action("ExportarExcel", "Compensacion")?periodoId=' + idPer + '&tipo=' + TIPO_ACTUAL;
    }

    function actualizarVista(mantenerDatos = false) {
        const idPer = $('#ddlPeriodo').val();
        if(!idPer) return;

        // Si solo estamos filtrando cambios locales, no re-cargamos de DB
        if(mantenerDatos) {
            renderizarTabla(g_Detalles);
            return;
        }

        // Cargar KPIs
        $.get('@Url.Action("ObtenerKPI", "Compensacion")?periodoId=' + idPer, function(res) {
            if(res.success) {
                var k = res.kpi;
                var perc = k.TotalJefes > 0 ? Math.round((k.Terminados / k.TotalJefes) * 100) : 0;
                $('#txtKPIPerc').text(perc + '%');
                $('#barKPI').css('width', perc + '%');
                $('#txtKPIPlazas').text(k.UniversoTotal);
                $('#txtKPIPeriodo').text($('#ddlPeriodo option:selected').text());
            }
        }).fail(function(xhr, status, error) {
            console.error("KPI Error:", xhr.responseText);
        });

        $('#tbCuerpoMaestro').html('<tr><td colspan="13" class="text-center p-4"><i class="fas fa-spinner fa-spin"></i> Cargando universo de empleados...</td></tr>');
        
        // Cargar lista detallada masiva
        $.get('@Url.Action("ObtenerTodosDetallesRevision", "Compensacion")?periodoId=' + idPer + '&tipo=' + TIPO_ACTUAL, function(res) {
            if(!res.success) {
                Swal.fire('Error al Cargar Detalle', res.message, 'error');
                $('#tbCuerpoMaestro').html('<tr><td colspan="13" class="text-center p-4 text-danger"><b>Error:</b> ' + res.message + '</td></tr>');
                return;
            }
            
            g_Detalles = res.data || [];
            
            // Calcular KPI de Discrepancias
            var cambios = g_Detalles.filter(function(d) {
                return (d.Cargo_Reportado && d.Cargo_Reportado !== d.Cargo_SIGHO) ||
                (d.Jefe_Reportado && d.Jefe_Reportado !== d.Jefe_SIGHO) ||
                (d.Ubicacion_Reportada && d.Ubicacion_Reportada !== d.Ubicacion_SIGHO) ||
                (d.Comisiona !== (d.Comisiona_Original || d.Comisiona));
            }).length;
            $('#txtKPICambios').text(cambios);
 
            prepararFiltrosUI(g_Detalles);
            renderizarTabla(g_Detalles);
        }).fail(function(xhr, status, error) {
            console.error("Detalle Error:", xhr.responseText);
            Swal.fire('Error de Conexion', 'No se pudo obtener el detalle maestro. Estado: ' + status + ', Error: ' + error, 'error');
            $('#tbCuerpoMaestro').html('<tr><td colspan="13" class="text-center p-4 text-danger"><b>Error Tecnico:</b> ' + status + ' - ' + error + '</td></tr>');
        });
    }

    function prepararFiltrosUI(detalles) {
        var setEmpresas = new Set(), setJefes = new Set(), setUbis = new Set(), setCargos = new Set();
        detalles.forEach(function(d) {
            setEmpresas.add(d.Empresa_SIGHO || 'N/A');
            setJefes.add(d.Jefe_SIGHO || 'Sin Jefe');
            setUbis.add(d.Ubicacion_SIGHO || 'Sin Ubicacion');
            setCargos.add(d.Cargo_SIGHO || 'Sin Cargo');
        });

        var sortedEmp = []; setEmpresas.forEach(function(v) { sortedEmp.push(v); });
        var sortedJef = []; setJefes.forEach(function(v) { sortedJef.push(v); });
        var sortedUbis = []; setUbis.forEach(function(v) { sortedUbis.push(v); });
        var sortedCargos = []; setCargos.forEach(function(v) { sortedCargos.push(v); });

        $('#fEmpresa').html('<option value="">[ Todas ]</option>' + sortedEmp.sort().map(function(x) { return '<option value="' + x + '">' + x + '</option>'; }).join(''));
        $('#fJefe').html('<option value="">[ Jefes ]</option>' + sortedJef.sort().map(function(x) { return '<option value="' + x + '">' + x + '</option>'; }).join(''));
        $('#fUbi').html('<option value="">[ Sedes ]</option>' + sortedUbis.sort().map(function(x) { return '<option value="' + x + '">' + x + '</option>'; }).join(''));
        $('#fCargo').html('<option value="">[ Cargos ]</option>' + sortedCargos.sort().map(function(x) { return '<option value="' + x + '">' + x + '</option>'; }).join(''));
        $('#filaFiltrosUI').show();
    }

    function filtraLocal() {
        const valEmp = $('#fEmpresa').val();
        const valCar = $('#fCargo').val();
        const valJef = $('#fJefe').val();
        const valUbi = $('#fUbi').val();

        if (g_Table) {
            // Empresa es columna i?ndice 2
            g_Table.column(2).search(valEmp ? '^' + valEmp + '$' : '', true, false);
            // Cargo SighoO es columna i?ndice 4
            g_Table.column(4).search(valCar);
            // Jefe SighoO es columna i?ndice 6
            g_Table.column(6).search(valJef);
            // Ubicacion SighoO es columna i?ndice 8
            g_Table.column(8).search(valUbi);
            
            g_Table.draw();
        }
    }

    let g_Table = null;

    function renderizarTabla(detalles) {
        var filtrados = detalles;
        
        // FILTRO DE DISCREPANCIAS (Frontend)
        if($('#chkSoloCambios').is(':checked')) {
            filtrados = detalles.filter(function(d) {
                return (d.Cargo_Reportado && d.Cargo_Reportado !== d.Cargo_SIGHO) ||
                (d.Jefe_Reportado && d.Jefe_Reportado !== d.Jefe_SIGHO) ||
                (d.Ubicacion_Reportada && d.Ubicacion_Reportada !== d.Ubicacion_SIGHO) ||
                (d.Comisiona !== (d.Comisiona_Original || d.Comisiona));
            });
        }

        if (g_Table) {
            g_Table.destroy();
            $('#tbCuerpoMaestro').empty();
        }

        g_Table = $('#tbMaestroRevision').DataTable({
            data: filtrados,
            pageLength: 50,
            autoWidth: false,
            responsive: false,
            columnDefs: [
                { targets: [10, 11], visible: (TIPO_ACTUAL != 2) }
            ],
            order: [[0, 'asc'], [1, 'asc']], // 0: Gerencia (oculta), 1: Nombre
            rowGroup: {
                dataSrc: 'OGERENCIA_SIGHO',
                startRender: function (rows, group) {
                    var firstRow = rows.data()[0];
                    var estClass = firstRow.Estado === 'Enviado' ? 'badge-primary' : (firstRow.Estado === 'Aprobado' ? 'badge-success' : 'badge-secondary');
                    var colorHeader = TIPO_ACTUAL === 1 ? '#01579B' : '#343a40';

                    var html = '<tr class="gerencia-header" style="background-color: ' + colorHeader + '">' +
                        '<td colspan="11">' +
                                    '<i class="fas fa-sitemap mr-2"></i> ' + (group || 'Sin asignar') + ' ' + 
                                    '<span class="badge ' + estClass + ' ml-2">' + (firstRow.Estado || '').toUpperCase() + '</span>' +
                                    '<small class="ml-2"><b>Validador:</b> ' + (firstRow.NombreGerente || '-') + '</small>' +
                                 '</td>' +
                                 '<td colspan="2" class="text-right">';
                    
                    if(firstRow.Estado === 'Enviado') {
                        html += '<button class="btn btn-xs btn-success py-0 px-2 font-weight-bold" onclick="aprobar(' + firstRow.PlantilliD + ')"><i class="fas fa-check"></i> Aprobar</button>' +
                                '<button class="btn btn-xs btn-danger py-0 px-2 font-weight-bold ml-1" onclick="abrirDevolver(' + firstRow.PlantilliD + ')"><i class="fas fa-undo"></i> Devolver</button>';
                    }
                    if(firstRow.Estado === 'Aprobado') {
                        html += '<button class="btn btn-xs btn-primary py-0 px-2 font-weight-bold" onclick="sincronizarSighoo(' + firstRow.PlantilliD + ')"><i class="fas fa-sync"></i> Sincronizar</button>';
                    }
                    
                    html += '<button class="btn btn-xs btn-info py-0 px-2 font-weight-bold ml-1" onclick="notificarJefe(\'' + firstRow.CarnetGerente + '\')">' +
                                        '<i class="fas fa-envelope"></i> Notificar' +
                                    '</button>' +
                                 '</td></tr>';
                    return $(html);
                }
            },
            columns: [
                { data: 'OGERENCIA_SIGHO', visible: false }, // Indice 0
                { 
                    data: 'NombreCompleto', // Indice 1
                    render: function(d, t, r) {
                        return '<strong>' + r.NombreCompleto + '</strong><br><small class="text-muted">' + r.CarnetEmpleado + '</small>';
                    }
                },
                { data: 'Empresa_SIGHO' }, // Indice 2
                { data: 'Departamento_SIGHO' }, // Indice 3
                { 
                    data: 'Cargo_SIGHO', // Indice 4
                    visible: true, // Siempre visible para certificar estructura
                    className: 'small',
                    render: function(d) { return '<div class="text-truncate" style="max-width:150px" title="' + (d || '') + '">' + (d || '-') + '</div>'; }
                },
                { 
                    data: 'Cargo_Reportado', // Indice 5
                    visible: true, // Siempre visible
                    className: 'small font-weight-bold text-primary',
                    render: function(d) { return '<div class="text-truncate" style="max-width:150px" title="' + (d || '') + '">' + (d || '-') + '</div>'; }
                },
                { 
                    data: 'Jefe_SIGHO', // Indice 6
                    visible: true, // Siempre visible
                    className: 'small',
                    render: function(d) { return '<div class="text-truncate" style="max-width:150px" title="' + (d || '') + '">' + (d || '-') + '</div>'; }
                },
                { 
                    data: 'Jefe_Reportado', // Indice 7
                    visible: true, // Siempre visible
                    className: 'small font-weight-bold text-primary',
                    render: function(d) { return '<div class="text-truncate" style="max-width:150px" title="' + (d || '') + '">' + (d || '-') + '</div>'; }
                },
                { 
                    data: 'Ubicacion_SIGHO',  // Indice 8
                    visible: true, // Siempre visible
                    className: 'small' 
                }, 
                { 
                    data: 'Ubicacion_Reportada', // Indice 9
                    visible: true, // Siempre visible
                    className: 'small font-weight-bold text-primary' 
                }, 
                { 
                    data: 'Comisiona_Original', // Indice 10
                    visible: (TIPO_ACTUAL === 1),
                    className: 'text-center align-middle',
                    render: function(d) { return d === 'S' ? '<span class="badge badge-success">SI</span>' : '<span class="badge badge-secondary">NO</span>'; }
                },
                { 
                    data: 'Comisiona', // Indice 11
                    visible: (TIPO_ACTUAL === 1),
                    className: 'text-center align-middle',
                    render: function(d, t, r) {
                        var changed = (r.Comisiona && r.Comisiona !== (r.Comisiona_Original || r.Comisiona)) ? 'bg-warning text-dark font-weight-bold' : '';
                        return '<span class="badge ' + (changed || (d === 'S' ? 'badge-success' : 'badge-secondary')) + '">' + (d === 'S' ? 'SI' : 'NO') + '</span>';
                    }
                },
                { 
                    data: 'Observacion', // Indice 12
                    render: function(d) { return '<small class="text-muted">' + (d || '-') + '</small>'; }
                },
                {
                    data: 'DetalleID', // Indice 13
                    className: 'text-center',
                    render: function(d, t, r) { return '<button class="btn btn-xs btn-outline-info" onclick="verHistorial(' + d + ', \'' + escapeJsString(r.NombreCompleto) + '\')"><i class="fas fa-history"></i></button>'; }
                }
            ],
            language: {
                url: "//cdn.datatables.net/plug-ins/1.10.25/i18n/Spanish.json"
            }
        });
    }

    function aplicarFiltroSuperior() {
        const emp = $('#selEmpresa').val();
        const jef = $('#selJefe').val();
        const ubi = $('#selUbicacion').val();

        if (g_Table) {
            g_Table.column(1).search(emp); // Columna Empresa
            g_Table.column(6).search(jef); // Columna Jefe SighoO (aprox, ajustar indice si falla)
            // Para filtros multiples o complejos, podemos usar g_Table.draw()
            g_Table.draw();
        }
    }

    function notificarJefe(carnet) {
