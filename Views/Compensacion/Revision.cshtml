                                    </div>' +
                                '</div>' +
                            '</div>';
                    });
                }
                $('#timelineHistorial').html(html);
            } else {
                $('#timelineHistorial').html('<div class="alert alert-danger m-3">Error al cargar historial: ' + res.message + '</div>');
            }
        });
