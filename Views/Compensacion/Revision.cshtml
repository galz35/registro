@{
    ViewBag.Title = "Certificacion de Plantillas RRHH";
}
<meta charset="utf-8" />

<style>
    body { background-color: #fff; color: #000; font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif; }
    .bg-claro { background-color: #B71C1C !important; color: #fff !important; }
    .btn-claro { background-color: #B71C1C; color: #fff; border: none; }
    .btn-claro:hover { background-color: #9A0007; color: #fff; }
    .card { border-radius: 0; border: 1px solid #e3e6f0; box-shadow: 0 .15rem 1.75rem 0 rgba(58,59,69,0.15); }
    .card-header { background-color: #B71C1C !important; color: #fff !important; border-radius: 0 !important; font-weight: bold; }
    .table thead th { background-color: #B71C1C !important; color: #fff !important; text-align: center; border: 1px solid #fff !important; }
    .table tbody tr { background-color: #f8f9fa; }
    .table-hover tbody tr:hover { background-color: #ffe6e6 !important; }
    .btn-rounded { border-radius: 20px; }
    
    /* Botones de seleccon de tipo (Personalizado para que parezcan botones de 511.html) */
    .btn-tipo { 
        border: 2px solid #B71C1C; 
        color: #B71C1C; 
        background-color: #fff; 
        font-weight: bold; 
        transition: all 0.3s;
        margin-right: 5px;
    }
    .btn-tipo.active { 
        background-color: #B71C1C; 
        color: #fff; 
    }
    .btn-tipo:hover {
        background-color: #ffe6e6;
        color: #B71C1C;
    }

    .estado-Enviado { color: #0056b3; font-weight: bold; }
    .estado-Aprobado { color: #28a745; font-weight: bold; }
    .estado-Devuelto { color: #dc3545; font-weight: bold; }
    .estado-Borrador { color: #6c757d; font-style: italic; }

    .dif-badge { font-size: 10px; margin-right: 5px; vertical-align: top; }
    
    .card-config { border-left: 5px solid #B71C1C; background: #fff; }
    
    .changed {
      background-color: #ffe6e6 !important;
      font-weight: bold;
      color: #000;
    }
    .gerencia-header {
      background-color: #343a40 !important;
      color: #fff !important;
      font-weight: bold;
    }
    .select-filtro {
      width: 100%;
      font-size: 11px;
      border: 1px solid #ccc;
      border-radius: 4px;
      padding: 2px;
    }
    .btn-xs { padding: 1px 5px; font-size: 10px; }
    
    /* Grid y densidad compacta */
    .table-sm td, .table-sm th { padding: 0.3rem !important; font-size: 11.5px; }
    .continer-fluid { max-width: 100%; }

    /* Ajustes para DataTables */
    #tbMaestroRevision_wrapper .dataTables_paginate .paginate_button { padding: 0.2rem 0.5rem; }
    #tbMaestroRevision_filter { display: none; } /* Usamos nuestros filtros manuales */
    
    .gerencia-header { background-color: #343a40 !important; color: #fff !important; }
    .dtrg-group th {
        background-color: #343a40 !important;
        color: #fff !important;
        font-weight: bold;
        padding: 5px 15px !important;
        border-left: 5px solid #B71C1C !important;
    }
</style>

<!-- DataTables CSS -->
<link href="~/onlinecss/jquery.dataTables.min.css" rel="stylesheet" />
<link href="~/onlinecss/dataTables.bootstrap4.min.css" rel="stylesheet" />
<link href="~/onlinecss/rowGroup.dataTables.min.css" rel="stylesheet" />
<link href="~/onlinecss/responsive.dataTables.min.css" rel="stylesheet" />

<!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="continer-fluid mt-2 px-4">
    <div class="d-flex justify-content-between align-items-center mt-3 mb-2">
        <h2 class="m-0 text-dark font-weight-bold" id="lblTituloPagina" style="color:#B71C1C !important;">
            <i class="fas fa-tasks"></i> Certificacion y Gestion (RRHH)
        </h2>
        <div class="form-inline">
            <label class="mr-2 font-weight-bold text-muted">Periodo:</label>
            <select id="ddlPeriodo" class="form-control form-control-sm border-0 shadow-sm" onchange="actualizarVista()">
                <option value="">Cargando...</option>
            </select>
            <button class="btn btn-sm btn-claro btn-rounded shadow-sm ml-2" onclick="actualizarVista()">
                <i class="fas fa-sync-alt"></i>
            </button>
            <button class="btn btn-sm btn-outline-dark btn-rounded shadow-sm ml-2" onclick="abrirModalExclusiones()">
                <i class="fas fa-ban"></i> Lista de Exclusiones
            </button>
            <a href="@Url.Action("GestionMaestra", "Compensacion")" class="btn btn-sm btn-danger btn-rounded shadow-sm ml-2">
                <i class="fas fa-users-cog"></i> Gestion Maestra
            </a>
        </div>
    </div>

    <!-- Indicadores de Avance (KPIs) -->
    <div class="row mb-3 animate__animated animate__fadeIn">
        <div class="col-md-4">
            <div class="card shadow-sm border-left-claro bg-white p-3">
                <h6 class="text-muted small font-weight-bold text-uppercase mb-1" id="lblKPIAvance">Avance Global Jefes</h6>
                <div class="row no-gutters align-items-center">
                    <div class="col-auto h5 mb-0 mr-3 font-weight-bold" id="txtKPIPerc">0%</div>
                    <div class="col">
                        <div class="progress progress-sm"><div id="barKPI" class="progress-bar bg-claro" style="width:0%"></div></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-left-claro bg-white p-3 text-center">
                <h6 class="text-muted small font-weight-bold text-uppercase mb-1">Colaboradores Procesados</h6>
                <div class="h5 mb-0 font-weight-bold" id="txtKPIPlazas">0</div>
            </div>
        </div>
        <div class="col-md-3 text-center">
            <div class="card shadow-sm border-left-claro bg-light p-3 position-relative">
                <h6 class="text-muted small font-weight-bold text-uppercase mb-1">Periodo Activo</h6>
                <div class="h5 mb-0 font-weight-bold text-claro" id="txtKPIPeriodo">...</div>
                <div id="wrapperBadgeEx" class="position-absolute" style="top: -10px; right: 10px; display: none;">
                    <span class="badge badge-pill badge-dark shadow-sm py-1 px-2" style="font-size: 10px;">
                        <i class="fas fa-ban mr-1 text-warning"></i> <span id="countExcluidos">0</span> EXCLUSIONES
                    </span>
                </div>
            </div>
        </div>
        <div class="col-md-3 text-center">
            <div class="card shadow-sm border-left-claro bg-dark text-white p-3">
                <h6 class="text-white-50 small font-weight-bold text-uppercase mb-1" id="lblKPICambios">Discrepancias Totales</h6>
                <div class="h5 mb-0 font-weight-bold text-warning" id="txtKPICambios">0</div>
            </div>
        </div>
    </div>

    <style>
        .border-left-claro { border-left: 5px solid #B71C1C !important; }
        .text-claro { color: #B71C1C; }
    </style>

    <!-- Seccion de Configuracion de Notificaciones -->
    <div class="card mb-4 shadow-sm card-config">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-md-3">
                    <label class="small font-weight-bold text-muted mb-1"><i class="fas fa-calendar-alt"></i> Fecha Limite de Entrega:</label>
                    <input type="date" id="txtFechaLimite" class="form-control form-control-sm">
                </div>
                <div class="col-md-5" id="colSelectorTipo">
                    <label class="small font-weight-bold text-muted mb-1"><i class="fas fa-envelope"></i> Tipo de Notificacion a Enviar:</label>
                    <div class="d-flex" id="pills-tab">
                        <button class="btn btn-tipo active py-1 flex-fill" id="btn-tab-1" onclick="setTipo(1)">Comisiones</button>
                        <button class="btn btn-tipo py-1 flex-fill" id="btn-tab-2" onclick="setTipo(2)">Plantilla Personal (Certificacion)</button>
                        <button class="btn btn-tipo py-1 flex-fill" id="btn-tab-eval" onclick="mostrarTabEvaluaciones()">Seguimiento Bajas/Ingresos</button>
                    </div>
                </div>
                <div class="col-md-4 text-right">
                    <button class="btn btn-sm btn-outline-secondary btn-rounded mt-3" onclick="guardarConfig()">
                        <i class="fas fa-save"></i> Guardar Plazo
                    </button>
                    <button class="btn btn-sm btn-primary btn-rounded shadow-sm mt-3 ml-2" id="btnMassMil" onclick="notificarMasivo()" disabled>
                        <i class="fas fa-paper-plane"></i> Notificar a Validadores Pendientes
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Panel de Certificaciones (Principal) -->
    <div id="panelCertificacion">

    <div class="card shadow mb-4">
        <div class="card-header bg-claro py-3 d-flex justify-content-between align-items-center" id="headerTablaPrincipal">
            <h6 class="m-0 font-weight-bold text-white" id="lblTituloTabla"><i class="fas fa-list"></i> Detalle Maestro de Certificacion (Revision RRHH)</h6>
            <div id="panelBotonera" class="d-flex align-items-center">
                <div class="custom-control custom-switch mr-3">
                    <input type="checkbox" class="custom-control-input" id="chkSoloCambios" onchange="actualizarVista(true)">
                    <label class="custom-control-label text-white small font-weight-bold" for="chkSoloCambios">
                        <i class="fas fa-filter mr-1"></i> VER SOLO CAMBIOS
                    </label>
                </div>
                <button class="btn btn-xs btn-light font-weight-bold shadow-sm" onclick="descargarExcel()">
                    <i class="fas fa-file-excel mr-1 text-success"></i> Exportar CSV
                </button>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover table-sm mb-0" id="tbMaestroRevision">
                    <thead class="bg-claro text-white text-center">
                        <tr>
                            <th rowspan="2" class="align-middle border-white" style="border: 1px solid #fff !important; min-width: 250px;">Empleado Oficial</th>
                            <th rowspan="2" class="align-middle border-white" style="border: 1px solid #fff !important;">Empresa</th>
                            <th rowspan="2" class="align-middle border-white" style="border: 1px solid #fff !important;">Departamento</th>
                            <th colspan="2" class="align-middle border-white col-cert-header" style="border: 1px solid #fff !important;">Cargo / Puesto</th>
                            <th colspan="2" class="align-middle border-white col-cert-header" style="border: 1px solid #fff !important;">Jefe Inmediato</th>
                            <th colspan="2" class="align-middle border-white col-cert-header" style="border: 1px solid #fff !important;">Edificio / Ubicacion</th>
                            <th colspan="2" class="align-middle border-white col-comision-header" style="border: 1px solid #fff !important;">Comisiona</th>
                            <th rowspan="2" class="align-middle border-white" style="border: 1px solid #fff !important;">Observaciones</th>
                            <th rowspan="2" class="align-middle border-white" style="border: 1px solid #fff !important;">Acciones</th>
                        </tr>
                        <tr class="text-white small">
                            <th class="bg-dark align-middle border-white col-cert-header" style="border: 1px solid #fff !important; min-width: 100px;">SighoO</th>
                            <th class="bg-claro align-middle border-white col-cert-header" style="border: 1px solid #fff !important; min-width: 100px;">Reportado</th>
                            <th class="bg-dark align-middle border-white col-cert-header" style="border: 1px solid #fff !important; min-width: 100px;">SighoO</th>
                            <th class="bg-claro align-middle border-white col-cert-header" style="border: 1px solid #fff !important; min-width: 100px;">Reportado</th>
                            <th class="bg-dark align-middle border-white col-cert-header" style="border: 1px solid #fff !important; min-width: 100px;">SighoO</th>
                            <th class="bg-claro align-middle border-white col-cert-header" style="border: 1px solid #fff !important; min-width: 100px;">Reportado</th>
                            <th class="bg-dark align-middle border-white col-comision-header" style="border: 1px solid #fff !important; min-width: 50px;">Orig.</th>
                            <th class="bg-claro align-middle border-white col-comision-header" style="border: 1px solid #fff !important; min-width: 50px;">Act.</th>
                        </tr>
                        <tr class="fila-filtros" id="filaFiltrosUI" style="display:none;">
                            <th></th> <!-- Nombre -->
                            <th><select id="fEmpresa" class="select-filtro" onchange="filtraLocal()"><option value="">[ Todas ]</option></select></th>
                            <th></th> <!-- Depto -->
                            <th class="col-cert-header"><select id="fCargo" class="select-filtro" onchange="filtraLocal()"><option value="">[ Cargos ]</option></select></th><th class="col-cert-header"></th>
                            <th class="col-cert-header"><select id="fJefe" class="select-filtro" onchange="filtraLocal()"><option value="">[ Jefes ]</option></select></th><th class="col-cert-header"></th>
                            <th class="col-cert-header"><select id="fUbi" class="select-filtro" onchange="filtraLocal()"><option value="">[ Sedes ]</option></select></th><th class="col-cert-header"></th>
                            <th class="col-comision-header"></th><th class="col-comision-header"></th>
                            <th></th> <!-- Obs -->
                            <th></th> <!-- Acciones -->
                        </tr>
                    </thead>
                    <tbody id="tbCuerpoMaestro">
                        <tr><td colspan="13" class="text-center p-4 text-muted font-italic">Seleccione un periodo para cargar los datos...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

    <!-- Panel de Evaluaciones (Bajas e Ingresos) -->
    <div id="panelEvaluaciones" style="display:none;">
        <div class="row">
            <div class="col-md-12">
                <div class="card shadow mb-4">
                    <div class="card-header bg-claro py-3 d-flex justify-content-between align-items-center">
                        <h6 class="m-0 font-weight-bold text-white"><i class="fas fa-chart-pie"></i> Resumen de Evaluaciones Pendientes</h6>
                        <div class="btn-group">
                            <button class="btn btn-xs btn-light font-weight-bold" onclick="notificarMasivoBajas()"><i class="fas fa-bell"></i> Recordar Bajas</button>
                            <button class="btn btn-xs btn-light font-weight-bold ml-1" onclick="notificarMasivoIngresos()"><i class="fas fa-bell"></i> Recordar Ingresos</button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered table-hover">
                                <thead class="bg-dark text-white text-center">
                                    <tr>
                                        <th>Gerencia / i?rea</th>
                                        <th>Bajas Pendientes</th>
                                        <th>Ingresos Pendientes</th>
                                        <th>Total Pendiente</th>
                                        <th>Accon</th>
                                    </tr>
                                </thead>
                                <tbody id="tbResumenEvalPorGerencia">
                                    <!-- Dinamico -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow mb-4 border-left-claro">
            <div class="card-header bg-white py-3">
                <h6 class="m-0 font-weight-bold text-claro"><i class="fas fa-history"></i> Historial Reciente de Evaluaciones</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-sm table-hover border">
                        <thead class="bg-light">
                            <tr>
                                <th>Tipo</th>
                                <th>Colaborador</th>
                                <th>Fecha Baja/Ingreso</th>
                                <th>Resultado</th>
                                <th>Evaluador</th>
                                <th>Fecha Evaluacon</th>
                                <th>Voucher</th>
                            </tr>
                        </thead>
                        <tbody id="tbodyHistorial"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

<!-- Modal Detalle -->
<div class="modal fade" id="modalDetalle" style="z-index: 1050;">
    <div class="modal-dialog" style="max-width: 95%;">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-claro text-white">
                <h5 class="modal-title"><i class="fas fa-users"></i> Detalle de Empleados - <span id="lblGerente"></span></h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body p-0 table-responsive" style="max-height: 70vh; overflow-y: auto;">
                <table class="table table-sm table-bordered table-hover mb-0" style="font-size: 0.85rem;">
                    <thead class="text-white text-center" style="position: sticky; top: 0; z-index: 10; font-size: 11px;">
                        <tr class="bg-claro">
                            <th rowspan="2" class="align-middle border-white" style="border: 1px solid #fff !important;">Empleado Oficial</th>
                            <th rowspan="2" class="align-middle border-white" style="border: 1px solid #fff !important;">Empresa</th>
                            <th rowspan="2" class="align-middle border-white" style="border: 1px solid #fff !important;">Departamento</th>
                            <th colspan="2" class="align-middle border-white" style="border: 1px solid #fff !important;">Cargo / Puesto</th>
                            <th colspan="2" class="align-middle border-white" style="border: 1px solid #fff !important;">Jefe Inmediato</th>
                            <th colspan="2" class="align-middle border-white" style="border: 1px solid #fff !important;">Edificio / Ubicacion</th>
                            <th colspan="2" class="align-middle border-white col-comision-header" style="border: 1px solid #fff !important;">Comisiona</th>
                            <th colspan="2" class="align-middle border-white" style="border: 1px solid #fff !important;">Observaciones</th>
                        </tr>
                        <tr class="text-white">
                            <th class="bg-dark align-middle border-white" style="border: 1px solid #fff !important; min-width: 100px;">SighoO</th>
                            <th class="bg-claro align-middle border-white" style="border: 1px solid #fff !important; min-width: 100px;">Reportado</th>
                            <th class="bg-dark align-middle border-white" style="border: 1px solid #fff !important; min-width: 100px;">SighoO</th>
                            <th class="bg-claro align-middle border-white" style="border: 1px solid #fff !important; min-width: 100px;">Reportado</th>
                            <th class="bg-dark align-middle border-white" style="border: 1px solid #fff !important; min-width: 100px;">SighoO</th>
                            <th class="bg-claro align-middle border-white" style="border: 1px solid #fff !important; min-width: 100px;">Reportado</th>
                            <th class="bg-dark align-middle border-white col-comision-header" style="border: 1px solid #fff !important; min-width: 50px;">Ant.</th>
                            <th class="bg-claro align-middle border-white col-comision-header" style="border: 1px solid #fff !important; min-width: 50px;">Act.</th>
                            <th class="bg-dark align-middle border-white" style="border: 1px solid #fff !important; min-width: 100px;">Ant.</th>
                            <th class="bg-claro align-middle border-white" style="border: 1px solid #fff !important; min-width: 100px;">Act.</th>
                        </tr>
                    </thead>
                    <tbody id="tbDetalles"></tbody>
                </table>
            </div>
            <div class="modal-footer bg-light" id="footerAcciones"></div>
        </div>
    </div>
</div>


<!-- Modal Exclusiones (Blacklist) -->
<div class="modal fade" id="modalExclusiones">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title"><i class="fas fa-ban"></i> Gestion de Exclusiones (Depuracion)</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info py-2" style="font-size:12px;">
                    <i class="fas fa-info-circle"></i> Las gerencias o carnet agregados aqui? <b>no recibiran notificaciones</b> y no apareceran en la lista de revison.
                </div>
                <div class="form-row align-items-end mb-3">
                    <div class="col-md-3">
                        <label class="small font-weight-bold">Tipo:</label>
                        <select id="ddlTipoEx" class="form-control form-control-sm">
                            <option value="OGERENCIA">Gerencia</option>
                            <option value="CARNET">Carnet Empleado</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="small font-weight-bold">Valor (Exacto):</label>
                        <input type="text" id="txtValorEx" class="form-control form-control-sm" placeholder="Ej: NI GERENCIA DE RRHH">
                    </div>
                    <div class="col-md-3">
                        <label class="small font-weight-bold">Motivo:</label>
                        <input type="text" id="txtMotivoEx" class="form-control form-control-sm" placeholder="Opcional">
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-sm btn-dark btn-block" onclick="guardarExclusion()"><i class="fas fa-plus"></i></button>
                    </div>
                </div>
                <div class="table-responsive" style="max-height: 300px;">
                    <table class="table table-sm table-striped">
                        <thead class="bg-light"><tr><th>Tipo</th><th>Valor</th><th>Motivo</th><th></th></tr></thead>
                        <tbody id="tbExclusiones"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

<!-- Modal Historial de Auditoria -->
<div class="modal fade" id="modalHistorial">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title"><i class="fas fa-history"></i> Historial de Cambios: <span id="txtHistorialEmp"></span></h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body p-0">
                <div id="timelineHistorial" class="p-4" style="max-height: 500px; overflow-y: auto;">
                    <!-- Se llena con JS -->
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Comentario Devolucon -->
<div class="modal fade" id="modalDevolver">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title font-weight-bold">Devolver a Validador</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="txtIdDevolver" />
                <div class="form-group">
                    <label class="small font-weight-bold text-uppercase">Motivo de la devolucon:</label>
                    <textarea id="txtComentarioDevolver" class="form-control" rows="4" placeholder="Indique que informacion debe corregir el jefe..."></textarea>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-sm btn-secondary" data-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-sm btn-warning font-weight-bold" onclick="ejecutarDevolucion()">Confirmar Devolucon</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
<script>
    var TIPO_ACTUAL = @(ViewBag.Tipo ?? 1); 

    function aplicarTemaVisual(tipo) {
        if(tipo == 2) {
            $('#lblTituloPagina').html('<i class="fas fa-id-badge"></i> Certificacion de Plantilla de Personal');
            $('#lblTituloTabla').html('<i class="fas fa-list"></i> Detalle Maestro de Certificacion (Revision RRHH)');
            $('#btn-tab-eval').hide(); 
            $('#btnMassMil').text('Notificar Pendientes (Certificacion)');
            $('.col-comision-header').hide();
            $('.col-cert-header').show();
