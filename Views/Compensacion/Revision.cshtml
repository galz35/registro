                    html = '<div class="text-center p-5 text-muted"><i class="fas fa-info-circle fa-2x mb-3"></i><p>No se registran cambios manuales para este empleado en el periodo actual. Todos los valores coinciden con SighoO1.</p></div>';
                } else {
                    res.data.forEach(function(x) {
                        var fecha = x.FechaModificacion ? new Date(parseInt(x.FechaModificacion.substr(6))).toLocaleString() : '-';
