    function cargarExclusiones() {
        $('#tbExclusiones').html('<tr><td colspan="4" class="text-center"><i class="fas fa-spinner fa-spin"></i> Cargando...</td></tr>');
        $.get('@Url.Action("ObtenerExclusiones", "Compensacion")', function (res) {
            if (res.success) {
                var html = '';
                res.data.forEach(function(x) {
                    html += '<tr>' +
                        '<td><span class="badge badge-dark">' + x.TipoExclusion + '</span></td>' +
                        '<td>' + x.ValorExclusion + '</td>' +
                        '<td><small>' + (x.Motivo || '-') + '</small></td>' +
                        '<td class="text-right">' +
                            '<button class="btn btn-xs btn-outline-danger border-0" onclick="quitarExclusion(' + x.ExclusionID + ')">' +
                                '<i class="fas fa-trash"></i>' +
                            '</button>' +
                        '</td>' +
                    '</tr>';
                });
                if (res.data.length == 0) html = '<tr><td colspan="4" class="text-center text-muted small">No hay exclusiones configuradas.</td></tr>';
                $('#tbExclusiones').html(html);
            }
        });
    }

    function guardarExclusion() {
        const tipo = $('#ddlTipoEx').val();
        const valor = $('#txtValorEx').val();
        const motivo = $('#txtMotivoEx').val();

        if (!valor) {
            Swal.fire('Atencion', 'Debe ingresar un valor (Carnet o Nombre de Gerencia).', 'warning');
            return;
        }

        $.post('@Url.Action("AgregarExclusion", "Compensacion")', { tipo, valor, motivo }, function (res) {
            if (res.success) {
                $('#txtValorEx').val('');
                $('#txtMotivoEx').val('');
                cargarExclusiones();
                Swal.fire('Exito', 'Exclusion agregada correctamente.', 'success');
            } else {
                Swal.fire('Error', res.message, 'error');
            }
        });
    }

    function quitarExclusion(id) {
        Swal.fire({
            title: 'a?Eliminar exclusion?',
            text: "Esta gerencia o empleado volvera a ser visible en el sistema.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Si, eliminar'
        }).then((result) => {
            if (result.isConfirmed) {
                $.post('@Url.Action("QuitarExclusion", "Compensacion")', { exclusionId: id }, function (res) {
                    if (res.success) {
                        cargarExclusiones();
                        Swal.fire('Eliminado', 'La exclusion ha sido removida.', 'success');
                    }
                });
            }
        });
    }
