    function verHistorial(detalleId, nombreEmp) {
        $('#lblHistorialEmp').text(nombreEmp);
        $.get('@Url.Action("ObtenerAuditoria", "Compensacion")?detalleId=' + detalleId, function(res) {
            var html = '';
            if(res.data.length === 0){
                html = '<tr><td colspan="5" class="text-center text-muted p-3">No hay registro de modificaciones o auditoria para este empleado.</td></tr>';
            } else {
                res.data.forEach(function(d) {
                    var fecha = new Date(parseInt(d.FechaCambio.substr(6))).toLocaleString('es-ES');
                    html += '<tr>' +
                        '<td class="align-middle">' + fecha + '</td>' +
                        '<td class="align-middle"><small>' + (d.NombreGeneraCambio || d.CarnetUsuario) + '</small></td>' +
                        '<td class="align-middle text-primary"><b>' + d.Campo + '</b></td>' +
                        '<td class="text-danger align-middle">' + (d.ValorAnterior || '-') + '</td>' +
                        '<td class="text-success align-middle font-weight-bold">' + (d.ValorNuevo || '-') + '</td>' +
                    '</tr>';
                });
            }
            $('#tbHistorial').html(html);
            $('#modalHistorial').modal('show');
        });
    }

    function abrirDevolver(id) {
        Swal.fire({
            title: 'Devolver Plantilla',
            input: 'text',
            inputPlaceholder: 'Motivo de devolucion...',
            showCancelButton: true,
            confirmButtonText: 'Enviar al Gerente'
        }).then(function(res) {
            if(res.value) {
                $.post('@Url.Action("DevolverPlantilla", "Compensacion")', { plantillid: id, comentario: res.value }, function(r) {
                    actualizarVista();
                });
            }
        });
    }

