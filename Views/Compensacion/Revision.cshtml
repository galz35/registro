        Swal.fire({
            title: 'Enviar notificacion?',
            text: "Se enviara un correo con la tabla de su personal al validador designado.",
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#B71C1C',
            confirmButtonText: 'Si, enviar ahora'
        }).then((result) => {
            if (result.isConfirmed) {
                Swal.showLoading();
                $.post('@Url.Action("NotificarJefe", "Compensacion")', { periodoId: idPer, carnetJefe: carnet, tipoPlantilla: TIPO_ACTUAL }, function(res) {
                    if(res.success) {
                        Swal.fire('Enviado', res.message, 'success');
                        actualizarVista();
                    } else {
                        Swal.fire('Error', res.message, 'error');
