    function cargarDashboardEvaluaciones() {
        $('#tbResumenEvalPorGerencia').html('<tr><td colspan="5" class="text-center p-3"><i class="fas fa-spinner fa-spin"></i> Cargando resumen...</td></tr>');
        
        // Cargar Resumen por Gerencia
        $.get('@Url.Action("ObtenerResumenPendientesRRHH", "Compensacion")', function(res) {
            var html = '';
            if (res.data && res.data.length > 0) {
                // Agrupar por Gerencia
                var map = {};
                res.data.forEach(function(item) {
                    if(!map[item.Gerencia]) map[item.Gerencia] = { Bajas: 0, Ingresos: 0 };
                    if(item.Tipo === 'BAJA') map[item.Gerencia].Bajas = item.Cantidad;
                    else map[item.Gerencia].Ingresos = item.Cantidad;
                });

                for (var g in map) {
                    var total = map[g].Bajas + map[g].Ingresos;
                    html += '<tr>' +
                        '<td><strong>' + g + '</strong></td>' +
                        '<td class="text-center"><span class="badge ' + (map[g].Bajas > 0 ? 'badge-danger' : 'badge-light') + '">' + map[g].Bajas + '</span></td>' +
                        '<td class="text-center"><span class="badge ' + (map[g].Ingresos > 0 ? 'badge-primary' : 'badge-light') + '">' + map[g].Ingresos + '</span></td>' +
                        '<td class="text-center font-weight-bold h6">' + total + '</td>' +
                        '<td class="text-center border-0">' +
                             '<button class="btn btn-xs btn-outline-danger" onclick="alert(\'Funcionalidad de recordatorio por gerencia en desarrollo\')"><i class="fas fa-envelope"></i> Avisar</button>' +
                        '</td>' +
                    '</tr>';
                }
            } else {
                html = '<tr><td colspan="5" class="text-center p-4 text-success"><i class="fas fa-check-circle"></i> No hay evaluaciones pendientes en ninguna gerencia.</td></tr>';
            }
            $('#tbResumenEvalPorGerencia').html(html);
        });

        cargarHistorial();
    }

