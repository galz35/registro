                        html += '' +
                            '<div class="d-flex mb-4">' +
                                '<div class="mr-3 text-center" style="width: 40px;">' +
                                    '<div class="rounded-circle bg-' + color + ' text-white shadow-sm d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">' +
                                        '<i class="fas ' + icono + ' fa-sm"></i>' +
                                    </div>' +
                                    '<div class="bg-light mx-auto" style="width: 2px; height: 100%;"></div>' +
                                '</div>' +
                                '<div class="flex-grow-1 bg-light p-3 rounded shadow-sm border-left border-' + color + '" style="border-left-width: 4px !important;">' +
                                    '<div class="d-flex justify-content-between align-items-center mb-1">' +
                                        '<span class="font-weight-bold text-dark text-uppercase small">' + x.CampoModificado + '</span>' +
                                        '<span class="badge badge-secondary py-1">' + fecha + '</span>' +
                                    </div>' +
                                    '<div class="small">' +
                                        '<div class="text-muted"><del>' + (x.ValorAnterior || '(Vaci?o)') + '</del></div>' +
                                        '<div class="font-weight-bold text-success"><i class="fas fa-arrow-right mr-1"></i> ' + x.ValorNuevo + '</div>' +
                                    </div>' +
                                    '<div class="mt-2 text-right">' +
