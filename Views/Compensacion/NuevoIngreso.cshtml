@{
    ViewBag.Title = "Evaluacon de Periodo de Prueba";
}
<meta charset="utf-8" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    body { background-color: #f0f2f5; }
    .header-ingreso { background: linear-gradient(135deg, #1a237e 0%, #0d47a1 100%); color: white; padding: 35px; border-radius: 0 0 30px 30px; margin-bottom: 30px; box-shadow: 0 4px 20px rgba(0,0,0,0.15); }
    .card-nuevo { border: none; border-radius: 12px; border-top: 4px solid #1a237e; transition: all 0.3s; }
    .card-nuevo:hover { transform: scale(1.02); box-shadow: 0 10px 25px rgba(0,0,0,0.1); cursor: pointer; }
    .days-badge { background: #e8eaf6; color: #1a237e; padding: 5px 12px; border-radius: 20px; font-weight: bold; font-size: 12px; }
    
    .rating-box { display: flex; align-items: center; gap: 10px; }
    .star-btn { font-size: 24px; color: #ccc; cursor: pointer; transition: color 0.2s; }
    .star-btn.active { color: #fbc02d; }
</style>

<div class="header-ingreso">
    <div class="continer">
        <h1 class="h3 font-weight-bold mb-1"><i class="fas fa-user-plus mr-2"></i> Periodo de Prueba (90 Dias)</h1>
        <p class="mb-0 opacity-75">Confirme el desempeno y la plaza de los colaboradores que han cumplido su periodo inicial.</p>
    </div>
</div>

<div class="continer">
    <div id="listaPendientesIngreso" class="row">
        <!-- Dinamico -->
        <div class="col-12 text-center p-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Buscando nuevos ingresos por evaluar...</p>
        </div>
    </div>
</div>

<!-- Modal Evaluacon Ingreso -->
<div class="modal fade" id="modalEvalIngreso">
    <div class="modal-dialog modal-lg border-0">
        <div class="modal-content rounded-lg border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body p-4 pt-0">
                <div class="text-center mb-4">
                    <div class="display-4 text-primary mb-2"><i class="fas fa-clipboard-check"></i></div>
                    <h4 class="font-weight-bold mb-1" id="lblNombreIngreso"></h4>
                    <span class="text-muted small" id="lblCargoIngreso"></span>
                </div>

                <input type="hidden" id="txtCarnetIngreso">
                <input type="hidden" id="txtFechingreso">

                <div class="row mb-4">
                    <div class="col-md-6 text-center border-right">
                        <label class="font-weight-bold small d-block">Adaptacion a la Cultura</label>
                        <div class="rating-box justify-content-center" data-type="adapt">
                            <i class="fas fa-star star-btn" data-val="1"></i>
                            <i class="fas fa-star star-btn" data-val="2"></i>
                            <i class="fas fa-star star-btn" data-val="3"></i>
                            <i class="fas fa-star star-btn" data-val="4"></i>
                            <i class="fas fa-star star-btn" data-val="5"></i>
                        </div>
                    </div>
                    <div class="col-md-6 text-center">
                        <label class="font-weight-bold small d-block">Competencias Tecnicas</label>
                        <div class="rating-box justify-content-center" data-type="comp">
                            <i class="fas fa-star star-btn" data-val="1"></i>
                            <i class="fas fa-star star-btn" data-val="2"></i>
                            <i class="fas fa-star star-btn" data-val="3"></i>
                            <i class="fas fa-star star-btn" data-val="4"></i>
                            <i class="fas fa-star star-btn" data-val="5"></i>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="font-weight-bold small">Resultado de la Evaluacion</label>
                    <select id="ddlResultado" class="form-control form-control-lg border-primary">
                        <option value="Confirmar Plaza">Confirmar Plaza (Exitoso)</option>
                        <option value="Extender Periodo">Extender Periodo de Prueba (1 mes mas)</option>
                        <option value="Terminacion">No Confirmar / Terminacion de Contrato</option>
                    </select>
                </div>

                <div class="form-group mt-3">
                    <label class="font-weight-bold small">Justificacion / Observaciones</label>
                    <textarea id="txtObsIngreso" class="form-control" rows="3" placeholder="Resuma las fortalezas o areas de mejora..."></textarea>
                </div>
            </div>
            <div class="modal-footer border-0 p-4">
                <button class="btn btn-primary btn-block btn-lg shadow font-weight-bold" onclick="guardarEvalIngreso()">Guardar Evaluacion Definitiva</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
<script>
    let valAdapt = 0;
    let valComp = 0;

    $(document).ready(function() {
        cargarPendientesIngreso();

        $('.star-btn').click(function() {
            const val = $(this).data('val');
            const type = $(this).parent().data('type');
            if(type === 'adapt') valAdapt = val; else valComp = val;

            $(this).parent().find('.star-btn').removeClass('active');
            $(this).parent().find('.star-btn').each(function() {
                if($(this).data('val') <= val) $(this).addClass('active');
            });
        });
    });

    function cargarPendientesIngreso() {
        $.get('@Url.Action("ObtenerPendientesIngreso", "Compensacion")', function(res) {
            let html = '';
            if (res.data && res.data.length > 0) {
                res.data.forEach(function(d) {
                    html += '<div class="col-md-4 mb-3">' +
                        '<div class="card h-100 shadow-sm border-left-info">' +
                            '<div class="card-body p-3">' +
                                '<h6 class="font-weight-bold mb-1">' + d.NombreEmpleado + '</h6>' +
                                '<div class="small text-muted mb-2">' + d.CarnetEmpleado + ' - ' + d.Cargo + '</div>' +
                                '<button class="btn btn-xs btn-outline-primary btn-rounded" onclick="evaluarIngreso(' + d.CarnetEmpleado + ')">Evaluar</button>' +
                            '</div>' +
                        '</div>' +
                    '</div>';
                });
            } else {
                html = '<div class="col-12 text-center p-5 font-italic text-muted"><h5>No hay colaboradores pendientes de evaluacon de prueba.</h5></div>';
            }
            $('#listaPendientesIngreso').html(html);
        });
    }

    function abrirEvalIngreso(carnet, nombre, cargo, fecha) {
        $('#txtCarnetIngreso').val(carnet);
        $('#lblNombreIngreso').text(nombre);
        $('#lblCargoIngreso').text(cargo);
        $('#txtFechingreso').val(fecha);
        valAdapt = 0; valComp = 0;
        $('.star-btn').removeClass('active');
        $('#txtObsIngreso').val('');
        $('#modalEvalIngreso').modal('show');
    }

    function guardarEvalIngreso() {
        if(valAdapt === 0 || valComp === 0) { Swal.fire('Error', 'Por favor complete las calificaciones.', 'error'); return; }

        const model = {
            CarnetEmpleado: $('#txtCarnetIngreso').val(),
            NombreEmpleado: $('#lblNombreIngreso').text(),
            Fechingreso: new Date(parseInt($('#txtFechingreso').val().substr(6))).toISOString(),
            CalificacionAdaptacion: valAdapt,
            CalificacionCompetencias: valComp,
            ResultadoFinal: $('#ddlResultado').val(),
            Observaciones: $('#txtObsIngreso').val()
        };

        Swal.showLoading();
        $.post('@Url.Action("GuardarEvaluacionIngreso", "Compensacion")', model, function(res) {
            if(res.success) {
                $('#modalEvalIngreso').modal('hide');
                Swal.fire('Evaluado!', res.message, 'success');
                cargarPendientesIngreso();
            } else {
                Swal.fire('Error', res.message, 'error');
            }
        });
    }
</script>
}



