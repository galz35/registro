@using slnRhonline.Reports
@Html.DevExpress().GetStyleSheets(

   new StyleSheet { ExtensionSuite = ExtensionSuite.Report }

)
@Html.DevExpress().GetScripts(

    new Script { ExtensionSuite = ExtensionSuite.Report }

)
@Html.DevExpress().DocumentViewer(settings =>
{
    settings.Name = "DocumentViewer";
    settings.CallbackRouteValues = new
    {
        Controller = "ExpenseDetail",
        Action = "TechnicalReportPartialv"
    };
    settings.ExportRouteValues = new
    {
        Controller = "ExpenseDetail",
        Action = "ExportTechnicalReport"
    };
    settings.Report = new TechnicalExpenseReport()
    {
        DataSource = Model
    };
}).GetHtml()

